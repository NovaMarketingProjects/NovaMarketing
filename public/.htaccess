# Nova Marketing - 301 Redirects & WWW Cleanup

# Custom 404 pages (ES + CA)
ErrorDocument 404 /404.html
RewriteCond %{REQUEST_URI} ^/ca/
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ /ca/404.html [L,R=404]

# Force Non-WWW
RewriteEngine On
RewriteCond %{HTTP_HOST} ^www\.novamarketing\.es [NC]
RewriteRule ^(.*)$ https://novamarketing.es/$1 [L,R=301]

# Blog posts redirects
Redirect 301 /las-redes-sociales-en-2024-analisis-del-estudio-de-iab-spain/ https://novamarketing.es/blog/mejores-herramientas-de-gestion-de-redes-sociales-para-pymes/

# Localized redirection for success stories (ES/CA)
# From /ca/casos-exito/ to /ca/casos-exit/
Redirect 301 /ca/casos-exito/ https://novamarketing.es/ca/casos-exit/
Redirect 301 /ca/casos-exito https://novamarketing.es/ca/casos-exit/

# Ensure HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Sitemap Redirect (from sitemap.xml to sitemap-index.xml)
RewriteRule ^sitemap\.xml$ /sitemap-index.xml [L,R=301]

# ── Cache Control ──────────────────────────────────────────────────────────────
# Astro hashes CSS/JS filenames on each build → safe to cache 1 year
<IfModule mod_headers.c>
  # Fonts: 1 year immutable
  <FilesMatch "\.(woff2|woff|ttf|otf|eot)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # CSS & JS: 1 year immutable (content-hashed by Astro)
  <FilesMatch "\.(css|js|mjs)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # Images: 1 month
  <FilesMatch "\.(webp|jpg|jpeg|png|gif|svg|ico|avif)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>
  # HTML: always revalidate
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType font/woff2                "access plus 1 year"
  ExpiresByType font/woff                 "access plus 1 year"
  ExpiresByType text/css                  "access plus 1 year"
  ExpiresByType application/javascript    "access plus 1 year"
  ExpiresByType image/webp                "access plus 1 month"
  ExpiresByType image/jpeg                "access plus 1 month"
  ExpiresByType image/png                 "access plus 1 month"
  ExpiresByType image/svg+xml             "access plus 1 month"
  ExpiresByType image/avif                "access plus 1 month"
  ExpiresByType text/html                 "access plus 0 seconds"
</IfModule>

# ── Compression ────────────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml font/woff2
</IfModule>
