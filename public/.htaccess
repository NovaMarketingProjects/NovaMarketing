# Localized redirection for success stories (ES/CA)
# From /ca/casos-exito/ to /ca/casos-exit/
Redirect 301 /ca/casos-exito/ https://novamarketing.es/ca/casos-exit/
Redirect 301 /ca/casos-exito https://novamarketing.es/ca/casos-exit/

# Ensure HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Sitemap Redirect (from sitemap.xml to sitemap-index.xml)
RewriteRule ^sitemap\.xml$ /sitemap-index.xml [L,R=301]

# ── Security Headers ───────────────────────────────────────────────────────────
<IfModule mod_headers.c>
  # HTTPS obligatorio durante 1 año (el sitio y el CMS ya sirven por HTTPS)
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
  # Impide que el navegador adivine el tipo MIME (MIME sniffing)
  Header always set X-Content-Type-Options "nosniff"
  # Impide que otras webs embeban el sitio en un iframe (clickjacking)
  Header always set X-Frame-Options "SAMEORIGIN"
  # Envía menos información de referencia a terceros
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ── Cache Control ──────────────────────────────────────────────────────────────
# Astro hashes CSS/JS filenames on each build → safe to cache 1 year
<IfModule mod_headers.c>
  # Fonts: 1 year immutable
  <FilesMatch "\.(woff2|woff|ttf|otf|eot)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # CSS & JS: 1 year immutable (content-hashed by Astro)
  <FilesMatch "\.(css|js|mjs)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # Images: 1 month
  <FilesMatch "\.(webp|jpg|jpeg|png|gif|svg|ico|avif)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>
  # HTML: caché corta con revalidación
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=3600, must-revalidate"
  </FilesMatch>
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType font/woff2                "access plus 1 year"
  ExpiresByType font/woff                 "access plus 1 year"
  ExpiresByType text/css                  "access plus 1 year"
  ExpiresByType application/javascript    "access plus 1 year"
  ExpiresByType image/webp                "access plus 1 month"
  ExpiresByType image/jpeg                "access plus 1 month"
  ExpiresByType image/png                 "access plus 1 month"
  ExpiresByType image/svg+xml             "access plus 1 month"
  ExpiresByType image/avif                "access plus 1 month"
  ExpiresByType text/html                 "access plus 1 hour"
</IfModule>

# ── Compression ────────────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml font/woff2
</IfModule>
