# Nova Marketing - 301 Redirects & WWW Cleanup

# Custom 404 pages (ES + CA)
ErrorDocument 404 /404.html
RewriteCond %{REQUEST_URI} ^/ca/
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ /ca/404.html [L,R=404]

# Force Non-WWW
RewriteEngine On
RewriteCond %{HTTP_HOST} ^www\.novamarketing\.es [NC]
RewriteRule ^(.*)$ https://novamarketing.es/$1 [L,R=301]

# SEO city pages moved under /agencia-seo-para-pymes/
Redirect 301 /agencia-seo-en-sabadell/ https://novamarketing.es/agencia-seo-para-pymes/sabadell/
