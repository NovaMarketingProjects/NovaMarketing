{
    "kind": "collectionType",
    "collectionName": "authors",
    "info": {
        "singularName": "author",
        "pluralName": "authors",
        "displayName": "Autor",
        "description": "Autores de artículos y casos de éxito"
    },
    "options": {
        "draftAndPublish": false
    },
    "pluginOptions": {},
    "attributes": {
        "name": {
            "type": "string",
            "required": true
        },
        "job_title": {
            "type": "string"
        },
        "description": {
            "type": "text"
        },
        "photo": {
            "type": "media",
            "multiple": false,
            "required": false,
            "allowedTypes": ["images"]
        },
        "social_links": {
            "type": "component",
            "component": "shared.social-link",
            "repeatable": true,
            "max": 7
        },
        "articles": {
            "type": "relation",
            "relation": "oneToMany",
            "target": "api::article.article",
            "mappedBy": "author"
        },
        "case_studies": {
            "type": "relation",
            "relation": "oneToMany",
            "target": "api::case-study.case-study",
            "mappedBy": "author"
        }
    }
}
