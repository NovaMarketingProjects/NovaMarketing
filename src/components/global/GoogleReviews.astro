---
/**
 * GoogleReviews.astro
 * Reseñas reales de las fichas de Google Business Profile, mostradas antes del footer.
 * Los textos son literales de GBP; los enlaces llevan a las fichas para verificarlas.
 */
const { locale = 'es', title: customTitle } = Astro.props;

const t = locale === 'ca' ? {
    eyebrow: 'Ressenyes de Google',
    title: 'El que diuen els nostres clients a Google sobre Nova',
    subtitle: 'Ressenyes reals i verificables a les nostres fitxes de Google Business Profile.',
    viewAll: 'Veure totes les ressenyes',
    reviewsWord: 'ressenyes',
} : {
    eyebrow: 'Reseñas de Google',
    title: 'Lo que dicen nuestros clientes en Google sobre Nova',
    subtitle: 'Reseñas reales y verificables en nuestras fichas de Google Business Profile.',
    viewAll: 'Ver todas las reseñas',
    reviewsWord: 'reseñas',
};

const listings = [
    { label: 'Sabadell', rating: '5,0', count: 16, url: 'https://maps.app.goo.gl/ETtzpajqEucNf22D7' },
    { label: 'Barcelona', rating: '5,0', count: 12, url: 'https://maps.app.goo.gl/9fbB12UcK32bgjj89' },
];

// Textos literales de GBP (todas 5 estrellas)
const allReviews = [
    { author: 'Antonio Melero', location: 'Barcelona', text: 'Soy quiromasajista y necesitaba hacerme una página web que también tuviera buen posicionamiento SEO local. Sergio entendió perfectamente que mi web no era solo un sitio bonito, sino una herramienta para conseguir pacientes de mi zona. El resultado es una web clara, rápida y pensada para que la gente que busca un quiromasajista cerca acabe encontrándome a mí.' },
    { author: 'Cristina Oliver', location: 'Barcelona', text: 'Totalmente recomendados para cualquier pyme. Sergio no se limita a darte consejos analiza tu mercado para mejorar tu posicionamiento SEO. En mi caso necesitaba posicionar en un entorno muy competitivo y Nova Marketing trazó el plan perfecto.' },
    { author: 'Rosmelys Lopez', location: 'Sabadell', text: 'Sinceramente estoy súper contenta con el trabajo que está haciendo Nova Marketing con el posicionamiento SEO y la página web de mi negocio ✨ Llevamos solo 3 meses y ya estoy notando resultados reales.' },
    { author: 'John Muñoz', location: 'Sabadell', text: 'Excelente agencia de marketing. Los he contactado en varias ocasiones para asesoramiento y siempre han cumplido con mis expectativas. Profesionalismo, creatividad y compromiso en cada proyecto. Totalmente recomendados.' },
    { author: 'Lidia Monterrubio', location: 'Sabadell', text: '¡Muy muy buen servicio! Nos ayudó a realizar y hacer posible los proyectos que teníamos en mente para hacer crecer nuestro negocio. Un diez en asesoramiento y acompañamiento en todo el proceso.' },
    { author: 'Belén Carrillo Comellas', location: 'Sabadell', text: 'Gestiono redes sociales y necesitaba posicionarme en Google Sabadell y empezamos a trabajar en una estrategia seo. Dos o tres meses después ya empezamos a ver los resultados.' },
    { author: 'Alba Delgado Arau', location: 'Barcelona', text: 'Tenemos un club de gimnasia artística y nos han ayudado con nuestra estrategia de marketing digital que teníamos un poquito olvidada.' },
    { author: 'Martin Garcia', location: 'Sabadell', text: 'Llevamos la estrategia SEM y publicidad en redes sociales con ellos, desde hace varios meses y de momento, trato y resultados de 10.' },
    { author: '이진만', location: 'Barcelona', text: 'Como guía turístico, buscaba algo que me ayudara a diferenciarme, y hablé con Sergio de Nova Marketing y ha hecho un trabajo excepcional. 👍👍👍 La ilustración que han diseñado para mi marca es increíble y me va a ayudar muchísimo a posicionar.' },
    { author: 'Jesús Antonio García', location: 'Barcelona', text: 'Excelente servicio de SEO y el trato siempre es muy cercano. Recomendados al 100%.' },
    { author: 'Ester Guillen', location: 'Barcelona', text: 'Llevamos un par de meses trabajando juntos y al principio solo cogimos el pack SEM pero seguramente contratamos una auditoría completa con vosotros. Profesionales y muy recomendable.' },
    { author: 'BARWI', location: 'Barcelona', text: 'Excelente SEO, pensé que podría hacerlo sola pero no veía resultados, me dieron su contacto y en menos de lo que imaginé logro posicionar mi pyme en primeras búsquedas, los contactos que obtengo a través de mi web aumentaron de tal manera que no me lo esperaba, super super contenta con la amabilidad y disponibilidad de Sergio en todo momento, siempre atento a mis dudas y solucionando de manera ágil lo que necesito. Gracias Sergio por trabajar de la mano para que mi empresa crezca!' },
    { author: 'Secretaria Cts', location: 'Barcelona', text: 'Nos ha revivido la empresa! Todo un profesional creativo, lógico y estratega. Excelente precio.' },
    { author: 'CTS Centro de Formación', location: 'Barcelona', text: 'Nova Marketing ( en particular Sergio) hizo desde cero nuestra pagina web (CTS Institut Metropolità) escuchando atentamente nuestras necesidades y sabiendo plasmar nuestra esencia en ella, tanto es así que al ver su buen trabajo decidimos contratarlo para que fuera nuestro SEO, y fue una excelente decisión ya que nos ha ayudado a lograr objetivos mensuales tanto a nivel de ventas como de visibilidad y posicionamiento. No podíamos haber encontrado otra agencia de marketing mejor en Barcelona para lo que necesitábamos, MUY recomendable.' },
    { author: 'Herminia Sanahuja', location: 'Barcelona', text: 'He trabajado con Sergio y ha sido de gran ayuda todo su conocimiento, ha valorado y encaminado lo mejor para mi empresa y ha sabido ayudarme a organizar ideas para que mi página web y posicionamiento funcionen adecuadamente, agradecida por trabajar con él mes a mes y por siempre contar con él para manejar todo lo relacionado con redes y web de mi empresa. Lo recomiendo sin duda!' },
];

// Selección aleatoria de 6 en cada build: cada página muestra una combinación distinta
const reviews = [...allReviews]
  .map(r => ({ r, k: Math.random() }))
  .sort((a, b) => a.k - b.k)
  .slice(0, 6)
  .map(x => x.r);

const gbpFor = (loc: string) => listings.find(l => l.label === loc)?.url || '#';
---

<section class="py-20 sm:py-28 bg-zinc-50 border-t border-black/5 px-4 sm:px-6">
    <div class="max-w-7xl mx-auto">
        <div class="text-center mb-12 sm:mb-16 reveal">
            <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">{t.eyebrow}</span>
            <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.9]">
                {customTitle || t.title}
            </h2>
            <p class="text-zinc-500 font-light text-sm sm:text-base leading-relaxed max-w-2xl mx-auto mb-8">
                {t.subtitle}
            </p>

            <!-- Resumen por ficha -->
            <div class="flex flex-wrap items-center justify-center gap-4">
                {listings.map(l => (
                    <a href={l.url} target="_blank" rel="noopener" class="group inline-flex items-center gap-3 bg-white border border-black/5 rounded-full pl-4 pr-5 py-2.5 shadow-sm hover:shadow-md transition-shadow">
                        <svg class="w-5 h-5" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.27-4.74 3.27-8.1z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18A10.96 10.96 0 001 12c0 1.77.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
                        <span class="text-sm font-bold text-zinc-900">{l.label}</span>
                        <span class="flex items-center gap-1">
                            <span class="text-sm font-black text-zinc-900">{l.rating}</span>
                            <span class="flex">
                                {Array.from({ length: 5 }).map(() => (
                                    <svg class="w-3.5 h-3.5 text-yellow-400 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                                ))}
                            </span>
                            <span class="text-xs text-zinc-500 font-light">({l.count})</span>
                        </span>
                    </a>
                ))}
            </div>
        </div>

        <!-- Tarjetas de reseñas -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 reveal">
            {reviews.map(r => (
                <div class="bg-white border border-black/5 rounded-2xl p-6 flex flex-col gap-4 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
                    <div class="flex items-center justify-between">
                        <div class="flex">
                            {Array.from({ length: 5 }).map(() => (
                                <svg class="w-4 h-4 text-yellow-400 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                            ))}
                        </div>
                        <svg class="w-4 h-4" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.27-4.74 3.27-8.1z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18A10.96 10.96 0 001 12c0 1.77.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
                    </div>
                    <p class="text-sm text-zinc-600 font-light leading-relaxed flex-1">"{r.text}"</p>
                    <div class="border-t border-zinc-100 pt-3 flex items-center justify-between">
                        <span class="text-xs font-black uppercase tracking-tight text-zinc-900">{r.author}</span>
                        <a href={gbpFor(r.location)} target="_blank" rel="noopener" class="text-[10px] font-black uppercase tracking-widest text-accent hover:underline">Google · {r.location}</a>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>
