---
/**
 * Footer.astro
 */
const { locale = 'es' } = Astro.props;

const t = locale === 'ca' ? {
    tagline: 'Agència de màrqueting digital per a pimes',
    explore: 'EXPLORA',
    legal: 'LEGAL',
    notice: 'AVÍS LEGAL',
    privacy: 'PRIVACITAT',
    cookies: 'COOKIES',
    terms: 'TERMES',
    cities: [
        { label: 'Agència de màrqueting digital a Sabadell',   href: '/ca/agencia-de-marketing-digital-a-sabadell/' },
        { label: 'Agència de màrqueting digital a Sant Cugat', href: '/ca/agencia-de-marketing-digital-a-sant-cugat/' },
        { label: 'Agència de màrqueting digital a Barcelona',  href: '/ca/agencia-de-marketing-digital-a-barcelona/' },
        { label: 'Agència de màrqueting digital a Terrassa',   href: '/ca/agencia-de-marketing-digital-a-terrassa/' },
    ],
} : {
    tagline: 'Agencia de marketing digital para pymes',
    explore: 'EXPLORAR',
    legal: 'LEGAL',
    notice: 'AVISO LEGAL',
    privacy: 'PRIVACIDAD',
    cookies: 'COOKIES',
    terms: 'TÉRMINOS',
    cities: [
        { label: 'Agencia de marketing digital en Sabadell',   href: '/agencia-de-marketing-digital-en-sabadell/' },
        { label: 'Agencia de marketing digital en Sant Cugat', href: '/agencia-de-marketing-digital-en-sant-cugat/' },
        { label: 'Agencia de marketing digital en Barcelona',  href: '/agencia-de-marketing-digital-en-barcelona/' },
        { label: 'Agencia de marketing digital en Terrassa',   href: '/agencia-de-marketing-digital-en-terrassa/' },
    ],
};

const prefix = locale === 'ca' ? '/ca' : '';

const locationsTitle = locale === 'ca' ? 'ON SOM' : 'DÓNDE ESTAMOS';
const mapLabel = locale === 'ca' ? 'Veure a Google Maps' : 'Ver en Google Maps';
const locations = [
    {
        name: 'Nova Marketing | Agencia de marketing digital en Sabadell',
        street: 'Carrer de Bilbao, 1',
        city: '08202 Sabadell, Barcelona',
        phone: '+34 644 73 82 70',
        phoneHref: 'tel:+34644738270',
        gbp: 'https://maps.app.goo.gl/ETtzpajqEucNf22D7',
        embed: 'https://www.google.com/maps?q=Nova%20Marketing%2C%20Carrer%20de%20Bilbao%201%2C%2008202%20Sabadell&output=embed',
        landing: locale === 'ca' ? '/ca/agencia-de-marketing-digital-a-sabadell/' : '/agencia-de-marketing-digital-en-sabadell/',
    },
    {
        name: 'Nova Marketing | Agencia de marketing digital en Barcelona',
        street: 'Carrer del General Mendoza, 10',
        city: '08035 Barcelona',
        phone: '+34 644 73 82 70',
        phoneHref: 'tel:+34644738270',
        gbp: 'https://maps.app.goo.gl/9fbB12UcK32bgjj89',
        embed: 'https://www.google.com/maps?q=Nova%20Marketing%2C%20Carrer%20del%20General%20Mendoza%2010%2C%2008035%20Barcelona&output=embed',
        landing: locale === 'ca' ? '/ca/agencia-de-marketing-digital-a-barcelona/' : '/agencia-de-marketing-digital-en-barcelona/',
    },
];
---

<footer class="py-24 bg-black border-t border-white/5 relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-6">
        <div class="flex flex-col lg:flex-row justify-between items-start gap-20">

            <!-- Brand -->
            <div>
                <div class="group inline-block cursor-default mb-8">
                    <span class="hover-animate-gradient text-6xl font-heading font-black tracking-tighter" style="color: white;">
                        nova.
                    </span>
                </div>
                <p class="text-zinc-500 font-light text-sm tracking-widest uppercase italic whitespace-nowrap">
                    {t.tagline}
                </p>
            </div>

            <!-- Nav columns -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-16 text-white">

                <!-- Ciudades -->
                <div class="flex flex-col gap-5">
                    <span class="text-[10px] font-black tracking-[0.3em] uppercase text-zinc-600">{t.explore}</span>
                    {t.cities.map(c => (
                        <a href={c.href} class="hover:text-accent transition-colors text-sm font-medium text-zinc-300 leading-snug">
                            {c.label}
                        </a>
                    ))}
                </div>

                <!-- Legal -->
                <div class="flex flex-col gap-5">
                    <span class="text-[10px] font-black tracking-[0.3em] uppercase text-zinc-600">{t.legal}</span>
                    <a href={locale === 'ca' ? '/ca/avis-legal/' : '/aviso-legal/'} class="hover:text-accent transition-colors text-sm font-medium text-zinc-300">{t.notice}</a>
                    <a href={locale === 'ca' ? '/ca/privacitat/' : '/privacidad/'} class="hover:text-accent transition-colors text-sm font-medium text-zinc-300">{t.privacy}</a>
                    <a href={locale === 'ca' ? '/ca/cookies/' : '/cookies/'} class="hover:text-accent transition-colors text-sm font-medium text-zinc-300">{t.cookies}</a>
                    <a href={locale === 'ca' ? '/ca/termes-i-condicions/' : '/terminos-y-condiciones/'} class="hover:text-accent transition-colors text-sm font-medium text-zinc-300">{t.terms}</a>
                </div>

            </div>
        </div>

        <!-- Ubicaciones (NAP de las fichas de Google Business Profile) -->
        <div class="mt-20 pt-16 border-t border-white/5">
            <span class="text-[10px] font-black tracking-[0.3em] uppercase text-zinc-600 block mb-8">{locationsTitle}</span>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
                {locations.map(loc => (
                    <div class="flex flex-col sm:flex-row gap-6">
                        <div class="flex-1 min-w-0">
                            <a href={loc.gbp} target="_blank" rel="noopener" class="text-white font-bold text-base hover:text-accent transition-colors">{loc.name}</a>
                            <address class="not-italic mt-3 space-y-1 text-sm text-zinc-400 font-light">
                                <div>{loc.street}</div>
                                <div>{loc.city}</div>
                                <div><a href={loc.phoneHref} class="hover:text-accent transition-colors">{loc.phone}</a></div>
                            </address>
                            <a href={loc.gbp} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 mt-4 text-[11px] font-black uppercase tracking-widest text-accent hover:underline">
                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                                {mapLabel}
                            </a>
                        </div>
                        <div class="sm:w-56 h-36 rounded-xl overflow-hidden border border-white/10 flex-shrink-0">
                            <iframe
                                src={loc.embed}
                                title={`Mapa - ${loc.name}`}
                                class="w-full h-full grayscale contrast-[1.1] opacity-80 hover:grayscale-0 hover:opacity-100 transition-all duration-500"
                                loading="lazy"
                                referrerpolicy="no-referrer-when-downgrade"
                                allowfullscreen
                            ></iframe>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </div>
</footer>
