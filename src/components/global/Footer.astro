---
/**
 * Footer.astro
 */
const { locale = 'es' } = Astro.props;

const t = locale === 'ca' ? {
    tagline: 'Agència de màrqueting digital per a pimes',
    explore: 'EXPLORA',
    legal: 'LEGAL',
    notice: 'AVÍS LEGAL',
    privacy: 'PRIVACITAT',
    cookies: 'COOKIES',
    terms: 'TERMES',
    cities: [
        { label: 'Agència de màrqueting digital a Sabadell',   href: '/ca/agencia-de-marketing-digital-a-sabadell/' },
        { label: 'Agència de màrqueting digital a Sant Cugat', href: '/ca/agencia-de-marketing-digital-a-sant-cugat/' },
        { label: 'Agència de màrqueting digital a Barcelona',  href: '/ca/agencia-de-marketing-digital-a-barcelona/' },
        { label: 'Agència de màrqueting digital a Terrassa',   href: '/ca/agencia-de-marketing-digital-a-terrassa/' },
    ],
} : {
    tagline: 'Agencia de marketing digital para pymes',
    explore: 'EXPLORAR',
    legal: 'LEGAL',
    notice: 'AVISO LEGAL',
    privacy: 'PRIVACIDAD',
    cookies: 'COOKIES',
    terms: 'TÉRMINOS',
    cities: [
        { label: 'Agencia de marketing digital en Sabadell',   href: '/agencia-de-marketing-digital-en-sabadell/' },
        { label: 'Agencia de marketing digital en Sant Cugat', href: '/agencia-de-marketing-digital-en-sant-cugat/' },
        { label: 'Agencia de marketing digital en Barcelona',  href: '/agencia-de-marketing-digital-en-barcelona/' },
        { label: 'Agencia de marketing digital en Terrassa',   href: '/agencia-de-marketing-digital-en-terrassa/' },
    ],
};

const prefix = locale === 'ca' ? '/ca' : '';
---

<footer class="py-24 bg-black border-t border-white/5 relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-6">
        <div class="flex flex-col lg:flex-row justify-between items-start gap-20">

            <!-- Brand -->
            <div>
                <div class="group inline-block cursor-default mb-8">
                    <span class="hover-animate-gradient text-6xl font-heading font-black tracking-tighter" style="color: white;">
                        nova.
                    </span>
                </div>
                <p class="text-zinc-500 font-light text-sm tracking-widest uppercase italic whitespace-nowrap">
                    {t.tagline}
                </p>
            </div>

            <!-- Nav columns -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-16 text-white">

                <!-- Ciudades -->
                <div class="flex flex-col gap-5">
                    <span class="text-[10px] font-black tracking-[0.3em] uppercase text-zinc-600">{t.explore}</span>
                    {t.cities.map(c => (
                        <a href={c.href} class="hover:text-accent transition-colors text-sm font-medium text-zinc-300 leading-snug">
                            {c.label}
                        </a>
                    ))}
                </div>

                <!-- Legal -->
                <div class="flex flex-col gap-5">
                    <span class="text-[10px] font-black tracking-[0.3em] uppercase text-zinc-600">{t.legal}</span>
                    <a href={locale === 'ca' ? '/ca/avis-legal/' : '/aviso-legal/'} class="hover:text-accent transition-colors text-sm font-medium text-zinc-300">{t.notice}</a>
                    <a href={locale === 'ca' ? '/ca/privacitat/' : '/privacidad/'} class="hover:text-accent transition-colors text-sm font-medium text-zinc-300">{t.privacy}</a>
                    <a href={locale === 'ca' ? '/ca/cookies/' : '/cookies/'} class="hover:text-accent transition-colors text-sm font-medium text-zinc-300">{t.cookies}</a>
                    <a href={locale === 'ca' ? '/ca/termes-i-condicions/' : '/terminos-y-condiciones/'} class="hover:text-accent transition-colors text-sm font-medium text-zinc-300">{t.terms}</a>
                </div>

            </div>
        </div>
    </div>
</footer>
