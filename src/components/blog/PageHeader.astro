---
interface Props {
  title: string;
  description: string;
  badge?: string;
}

const { title, description, badge } = Astro.props;
---

<header class="pt-20 pb-8 px-6 sm:px-12 relative overflow-hidden text-center bg-white border-b border-black/5 flex items-center">
  <!-- Background Grid Mesh -->
  <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808008_1px,transparent_1px),linear-gradient(to_bottom,#80808008_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_40%,#000_75%,transparent_100%)]"></div>

  <!-- Glow Orbs -->
  <div class="absolute -top-10 left-1/4 w-48 h-48 bg-accent/15 rounded-full blur-3xl opacity-30 animate-pulse"></div>
  <div class="absolute top-10 right-1/4 w-56 h-56 bg-purple-500/5 rounded-full blur-3xl opacity-20"></div>

  <div class="max-w-4xl mx-auto w-full text-center relative z-10">
      <div class="reveal">
          <div class="inline-flex items-center gap-2 bg-accent/5 backdrop-blur-sm px-3 py-1.5 border border-accent/10 rounded-full text-accent text-[8px] sm:text-[9px] font-black uppercase tracking-[0.3em] mb-4 shadow-sm">
            <span class="w-1.5 h-1.5 bg-accent rounded-full animate-ping"></span>
            {badge || 'Sección'}
          </div>
          
          <h1 class="text-2xl sm:text-4xl md:text-5xl lg:text-6xl uppercase font-black tracking-tighter leading-tight mb-3 text-zinc-900">
              <Fragment set:html={title} />
          </h1>
          
          <p class="text-sm sm:text-base text-zinc-500 font-light leading-relaxed max-w-xl mx-auto whitespace-normal text-balance">
              {description}
          </p>
      </div>
  </div>
</header>

<style>
  .reveal {
    opacity: 0;
    transform: translateY(20px);
    animation: revealFixed 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes revealFixed {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
