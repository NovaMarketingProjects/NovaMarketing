---
import type { CaseStudy } from '../../lib/strapi';
import { getStrapiImageUrl } from '../../lib/strapi';

interface Props {
  caseStudy: CaseStudy;
  locale: 'es' | 'ca';
}

const { caseStudy, locale } = Astro.props;
const prefix = locale === 'ca' ? '/ca' : '';
const caseUrl = locale === 'ca' ? `/ca/casos-exit/${caseStudy.slug}/` : `/casos-exito/${caseStudy.slug}/`;
const imageUrl = getStrapiImageUrl(caseStudy.cover_image) || '/og-default.jpg';
const categories = caseStudy.categories || [];
const firstCategory = categories.length > 0 ? (categories[0].attributes?.name || categories[0].name) : (locale === 'ca' ? 'Cas d\'èxit' : 'Caso de éxito');
const company = caseStudy.company || '';
---

<a href={caseUrl} class="group bg-white border border-black/5 rounded-2xl overflow-hidden hover:shadow-xl hover:-translate-y-1 transition-all duration-500 shadow-sm flex flex-col h-full relative">
  <!-- Image Container -->
  <div class="relative aspect-[4/3] overflow-hidden">
    <img 
      src={imageUrl} 
      alt={caseStudy.title}
      class="w-full h-full object-cover grayscale transition-all duration-700 group-hover:grayscale-0 group-hover:scale-105"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent opacity-60 group-hover:opacity-40 transition-opacity"></div>
    
    <div class="absolute top-3 left-3 z-10">
      <span class="bg-white/95 backdrop-blur-sm border border-black/5 px-3 py-1 rounded-full text-[8px] font-black uppercase tracking-[0.2em] text-accent shadow-md">
        {firstCategory}
      </span>
    </div>

    {company && (
    <div class="absolute bottom-3 left-3 z-10 bg-white/10 backdrop-blur-md rounded-lg px-3 py-1.5 flex items-center border border-white/20">
        <span class="text-white font-black uppercase tracking-tighter text-[9px]">{company}</span>
    </div>
    )}
  </div>

  <!-- Content Section -->
  <div class="p-5 flex flex-col flex-1 bg-white">
    <div class="mb-3 flex-1">
       <h2 class="text-sm font-black uppercase tracking-tight text-zinc-900 leading-tight group-hover:text-accent transition-colors line-clamp-2">
         {caseStudy.title}
       </h2>
       <p class="text-zinc-500 font-light text-xs line-clamp-2 mt-2 leading-relaxed">
         {caseStudy.description}
       </p>
    </div>

    {caseStudy.results && caseStudy.results.length > 0 && (
      <div class="grid grid-cols-2 gap-2 pt-3 border-t border-zinc-50 mb-3">
          <div class="flex flex-col">
            <span class="text-base font-black text-black leading-none">{caseStudy.results[0].value}</span>
            <span class="text-[7px] font-black uppercase tracking-wider text-accent">{caseStudy.results[0].metric}</span>
          </div>
          {caseStudy.results[1] && (
          <div class="flex flex-col">
            <span class="text-base font-black text-black leading-none">{caseStudy.results[1].value}</span>
            <span class="text-[7px] font-black uppercase tracking-wider text-accent">{caseStudy.results[1].metric}</span>
          </div>
          )}
      </div>
    )}

    <div class="flex items-center justify-between pt-3 border-t border-zinc-50">
      <span class="text-[8px] font-black tracking-[0.25em] text-accent flex items-center gap-1.5 group-hover:gap-3 transition-all uppercase">
        {locale === 'ca' ? 'VEURE RESULTATS' : 'VER RESULTADOS'} <span class="text-sm">→</span>
      </span>
    </div>
  </div>
</a>
