---
interface Props {
  categories: { name: string; slug: string; count?: number }[];
  currentCategory?: string;
  baseUrl: string;
  locale?: 'es' | 'ca';
}

const { categories, currentCategory = 'all', baseUrl, locale = 'es' } = Astro.props;
const allLabel = locale === 'ca' ? 'Totes' : 'Todas';
---

<div class="flex flex-nowrap justify-center gap-2 mb-8 reveal overflow-x-auto max-w-3xl mx-auto pb-1">
  <a
    href={`${baseUrl}/`}
    class:list={[
      'px-4 py-2 text-[10px] font-black uppercase tracking-[0.2em] rounded-xl transition-all duration-300 border whitespace-nowrap flex-shrink-0',
      currentCategory === 'all'
        ? 'bg-accent border-accent text-white shadow-[0_8px_20px_rgba(255,107,0,0.2)]'
        : 'bg-white border-black/10 text-zinc-500 hover:border-black/20 hover:text-black hover:bg-zinc-50'
    ]}
  >
    {allLabel}
  </a>

  {categories.map((cat) => (
    <a
      href={`${baseUrl}/${cat.slug}/`}
      class:list={[
        'px-4 py-2 text-[10px] font-black uppercase tracking-[0.2em] rounded-xl transition-all duration-300 border whitespace-nowrap flex-shrink-0',
        currentCategory === cat.slug
          ? 'bg-accent border-accent text-white shadow-[0_8px_20px_rgba(255,107,0,0.2)]'
          : 'bg-white border-black/10 text-zinc-500 hover:border-black/20 hover:text-black hover:bg-zinc-50'
      ]}
    >
      {cat.name}
    </a>
  ))}
</div>

<style>
  .reveal {
    opacity: 0;
    transform: translateY(10px);
    animation: revealFixed 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes revealFixed {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
