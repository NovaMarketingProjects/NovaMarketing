---
/**
 * src/components/cta/ContactModal.astro
 * Modal popup para contacto en Desktop.
 */
interface Props {
  locale?: string;
}
const { locale = 'es' } = Astro.props;

const t = {
  es: {
    title: 'CUÉNTANOS TU PROYECTO',
    name: 'Nombre *',
    email: 'Email Profesional *',
    web: 'Web / URL',
    phone: 'Teléfono',
    msg: 'Mensaje',
    terms: 'Acepto y he leído los términos y condiciones',
    submit: 'ENVIAR SOLICITUD',
  },
  ca: {
    title: 'EXPLICA\'NS EL TEU PROJECTE',
    name: 'Nom *',
    email: 'Email Professional *',
    web: 'Web / URL',
    phone: 'Telèfon',
    msg: 'Missatge',
    terms: 'Accepto i he llegit els termes i condicions',
    submit: 'ENVIAR SOL·LICITUD',
  }
}[locale as 'es' | 'ca'] || {
  es: {
    title: 'CUÉNTANOS TU PROYECTO',
    name: 'Nombre *',
    email: 'Email Profesional *',
    web: 'Web / URL',
    phone: 'Teléfono',
    msg: 'Mensaje',
    terms: 'Acepto y he leído los términos y condiciones',
    submit: 'ENVIAR SOLICITUD',
  }
};
---

<!-- Sending overlay -->
<div id="contact-sending" class="fixed inset-0 z-[200] bg-white flex flex-col items-center justify-center hidden">
  <div class="flex flex-col items-center gap-8 px-8 max-w-sm w-full text-center">
    <div class="w-16 h-16 rounded-full border-4 border-zinc-100 border-t-accent animate-spin"></div>
    <div>
      <div class="text-2xl font-black uppercase tracking-tighter text-black mb-2">Enviando...</div>
      <p class="text-zinc-400 font-light text-sm">Estamos procesando tu solicitud,<br>un momento por favor.</p>
    </div>
    <div class="w-full bg-zinc-100 rounded-full h-1 overflow-hidden">
      <div id="contact-progress" class="h-full bg-accent rounded-full" style="width:0%;transition:width 0.4s ease"></div>
    </div>
  </div>
</div>

<!-- Modal Overlay -->
<div id="contact-modal" class="fixed inset-0 z-[100] bg-black/40 backdrop-blur-md items-center justify-center p-4 transition-all duration-300 opacity-0 pointer-events-none hidden">
    <!-- Modal Dialog -->
    <div class="bg-white max-w-xl w-full p-8 sm:p-12 shadow-[0_40px_100px_rgba(0,0,0,0.2)] rounded-sm relative scale-95 transition-transform duration-300" id="modal-content">
        
        <!-- Close button -->
        <button id="close-modal-btn" class="absolute top-5 right-5 text-zinc-400 hover:text-black transition-colors focus:outline-none">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" class="w-6 h-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        </button>

        <span class="text-[10px] font-black uppercase tracking-[0.5em] text-accent mb-4 block">{t.title}</span>
        <div class="text-3xl sm:text-4xl font-black uppercase tracking-tighter mb-8 text-gradient">CONTACTAR</div>

        <form id="desktop-modal-form" class="space-y-6">
            <div class="grid sm:grid-cols-2 gap-6 text-[10px] font-black tracking-widest uppercase">
                <div class="flex flex-col gap-3">
                    <label class="opacity-30">{t.name}</label>
                    <input type="text" name="name" aria-label="Nombre" required class="border-b border-black/10 py-2 focus:border-accent outline-none">
                </div>
                <div class="flex flex-col gap-3">
                    <label class="opacity-30">{t.email}</label>
                    <input type="email" name="email" aria-label="Correo electrónico" required class="border-b border-black/10 py-2 focus:border-accent outline-none">
                </div>
            </div>

            <div class="grid sm:grid-cols-2 gap-6 text-[10px] font-black tracking-widest uppercase">
                <div class="flex flex-col gap-3">
                    <label class="opacity-30">{t.web}</label>
                    <input type="text" name="url" aria-label="Sitio web" class="border-b border-black/10 py-2 focus:border-accent outline-none">
                </div>
                <div class="flex flex-col gap-3">
                    <label class="opacity-30">{t.phone}</label>
                    <input type="tel" name="phone" class="border-b border-black/10 py-2 focus:border-accent outline-none">
                </div>
            </div>

            <div class="flex flex-col gap-3 text-[10px] font-black tracking-widest uppercase">
                <label class="opacity-30">{t.msg}</label>
                <textarea name="msg" aria-label="Mensaje" rows="3" class="border-b border-black/10 py-2 focus:border-accent outline-none resize-none"></textarea>
            </div>

            <!-- Terms and conditions Checkbox -->
            <div class="flex items-start gap-2 mt-4">
                <input type="checkbox" id="terms-agree" name="terms" required class="mt-1 accent-accent">
                <label for="terms-agree" class="text-xs text-zinc-500 font-light cursor-pointer select-none">
                    {t.terms}
                </label>
            </div>

            <button type="submit" class="w-full btn-mktg-v5 !py-5 shadow-[0_10px_30px_rgba(0,0,0,0.1)]">{t.submit}</button>
        </form>
    </div>
</div>

<script>
    function openModal() {
        const modal = document.getElementById('contact-modal');
        const content = document.getElementById('modal-content');
        if (!modal || !content) return;
        modal.classList.remove('hidden');
        setTimeout(() => {
            modal.classList.remove('pointer-events-none');
            modal.classList.add('pointer-events-auto', 'flex', 'opacity-100');
            content.classList.remove('scale-95');
            content.classList.add('scale-100');
        }, 10);
    }

    function closeModal() {
        const modal = document.getElementById('contact-modal');
        const content = document.getElementById('modal-content');
        if (!modal || !content) return;
        content.classList.remove('scale-100');
        content.classList.add('scale-95');
        modal.classList.remove('opacity-100', 'pointer-events-auto');
        modal.classList.add('pointer-events-none');
        setTimeout(() => {
            modal.classList.add('hidden');
            modal.classList.remove('flex');
        }, 300);
    }

    /* Event bindings - outside page load for maximum reliability */
    document.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        
        // Open trigger
        if (target && target.closest('.contact-modal-trigger')) {
            e.preventDefault();
            openModal();
        }
        
        // Close on backdrop click
        if (target && target.id === 'contact-modal') {
             closeModal();
        }
    });

    // Close on explicitly x button trigger hook
    document.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        if (target && target.closest('#close-modal-btn')) {
             closeModal();
        }
    });

    function showSendingOverlay() {
        const overlay = document.getElementById('contact-sending');
        const bar = document.getElementById('contact-progress');
        if (!overlay || !bar) return;
        overlay.classList.remove('hidden');
        // Animate bar: quickly to 80%, then wait (real progress finishes it)
        setTimeout(() => { bar.style.width = '40%'; }, 50);
        setTimeout(() => { bar.style.width = '70%'; }, 600);
        setTimeout(() => { bar.style.width = '85%'; }, 1800);
    }

    function completeSendingOverlay() {
        const bar = document.getElementById('contact-progress');
        if (bar) bar.style.width = '100%';
    }

    function hideSendingOverlay(showError: boolean, btn: HTMLButtonElement | null) {
        const overlay = document.getElementById('contact-sending');
        if (overlay) overlay.classList.add('hidden');
        const bar = document.getElementById('contact-progress');
        if (bar) bar.style.width = '0%';
        if (showError && btn) {
            btn.innerHTML = 'ERROR — INTÉNTALO DE NUEVO';
            btn.disabled = false;
            btn.style.background = '#ef4444';
        }
    }

    document.addEventListener('input', (e) => {
        const input = e.target as HTMLInputElement;
        if (input.name === 'url') input.setCustomValidity('');
    });

    document.addEventListener('submit', async (e) => {
         const target = e.target as HTMLFormElement;
         if (target && target.id === 'desktop-modal-form') {
              e.preventDefault();
              const urlInput = target.querySelector<HTMLInputElement>('[name="url"]');
              if (urlInput && urlInput.value.trim() && !/\.[a-zA-Z]{2,}/.test(urlInput.value.trim())) {
                urlInput.setCustomValidity('Introduce una URL válida, por ejemplo: miempresa.com');
                urlInput.reportValidity();
                return;
              }
              if (urlInput) urlInput.setCustomValidity('');
              const btn = target.querySelector('button') as HTMLButtonElement;
              if (btn) { btn.disabled = true; }
              showSendingOverlay();
              const data = { ...Object.fromEntries(new FormData(target)), source: window.location.href };
              try {
                  const res = await fetch('https://cms.novamarketing.es/api/contact', {
                      method: 'POST',
                      headers: { 'Content-Type': 'application/json' },
                      body: JSON.stringify(data),
                  });
                  if (res.ok) {
                      completeSendingOverlay();
                      setTimeout(() => {
                          const isCA = window.location.pathname.startsWith('/ca');
                          window.location.href = isCA ? '/ca/gracies/' : '/gracias/';
                      }, 400);
                  } else {
                      throw new Error('Error');
                  }
              } catch {
                  hideSendingOverlay(true, btn);
              }
         }
    });

</script>
