---
/** components/sections/FaqHome.astro — Native HTML <details> Accordion FAQ */
interface Props {
  title?: string;
  items: { question: string; answer: string }[];
}

const {
    title = 'Preguntas frecuentes',
    items = []
} = Astro.props;

// Schema FAQ format
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": items.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
};
---

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

<section class="py-24 sm:py-32 bg-white relative overflow-hidden px-4 sm:px-6">
    <!-- Subtle Background Element -->
    <div class="absolute top-0 right-0 -translate-y-1/2 translate-x-1/2 w-[500px] h-[500px] bg-accent/5 rounded-full blur-[100px] pointer-events-none"></div>

    <div class="max-w-8xl mx-auto relative z-10">
        <div class="text-center mb-16 sm:mb-20 reveal">
            <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Resolviendo dudas</span>
            <h2 class="text-3xl sm:text-5xl lg:text-6xl uppercase tracking-tighter font-extrabold mb-4 leading-[0.9] text-zinc-900" set:html={title} />
        </div>

        <div class="space-y-4 reveal max-w-4xl mx-auto">
            {items.map((item, i) => (
                <details class="faq-item group border border-black/5 rounded-2xl bg-zinc-50/50 overflow-hidden hover:bg-white hover:border-accent/10 hover:shadow-[0_15px_40px_rgba(0,0,0,0.03)] transition-all duration-300">
                    <summary class="w-full px-6 sm:px-8 py-6 flex items-center justify-between text-left gap-6 cursor-pointer list-none">
                        <h3 class="text-base sm:text-lg font-bold tracking-tight text-zinc-900 group-hover:text-accent transition-colors">
                            {item.question}
                        </h3>
                        <div class="relative w-6 h-6 shrink-0 transition-transform duration-500 group-open:rotate-45">
                            <div class="absolute top-1/2 left-0 w-full h-[2px] bg-accent/30 rounded-full group-hover:bg-accent transition-colors"></div>
                            <div class="absolute top-0 left-1/2 h-full w-[2px] bg-accent/30 rounded-full group-hover:bg-accent transition-colors"></div>
                        </div>
                    </summary>
                    <div class="px-6 sm:px-8 pb-8 pt-2 text-zinc-500 font-light text-sm sm:text-base leading-relaxed">
                        <Fragment set:html={item.answer} />
                    </div>
                </details>
            ))}
        </div>
    </div>
</section>

<style>
    details > summary::-webkit-details-marker {
        display: none;
    }

    details summary {
        transition: color 0.3s ease;
    }

    details[open] > summary {
        margin-bottom: 0;
    }
</style>
