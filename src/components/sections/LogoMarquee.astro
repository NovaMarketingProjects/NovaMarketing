---
/**
 * src/components/sections/LogoMarquee.astro
 * Social Proof component with scrolling logos of clients.
 * Server-rendered (no JS): one visible set + one aria-hidden copy for the seamless -50% loop.
 */
const logos = [
    { src: "/clients/bermaq-cliente-novamarketing.webp", alt: "Bermaq" },
    { src: "/clients/cb-lhospitalet-cliente-novamarketing.webp", alt: "CB l'Hospitalet" },
    { src: "/clients/medhs-cliente-novamarketing.webp", alt: "MedHS" },
    { src: "/clients/palacio-del-bebe-cliente-novamarketing.webp", alt: "Palacio del bebé" },
    { src: "/clients/tagtio-cliente-novamarketing.webp", alt: "Tagtio" },
    { src: "/clients/tejados-tapar-cliente-novamarketing.webp", alt: "Tejados Tapar" },
    { src: "/clients/fastpoint-cliente-novamarketing.webp", alt: "FastPoint" },
    { src: "/clients/mundeta-cliente-novamarketing.webp", alt: "Mundeta" },
    { src: "/clients/tattoox-cliente-novamarketing.webp", alt: "TattooX" },
    { src: "/clients/voltura-projects-cliente-novamarketing.webp", alt: "Voltura Projects" }
];
---

<section class="py-12 border-b border-black/5 bg-zinc-50/40 relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <p class="text-[9px] sm:text-[10px] uppercase font-black tracking-widest text-zinc-400 text-center mb-8">Pymes que ya crecen con Nova Marketing</p>

        <!-- Contenedor Maratón -->
        <div class="overflow-hidden w-full relative [mask-image:linear-gradient(to_right,transparent,white_10%,white_90%,transparent)]">
            <div class="flex items-center gap-16 w-max animate-scroll-logo">
                {logos.map(item => (
                    <img src={item.src} alt={item.alt} title={item.alt} loading="lazy" class="h-[50px] w-auto object-contain filter grayscale opacity-60 hover:grayscale-0 hover:opacity-100 transition-all duration-300 pointer-events-none mix-blend-multiply" />
                ))}
                {logos.map(item => (
                    <img src={item.src} alt={item.alt} title={item.alt} aria-hidden="true" loading="lazy" class="h-[50px] w-auto object-contain filter grayscale opacity-60 hover:grayscale-0 hover:opacity-100 transition-all duration-300 pointer-events-none mix-blend-multiply" />
                ))}
            </div>
        </div>
    </div>
</section>

<style>
    @keyframes scrollMarqueeLogo {
        0% { transform: translateX(0); }
        100% { transform: translateX(-50%); }
    }
    .animate-scroll-logo {
        animation: scrollMarqueeLogo 60s linear infinite;
    }
</style>
