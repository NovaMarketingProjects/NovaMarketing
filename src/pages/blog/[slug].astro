---
/**
 * pages/blog/[slug].astro
 * Artículo individual del blog con diseño Cinematic Hero
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageBlocks from '../../components/blocks/PageBlocks.astro';
import { strapiClient } from '../../lib/strapi';
import { buildAlternates } from '../../lib/i18n';
import { articleSchema } from '../../lib/schema';
import type { BlogPost, Author } from '../../lib/strapi';
import { getStrapiImageUrl } from '../../lib/strapi';

export async function getStaticPaths() {
  try {
    const res = await strapiClient.getBlogPosts('es');
    return res.data.map((item: any) => {
      const post: BlogPost = item.attributes ?? item;
      return {
        params: { slug: post.slug },
        props: { post },
      };
    });
  } catch {
    return [];
  }
}

const { post }: { post: BlogPost } = Astro.props;
const author: Author | undefined = post.author;
const SITE_URL = import.meta.env.PUBLIC_SITE_URL || 'https://novamarketing.es';
const canonicalPath = `/blog/${post.slug}`;
const canonicalUrl = `${SITE_URL}${canonicalPath}`;
const alternates = buildAlternates(canonicalPath, `/blog/${post.slug}`, SITE_URL);

const schemas: object[] = [];

const SOCIAL_ICONS: Record<string, string> = {
  instagram: `<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>`,
  youtube: `<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M23.495 6.205a3.007 3.007 0 00-2.088-2.088c-1.87-.501-9.396-.501-9.396-.501s-7.507-.01-9.396.501A3.007 3.007 0 00.527 6.205a31.247 31.247 0 00-.522 5.805 31.247 31.247 0 00.522 5.783 3.007 3.007 0 002.088 2.088c1.868.502 9.396.502 9.396.502s7.506 0 9.396-.502a3.007 3.007 0 002.088-2.088 31.247 31.247 0 00.5-5.783 31.247 31.247 0 00-.5-5.805zM9.609 15.601V8.408l6.264 3.602z"/></svg>`,
  linkedin: `<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
  twitter: `<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>`,
  facebook: `<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>`,
  tiktok: `<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>`,
  website: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>`,
};

function getSocialIcon(network: string): string {
  return SOCIAL_ICONS[network] ?? SOCIAL_ICONS.website;
}

function formatDate(dateStr?: string) {
  if (!dateStr) return '';
  return new Date(dateStr).toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' });
}

const coverUrl = getStrapiImageUrl(post.featuredImage) || '/og-default.jpg';
---

<BaseLayout
  title={post.seo?.metaTitle || `${post.title} | Blog Nova Marketing`}
  description={post.seo?.metaDescription || post.excerpt || ''}
  canonical={canonicalUrl}
  locale="es"
  alternates={alternates}
  schemas={schemas}
>
  <!-- Cinematic Hero -->
  <header class="relative min-h-[75vh] flex items-end pb-24 px-6 sm:px-12 overflow-hidden bg-black">
    <!-- background image -->
    <div class="absolute inset-0 z-0 opacity-60">
        <img 
          src={coverUrl} 
          alt={post.title} 
          class="w-full h-full object-cover scale-105"
        />
        <!-- Vignette & Gradient Overlay -->
        <div class="absolute inset-0 bg-gradient-to-t from-black via-black/40 to-transparent"></div>
    </div>

    <div class="max-w-5xl mx-auto w-full relative z-10 animate-reveal">
      <div class="flex flex-wrap items-center gap-4 mb-8">
        <a href="/blog" class="text-white/60 hover:text-white text-[10px] font-black uppercase tracking-[0.3em] flex items-center gap-2 transition-colors">
            ← VOLVER AL BLOG
        </a>
        <span class="w-1 h-1 bg-white/30 rounded-full"></span>
        {post.category && (
          <span class="px-3 py-1 text-[10px] tracking-widest font-black uppercase bg-accent text-white rounded-lg">
            {post.category.name.toUpperCase()}
          </span>
        )}
        <span class="text-white/60 text-[10px] font-black tracking-widest uppercase">
            {post.publishedDate && formatDate(post.publishedDate).toUpperCase()}
        </span>
      </div>
      
      <h1 class="text-5xl md:text-8xl font-black mb-12 leading-[0.95] tracking-tighter text-white max-w-5xl">
        {post.title}
      </h1>
      
      <div class="flex flex-wrap items-center justify-between gap-8 border-t border-white/10 pt-10">
          {author && (
            <div class="flex items-center gap-4">
                {author.photo && (
                    <img
                        src={getStrapiImageUrl(author.photo)}
                        alt={author.name}
                        class="w-14 h-14 rounded-full border-2 border-white/20 object-cover"
                    />
                )}
                <div>
                   <div class="text-white font-bold text-lg leading-none mb-1">{author.name}</div>
                   <div class="text-white/40 text-[10px] font-black uppercase tracking-widest">{author.jobTitle || 'Equipo Nova'}</div>
                </div>
            </div>
          )}
          
          <div class="flex items-center gap-4">
               <button class="px-6 py-3 rounded-xl bg-white/5 border border-white/10 text-white text-[10px] font-black tracking-widest uppercase hover:bg-white/10 transition-colors">
                COMPARTIR
               </button>
          </div>
      </div>
    </div>
  </header>

  <main class="py-24 px-6 sm:px-12 bg-white relative">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-[1fr_350px] gap-20">
      
      <!-- Contenido Principal -->
      <article class="prose prose-zinc prose-2xl max-w-none">
        {post.excerpt && (
            <p class="text-2xl font-light text-zinc-500 italic border-l-4 border-accent pl-8 mb-16 leading-relaxed">
                {post.excerpt}
            </p>
        )}

        {post.page_blocks?.length > 0
          ? <PageBlocks blocks={post.page_blocks} />
          : <p class="text-zinc-500 italic">Contenido no disponible.</p>
        }

        <!-- Bio del Autor -->
        {author && (
          <div class="mt-24 p-10 rounded-[2rem] bg-zinc-50 border border-zinc-100 flex flex-col sm:flex-row gap-8 items-start">
            {author.photo && (
              <img
                src={getStrapiImageUrl(author.photo)}
                alt={author.name}
                class="w-20 h-20 rounded-2xl object-cover shrink-0 grayscale shadow-lg"
              />
            )}
            <div class="flex-1">
              <div class="font-black text-xl text-black mb-1 uppercase tracking-tight">{author.name}</div>
              {author.job_title && <div class="text-accent text-[10px] font-black uppercase tracking-widest mb-3">{author.job_title}</div>}
              {author.description && <p class="text-zinc-500 text-base leading-relaxed font-light mb-4">{author.description}</p>}
              {author.social_links && author.social_links.length > 0 && (
                <div class="flex flex-wrap gap-2">
                  {author.social_links.map((s: any) => (
                    <a href={s.url} target="_blank" rel="noopener noreferrer" class="author-social-link" aria-label={s.label || s.network}>
                      <span class={`social-icon social-icon--${s.network}`} set:html={getSocialIcon(s.network)} />
                      {s.label && <span class="text-[10px] font-bold uppercase tracking-wider">{s.label}</span>}
                    </a>
                  ))}
                </div>
              )}
            </div>
          </div>
        )}
      </article>

      <!-- Sidebar Minimalista -->
      <aside class="space-y-12">
        <div class="sticky top-32 space-y-12">
            <!-- CTA Pro -->
            <div class="bg-black p-10 rounded-[2.5rem] text-white">
                <span class="inline-block px-3 py-1 bg-accent text-[9px] font-black tracking-widest rounded-full mb-6">GRATIS</span>
                <h3 class="text-3xl font-black mb-4 leading-none uppercase">Auditoría SEO Express</h3>
                <p class="text-white/50 font-light mb-8 text-sm">Analizamos 5 puntos clave de tu web que te están haciendo perder dinero hoy mismo.</p>
                <a href="#contacto" class="block w-full text-center py-5 bg-white text-black text-[10px] font-black tracking-widest rounded-2xl hover:bg-accent hover:text-white transition-all">
                    SOLICITAR AHORA
                </a>
            </div>

            <!-- Servicios -->
            <div class="px-4">
                <h4 class="text-xs font-black tracking-[0.2em] uppercase text-zinc-400 mb-8">Soluciones Relacionadas</h4>
                <ul class="space-y-6">
                    {['Marketing de Contenidos', 'SEO Técnico', 'Estrategia Digital'].map(s => (
                        <li>
                            <a href="/servicios" class="group flex items-center justify-between">
                                <span class="text-xl font-black text-black group-hover:text-accent transition-colors uppercase tracking-tighter">{s}</span>
                                <span class="text-accent opacity-0 group-hover:opacity-100 transition-all font-black">→</span>
                            </a>
                        </li>
                    ))}
                </ul>
            </div>
        </div>
      </aside>

    </div>
  </main>
</BaseLayout>

<style>
    .animate-reveal {
        animation: reveal 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    @keyframes reveal {
        from { opacity: 0; transform: translateY(60px); filter: blur(10px); }
        to { opacity: 1; transform: translateY(0); filter: blur(0); }
    }

    /* Los estilos del blog los gestiona StrapiBlocks.astro */

    .author-social-link {
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
        padding: 0.375rem 0.75rem;
        border-radius: 999px;
        border: 1px solid #e4e4e7;
        color: #52525b;
        text-decoration: none;
        font-size: 0.75rem;
        transition: all 0.15s;
    }
    .author-social-link:hover { border-color: #09090b; color: #09090b; background: #f4f4f5; }
</style>
