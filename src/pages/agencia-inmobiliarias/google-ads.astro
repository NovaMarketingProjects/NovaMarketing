---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { buildAlternates } from '../../lib/i18n';
import { localAgencySchema } from '../../lib/schema';
import { strapiClient } from '../../lib/strapi';
import LogoMarquee from '../../components/sections/LogoMarquee.astro';
import FaqHome from '../../components/sections/FaqHome.astro';
import CityPills from '../../components/global/CityPills.astro';
import GoogleReviews from '../../components/global/GoogleReviews.astro';

const SITE_URL = import.meta.env.PUBLIC_SITE_URL || 'https://novamarketing.es';
const alternates = buildAlternates('/agencia-inmobiliarias/google-ads/', '/ca/agencia-inmobiliarias/google-ads/', SITE_URL);

let allCases: any[] = [];
try {
  const casesRes = await strapiClient.getCaseStudies('es');
  allCases = casesRes.data.map((i: any) => i.attributes ?? i).filter((c: any) => {
    const cats = (c.categories || []).map((cat: any) => (cat.slug || cat.attributes?.slug || '').toLowerCase());
    return cats.some((s: string) => s.includes('google-ads') || s === 'marketing-digital');
  });
} catch {}

const faqs = [
  { question: "¿Qué incluye la gestión de Google Ads para una inmobiliaria?", answer: "Incluye auditoría inicial, estrategia documentada y gestión semanal. Campañas de propietario y comprador por zona, landing y valorador optimizados, protección de marca, medición de conversiones y un informe mensual con leads, coste por captación y encargos." },
  { question: "¿Cuánto cuesta?", answer: "La auditoría de tu cuenta cuesta 900 euros y la gestión mensual empieza en 150 euros al mes con fee fijo, sin porcentajes sobre tu inversión. A eso se suma tu presupuesto publicitario, que va íntegro a Google. Presupuesto cerrado por escrito." },
  { question: "¿Cuánto cuesta un lead de propietario?", answer: "Depende de tu zona y su competencia. En la auditoría te damos la cifra realista para tu plaza y qué coste por captación final es razonable. Lo importante no es el coste del lead, es el coste del encargo firmado." },
  { question: "¿Los leads son exclusivos?", answer: "Siempre. Las campañas se hacen con tu marca, tu zona y tu landing, así que cada contacto es tuyo y solo tuyo. Nada de leads comprados a granel y compartidos con otras cinco agencias." },
  { question: "¿La cuenta de Google Ads será mía?", answer: "Sí, siempre. La cuenta, el historial y las conversiones quedan a tu nombre desde el primer día. Si algún día dejas de trabajar con nosotros, te llevas todo el aprendizaje acumulado." },
  { question: "¿Cómo medís los resultados?", answer: "En leads, coste por captación y encargos. Cada valoración y cada llamada quedan atribuidas a su campaña. En el informe mensual ves cuánto has invertido y cuántas captaciones han llegado." },
  { question: "¿Trabajáis con permanencia?", answer: "No, trabajamos mes a mes. Si el servicio no te aporta valor, puedes cancelarlo cuando quieras. Nuestra permanencia real es el resultado que ves en los informes cada mes." },
];

const pageSchema = localAgencySchema({
  pageUrl: `${SITE_URL}/agencia-inmobiliarias/google-ads/`,
  lang: 'es',
  cityName: 'Barcelona',
  postalCode: '08035',
  geo: { lat: 41.4114, lng: 2.1526 },
  areaServed: ["España", "Barcelona", "Sabadell", "Sant Cugat del Vallès", "Terrassa", "Vallès Occidental"],
  title: "▷ Google Ads para Inmobiliarias | Captación de Leads Exclusivos",
  description: "Campañas de Google Ads para inmobiliarias con fee fijo ✅ leads exclusivos de propietarios y compradores 💡 conoce cómo gestionamos la captación",
  datePublished: '2026-07-17',
  dateModified: '2026-07-17',
  streetAddress: 'Carrer del General Mendoza, 10',
  hasMap: 'https://maps.app.goo.gl/9fbB12UcK32bgjj89',
  aggregateRating: { ratingValue: '5.0', reviewCount: '8' },
  breadcrumbName: "Agencia Google Ads para Inmobiliarias",
  faqs,
});
---

<BaseLayout
  title="▷ Google Ads para Inmobiliarias | Captación de Leads Exclusivos"
  description="Campañas de Google Ads para inmobiliarias con fee fijo ✅ leads exclusivos de propietarios y compradores 💡 conoce cómo gestionamos la captación"
  locale="es"
  alternates={alternates}
  schemas={[pageSchema]}
>

    <!-- ═══ HERO / H1 ═══════════════════════════════════════════════════════ -->
    <section class="pt-24 sm:pt-40 pb-20 px-4 sm:px-6 relative overflow-hidden text-center bg-white border-b border-black/5">
        <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808008_1px,transparent_1px),linear-gradient(to_bottom,#80808008_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_40%,#000_75%,transparent_100%)]"></div>
        <div class="absolute -top-10 left-1/4 w-72 h-72 bg-accent/15 rounded-full blur-3xl opacity-30 animate-pulse"></div>
        <div class="absolute top-20 right-1/4 w-80 h-80 bg-purple-500/5 rounded-full blur-3xl opacity-20"></div>

        <div class="max-w-5xl mx-auto reveal">
            <span class="inline-flex items-center gap-2 bg-accent/5 backdrop-blur-sm px-4 py-2 border border-accent/10 rounded-full text-accent text-[8px] sm:text-[10px] font-black uppercase tracking-[0.3em] mb-8 shadow-sm">
                <span class="w-1.5 h-1.5 bg-accent rounded-full animate-ping"></span>
                Publicidad en Google para Inmobiliarias
            </span>
            <h1 class="text-3xl sm:text-5xl md:text-7xl lg:text-8xl uppercase font-extrabold tracking-tighter leading-[0.88] mb-8 text-gradient flex flex-col items-center text-center">
                <span class="lg:whitespace-nowrap">Agencia Google Ads </span>
                <span class="lg:whitespace-nowrap text-mktg-gradient">para Inmobiliarias</span>
            </h1>
            <p class="text-lg sm:text-xl text-zinc-500 font-light leading-relaxed w-[75%] mx-auto mb-8">
                Aparece hoy mismo cuando un propietario de tu zona busca vender. Campañas de Google Ads para inmobiliarias con fee fijo y leads exclusivos de tu marca.
            </p>
            <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3 mb-10">
                {['Sin permanencias', 'Trato directo con el consultor', 'Resultados medidos en captaciones'].map(item => (
                    <span class="inline-flex items-center gap-2 text-[11px] sm:text-xs font-black uppercase tracking-widest text-zinc-700">
                        <svg class="w-4 h-4 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                        {item}
                    </span>
                ))}
            </div>
            <div class="flex justify-center mt-4">
                <a href="#contacto" class="contact-modal-trigger btn-mktg-v5 shadow-[0_10px_30px_rgba(0,0,0,0.1)] !py-4 sm:!py-5 !px-6 sm:!px-10 !text-[11px] !tracking-widest font-black">
                    HABLEMOS DE TU INMOBILIARIA
                </a>
            </div>
        </div>
    </section>

    <LogoMarquee />

    <!-- ═══ INTRO ═══════════════════════════════════════════════════════ -->
    <section class="py-16 sm:py-24 bg-white px-4 sm:px-6 border-b border-black/5">
        <div class="max-w-6xl mx-auto reveal grid md:grid-cols-[1.3fr_1fr] gap-10 md:gap-16 items-center">
            <div>
                <p class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4">¿Por qué Google Ads?</p>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-8 text-zinc-900 leading-[0.9]">
                    La agencia de Google Ads para tu inmobiliaria
                </h2>
                <div class="space-y-6 text-zinc-600 font-light text-base sm:text-lg leading-relaxed">
                    <p>
                        <strong class="font-semibold text-zinc-900">Cuánto vale mi piso es una de las búsquedas con más intención que existen</strong>. Quien responde con un anuncio y un valorador se lleva el contacto del propietario, y ese contacto es la puerta de la exclusiva.
                    </p>
                    <p>
                        Nova es una <strong class="font-semibold text-zinc-900">agencia SEM especializada en inmobiliarias</strong>. Campañas por zona, leads exclusivos y una sola métrica que importa. <strong class="font-semibold text-zinc-900">Cuánto te cuesta cada captación</strong>.
                    </p>
                </div>
            </div>
            <div class="hidden md:block">
                <img src="/sergio-galos-agencia-inmobiliarias-google-ads.webp" alt="Sergio Galo's, Consultor de Google Ads inmobiliario" title="Sergio Galo's, Consultor de Google Ads inmobiliario" class="w-full h-auto" loading="lazy" width="473" height="591" />
            </div>
        </div>
    </section>

    <!-- ═══ SERVICIOS ══════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-zinc-50 px-4 sm:px-6 border-t border-b border-black/5">
        <div class="max-w-7xl mx-auto text-center reveal">
            <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Qué hacemos</span>
            <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.9]">
                Servicio de Google Ads para inmobiliarias
            </h2>
            <p class="text-zinc-500 font-light text-sm sm:text-base leading-relaxed max-w-3xl mx-auto mb-16">
                Gestionar Google Ads en el sector inmobiliario es un sistema. Estas son las nueve piezas que trabajamos para que cada euro vuelva convertido en captaciones.
            </p>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 text-left">
                {[
                    { t: "Auditoría de la cuenta", d: "Radiografía de tus campañas y tu zona antes de tocar nada. Dónde se pierde presupuesto y por qué." },
                    { t: "Campañas de propietario", d: "Las búsquedas de quien quiere vender, de la valoración a la venta urgente. El lead más valioso del sector." },
                    { t: "Campañas de comprador", d: "Demanda para tus exclusivas y para tu bolsa de compradores, segmentada por zona y tipo de propiedad." },
                    { t: "Landing y valorador", d: "El anuncio trae el clic y el valorador captura el contacto. Sin una landing que convierta, el clic se pierde." },
                    { t: "Segmentación por zona", d: "Radio fino sobre los barrios donde captas. Ni un euro en clics de zonas donde no trabajas." },
                    { t: "Remarketing", d: "El propietario tarda semanas en decidir. Seguimos presentes durante todo ese proceso de decisión." },
                    { t: "Medición de conversiones", d: "Cada valoración y cada llamada atribuidas a su campaña. Decisiones por coste por captación, no por clics." },
                    { t: "Protección de marca", d: "Que nadie compre tu nombre para robarte contactos. Tu marca, tus leads." },
                    { t: "Google Ads más SEO", d: "Los datos de campañas revelan qué busca tu zona. Los usamos para construir SEO y depender menos de pagar." },
                ].map((c: any) => (
                    <div class="bg-white border border-black/5 rounded-2xl p-6 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
                        <h3 class="text-sm font-black uppercase tracking-tight text-zinc-900 mb-3">
                            {c.href ? <a href={c.href} class="hover:text-accent transition-colors">{c.t}</a> : c.t}
                            {c.b && <span class="block text-[11px] uppercase tracking-[0.2em] text-accent mt-1 font-semibold">{c.b}</span>}
                        </h3>
                        <p class="text-sm text-zinc-500 font-light leading-relaxed mb-2">{c.d}</p>
                        {c.href && <a href={c.href} class="text-[11px] font-black tracking-widest text-accent hover:underline">SABER MÁS →</a>}
                    </div>
                ))}
            </div>
            <div class="mt-12 text-center reveal">
                <a href="#contacto" class="contact-modal-trigger btn-mktg-v5 shadow-[0_10px_30px_rgba(37,211,102,0.3)] !py-4 sm:!py-5 !px-6 sm:!px-10 !text-[11px] !tracking-widest font-black">HABLEMOS DE TU INMOBILIARIA</a>
            </div>
        </div>
    </section>

    <!-- ═══ ESTRATEGIA ════════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-white px-4 sm:px-6 relative overflow-hidden">
        <div class="max-w-5xl mx-auto">
            <div class="text-center mb-16 sm:mb-24 reveal">
                <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Cómo trabajamos</span>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.9]">
                    Estrategia de Google Ads para tu inmobiliaria
                </h2>
                <p class="text-zinc-500 font-light text-sm sm:text-base leading-relaxed max-w-2xl mx-auto">
                    Una metodología documentada, paso a paso y sin humo.
                </p>
            </div>

            <div id="timeline-container" class="relative">
                <div class="hidden md:block absolute left-1/2 top-4 bottom-4 w-px bg-zinc-200 -translate-x-1/2"></div>
                <div id="progress-bar" class="hidden md:block absolute left-1/2 top-4 w-px bg-accent -translate-x-1/2 transition-all duration-100"></div>

                <div class="space-y-16 md:space-y-24 flex flex-col items-center">
                    {[
                        { title: "Auditoría de Cuenta y Zona", desc: "Analizamos tus campañas si las tienes y el coste real por lead en tu zona. Detectamos presupuesto desperdiciado y oportunidades." },
                        { title: "Estrategia de Campañas Documentada", desc: "Plan por escrito. Qué campañas lanzar, qué zona cubrir, qué presupuesto necesitas y qué coste por captación es razonable." },
                        { title: "Landings, Valorador y Campañas", desc: "Montamos las campañas con radio fino y preparamos la landing y el valorador que convierten el clic en contacto." },
                        { title: "Optimización Semanal", desc: "Cortamos las búsquedas que gastan sin captar, ajustamos pujas por zona y horario y renovamos anuncios." },
                        { title: "Medición y Escalado", desc: "Monitorizamos leads, coste por captación y encargos firmados. Lo que capta escala, lo que no se corta." },
                    ].map((step, index) => (
                        <div class="flex flex-col md:flex-row items-center gap-6 md:gap-12 w-full relative reveal">
                            <div class:list={["flex-1 w-full", index % 2 === 0 ? "md:order-1 md:text-right" : "md:order-3 md:text-left"]}>
                                <div class="p-8 sm:p-10 bg-zinc-50 border border-black/5 rounded-3xl hover:border-accent/10 hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 relative overflow-hidden group">
                                    <h3 class="text-xl font-black uppercase tracking-tighter mb-2 text-zinc-900">{index + 1}. {step.title}</h3>
                                    <div class:list={["h-0.5 bg-accent w-full mb-4 opacity-80", index % 2 === 0 ? "md:ml-auto" : ""]}></div>
                                    <p class:list={["text-sm text-zinc-500 font-light max-w-md", index % 2 === 0 ? "md:ml-auto" : ""]}>{step.desc}</p>
                                    <div class="absolute -bottom-6 -right-5 text-8xl font-black text-black/[0.02] select-none z-0 group-hover:scale-105 transition-transform duration-500">0{index+1}</div>
                                </div>
                            </div>
                            <div class="md:order-2 w-12 h-12 rounded-full border-2 border-zinc-200 bg-white flex items-center justify-center font-black text-lg z-10 shrink-0 shadow-sm node-circle transition-all">
                                0{index + 1}
                            </div>
                            <div class:list={["hidden md:block md:flex-1", index % 2 === 0 ? "md:order-3" : "md:order-1"]}></div>
                        </div>
                    ))}
                </div>
            </div>
        </div>
    </section>

    <!-- ═══ AUDITORÍA ═════════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-zinc-50/50 px-4 sm:px-6 border-t border-black/5 overflow-hidden">
        <div class="max-w-7xl mx-auto grid lg:grid-cols-[6fr_4fr] gap-12 lg:gap-16 items-start">
            <div class="reveal lg:col-span-2">
                <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Punto de partida</span>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase text-zinc-900 leading-[0.9]">
                    Auditoría de Google Ads para tu inmobiliaria
                </h2>
            </div>
            <div class="reveal">
                <div class="space-y-5 text-zinc-600 font-light text-base leading-relaxed mb-8">
                    <p>¿Sabes cuánto te cuesta cada lead de propietario? ¿Qué parte de tu presupuesto se va en clics de curiosos o de fuera de tu zona? Casi ninguna agencia lo sabe con datos, y ahí empieza todo.</p>
                    <p>Nuestra <strong class="font-semibold text-zinc-900">auditoría de Google Ads inmobiliaria</strong> revisa tu cuenta campaña a campaña y tu landing, y termina con un plan de acción priorizado por ahorro e impacto en captaciones.</p>
                    <p>Cada punto lo revisa un consultor senior con experiencia en el sector. El resultado es un diagnóstico de negocio que entiende cualquier gerente.</p>
                </div>
                <ul class="space-y-3">
                    {["Estructura de la cuenta y calidad de campañas","Coste real por lead de propietario y comprador","Búsquedas que gastan sin captar","Conversión de la landing y el valorador","Cobertura real de tu zona","Plan de acción priorizado por ahorro"].map(item => (
                        <li class="flex items-start gap-3 text-sm text-zinc-700 font-light">
                            <svg class="w-4 h-4 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                            {item}
                        </li>
                    ))}
                </ul>
                <div class="mt-16">
                    <a href="#contacto" class="contact-modal-trigger btn-mktg-v5 shadow-[0_10px_30px_rgba(37,211,102,0.3)] !py-4 sm:!py-5 !px-6 sm:!px-10 !text-[11px] !tracking-widest font-black">
                        QUIERO MI AUDITORÍA DE GOOGLE ADS
                    </a>
                </div>
            </div>
            <div class="reveal flex flex-col gap-4">
                {[
                    { bg: 'bg-purple-100', color: 'text-purple-600', t: "Revisión completa de la cuenta", d: "Estructura, campañas, pujas y configuración. Todo lo que encarece tus leads, documentado." },
                    { bg: 'bg-green-100', color: 'text-green-600', t: "Plan de acción priorizado", d: "Ordenado por ahorro e impacto. Sabrás qué cortar la primera semana y dónde reinvertir." },
                    { bg: 'bg-purple-100', color: 'text-purple-600', t: "Leads con intención real", d: "Separamos las búsquedas de quien quiere vender de las de curiosos que solo miran precios." },
                    { bg: 'bg-amber-100', color: 'text-amber-600', t: "Landing y valorador", d: "Revisamos si la página que recibe el clic está preparada para convertirlo en contacto." },
                    { bg: 'bg-blue-100', color: 'text-blue-600', t: "Benchmark de tu zona", d: "Qué agencias pujan en tus búsquedas, qué prometen y qué puedes hacer mejor." },
                ].map(card => (
                    <div class="bg-white rounded-2xl shadow-[0_15px_40px_rgba(0,0,0,0.08)] p-5 flex items-start gap-4">
                        <div class:list={["w-11 h-11 rounded-full flex items-center justify-center flex-shrink-0", card.bg]}>
                            <svg class:list={["w-5 h-5", card.color]} fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                        </div>
                        <div>
                            <h3 class="text-sm font-black text-zinc-900 mb-1">{card.t}</h3>
                            <p class="text-xs text-zinc-500 font-light leading-relaxed">{card.d}</p>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- ═══ QUÉ INCLUYE LA AUDITORÍA ═══════════════════════════ -->
    <section class="py-20 sm:py-28 bg-white px-4 sm:px-6 border-t border-black/5">
        <div class="max-w-7xl mx-auto">
            <div class="text-center mb-12 sm:mb-16 reveal">
                <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Paso a paso</span>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase text-zinc-900 leading-[0.9]">
                    Qué incluye la auditoría Google Ads de nova
                </h2>
            </div>
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 items-stretch reveal">
                {[
                    { n: '1', t: "Radiografía de tu inversión", d: "Cuánto inviertes, qué campañas traen leads, a qué coste y qué parte se pierde." },
                    { n: '2', t: "Diagnóstico de landing y valorador", d: "Qué encarece cada contacto, del anuncio al formulario." },
                    { n: '3', t: "Hoja de ruta para rentabilizar", d: "Acciones ordenadas por ahorro e impacto y una videollamada donde lo repasamos contigo." },
                ].map((st, i) => (
                    <div class="flex items-center gap-4 lg:gap-6">
                        {i > 0 && <div class="hidden lg:flex text-3xl text-accent font-black select-none">→</div>}
                        <div class="bg-white border border-black/5 rounded-2xl p-8 shadow-[0_15px_40px_rgba(0,0,0,0.06)] flex-1 text-center h-full">
                            <div class="w-12 h-12 rounded-full bg-accent/10 border border-accent/20 flex items-center justify-center mx-auto mb-4 text-accent font-black text-lg">{st.n}</div>
                            <h3 class="text-base font-black uppercase tracking-tight text-zinc-900 mb-3">{st.t}</h3>
                            <p class="text-sm text-zinc-500 font-light leading-relaxed">{st.d}</p>
                        </div>
                    </div>
                ))}
            </div>
            <p class="text-zinc-500 font-light text-sm sm:text-base leading-relaxed max-w-3xl mx-auto text-center mt-16 reveal">
                Nuestra auditoría de Google Ads es el primer paso de cualquier estrategia de captación de pago en el sector. Analiza cómo trabaja hoy tu presupuesto y te deja una hoja de ruta clara. También puedes contratarla suelta como segunda opinión.
            </p>
            <div class="mt-12 text-center reveal">
                <a href="#contacto" class="contact-modal-trigger btn-mktg-v5 shadow-[0_10px_30px_rgba(37,211,102,0.3)] !py-4 sm:!py-5 !px-6 sm:!px-10 !text-[11px] !tracking-widest font-black">QUIERO MI AUDITORÍA DE GOOGLE ADS</a>
            </div>
        </div>
    </section>

    <!-- ═══ PRECIOS ════════════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-zinc-50/50 px-4 sm:px-6 border-t border-black/5">
        <div class="max-w-7xl mx-auto">
            <div class="text-center mb-12 sm:mb-16 reveal">
                <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Tarifas claras</span>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.9]">
                    Precios de Google Ads para inmobiliarias
                </h2>
                <p class="text-zinc-500 font-light text-sm sm:text-base leading-relaxed max-w-3xl mx-auto">
