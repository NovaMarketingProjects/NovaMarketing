---
import BaseLayout from '../layouts/BaseLayout.astro';
import { buildAlternates } from '../lib/i18n';
import { localAgencySchema } from '../lib/schema';
import LogoMarquee from '../components/sections/LogoMarquee.astro';
import FaqHome from '../components/sections/FaqHome.astro';
import GoogleReviews from '../components/global/GoogleReviews.astro';

const SITE_URL = import.meta.env.PUBLIC_SITE_URL || 'https://novamarketing.es';
const alternates = buildAlternates('/agencia-de-marketing-digital-en-barcelona/', '/ca/agencia-de-marketing-digital-a-barcelona/', SITE_URL);

const steps = [
  { title: "Diagnóstico Local", desc: "Auditamos tu web, tu visibilidad actual y tu competencia directa en Barcelona y el área metropolitana. Detectamos fugas de tráfico, keywords rentables sin explotar y oportunidades de venta que tu competencia ya está capturando." },
  { title: "Estrategia Documentada", desc: "Recibes una hoja de ruta por escrito: qué canales usar, qué keywords atacar, qué inversión necesita cada fase y qué resultados esperar en 3, 6 y 12 meses. Sabes en qué se invierte cada euro antes de invertirlo." },
  { title: "Ejecución Multicanal", desc: "Coordinamos SEO, Google Ads, contenidos y analítica para que la inversión genere leads de calidad desde el primer mes. Ads acelera el corto plazo mientras el SEO construye tu activo a medio plazo." },
  { title: "Medición Sin Humo", desc: "Configuramos la analítica para atribuir cada lead a su canal. En el informe mensual verás llamadas, formularios y ventas generadas, no métricas de vanidad. Reunión mensual con el consultor para revisar números." },
  { title: "Optimización Continua", desc: "Exprimimos cada euro adaptando campañas y contenidos a los picos de demanda de Barcelona: estacionalidad del sector, cambios de algoritmo y movimientos de tu competencia." }
];

const districts = [
  { title: "Eixample y Centro de Barcelona", desc: "La zona más disputada de la ciudad: clínicas, despachos profesionales y retail compitiendo por las mismas búsquedas. Aquí el posicionamiento se gana con SEO local quirúrgico, una ficha de Google Business Profile impecable y reseñas que te diferencien del vecino de la misma calle." },
  { title: "22@, Poblenou y Sant Martí", desc: "El nodo tecnológico de Barcelona. Para startups, SaaS y B2B que operan aquí, la captación pasa por keywords de nicho con alta intención, contenido que demuestre autoridad técnica y campañas segmentadas a decisores, no a curiosos." },
  { title: "Gràcia, Sants, Les Corts y Sarrià", desc: "Barrios de negocio de proximidad donde el cliente busca \"cerca de mí\" desde el móvil. Trabajamos el pack local completo: Google Business Profile, reseñas, landings por zona y anuncios geolocalizados a pocos minutos de tu local." },
];

const criteria = [
  { title: "Pide casos de éxito verificables en Barcelona", desc: "Un muro de logos no demuestra nada. Pide casos de negocios de Barcelona con datos concretos: qué keyword local, qué posición alcanzó, en cuánto tiempo y con qué inversión. Una agencia que trabaja el mercado barcelonés debería poder enseñarte resultados en tu ciudad, o incluso en tu sector. Si no pueden enseñarte ni uno, sigue buscando." },
  { title: "Pregunta quién llevará tu cuenta", desc: "En muchas agencias de Barcelona vende un director y ejecuta un junior con 30 cuentas. Exige conocer a la persona que trabajará tu proyecto antes de firmar, y pregunta si podrás reunirte con ella cara a cara: en nova las reuniones con clientes de Barcelona y su área metropolitana pueden ser presenciales." },
  { title: "Exige propiedad de tus activos", desc: "La web, la cuenta de Google Ads, la ficha de Google Business Profile y la analítica deben estar a tu nombre. Es más habitual de lo que parece: PYMEs de Barcelona que llevan años pagando y descubren al querer cambiar de agencia que no son dueñas ni de su propio dominio. Si la agencia retiene tus activos, no estás contratando un servicio: estás firmando una dependencia." },
  { title: "Desconfía de quien garantiza la posición 1 en Google en Barcelona", desc: "Nadie puede garantizar la posición 1 en Google, y menos en un mercado tan disputado como el de Barcelona, donde cada keyword local la pelean decenas de competidores. Quien lo promete, o miente o usa técnicas que acabarán penalizando tu web. Lo serio es garantizar método, transparencia y trabajo verificable." },
  { title: "Revisa qué mide el informe mensual", desc: "Si el informe habla de impresiones y alcance pero no de llamadas, formularios y ventas de clientes de Barcelona, la agencia está midiendo su actividad, no tu negocio. El posicionamiento local en Barcelona se mide en visitas a tu ficha, rutas a tu local y presupuestos solicitados, no en likes." },
  { title: "Huye de las agencias de marketing con permanencias largas", desc: "Una permanencia de 12 meses protege a la agencia, no a ti. En una ciudad con tanta oferta de agencias de marketing digital como Barcelona, el trabajo bien hecho retiene clientes sin necesidad de contratos que los aten. Por eso en nova trabajamos mes a mes." },
  { title: "Conocimiento del negocio local", desc: "No es lo mismo posicionar una clínica en el Eixample que una industria en el Vallès o un ecommerce que vende a toda España. Una agencia que conoce el mercado de Barcelona sabe qué busca el cliente de cada zona, qué competencia hay en cada sector y qué keywords locales convierten. Pregunta qué sabe la agencia de tu barrio, de tu sector y de tu cliente antes de firmar." }
];

const faqs = [
  { question: "¿Cuánto cuesta una agencia de marketing digital en Barcelona?", answer: "Depende mucho de los servicios que necesites y de si es un proyecto puntual o un trabajo recurrente. No cuesta lo mismo una auditoría o el lanzamiento de una web que una estrategia mensual de posicionamiento y captación. Por eso en nova no trabajamos con tarifas genéricas sino con presupuestos cerrados a medida: antes de firmar sabes exactamente qué se hace, quién lo hace y qué resultado se persigue." },
  { question: "¿Qué incluye una estrategia de marketing digital para una PYME en Barcelona?", answer: "Incluye una auditoría inicial, una hoja de ruta documentada y la ejecución y medición mensual de cada acción. Analizamos tu situación actual y tu competencia en Barcelona, definimos qué canales usar, qué inversión necesita cada fase y qué resultados esperar a 3, 6 y 12 meses. No aplicamos plantillas: cada sector y cada zona de Barcelona compite de forma distinta." },
  { question: "¿Quién llevará mi cuenta?", answer: "Tu cuenta la lleva directamente Sergio Galo's, consultor de marketing digital en Barcelona y fundador de Nova Marketing. Sin gestores junior ni intermediarios: la persona que diseña tu estrategia es la misma que la ejecuta y la que te responde en la reunión mensual." },
  { question: "¿Cuánto tardaré en ver resultados?", answer: "Hay acciones que generan clientes en semanas y otras que consolidan resultados entre el sexto y el duodécimo mes. El plazo exacto depende del punto de partida de tu negocio y de la competencia de tu sector en Barcelona. En la hoja de ruta inicial te decimos qué esperar en cada fase, con plazos realistas y sin promesas de humo." },
  { question: "¿Cómo medís los resultados de la estrategia?", answer: "Medimos leads y ventas: cada llamada, formulario o pedido queda atribuido a su canal de origen. Configuramos la analítica desde el primer día y en el informe mensual ves resultados de negocio, no métricas de vanidad. Además tienes acceso total a tus cuentas y herramientas: los datos son tuyos." },
  { question: "¿Trabajáis con permanencia?", answer: "No, trabajamos mes a mes. Si el servicio no te aporta valor, puedes cancelarlo cuando quieras. Nuestra permanencia real es el resultado que ves en los informes cada mes." },
  { question: "¿Atendéis solo a empresas de Barcelona ciudad?", answer: "No: tenemos la sede en Barcelona, pero trabajamos con clientes en toda España. La mayor parte de nuestros proyectos están en Barcelona y su área metropolitana (Sabadell, Sant Cugat, Terrassa), donde las reuniones pueden ser presenciales, y con el resto de clientes trabajamos por videollamada con el mismo nivel de seguimiento." }
];


const pageSchema = localAgencySchema({
  pageUrl: `${SITE_URL}/agencia-de-marketing-digital-en-barcelona/`,
  lang: 'es',
  cityName: 'Barcelona',
  postalCode: '08035',
  geo: { lat: 41.4114, lng: 2.1526 },
  areaServed: ["Barcelona","Sabadell","Sant Cugat del Vallès","Terrassa","Vallès Occidental"],
  title: "Marketing Digital en Barcelona | Nova Marketing",
  description: "Estrategias de crecimiento digital para pymes en Barcelona. SEO, Google Ads y Diseño Web enfocados a captar clientes y competir en el mercado actual.",
  datePublished: '2025-06-09',
  dateModified: '2026-07-14',
  streetAddress: 'Carrer del General Mendoza, 10',
  hasMap: 'https://maps.app.goo.gl/9fbB12UcK32bgjj89',
  aggregateRating: { ratingValue: '5.0', reviewCount: '7' },
  reviews: [
    { author: "이진만", date: '2026-05-14', body: "Como guía turístico, buscaba algo que me ayudara a diferenciarme, y hablé con Sergio de Nova Marketing y ha hecho un trabajo excepcional. 👍👍👍 La ilustración que han diseñado para mi marca es increíble y me va a ayudar muchísimo a posicionar" },
    { author: "Cristina Oliver", date: '2026-05-14', body: "Totalmente recomendados para cualquier pyme. Sergio no se limita a darte consejos analiza tu mercado para mejorar tu posicionamiento SEO. En mi caso necesitaba posicionar en un entorno muy competitivo y Nova Marketing trazó el plan perfecto. Una agencia de marketing que realmente se implica en el éxito de sus clientes." },
    { author: "Alba Delgado Arau", date: '2025-08-14', body: "Tenemos un club de gimnasia artística y nos han ayudado con nuestra estrategia de marketing digital que teníamos un poquito olvidada." },
    { author: "Jesús Antonio García", date: '2025-07-14', body: "Excelente servicio de SEO y el trato siempre ds muy cercano. Recomendados al 100%" },
    { author: "Ester Guillen", date: '2022-07-14', body: "Llegamos un par de meses trabajando juntos y al principio solo cogimos el pack SEM pero segurament contamos una auditoría completa con vosotros. Profesionales y muy recomendable." },
  ],
  faqs,
});

---

<BaseLayout
  title="Marketing Digital en Barcelona | Nova Marketing"
  description="Estrategias de crecimiento digital para pymes en Barcelona. SEO, Google Ads y Diseño Web enfocados a captar clientes y competir en el mercado actual."
  locale="es"
  alternates={alternates}
  schemas={[pageSchema]}
>

    <!-- ═══ HERO / H1 ═══════════════════════════════════════════════════════ -->
    <section class="pt-24 sm:pt-40 pb-20 px-4 sm:px-6 relative overflow-hidden text-center bg-white border-b border-black/5">
        <!-- Background Grid Mesh -->
        <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808008_1px,transparent_1px),linear-gradient(to_bottom,#80808008_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_40%,#000_75%,transparent_100%)]"></div>

        <!-- Glow Orbs -->
        <div class="absolute -top-10 left-1/4 w-72 h-72 bg-accent/15 rounded-full blur-3xl opacity-30 animate-pulse"></div>
        <div class="absolute top-20 right-1/4 w-80 h-80 bg-purple-500/5 rounded-full blur-3xl opacity-20"></div>

        <div class="max-w-5xl mx-auto reveal">
            <span class="inline-flex items-center gap-2 bg-accent/5 backdrop-blur-sm px-4 py-2 border border-accent/10 rounded-full text-accent text-[8px] sm:text-[10px] font-black uppercase tracking-[0.3em] mb-8 shadow-sm">
                <span class="w-1.5 h-1.5 bg-accent rounded-full animate-ping"></span>
                Impulso Digital para Pymes
            </span>
            <h1 class="text-3xl sm:text-5xl md:text-7xl lg:text-8xl uppercase font-extrabold tracking-tighter leading-[0.88] mb-8 text-gradient flex flex-col items-center text-center">
                <span class="lg:whitespace-nowrap">Agencia de Marketing </span>
                <span class="lg:whitespace-nowrap">Digital en Barcelona</span>
            </h1>
            <p class="text-lg sm:text-xl text-zinc-500 font-light leading-relaxed w-[75%] mx-auto mb-8">
                En nova ayudamos a PYMEs y autónomos de Barcelona a captar clientes con SEO, Google Ads y diseño web. Estrategia a medida, precios claros y resultados que se miden en ventas.
            </p>
            <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3 mb-10">
                {['Sin permanencias', 'Trato directo con el consultor', 'Informes de negocio'].map(item => (
                    <span class="inline-flex items-center gap-2 text-[11px] sm:text-xs font-black uppercase tracking-widest text-zinc-700">
                        <svg class="w-4 h-4 text-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                        </svg>
                        {item}
                    </span>
                ))}
            </div>
            <div class="flex justify-center mt-4">
                <a href="#contacto" class="contact-modal-trigger btn-mktg-v5 shadow-[0_10px_30px_rgba(0,0,0,0.1)] !py-4 sm:!py-5 !px-6 sm:!px-10 !text-[11px] !tracking-widest font-black">
                    HABLEMOS DE TU NEGOCIO
                </a>
            </div>
        </div>
    </section>

    <LogoMarquee />

    <!-- ═══ INTRO: QUIÉNES SOMOS ═══════════════════════════════════════════ -->
    <section class="py-16 sm:py-24 bg-white px-4 sm:px-6 border-b border-black/5">
        <div class="max-w-6xl mx-auto reveal grid md:grid-cols-[1.3fr_1fr] gap-10 md:gap-16 items-center">
            <div>
                <p class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4">¿Qué es Nova?</p>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-8 text-zinc-900 leading-[0.9]">
                    La agencia de marketing digital para tu pyme en Barcelona
                </h2>
                <div class="space-y-6 text-zinc-600 font-light text-base sm:text-lg leading-relaxed">
                    <p>
                        <strong class="font-semibold text-zinc-900">Nova Marketing es una agencia de marketing digital especializada en PYMEs</strong> que opera en Barcelona y su área metropolitana, con servicios de posicionamiento SEO, Google Ads, diseño web y consultoría de marketing.
                    </p>
                    <p>
                        Nuestro enfoque es distinto: trabajamos con un número limitado de clientes, cada cuenta la lleva directamente el consultor fundador y toda la estrategia se orienta a una sola métrica que importa: <strong class="font-semibold text-zinc-900">cuántos clientes nuevos genera tu inversión cada mes</strong>.
                    </p>
                </div>
            </div>
            <div class="hidden md:block">
                <img src="/consultor-marketing-digital.webp" alt="Sergio Galo's - Consultor de marketing digital en Barcelona" class="w-full h-auto" loading="lazy" />
            </div>
        </div>
    </section>

    <!-- ═══ SECCIÓN 1: SERVICIOS ═══════════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-zinc-50 border-b border-black/5 px-4 sm:px-6">
        <div class="max-w-7xl mx-auto text-center reveal">
            <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Qué hacemos</span>
            <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.9]">
                Servicios de Marketing Online en Barcelona
            </h2>
            <p class="text-zinc-500 font-light text-sm sm:text-base leading-relaxed max-w-2xl mx-auto mb-16">
                Cuatro servicios, un mismo objetivo: que tu empresa aparezca donde buscan tus clientes en Barcelona y convierta ese tráfico en facturación.
            </p>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 text-left">
                <!-- SEO -->
                <div class="service-card p-8 bg-white rounded-2xl border border-zinc-100/80 shadow-sm hover:shadow-2xl hover:-translate-y-2 hover:border-accent/10 transition-all duration-500 relative overflow-hidden flex flex-col justify-between">
        <!-- Hover Gradient Overlay -->
        <div class="absolute inset-x-0 h-1 bottom-0 bg-gradient-to-r from-accent via-accent/90 to-purple-600 w-0 group-hover:w-full transition-all duration-500"></div>
                    <h3 class="text-xl font-black uppercase tracking-tighter mb-4 text-zinc-900">
                        <a href="/agencia-seo-en-barcelona/" class="hover:text-accent transition-colors">Agencia de Posicionamiento SEO en Barcelona</a>
                    </h3>
                    <p class="text-sm text-zinc-500 font-light leading-relaxed mb-4">
                        Aparece en los primeros resultados de Google cuando tus clientes buscan tus servicios en Barcelona. Optimizamos tu ficha de Google Business Profile, tu web y tus contenidos para dominar las búsquedas locales de tu sector, desde el Eixample hasta el área metropolitana.
                    </p>
                    <a href="/agencia-seo-en-barcelona/" class="text-[11px] font-black tracking-widest text-accent hover:underline">SABER MÁS →</a>
                </div>

                <!-- Google Ads -->
                <div class="service-card p-8 bg-white rounded-2xl border border-zinc-100/80 shadow-sm hover:shadow-2xl hover:-translate-y-2 hover:border-accent/10 transition-all duration-500 relative overflow-hidden flex flex-col justify-between">
        <!-- Hover Gradient Overlay -->
        <div class="absolute inset-x-0 h-1 bottom-0 bg-gradient-to-r from-accent via-accent/90 to-purple-600 w-0 group-hover:w-full transition-all duration-500"></div>
                    <h3 class="text-xl font-black uppercase tracking-tighter mb-4 text-zinc-900">
                        <a href="/agencia-google-ads-barcelona/" class="hover:text-accent transition-colors">Agencia de Google Ads en Barcelona</a>
                    </h3>
                    <p class="text-sm text-zinc-500 font-light leading-relaxed mb-4">
                        Anuncios hipersegmentados para captar clientes desde la primera semana. No tires el dinero en clics vacíos: dirigimos tus campañas a usuarios de Barcelona con intención real de compra y optimizamos el CPC para maximizar el retorno de cada euro invertido.
                    </p>
                    <a href="/agencia-google-ads-barcelona/" class="text-[11px] font-black tracking-widest text-accent hover:underline">SABER MÁS →</a>
                </div>

                <!-- Diseño Web -->
                <div class="service-card p-8 bg-white rounded-2xl border border-zinc-100/80 shadow-sm hover:shadow-2xl hover:-translate-y-2 hover:border-accent/10 transition-all duration-500 relative overflow-hidden flex flex-col justify-between">
        <!-- Hover Gradient Overlay -->
        <div class="absolute inset-x-0 h-1 bottom-0 bg-gradient-to-r from-accent via-accent/90 to-purple-600 w-0 group-hover:w-full transition-all duration-500"></div>
                    <h3 class="text-xl font-black uppercase tracking-tighter mb-4 text-zinc-900">
                        <a href="/agencia-diseno-web-barcelona/" class="hover:text-accent transition-colors">Agencia de Diseño Web en Barcelona</a>
                    </h3>
                    <p class="text-sm text-zinc-500 font-light leading-relaxed mb-4">
                        Diseñamos el escaparate digital 24/7 que tu empresa necesita: páginas web ultrarrápidas, adaptadas a móvil y 100% enfocadas a la conversión, con la autoridad que exige un mercado internacional como el de Barcelona.
                    </p>
                    <a href="/agencia-diseno-web-barcelona/" class="text-[11px] font-black tracking-widest text-accent hover:underline">SABER MÁS →</a>
                </div>

                <!-- Consultoría -->
                <div class="service-card p-8 bg-white rounded-2xl border border-zinc-100/80 shadow-sm hover:shadow-2xl hover:-translate-y-2 hover:border-accent/10 transition-all duration-500 relative overflow-hidden flex flex-col justify-between">
        <!-- Hover Gradient Overlay -->
        <div class="absolute inset-x-0 h-1 bottom-0 bg-gradient-to-r from-accent via-accent/90 to-purple-600 w-0 group-hover:w-full transition-all duration-500"></div>
                    <h3 class="text-xl font-black uppercase tracking-tighter mb-4 text-zinc-900">
                        <a href="/consultoria-marketing-digital-barcelona/" class="hover:text-accent transition-colors">Consultoría de Marketing en Barcelona</a>
                    </h3>
                    <p class="text-sm text-zinc-500 font-light leading-relaxed mb-4">
                        ¿Tu marketing no da resultados? Auditamos tus procesos de captación, detectamos dónde se pierde el presupuesto y trazamos una hoja de ruta con embudos de venta sólidos para escalar tu negocio en Barcelona.
                    </p>
                    <a href="/consultoria-marketing-digital-barcelona/" class="text-[11px] font-black tracking-widest text-accent hover:underline">SABER MÁS →</a>
                </div>
            </div>
        </div>
    </section>

    <!-- ═══ SECCIÓN 2: COMO TRABAJAMOS ════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-white px-4 sm:px-6 relative overflow-hidden">
        <div class="max-w-5xl mx-auto">
            <div class="text-center mb-16 sm:mb-24 reveal">
                <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Cómo trabajamos</span>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.9]">
                    Estrategias de marketing digital para PYMEs en Barcelona
                </h2>
                <p class="text-zinc-500 font-light text-sm sm:text-base leading-relaxed max-w-2xl mx-auto">
                    Una metodología probada en más de 20 proyectos para que compitas con garantías en el mercado barcelonés, paso a paso y sin humo.
                </p>
            </div>

            <div id="timeline-container" class="relative">
                <div class="hidden md:block absolute left-1/2 top-4 bottom-4 w-px bg-zinc-200 -translate-x-1/2"></div>
                <div id="progress-bar" class="hidden md:block absolute left-1/2 top-4 w-px bg-accent -translate-x-1/2 transition-all duration-100" style="height: 0%;"></div>
                
                <div class="space-y-16 md:space-y-24 flex flex-col items-center">
                    {steps.map((step, index) => (
                        <div class="flex flex-col md:flex-row items-center gap-6 md:gap-12 w-full relative reveal">
                            <div class:list={["flex-1 w-full", index % 2 === 0 ? "md:order-1 md:text-right" : "md:order-3 md:text-left"]}>
                                <div class="p-8 sm:p-10 bg-zinc-50 border border-black/5 rounded-3xl hover:border-accent/10 hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 relative overflow-hidden group">
                                    <h3 class="text-xl font-black uppercase tracking-tighter mb-2 text-zinc-900">{index + 1}. {step.title}</h3>
                                    <div class:list={["h-0.5 bg-accent w-full mb-4 opacity-80", index % 2 === 0 ? "md:ml-auto" : ""]}></div>
                                    <p class:list={["text-sm text-zinc-500 font-light max-w-md", index % 2 === 0 ? "md:ml-auto" : ""]}>{step.desc}</p>
                                    <div class="absolute -bottom-6 -right-5 text-8xl font-black text-black/[0.02] select-none z-0 group-hover:scale-105 transition-transform duration-500">0{index+1}</div>
                                </div>
                            </div>
                            <div class="md:order-2 w-12 h-12 rounded-full border-2 border-zinc-200 bg-white flex items-center justify-center font-black text-lg z-10 shrink-0 shadow-sm node-circle transition-all">
                                0{index + 1}
                            </div>
                            <div class:list={["hidden md:block md:flex-1", index % 2 === 0 ? "md:order-3" : "md:order-1"]}></div>
                        </div>
                    ))}
                </div>
            </div>
        </div>
    </section>

    <!-- ═══ AUDITORÍA DE MARKETING ═════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-zinc-50/50 px-4 sm:px-6 border-t border-black/5 overflow-hidden">
        <div class="max-w-7xl mx-auto grid lg:grid-cols-[6fr_4fr] gap-12 lg:gap-16 items-start">

            <!-- Cabecera: ancho completo -->
            <div class="reveal lg:col-span-2">
                <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Punto de partida</span>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase text-zinc-900 leading-[0.9]">
                    Auditoría de marketing digital para PYMEs en la Ciudad Condal
                </h2>
            </div>

            <!-- Texto: izquierda -->
            <div class="reveal">
                <div class="space-y-5 text-zinc-600 font-light text-base leading-relaxed mb-8">
                    <p>
