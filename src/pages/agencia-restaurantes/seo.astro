---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { buildAlternates } from '../../lib/i18n';
import { localAgencySchema } from '../../lib/schema';
import { strapiClient } from '../../lib/strapi';
import LogoMarquee from '../../components/sections/LogoMarquee.astro';
import FaqHome from '../../components/sections/FaqHome.astro';
import CityPills from '../../components/global/CityPills.astro';
import GoogleReviews from '../../components/global/GoogleReviews.astro';

const SITE_URL = import.meta.env.PUBLIC_SITE_URL || 'https://novamarketing.es';
const alternates = buildAlternates('/agencia-restaurantes/seo/', '/ca/agencia-restaurantes/seo/', SITE_URL);

let allCases: any[] = [];
try {
  const casesRes = await strapiClient.getCaseStudies('es');
  allCases = casesRes.data.map((i: any) => i.attributes ?? i).filter((c: any) => {
    const cats = (c.categories || []).map((cat: any) => (cat.slug || cat.attributes?.slug || '').toLowerCase());
    return cats.some((s: string) => s.includes('seo') || s === 'marketing-digital');
  });
} catch {}

const faqs = [
  { question: "¿Qué incluye el SEO para un restaurante?", answer: "Incluye auditoría inicial, estrategia documentada y ejecución mensual. Ficha de Google trabajada cada mes, sistema de reseñas, carta indexable, contenido local, optimización técnica de la web y un informe mensual con posiciones, rutas al local, llamadas y reservas." },
  { question: "¿Cuánto cuesta el SEO para un restaurante?", answer: "La auditoría cuesta 1.800 euros y los planes mensuales van desde 400 euros al mes para locales con una sede y desde 900 para grupos o zonas muy competidas. Presupuesto cerrado por escrito y sin permanencias." },
  { question: "¿Cuánto tarda en dar resultados?", answer: "La ficha de Google puede mover rutas y llamadas en semanas. Las posiciones orgánicas consolidan entre el tercer y el duodécimo mes. En la hoja de ruta te decimos qué esperar en cada fase." },
  { question: "¿Puedo competir con TheFork y TripAdvisor en Google?", answer: "En las búsquedas genéricas es difícil, pero en las locales de tu zona el mapa manda, y ahí compites tú con tu ficha y tus reseñas, no las plataformas. Cada mesa que llega del mapa es una mesa sin comisión." },
  { question: "¿Gestionáis también las reseñas?", answer: "Sí, es parte central del servicio. Montamos el sistema para conseguirlas de forma constante, las respondemos contigo y las convertimos en argumento de venta en tu ficha y tu web." },
  { question: "¿Cómo medís los resultados?", answer: "En rutas hasta tu local, llamadas, reservas y visitas a la carta, atribuidas a su búsqueda. Los datos son siempre tuyos." },
  { question: "¿Trabajáis con permanencia?", answer: "No, trabajamos mes a mes. Si el servicio no te aporta valor, puedes cancelarlo cuando quieras." },
];

const pageSchema = localAgencySchema({
  pageUrl: `${SITE_URL}/agencia-restaurantes/seo/`,
  lang: 'es',
  cityName: 'Barcelona',
  postalCode: '08035',
  geo: { lat: 41.4114, lng: 2.1526 },
  areaServed: ["España", "Barcelona", "Sabadell", "Sant Cugat del Vallès", "Terrassa", "Vallès Occidental"],
  title: "Agencia SEO para Restaurantes | Llena Mesas desde Google | Nova Marketing",
  description: "SEO para restaurantes. Ficha de Google, reseñas y contenido local para aparecer cuando alguien busca dónde comer en tu zona. Sin comisiones y sin permanencias.",
  datePublished: '2026-07-17',
  dateModified: '2026-07-17',
  streetAddress: 'Carrer del General Mendoza, 10',
  hasMap: 'https://maps.app.goo.gl/9fbB12UcK32bgjj89',
  aggregateRating: { ratingValue: '5.0', reviewCount: '8' },
  breadcrumbName: "Agencia SEO para Restaurantes",
  faqs,
});
---

<BaseLayout
  title="Agencia SEO para Restaurantes | Llena Mesas desde Google | Nova Marketing"
  description="SEO para restaurantes. Ficha de Google, reseñas y contenido local para aparecer cuando alguien busca dónde comer en tu zona. Sin comisiones y sin permanencias."
  locale="es"
  alternates={alternates}
  schemas={[pageSchema]}
>

    <!-- ═══ HERO / H1 ═══════════════════════════════════════════════════════ -->
    <section class="pt-24 sm:pt-40 pb-20 px-4 sm:px-6 relative overflow-hidden text-center bg-white border-b border-black/5">
        <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808008_1px,transparent_1px),linear-gradient(to_bottom,#80808008_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_40%,#000_75%,transparent_100%)]"></div>
        <div class="absolute -top-10 left-1/4 w-72 h-72 bg-accent/15 rounded-full blur-3xl opacity-30 animate-pulse"></div>
        <div class="absolute top-20 right-1/4 w-80 h-80 bg-purple-500/5 rounded-full blur-3xl opacity-20"></div>

        <div class="max-w-5xl mx-auto reveal">
            <span class="inline-flex items-center gap-2 bg-accent/5 backdrop-blur-sm px-4 py-2 border border-accent/10 rounded-full text-accent text-[8px] sm:text-[10px] font-black uppercase tracking-[0.3em] mb-8 shadow-sm">
                <span class="w-1.5 h-1.5 bg-accent rounded-full animate-ping"></span>
                Posicionamiento SEO Gastronómico
            </span>
            <h1 class="text-3xl sm:text-5xl md:text-7xl lg:text-8xl uppercase font-extrabold tracking-tighter leading-[0.88] mb-8 text-gradient flex flex-col items-center text-center">
                <span class="lg:whitespace-nowrap">Agencia SEO </span>
                <span class="lg:whitespace-nowrap text-mktg-gradient">para Restaurantes</span>
            </h1>
            <p class="text-lg sm:text-xl text-zinc-500 font-light leading-relaxed w-[75%] mx-auto mb-8">
                Aparece cuando alguien busca dónde comer en tu zona. SEO local para restaurantes con estrategia a medida y resultados que se miden en reservas.
            </p>
            <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3 mb-10">
                {['Sin permanencias', 'Trato directo con el consultor', 'Resultados medidos en reservas'].map(item => (
                    <span class="inline-flex items-center gap-2 text-[11px] sm:text-xs font-black uppercase tracking-widest text-zinc-700">
                        <svg class="w-4 h-4 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                        {item}
                    </span>
                ))}
            </div>
            <div class="flex justify-center mt-4">
                <a href="#contacto" class="contact-modal-trigger btn-mktg-v5 shadow-[0_10px_30px_rgba(0,0,0,0.1)] !py-4 sm:!py-5 !px-6 sm:!px-10 !text-[11px] !tracking-widest font-black">
                    HABLEMOS DE TU RESTAURANTE
                </a>
            </div>
        </div>
    </section>

    <LogoMarquee />

    <!-- ═══ INTRO ═══════════════════════════════════════════════════════ -->
    <section class="py-16 sm:py-24 bg-white px-4 sm:px-6 border-b border-black/5">
        <div class="max-w-6xl mx-auto reveal grid md:grid-cols-[1.3fr_1fr] gap-10 md:gap-16 items-center">
            <div>
                <p class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4">¿Por qué SEO?</p>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-8 text-zinc-900 leading-[0.9]">
                    La agencia de posicionamiento SEO para tu restaurante
                </h2>
                <div class="space-y-6 text-zinc-600 font-light text-base sm:text-lg leading-relaxed">
                    <p>
                        <strong class="font-semibold text-zinc-900">Dónde comer cerca de mí se busca millones de veces al día</strong>. Quien aparece en ese mapa con buenas fotos y buenas reseñas se lleva la mesa, sin pagar comisión a nadie. Es el canal más rentable de un restaurante.
                    </p>
                    <p>
                        Nova es una <strong class="font-semibold text-zinc-900">agencia SEO especializada en restaurantes</strong>. Ficha de Google, reseñas y contenido local con una sola métrica que importa. <strong class="font-semibold text-zinc-900">Cuántas mesas llegan desde Google cada mes</strong>.
                    </p>
                </div>
            </div>
            <div class="hidden md:block">
                <img src="/sergio-galos-agencia-restaurantes-seo.webp" alt="Sergio Galo's, Consultor SEO gastronómico" title="Sergio Galo's, Consultor SEO gastronómico" class="w-full h-auto" loading="lazy" />
            </div>
        </div>
    </section>

    <!-- ═══ SERVICIOS ══════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-zinc-50 px-4 sm:px-6 border-t border-b border-black/5">
        <div class="max-w-7xl mx-auto text-center reveal">
            <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Qué hacemos</span>
            <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.9]">
                Servicio de posicionamiento SEO para restaurantes
            </h2>
            <p class="text-zinc-500 font-light text-sm sm:text-base leading-relaxed max-w-3xl mx-auto mb-16">
                El SEO de un restaurante no es una sola tarea, es un sistema. Estas son las nueve piezas que trabajamos para que domines las búsquedas de tu zona.
            </p>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 text-left">
                {[
                    { t: "Auditoría SEO gastronómica", d: "Radiografía de tu visibilidad cuando alguien busca dónde comer en tu zona." },
                    { t: "Ficha de Google al máximo", d: "El escaparate número uno de un restaurante. Categorías, fotos, carta, horarios y publicaciones trabajados cada mes." },
                    { t: "Gestión de reseñas", d: "Las reseñas deciden mesas. Sistema para conseguirlas, responderlas y convertirlas en tu mejor argumento." },
                    { t: "Keywords de comensal", d: "Las búsquedas de quien tiene hambre cerca, del menú del día a la cena de grupo. Cada una llena mesas distintas." },
                    { t: "Carta indexable", d: "Tu carta visible para Google, no un PDF que nadie puede leer. Cada plato es una búsqueda potencial." },
                    { t: "Contenido local", d: "Tu cocina, tus eventos y tu barrio contados de forma que posiciona y da hambre." },
                    { t: "Analítica y medición", d: "Cada reserva, llamada y ruta al local atribuidas a su búsqueda. Decisiones con datos." },
                    { t: "SEO más GEO", d: "Cada vez más gente pregunta a la IA dónde comer. Integramos Google y la IA en una sola estrategia." },
                    { t: "Fotos que posicionan", d: "Las fotos de la ficha y la web optimizadas para cargar rápido y salir en los resultados visuales." },
                ].map((c: any) => (
                    <div class="bg-white border border-black/5 rounded-2xl p-6 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
                        <h3 class="text-sm font-black uppercase tracking-tight text-zinc-900 mb-3">
                            {c.href ? <a href={c.href} class="hover:text-accent transition-colors">{c.t}</a> : c.t}
                            {c.b && <span class="block text-[11px] uppercase tracking-[0.2em] text-accent mt-1 font-semibold">{c.b}</span>}
                        </h3>
                        <p class="text-sm text-zinc-500 font-light leading-relaxed mb-2">{c.d}</p>
                        {c.href && <a href={c.href} class="text-[11px] font-black tracking-widest text-accent hover:underline">SABER MÁS →</a>}
                    </div>
                ))}
            </div>
            <div class="mt-12 text-center reveal">
                <a href="#contacto" class="contact-modal-trigger btn-mktg-v5 shadow-[0_10px_30px_rgba(37,211,102,0.3)] !py-4 sm:!py-5 !px-6 sm:!px-10 !text-[11px] !tracking-widest font-black">HABLEMOS DE TU RESTAURANTE</a>
            </div>
        </div>
    </section>

    <!-- ═══ ESTRATEGIA ════════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-white px-4 sm:px-6 relative overflow-hidden">
        <div class="max-w-5xl mx-auto">
            <div class="text-center mb-16 sm:mb-24 reveal">
                <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Cómo trabajamos</span>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.9]">
                    Estrategia SEO para posicionar tu restaurante en Google
                </h2>
                <p class="text-zinc-500 font-light text-sm sm:text-base leading-relaxed max-w-2xl mx-auto">
                    Una metodología documentada, paso a paso y sin humo.
                </p>
            </div>

            <div id="timeline-container" class="relative">
                <div class="hidden md:block absolute left-1/2 top-4 bottom-4 w-px bg-zinc-200 -translate-x-1/2"></div>
                <div id="progress-bar" class="hidden md:block absolute left-1/2 top-4 w-px bg-accent -translate-x-1/2 transition-all duration-100"></div>

                <div class="space-y-16 md:space-y-24 flex flex-col items-center">
                    {[
                        { title: "Auditoría SEO Completa", desc: "Analizamos tu visibilidad en las búsquedas de tu zona, tu ficha de Google y los locales que hoy salen por delante de ti." },
                        { title: "Estrategia SEO Documentada", desc: "Hoja de ruta por escrito. Qué búsquedas atacar, qué arreglar en la ficha y la web y qué resultados esperar en 3, 6 y 12 meses." },
                        { title: "Ficha, Web y Contenidos", desc: "Optimizamos la ficha de Google a fondo, hacemos tu carta indexable y creamos el contenido local que posiciona." },
                        { title: "Reseñas y Autoridad Local", desc: "Sistema de reseñas funcionando y menciones locales que te convierten en la referencia de tu zona." },
                        { title: "Medición y Ajuste Continuo", desc: "Monitorizamos posiciones, rutas al local, llamadas y reservas mes a mes. Lo que funciona se refuerza." },
                    ].map((step, index) => (
                        <div class="flex flex-col md:flex-row items-center gap-6 md:gap-12 w-full relative reveal">
                            <div class:list={["flex-1 w-full", index % 2 === 0 ? "md:order-1 md:text-right" : "md:order-3 md:text-left"]}>
                                <div class="p-8 sm:p-10 bg-zinc-50 border border-black/5 rounded-3xl hover:border-accent/10 hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 relative overflow-hidden group">
                                    <h3 class="text-xl font-black uppercase tracking-tighter mb-2 text-zinc-900">{index + 1}. {step.title}</h3>
                                    <div class:list={["h-0.5 bg-accent w-full mb-4 opacity-80", index % 2 === 0 ? "md:ml-auto" : ""]}></div>
                                    <p class:list={["text-sm text-zinc-500 font-light max-w-md", index % 2 === 0 ? "md:ml-auto" : ""]}>{step.desc}</p>
                                    <div class="absolute -bottom-6 -right-5 text-8xl font-black text-black/[0.02] select-none z-0 group-hover:scale-105 transition-transform duration-500">0{index+1}</div>
                                </div>
                            </div>
                            <div class="md:order-2 w-12 h-12 rounded-full border-2 border-zinc-200 bg-white flex items-center justify-center font-black text-lg z-10 shrink-0 shadow-sm node-circle transition-all">
                                0{index + 1}
                            </div>
                            <div class:list={["hidden md:block md:flex-1", index % 2 === 0 ? "md:order-3" : "md:order-1"]}></div>
                        </div>
                    ))}
                </div>
            </div>
        </div>
    </section>

    <!-- ═══ AUDITORÍA ═════════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-zinc-50/50 px-4 sm:px-6 border-t border-black/5 overflow-hidden">
        <div class="max-w-7xl mx-auto grid lg:grid-cols-[6fr_4fr] gap-12 lg:gap-16 items-start">
            <div class="reveal lg:col-span-2">
                <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Punto de partida</span>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase text-zinc-900 leading-[0.9]">
                    Auditoría SEO para tu restaurante
                </h2>
            </div>
            <div class="reveal">
                <div class="space-y-5 text-zinc-600 font-light text-base leading-relaxed mb-8">
                    <p>¿Sabes en qué posición sale tu local cuando alguien busca dónde comer en tu zona? ¿Quién se lleva hoy esas mesas? Casi ningún restaurante lo sabe con datos, y ahí empieza todo.</p>
                    <p>Nuestra <strong class="font-semibold text-zinc-900">auditoría SEO gastronómica</strong> mide tu visibilidad real en las búsquedas de tu zona, revisa tu ficha de Google, tus reseñas y tu web, y analiza a los locales que salen por delante de ti.</p>
                    <p>Cada punto lo revisa un consultor senior con experiencia en hostelería. El resultado es un diagnóstico de negocio que entiende cualquier hostelero.</p>
                </div>
                <ul class="space-y-3">
                    {["Posiciones en las búsquedas de tu zona","Ficha de Google frente a tu competencia","Volumen y calidad de tus reseñas","Carta y web indexables por Google","Búsquedas de comensal sin explotar","Plan de acción priorizado por mesas"].map(item => (
                        <li class="flex items-start gap-3 text-sm text-zinc-700 font-light">
                            <svg class="w-4 h-4 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                            {item}
                        </li>
                    ))}
                </ul>
                <div class="mt-16">
                    <a href="#contacto" class="contact-modal-trigger btn-mktg-v5 shadow-[0_10px_30px_rgba(37,211,102,0.3)] !py-4 sm:!py-5 !px-6 sm:!px-10 !text-[11px] !tracking-widest font-black">
                        QUIERO MI AUDITORÍA SEO
                    </a>
                </div>
            </div>
            <div class="reveal flex flex-col gap-4">
                {[
                    { bg: 'bg-purple-100', color: 'text-purple-600', t: "Revisión de tu ficha de Google", d: "Categorías, fotos, atributos y publicaciones frente a los locales que más llenan de tu zona." },
                    { bg: 'bg-green-100', color: 'text-green-600', t: "Plan de acción priorizado", d: "Un plan ordenado por impacto en reservas y esfuerzo. Sabrás qué arreglar la primera semana." },
                    { bg: 'bg-purple-100', color: 'text-purple-600', t: "Keywords de comensal", d: "Las búsquedas que hace quien decide dónde comer en tu zona, con volumen real." },
                    { bg: 'bg-amber-100', color: 'text-amber-600', t: "Auditoría de reseñas", d: "Cuántas tienes, cómo respondes y cómo conseguir más. Las reseñas deciden mesas." },
                    { bg: 'bg-blue-100', color: 'text-blue-600', t: "Benchmark de tu zona", d: "Comparamos tu visibilidad con los tres locales que más llenan en tu barrio." },
                ].map(card => (
                    <div class="bg-white rounded-2xl shadow-[0_15px_40px_rgba(0,0,0,0.08)] p-5 flex items-start gap-4">
                        <div class:list={["w-11 h-11 rounded-full flex items-center justify-center flex-shrink-0", card.bg]}>
                            <svg class:list={["w-5 h-5", card.color]} fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                        </div>
                        <div>
                            <h3 class="text-sm font-black text-zinc-900 mb-1">{card.t}</h3>
                            <p class="text-xs text-zinc-500 font-light leading-relaxed">{card.d}</p>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- ═══ QUÉ INCLUYE LA AUDITORÍA ═══════════════════════════ -->
    <section class="py-20 sm:py-28 bg-white px-4 sm:px-6 border-t border-black/5">
        <div class="max-w-7xl mx-auto">
            <div class="text-center mb-12 sm:mb-16 reveal">
                <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Paso a paso</span>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase text-zinc-900 leading-[0.9]">
                    Qué incluye la auditoría SEO de nova
                </h2>
            </div>
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 items-stretch reveal">
                {[
                    { n: '1', t: "Radiografía de tu visibilidad local", d: "En qué posición sales para las búsquedas de tu zona y quién se las lleva hoy." },
                    { n: '2', t: "Diagnóstico de ficha, web y reseñas", d: "Qué te frena en el mapa y en el buscador, explicado sin tecnicismos." },
                    { n: '3', t: "Hoja de ruta para llenar mesas", d: "Acciones ordenadas por impacto y una videollamada donde repasamos cada punto contigo." },
                ].map((st, i) => (
                    <div class="flex items-center gap-4 lg:gap-6">
                        {i > 0 && <div class="hidden lg:flex text-3xl text-accent font-black select-none">→</div>}
                        <div class="bg-white border border-black/5 rounded-2xl p-8 shadow-[0_15px_40px_rgba(0,0,0,0.06)] flex-1 text-center h-full">
                            <div class="w-12 h-12 rounded-full bg-accent/10 border border-accent/20 flex items-center justify-center mx-auto mb-4 text-accent font-black text-lg">{st.n}</div>
                            <h3 class="text-base font-black uppercase tracking-tight text-zinc-900 mb-3">{st.t}</h3>
                            <p class="text-sm text-zinc-500 font-light leading-relaxed">{st.d}</p>
                        </div>
                    </div>
                ))}
            </div>
            <p class="text-zinc-500 font-light text-sm sm:text-base leading-relaxed max-w-3xl mx-auto text-center mt-16 reveal">
                Nuestra auditoría SEO es el primer paso para que tu restaurante domine las búsquedas de su zona. Analiza cómo te ve hoy Google, explica por qué otros locales salen antes que tú y te deja una hoja de ruta clara. También puedes contratarla suelta como segunda opinión.
            </p>
            <div class="mt-12 text-center reveal">
                <a href="#contacto" class="contact-modal-trigger btn-mktg-v5 shadow-[0_10px_30px_rgba(37,211,102,0.3)] !py-4 sm:!py-5 !px-6 sm:!px-10 !text-[11px] !tracking-widest font-black">QUIERO MI AUDITORÍA SEO</a>
            </div>
        </div>
    </section>

    <!-- ═══ PRECIOS ════════════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-zinc-50/50 px-4 sm:px-6 border-t border-black/5">
        <div class="max-w-7xl mx-auto">
            <div class="text-center mb-12 sm:mb-16 reveal">
                <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Tarifas claras</span>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.9]">
                    Precios de SEO para restaurantes
