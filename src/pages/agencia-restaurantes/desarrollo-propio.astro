---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { buildAlternates } from '../../lib/i18n';
import { localAgencySchema } from '../../lib/schema';
import { strapiClient } from '../../lib/strapi';
import LogoMarquee from '../../components/sections/LogoMarquee.astro';
import FaqHome from '../../components/sections/FaqHome.astro';
import CityPills from '../../components/global/CityPills.astro';
import GoogleReviews from '../../components/global/GoogleReviews.astro';

const SITE_URL = import.meta.env.PUBLIC_SITE_URL || 'https://novamarketing.es';
const alternates = buildAlternates('/agencia-restaurantes/desarrollo-propio/', '/ca/agencia-restaurantes/desarrollo-propio/', SITE_URL);

let allCases: any[] = [];
try {
  const casesRes = await strapiClient.getCaseStudies('es');
  allCases = casesRes.data.map((i: any) => i.attributes ?? i).filter((c: any) => {
    const cats = (c.categories || []).map((cat: any) => (cat.slug || cat.attributes?.slug || '').toLowerCase());
    return cats.some((s: string) => s === 'marketing-digital' || s.includes('seo') || s === 'diseno-web');
  });
} catch {}

const faqs = [
  { question: "¿Cuánto cuesta una agencia de marketing para restaurantes?", answer: "Los planes mensuales parten de 400 euros al mes para restaurantes que arrancan con uno o dos canales, y crecen según la inversión publicitaria y el volumen de trabajo. Antes de empezar recibes un presupuesto cerrado por escrito, con fee de gestión fijo y sin porcentajes ocultos sobre tu inversión." },
  { question: "¿Qué incluye el servicio de marketing gastronómico?", answer: "Incluye un diagnóstico inicial, una estrategia documentada y la ejecución y medición mensual de cada canal activado. SEO local y ficha de Google, campañas de Google Ads y Meta Ads, email marketing, optimización de la web y las reservas, y visibilidad en la IA." },
  { question: "¿Trabajáis con nuestro desarrollador o necesitamos el vuestro?", answer: "Trabajamos con tu equipo técnico. Nosotros aportamos el análisis, las especificaciones y la prioridad de cada cambio, y tu desarrollador implementa con nuestra supervisión. Si no tienes equipo propio, también podemos encargarnos." },
  { question: "¿Quién llevará mi cuenta?", answer: "Siempre la misma persona, el consultor fundador. Nada de gestores junior que cambian cada trimestre. Trabajamos con un número limitado de clientes para que cada restaurante tenga seguimiento senior de verdad." },
  { question: "¿Cuánto tardaré en ver resultados?", answer: "Depende del canal. Las campañas de pago y la ficha de Google pueden mover reservas las primeras semanas, y el SEO consolida resultados entre el tercer y el duodécimo mes." },
  { question: "¿Cómo medís los resultados?", answer: "En reservas, llamadas, rutas hasta tu local y pedidos, cada uno atribuido a su canal y su campaña. En el informe mensual ves cuánto has invertido y cuántas mesas ha llenado el marketing. Los datos y las cuentas son siempre tuyos." },
  { question: "¿Trabajáis con permanencia?", answer: "No, trabajamos mes a mes. Si el servicio no te aporta valor, puedes cancelarlo cuando quieras. Nuestra permanencia real es el resultado que ves en los informes cada mes." },
];

const pageSchema = localAgencySchema({
  pageUrl: `${SITE_URL}/agencia-restaurantes/desarrollo-propio/`,
  lang: 'es',
  cityName: 'Barcelona',
  postalCode: '08035',
  geo: { lat: 41.4114, lng: 2.1526 },
  areaServed: ["España", "Barcelona", "Sabadell", "Sant Cugat del Vallès", "Terrassa", "Vallès Occidental"],
  title: "▷ Marketing para restaurantes con desarrollo web propio | SEO y Ads",
  description: "Estrategias de marketing para restaurantes con web propia ⭐ SEO local, Ads y CRO integrados para optimizar reservas y atraer clientes ✅",
  datePublished: '2026-07-17',
  dateModified: '2026-07-17',
  streetAddress: 'Carrer del General Mendoza, 10',
  hasMap: 'https://maps.app.goo.gl/9fbB12UcK32bgjj89',
  aggregateRating: { ratingValue: '5.0', reviewCount: '8' },
  breadcrumbName: "Marketing Restaurantes Desarrollo Propio",
  faqs,
});
---

<BaseLayout
  title="▷ Marketing para restaurantes con desarrollo web propio | SEO y Ads"
  description="Estrategias de marketing para restaurantes con web propia ⭐ SEO local, Ads y CRO integrados para optimizar reservas y atraer clientes ✅"
  locale="es"
  alternates={alternates}
  schemas={[pageSchema]}
>

    <!-- ═══ HERO / H1 ═══════════════════════════════════════════════════════ -->
    <section class="pt-24 sm:pt-40 pb-20 px-4 sm:px-6 relative overflow-hidden text-center bg-white border-b border-black/5">
        <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808008_1px,transparent_1px),linear-gradient(to_bottom,#80808008_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_40%,#000_75%,transparent_100%)]"></div>
        <div class="absolute -top-10 left-1/4 w-72 h-72 bg-accent/15 rounded-full blur-3xl opacity-30 animate-pulse"></div>
        <div class="absolute top-20 right-1/4 w-80 h-80 bg-purple-500/5 rounded-full blur-3xl opacity-20"></div>

        <div class="max-w-5xl mx-auto reveal">
            <span class="inline-flex items-center gap-2 bg-accent/5 backdrop-blur-sm px-4 py-2 border border-accent/10 rounded-full text-accent text-[8px] sm:text-[10px] font-black uppercase tracking-[0.3em] mb-8 shadow-sm">
                <span class="w-1.5 h-1.5 bg-accent rounded-full animate-ping"></span>
                Marketing Gastronómico en Desarrollo Propio
            </span>
            <h1 class="text-3xl sm:text-5xl md:text-7xl lg:text-8xl uppercase font-extrabold tracking-tighter leading-[0.88] mb-8 text-gradient flex flex-col items-center text-center">
                <span class="lg:whitespace-nowrap">Marketing para tu </span>
                <span class="lg:whitespace-nowrap text-mktg-gradient">Restaurante en Desarrollo Propio</span>
            </h1>
            <p class="text-lg sm:text-xl text-zinc-500 font-light leading-relaxed w-[75%] mx-auto mb-8">
                Tu web a medida merece un marketing a su altura. Estrategia especializada para restaurantes con web propia y motor de reservas integrado.
            </p>
            <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3 mb-10">
                {['Sin permanencias', 'Trato directo con el consultor', 'Resultados medidos en reservas'].map(item => (
                    <span class="inline-flex items-center gap-2 text-[11px] sm:text-xs font-black uppercase tracking-widest text-zinc-700">
                        <svg class="w-4 h-4 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                        {item}
                    </span>
                ))}
            </div>
            <div class="flex justify-center mt-4">
                <a href="#contacto" class="contact-modal-trigger btn-mktg-v5 shadow-[0_10px_30px_rgba(0,0,0,0.1)] !py-4 sm:!py-5 !px-6 sm:!px-10 !text-[11px] !tracking-widest font-black">
                    HABLEMOS DE TU RESTAURANTE
                </a>
            </div>
        </div>
    </section>

    <LogoMarquee />

    <!-- ═══ INTRO ═══════════════════════════════════════════════════════ -->
    <section class="py-16 sm:py-24 bg-white px-4 sm:px-6 border-b border-black/5">
        <div class="max-w-6xl mx-auto reveal grid md:grid-cols-[1.3fr_1fr] gap-10 md:gap-16 items-center">
            <div>
                <p class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4">¿Por qué marketing para Desarrollo Propio?</p>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-8 text-zinc-900 leading-[0.9]">
                    La agencia de marketing para tu web de restaurante en Desarrollo Propio
                </h2>
                <div class="space-y-6 text-zinc-600 font-light text-base sm:text-lg leading-relaxed">
                    <p>
                        <strong class="font-semibold text-zinc-900">La web no llena mesas sola, las llena el sistema que la rodea</strong>. Visitas que llegan con hambre, carta que convence, reservas sin fricción y campañas rentables. Desarrollo Propio pone la base, el marketing pone los comensales.
                    </p>
                    <p>
                        Nova es una <strong class="font-semibold text-zinc-900">agencia de marketing especializada en restaurantes</strong> acostumbrada a trabajar con desarrollos a medida. Nos coordinamos con tu equipo técnico y hablamos su idioma.
                    </p>
                </div>
            </div>
            <div class="hidden md:block">
                <img src="/sergio-galos-agencia-restaurantes-desarrollo-propio.webp" alt="Sergio Galo's, consultor de marketing gastronómico" title="Sergio Galo's, consultor de marketing gastronómico" class="w-full h-auto" loading="lazy" width="473" height="591" />
            </div>
        </div>
    </section>

    <!-- ═══ SERVICIOS ═══════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-zinc-50 px-4 sm:px-6 border-t border-black/5">
        <div class="max-w-7xl mx-auto">
            <div class="text-center mb-14 sm:mb-20 reveal">
                <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Qué hacemos</span>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.9]">
                    Servicios de Marketing para tu web en Desarrollo Propio
                </h2>
                <p class="text-zinc-500 font-light text-sm sm:text-base leading-relaxed max-w-2xl mx-auto">
                    Las seis piezas que combinamos según lo que necesite tu local. No pagas por un paquete cerrado, pagas por lo que tu captación necesita.
                </p>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 reveal text-left">
                <div class="service-card p-8 bg-white rounded-2xl border border-zinc-100/80 shadow-sm hover:shadow-2xl hover:-translate-y-2 hover:border-accent/10 transition-all duration-500 relative overflow-hidden flex flex-col justify-between">
                    <h3 class="text-xl font-black uppercase tracking-tighter mb-4 text-zinc-900">
                        <a href="/agencia-restaurantes/seo/" class="hover:text-accent transition-colors">SEO para Restaurantes</a>
                    </h3>
                    <p class="text-sm text-zinc-500 font-light leading-relaxed mb-4">Aparece cuando alguien busca dónde comer en tu zona. Ficha de Google, reseñas y contenido que llena mesas sin pagar comisiones.</p>
                    <a href="/agencia-restaurantes/seo/" class="text-[11px] font-black tracking-widest text-accent hover:underline">SABER MÁS →</a>
                </div>
                <div class="service-card p-8 bg-white rounded-2xl border border-zinc-100/80 shadow-sm hover:shadow-2xl hover:-translate-y-2 hover:border-accent/10 transition-all duration-500 relative overflow-hidden flex flex-col justify-between">
                    <h3 class="text-xl font-black uppercase tracking-tighter mb-4 text-zinc-900">
                        <a href="/agencia-restaurantes/google-ads/" class="hover:text-accent transition-colors">Google Ads para Restaurantes</a>
                    </h3>
                    <p class="text-sm text-zinc-500 font-light leading-relaxed mb-4">Campañas para quien busca restaurante ahora mismo cerca de ti. Del clic a la reserva sin intermediarios.</p>
                    <a href="/agencia-restaurantes/google-ads/" class="text-[11px] font-black tracking-widest text-accent hover:underline">SABER MÁS →</a>
                </div>
                <div class="service-card p-8 bg-white rounded-2xl border border-zinc-100/80 shadow-sm hover:shadow-2xl hover:-translate-y-2 hover:border-accent/10 transition-all duration-500 relative overflow-hidden flex flex-col justify-between">
                    <h3 class="text-xl font-black uppercase tracking-tighter mb-4 text-zinc-900">
                        <a href="/agencia-restaurantes/meta-ads/" class="hover:text-accent transition-colors">Meta Ads para Restaurantes</a>
                    </h3>
                    <p class="text-sm text-zinc-500 font-light leading-relaxed mb-4">Tus platos en el feed de tu barrio. Instagram y Facebook con creativos que abren el apetito y llenan el fin de semana.</p>
                    <a href="/agencia-restaurantes/meta-ads/" class="text-[11px] font-black tracking-widest text-accent hover:underline">SABER MÁS →</a>
                </div>
                <div class="service-card p-8 bg-white rounded-2xl border border-zinc-100/80 shadow-sm hover:shadow-2xl hover:-translate-y-2 hover:border-accent/10 transition-all duration-500 relative overflow-hidden flex flex-col justify-between">
                    <h3 class="text-xl font-black uppercase tracking-tighter mb-4 text-zinc-900">
                        <a href="/agencia-restaurantes/email-marketing/" class="hover:text-accent transition-colors">Email Marketing Gastronómico</a>
                    </h3>
                    <p class="text-sm text-zinc-500 font-light leading-relaxed mb-4">Tu base de clientes avisada de eventos, menús y fechas señaladas. La mesa más barata es la del cliente que repite.</p>
                    <a href="/agencia-restaurantes/email-marketing/" class="text-[11px] font-black tracking-widest text-accent hover:underline">SABER MÁS →</a>
                </div>
                <div class="service-card p-8 bg-white rounded-2xl border border-zinc-100/80 shadow-sm hover:shadow-2xl hover:-translate-y-2 hover:border-accent/10 transition-all duration-500 relative overflow-hidden flex flex-col justify-between">
                    <h3 class="text-xl font-black uppercase tracking-tighter mb-4 text-zinc-900">
                        <a href="/agencia-restaurantes/diseno-web/" class="hover:text-accent transition-colors">Diseño Web</a>
                    </h3>
                    <p class="text-sm text-zinc-500 font-light leading-relaxed mb-4">Una web rápida, adaptada a móvil y pensada para convertir la visita en cliente. La base sobre la que trabaja cada canal.</p>
                    <a href="/agencia-restaurantes/diseno-web/" class="text-[11px] font-black tracking-widest text-accent hover:underline">SABER MÁS →</a>
                </div>
                <div class="service-card p-8 bg-white rounded-2xl border border-zinc-100/80 shadow-sm hover:shadow-2xl hover:-translate-y-2 hover:border-accent/10 transition-all duration-500 relative overflow-hidden flex flex-col justify-between">
                    <h3 class="text-xl font-black uppercase tracking-tighter mb-4 text-zinc-900">
                        <a href="/agencia-restaurantes/posicionamiento-geo/" class="hover:text-accent transition-colors">GEO y Visibilidad en IA</a>
                    </h3>
                    <p class="text-sm text-zinc-500 font-light leading-relaxed mb-4">Cuando alguien pregunta a ChatGPT dónde comer en tu zona, la respuesta recomienda dos o tres sitios. Trabajamos para que seas uno.</p>
                    <a href="/agencia-restaurantes/posicionamiento-geo/" class="text-[11px] font-black tracking-widest text-accent hover:underline">SABER MÁS →</a>
                </div>
            </div>
            <div class="mt-12 text-center reveal">
                <a href="#contacto" class="contact-modal-trigger btn-mktg-v5 shadow-[0_10px_30px_rgba(37,211,102,0.3)] !py-4 sm:!py-5 !px-6 sm:!px-10 !text-[11px] !tracking-widest font-black">HABLEMOS DE TU RESTAURANTE</a>
            </div>
        </div>
    </section>

    <!-- ═══ ESTRATEGIA ════════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-white px-4 sm:px-6 relative overflow-hidden">
        <div class="max-w-5xl mx-auto">
            <div class="text-center mb-16 sm:mb-24 reveal">
                <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Cómo trabajamos</span>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.9]">
                    Estrategias de marketing para tu restaurante en Desarrollo Propio
                </h2>
                <p class="text-zinc-500 font-light text-sm sm:text-base leading-relaxed max-w-2xl mx-auto">
                    Una metodología documentada para llenar más mesas cada mes, paso a paso y sin humo.
                </p>
            </div>

            <div id="timeline-container" class="relative">
                <div class="hidden md:block absolute left-1/2 top-4 bottom-4 w-px bg-zinc-200 -translate-x-1/2"></div>
                <div id="progress-bar" class="hidden md:block absolute left-1/2 top-4 w-px bg-accent -translate-x-1/2 transition-all duration-100"></div>

                <div class="space-y-16 md:space-y-24 flex flex-col items-center">
                    {[
                        { title: "Diagnóstico del Restaurante", desc: "Analizamos tu captación con datos. De dónde salen hoy tus reservas, cuánto pagas en comisiones a plataformas y qué visibilidad tienes en tu barrio. Ese es tu punto de partida real." },
                        { title: "Estrategia Documentada", desc: "Recibes un plan por escrito. Qué canales activar, qué servicios empujar, qué presupuesto necesita cada campaña y cuántas reservas es razonable esperar en 3, 6 y 12 meses." },
                        { title: "Ejecución Multicanal", desc: "SEO local para quien busca dónde comer, Ads para quien decide ahora, redes para abrir el apetito y email para que repitan. Cada canal con su función." },
                        { title: "Medición Sin Humo", desc: "Medimos reservas, llamadas y pedidos, no likes. Cada reserva queda atribuida a su canal y su campaña en el informe mensual." },
                        { title: "Optimización Continua", desc: "Revisamos cada semana campañas y conversión, cortamos lo que no llena mesas y reinvertimos en lo que funciona. Mes a mes, la cuenta mejora o se explica por qué." },
                    ].map((step, index) => (
                        <div class="flex flex-col md:flex-row items-center gap-6 md:gap-12 w-full relative reveal">
                            <div class:list={["flex-1 w-full", index % 2 === 0 ? "md:order-1 md:text-right" : "md:order-3 md:text-left"]}>
                                <div class="p-8 sm:p-10 bg-zinc-50 border border-black/5 rounded-3xl hover:border-accent/10 hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 relative overflow-hidden group">
                                    <h3 class="text-xl font-black uppercase tracking-tighter mb-2 text-zinc-900">{index + 1}. {step.title}</h3>
                                    <div class:list={["h-0.5 bg-accent w-full mb-4 opacity-80", index % 2 === 0 ? "md:ml-auto" : ""]}></div>
                                    <p class:list={["text-sm text-zinc-500 font-light max-w-md", index % 2 === 0 ? "md:ml-auto" : ""]}>{step.desc}</p>
                                    <div class="absolute -bottom-6 -right-5 text-8xl font-black text-black/[0.02] select-none z-0 group-hover:scale-105 transition-transform duration-500">0{index+1}</div>
                                </div>
                            </div>
                            <div class="md:order-2 w-12 h-12 rounded-full border-2 border-zinc-200 bg-white flex items-center justify-center font-black text-lg z-10 shrink-0 shadow-sm node-circle transition-all">
                                0{index + 1}
                            </div>
                            <div class:list={["hidden md:block md:flex-1", index % 2 === 0 ? "md:order-3" : "md:order-1"]}></div>
                        </div>
                    ))}
                </div>
            </div>
        </div>
    </section>

    <!-- ═══ POR QUÉ ESPECIALIZADO ═════════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-zinc-50/50 px-4 sm:px-6 border-t border-black/5 overflow-hidden">
        <div class="max-w-4xl mx-auto">
            <div class="reveal mb-10">
                <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Especialización real</span>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase text-zinc-900 leading-[0.9]">
                    Por qué tu web de restaurante en Desarrollo Propio necesita marketing especializado
                </h2>
            </div>
            <div class="reveal space-y-5 text-zinc-600 font-light text-base leading-relaxed mb-8">
                <p>Una web a medida te da lo que ninguna plantilla puede. Motor de reservas propio, carta integrada y una experiencia única de marca. Pero también significa que ninguna receta genérica de marketing le sirve.</p>
                <p>Su gran ventaja es el control. Cada página, cada foto y cada botón puede diseñarse exactamente para convertir la visita en reserva, sin las limitaciones de un tema comprado.</p>
                <p>Su riesgo es el aislamiento. Muchos desarrollos a medida nacen sin SEO técnico, sin datos estructurados de restaurante y sin medición, porque se construyeron pensando en la imagen y no en la captación.</p>
                <p>Trabajamos tu web a medida con ese conocimiento de serie. Especificaciones claras para tu desarrollador, SEO local auditado y campañas conectadas a tu motor de reservas.</p>
            </div>
            <ul class="space-y-3 reveal">
                {["SEO técnico auditado sobre tu desarrollo","Datos estructurados de restaurante correctos","Reservas medidas de punta a punta","Carta y menús indexables por Google","Campañas conectadas a tu motor de reservas","Coordinación directa con tu equipo técnico"].map(item => (
                    <li class="flex items-start gap-3 text-sm text-zinc-700 font-light">
                        <svg class="w-4 h-4 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                        {item}
                    </li>
                ))}
            </ul>
            <div class="mt-16 reveal">
                <a href="#contacto" class="contact-modal-trigger btn-mktg-v5 shadow-[0_10px_30px_rgba(37,211,102,0.3)] !py-4 sm:!py-5 !px-6 sm:!px-10 !text-[11px] !tracking-widest font-black">
                    QUIERO MI AUDITORÍA GASTRONÓMICA
                </a>
            </div>
        </div>
    </section>

    <!-- ═══ CITA ══════════════════════════════════════════════════ -->
    <section class="py-20 sm:py-28 bg-zinc-950 px-4 sm:px-6">
        <div class="max-w-4xl mx-auto text-center reveal">
            <blockquote class="text-2xl sm:text-4xl lg:text-5xl font-black tracking-tight text-white leading-[1.15] mb-8">
                “Tu competencia tiene una web parecida a la tuya. La diferencia no está en la plataforma. Está en el sistema de captación que la llena de comensales.”
            </blockquote>
            <p class="text-sm text-zinc-400 font-light mb-10">Sergio Galo's · Consultor de marketing gastronómico</p>
            <a href="#contacto" class="contact-modal-trigger btn-mktg-v5 shadow-[0_10px_30px_rgba(37,211,102,0.3)] !py-4 sm:!py-5 !px-6 sm:!px-10 !text-[11px] !tracking-widest font-black">
                HABLEMOS DE TU RESTAURANTE
            </a>
        </div>
    </section>

    <!-- ═══ POR QUÉ NOVA (COMPARATIVA) ═════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-white px-4 sm:px-6 border-t border-black/5">
        <div class="max-w-5xl mx-auto">
            <div class="text-center mb-12 sm:mb-16 reveal">
                <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Por qué nova</span>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.9]">
                    Qué diferencia a nova de otra agencia de marketing con Desarrollo Propio
                </h2>
                <p class="text-zinc-500 font-light text-sm sm:text-base leading-relaxed max-w-2xl mx-auto">
                    El marketing para restaurantes está lleno de fotos bonitas que no llenan mesas. Nosotros lo trabajamos con método, transparencia y resultados en reservas.
                </p>
            </div>

            <div class="reveal overflow-x-auto rounded-2xl shadow-[0_20px_60px_rgba(0,0,0,0.06)]">
                <table class="w-full min-w-[640px] text-left border-collapse bg-white">
                    <thead>
                        <tr class="bg-black text-white">
                            <th class="px-6 py-5 text-[11px] font-black uppercase tracking-widest">Criterio</th>
