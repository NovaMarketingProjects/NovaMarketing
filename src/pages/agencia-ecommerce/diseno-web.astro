---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { buildAlternates } from '../../lib/i18n';
import { localAgencySchema } from '../../lib/schema';
import { strapiClient } from '../../lib/strapi';
import LogoMarquee from '../../components/sections/LogoMarquee.astro';
import FaqHome from '../../components/sections/FaqHome.astro';
import CityPills from '../../components/global/CityPills.astro';
import GoogleReviews from '../../components/global/GoogleReviews.astro';

const SITE_URL = import.meta.env.PUBLIC_SITE_URL || 'https://novamarketing.es';
const alternates = buildAlternates('/agencia-ecommerce/diseno-web/', '/ca/agencia-ecommerce/diseno-web/', SITE_URL);

let allCases: any[] = [];
try {
  const casesRes = await strapiClient.getCaseStudies('es');
  allCases = casesRes.data.map((i: any) => i.attributes ?? i).filter((c: any) => {
    const cats = (c.categories || []).map((cat: any) => (cat.slug || cat.attributes?.slug || '').toLowerCase());
    return cats.some((s: string) => s === 'diseno-web' || s === 'e-commerce');
  });
} catch {}

const faqs = [
  { question: "¿Cuánto cuesta una web para una tienda online?", answer: "Una landing parte de 400 euros y una web a medida desde 120 euros al mes en 12 cuotas. El precio depende del tamaño y las funcionalidades. Antes de empezar recibes un presupuesto cerrado por escrito, sin permanencias." },
  { question: "¿La web incluye SEO?", answer: "Toda web que sale de nova incluye la base SEO de serie: arquitectura, velocidad, datos estructurados e indexación. Si después quieres competir por posiciones, nuestro SEO para ecommerce continúa desde esa base." },
  { question: "¿La web y el dominio serán míos?", answer: "Sí, siempre. El dominio se registra a tu nombre, los contenidos son tuyos y tienes acceso completo a todo. Si algún día dejas de trabajar con nosotros, te llevas tu web entera." },
  { question: "¿Con qué tecnología la hacéis?", answer: "La que más convenga a tu proyecto. Trabajamos Shopify, PrestaShop, WooCommerce según lo que necesites. La tecnología es un medio, el criterio es qué convierte mejor para tu negocio." },
  { question: "¿Cuánto se tarda?", answer: "Una web corporativa suele estar lista en 3 a 5 semanas contando desde que recibimos los contenidos. En el briefing inicial te damos un calendario con fechas concretas." },
  { question: "¿Qué pasa después del lanzamiento?", answer: "Tienes un periodo de ajustes incluido y después puedes contratar mantenimiento mensual o pedir cambios puntuales con presupuesto cerrado. Nunca te quedas solo con la web." },
  { question: "¿Trabajáis con permanencia?", answer: "No. Pagas por el trabajo entregado, en pago único o en 12 cuotas, sin permanencias ni cuotas ocultas. Nuestra permanencia real es que la web te genere clientes." },
];

const pageSchema = localAgencySchema({
  pageUrl: `${SITE_URL}/agencia-ecommerce/diseno-web/`,
  lang: 'es',
  cityName: 'Barcelona',
  postalCode: '08035',
  geo: { lat: 41.4114, lng: 2.1526 },
  areaServed: ["España", "Barcelona", "Sabadell", "Sant Cugat del Vallès", "Terrassa", "Vallès Occidental"],
  title: "▷ Diseño Web Ecommerce | Tiendas Online Rápidas y Optimizadas",
  description: "Diseño web ecommerce enfocado en velocidad, SEO y usabilidad para mejorar la experiencia de usuario ✅ Sistema integral que potencia la conversión.",
  datePublished: '2026-07-17',
  dateModified: '2026-07-17',
  streetAddress: 'Carrer del General Mendoza, 10',
  hasMap: 'https://maps.app.goo.gl/9fbB12UcK32bgjj89',
  aggregateRating: { ratingValue: '5.0', reviewCount: '12' },
  breadcrumbName: "Diseño Web para Ecommerce",
  faqs,
});
---

<BaseLayout
  title="▷ Diseño Web Ecommerce | Tiendas Online Rápidas y Optimizadas"
  description="Diseño web ecommerce enfocado en velocidad, SEO y usabilidad para mejorar la experiencia de usuario ✅ Sistema integral que potencia la conversión."
  locale="es"
  schemas={[pageSchema]}
  alternates={alternates}
>

    <!-- ═══ HERO / H1 ═══════════════════════════════════════════════════════ -->
    <section class="pt-24 sm:pt-40 pb-20 px-4 sm:px-6 relative overflow-hidden text-center bg-white border-b border-black/5">
        <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808008_1px,transparent_1px),linear-gradient(to_bottom,#80808008_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_40%,#000_75%,transparent_100%)]"></div>
        <div class="absolute -top-10 left-1/4 w-72 h-72 bg-accent/15 rounded-full blur-3xl opacity-30 animate-pulse"></div>
        <div class="absolute top-20 right-1/4 w-80 h-80 bg-purple-500/5 rounded-full blur-3xl opacity-20"></div>

        <div class="max-w-5xl mx-auto reveal">
            <span class="inline-flex items-center gap-2 bg-accent/5 backdrop-blur-sm px-4 py-2 border border-accent/10 rounded-full text-accent text-[8px] sm:text-[10px] font-black uppercase tracking-[0.3em] mb-8 shadow-sm">
                <span class="w-1.5 h-1.5 bg-accent rounded-full animate-ping"></span>
                Diseño Web para Ecommerce
            </span>
            <h1 class="text-3xl sm:text-5xl md:text-7xl lg:text-8xl uppercase font-extrabold tracking-tighter leading-[0.88] mb-8 text-gradient flex flex-col items-center text-center">
                <span class="lg:whitespace-nowrap">Diseño Web </span>
                <span class="lg:whitespace-nowrap text-mktg-gradient">para Ecommerce</span>
            </h1>
            <p class="text-lg sm:text-xl text-zinc-500 font-light leading-relaxed w-[75%] mx-auto mb-8">
                Tu web es tu mejor comercial o tu peor enemigo. Diseñamos webs para ecommerce rápidas, optimizadas para Google y pensadas para vender.
            </p>
            <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3 mb-10">
                {['Sin permanencias', 'Trato directo con el consultor', 'Resultados medidos en ventas'].map(item => (
                    <span class="inline-flex items-center gap-2 text-[11px] sm:text-xs font-black uppercase tracking-widest text-zinc-700">
                        <svg class="w-4 h-4 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                        {item}
                    </span>
                ))}
            </div>
            <div class="flex justify-center mt-4">
                <a href="#contacto" class="contact-modal-trigger btn-mktg-v5 shadow-[0_10px_30px_rgba(0,0,0,0.1)] !py-4 sm:!py-5 !px-6 sm:!px-10 !text-[11px] !tracking-widest font-black">
                    HABLEMOS DE TU TIENDA
                </a>
            </div>
        </div>
    </section>

    <LogoMarquee />

    <!-- ═══ INTRO ═══════════════════════════════════════════════════════ -->
    <section class="py-16 sm:py-24 bg-white px-4 sm:px-6 border-b border-black/5">
        <div class="max-w-6xl mx-auto reveal grid md:grid-cols-[1.3fr_1fr] gap-10 md:gap-16 items-center">
            <div>
                <p class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4">¿Por qué tu web importa?</p>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-8 text-zinc-900 leading-[0.9]">
                    La agencia de diseño web para tu tienda online
                </h2>
                <div class="space-y-6 text-zinc-600 font-light text-base sm:text-lg leading-relaxed">
                    <p>
                        <strong class="font-semibold text-zinc-900">Tu cliente entra en tu web antes de decidir</strong>. En segundos juzga si eres de fiar. Una web lenta o anticuada le manda directo a tu competencia.
                    </p>
                    <p>
                        Nova es una <strong class="font-semibold text-zinc-900">agencia de diseño web especializada en ecommerce</strong>. No hacemos webs bonitas, hacemos webs con un objetivo medible. <strong class="font-semibold text-zinc-900">Que cada visita tenga la máxima probabilidad de vender</strong>.
                    </p>
                </div>
            </div>
            <div class="hidden md:block">
                <img src="/sergio-galos-agencia-ecommerce-diseno-web.webp" alt="Sergio Galo's, consultor de diseño web para ecommerce" title="Sergio Galo's, consultor de diseño web para ecommerce" class="w-full h-auto" loading="lazy" width="473" height="591" />
            </div>
        </div>
    </section>

    <!-- ═══ SERVICIOS ══════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-zinc-50 px-4 sm:px-6 border-t border-b border-black/5">
        <div class="max-w-7xl mx-auto text-center reveal">
            <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Qué hacemos</span>
            <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.9]">
                Servicio de diseño web para Ecommerce
            </h2>
            <p class="text-zinc-500 font-light text-sm sm:text-base leading-relaxed max-w-3xl mx-auto mb-16">
                Una web que convierte no es solo diseño, es un sistema. Estas son las nueve piezas que trabajamos.
            </p>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 text-left">
                {[
                    { t: "Diseño de tienda a medida", d: "Una tienda que transmite confianza y guía al comprador del catálogo al carrito sin fricción." },
                    { t: "Fichas de producto que venden", d: "Fotos, argumentos, reseñas y llamadas a la acción trabajados para convertir la visita en pedido." },
                    { t: "Checkout optimizado", d: "Cada campo de más cuesta ventas. Un proceso de compra corto y claro recupera carritos cada día." },
                    { t: "Velocidad y Core Web Vitals", d: "Una tienda lenta pierde ventas y posiciones. Optimizamos el rendimiento real desde el móvil." },
                    { t: "SEO de serie", d: "Arquitectura de categorías, datos estructurados de producto e indexación pensados desde el primer boceto." },
                    { t: "Buscador y filtros", d: "Que el comprador encuentre lo que quiere en dos toques. Un buen buscador vende más que un banner." },
                    { t: "Migraciones de plataforma", d: "Cambios de tienda sin perder el posicionamiento ni los pedidos por el camino." },
                    { t: "Diseño responsive real", d: "La mayoría compra desde el móvil. Diseñamos ahí primero, no como un añadido." },
                    { t: "Mantenimiento y soporte", d: "Actualizaciones, seguridad y cambios sin esperas. Tu tienda siempre disponible y al día." },
                ].map((c) => (
                    <div class="bg-white border border-black/5 rounded-2xl p-6 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
                        <h3 class="text-sm font-black uppercase tracking-tight text-zinc-900 mb-3">
                            {c.href ? <a href={c.href} class="hover:text-accent transition-colors">{c.t}</a> : c.t}
                            {c.b && <span class="block text-[11px] uppercase tracking-[0.2em] text-accent mt-1 font-semibold">{c.b}</span>}
                        </h3>
                        <p class="text-sm text-zinc-500 font-light leading-relaxed mb-2">{c.d}</p>
                        {c.href && <a href={c.href} class="text-[11px] font-black tracking-widest text-accent hover:underline">SABER MÁS →</a>}
                    </div>
                ))}
            </div>
            <div class="mt-12 text-center reveal">
                <a href="#contacto" class="contact-modal-trigger btn-mktg-v5 shadow-[0_10px_30px_rgba(37,211,102,0.3)] !py-4 sm:!py-5 !px-6 sm:!px-10 !text-[11px] !tracking-widest font-black">HABLEMOS DE TU TIENDA</a>
            </div>
        </div>
    </section>

    <!-- ═══ ESTRATEGIA ════════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-white px-4 sm:px-6 relative overflow-hidden">
        <div class="max-w-5xl mx-auto">
            <div class="text-center mb-16 sm:mb-24 reveal">
                <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Cómo trabajamos</span>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.9]">
                    Así creamos la web que vende
                </h2>
                <p class="text-zinc-500 font-light text-sm sm:text-base leading-relaxed max-w-2xl mx-auto">
                    Una metodología documentada, paso a paso y sin humo.
                </p>
            </div>

            <div id="timeline-container" class="relative">
                <div class="hidden md:block absolute left-1/2 top-4 bottom-4 w-px bg-zinc-200 -translate-x-1/2"></div>
                <div id="progress-bar" class="hidden md:block absolute left-1/2 top-4 w-px bg-accent -translate-x-1/2 transition-all duration-100"></div>

                <div class="space-y-16 md:space-y-24 flex flex-col items-center">
                    {[
                        { title: "Briefing y Objetivos", desc: "Entendemos tu tienda online, tu cliente y qué tiene que conseguir la web antes de diseñar nada." },
                        { title: "Arquitectura y Contenidos", desc: "Definimos qué páginas necesitas y cómo se organizan, con las keywords de tu sector integradas de serie." },
                        { title: "Diseño y Desarrollo", desc: "Diseñamos una web que transmite confianza en tres segundos y la desarrollamos rápida y adaptada a móvil." },
                        { title: "SEO Técnico y Velocidad", desc: "Core Web Vitals en verde, datos estructurados e indexación correcta. Lo que otros venden como extra, aquí es el estándar." },
                        { title: "Lanzamiento y Mantenimiento", desc: "Publicamos, medimos y no desaparecemos. Analítica, seguridad, copias y soporte directo." },
                    ].map((step, index) => (
                        <div class="flex flex-col md:flex-row items-center gap-6 md:gap-12 w-full relative reveal">
                            <div class:list={["flex-1 w-full", index % 2 === 0 ? "md:order-1 md:text-right" : "md:order-3 md:text-left"]}>
                                <div class="p-8 sm:p-10 bg-zinc-50 border border-black/5 rounded-3xl hover:border-accent/10 hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 relative overflow-hidden group">
                                    <h3 class="text-xl font-black uppercase tracking-tighter mb-2 text-zinc-900">{index + 1}. {step.title}</h3>
                                    <div class:list={["h-0.5 bg-accent w-full mb-4 opacity-80", index % 2 === 0 ? "md:ml-auto" : ""]}></div>
                                    <p class:list={["text-sm text-zinc-500 font-light max-w-md", index % 2 === 0 ? "md:ml-auto" : ""]}>{step.desc}</p>
                                    <div class="absolute -bottom-6 -right-5 text-8xl font-black text-black/[0.02] select-none z-0 group-hover:scale-105 transition-transform duration-500">0{index+1}</div>
                                </div>
                            </div>
                            <div class="md:order-2 w-12 h-12 rounded-full border-2 border-zinc-200 bg-white flex items-center justify-center font-black text-lg z-10 shrink-0 shadow-sm node-circle transition-all">
                                0{index + 1}
                            </div>
                            <div class:list={["hidden md:block md:flex-1", index % 2 === 0 ? "md:order-3" : "md:order-1"]}></div>
                        </div>
                    ))}
                </div>
            </div>
        </div>
    </section>

    <!-- ═══ AUDITORÍA ═════════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-zinc-50/50 px-4 sm:px-6 border-t border-black/5 overflow-hidden">
        <div class="max-w-7xl mx-auto grid lg:grid-cols-[6fr_4fr] gap-12 lg:gap-16 items-start">
            <div class="reveal lg:col-span-2">
                <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Punto de partida</span>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase text-zinc-900 leading-[0.9]">Auditoría web gratuita para tu tienda online</h2>
            </div>
            <div class="reveal">
                <div class="space-y-5 text-zinc-600 font-light text-base leading-relaxed mb-8">
                    <p>¿Sabes cuántos segundos tarda tu web en cargar desde un móvil? ¿Cuántas visitas acaban en ventas? Casi nadie lo sabe con datos, y ahí empieza todo.</p>
                    <p>Nuestra <strong class="font-semibold text-zinc-900">auditoría web gratuita</strong> revisa tu página actual con ojos de cliente y de consultor. Velocidad, diseño, textos, SEO y conversión, y termina con un diagnóstico claro.</p>
                    <p>A diferencia de los análisis automáticos, aquí cada punto lo revisa un consultor senior. El resultado es un diagnóstico de negocio, no un listado técnico.</p>
                </div>
                <ul class="space-y-3">
                    {["Velocidad de carga desde el móvil","Primera impresión y confianza que transmite","Textos y llamadas a la acción","Salud SEO e indexación en Google","Puntos de fuga en el camino a la conversión","Diagnóstico priorizado por impacto"].map(item => (
                        <li class="flex items-start gap-3 text-sm text-zinc-700 font-light"><svg class="w-4 h-4 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>{item}</li>
                    ))}
                </ul>
                <div class="mt-16">
                    <a href="#contacto" class="contact-modal-trigger btn-mktg-v5 shadow-[0_10px_30px_rgba(37,211,102,0.3)] !py-4 sm:!py-5 !px-6 sm:!px-10 !text-[11px] !tracking-widest font-black">QUIERO MI AUDITORÍA WEB GRATIS</a>
                </div>
            </div>
            <div class="reveal flex flex-col gap-4">
                {[
                    { bg: 'bg-purple-100', color: 'text-purple-600', t: "Test de velocidad real", d: "Cuánto tarda tu web desde un móvil con conexión normal, que es como llega tu cliente." },
                    { bg: 'bg-green-100', color: 'text-green-600', t: "Revisión con ojos de cliente", d: "Qué entiende en tres segundos, qué le genera dudas y por qué se va sin convertir." },
                    { bg: 'bg-purple-100', color: 'text-purple-600', t: "Salud SEO de tu web", d: "Si Google entiende tu página y qué visibilidad estás dejando escapar." },
                    { bg: 'bg-amber-100', color: 'text-amber-600', t: "Análisis de conversión", d: "Dónde pierde clientes tu web y qué cambio tendría más impacto." },
                    { bg: 'bg-blue-100', color: 'text-blue-600', t: "Comparativa con tu competencia", d: "Tu web al lado de tus tres competidores directos. Dónde está la oportunidad." },
                ].map(card => (
                    <div class="bg-white rounded-2xl shadow-[0_15px_40px_rgba(0,0,0,0.08)] p-5 flex items-start gap-4">
                        <div class:list={["w-11 h-11 rounded-full flex items-center justify-center flex-shrink-0", card.bg]}>
                            <svg class:list={["w-5 h-5", card.color]} fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                        </div>
                        <div>
                            <h3 class="text-sm font-black text-zinc-900 mb-1">{card.t}</h3>
                            <p class="text-xs text-zinc-500 font-light leading-relaxed">{card.d}</p>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- ═══ QUÉ INCLUYE LA AUDITORÍA ═══════════════════════════ -->
    <section class="py-20 sm:py-28 bg-white px-4 sm:px-6 border-t border-black/5">
        <div class="max-w-7xl mx-auto">
            <div class="text-center mb-12 sm:mb-16 reveal">
                <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Paso a paso</span>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase text-zinc-900 leading-[0.9]">Qué incluye la auditoría web de nova</h2>
            </div>
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 items-stretch reveal">
                {[
                    { n: '1', t: "Radiografía de tu web actual", d: "Velocidad, diseño, contenidos y SEO tal y como los ve hoy tu cliente y Google." },
                    { n: '2', t: "Diagnóstico de conversión", d: "Dónde y por qué tu web pierde clientes, cruzando datos con el recorrido real del usuario." },
                    { n: '3', t: "Hoja de ruta con presupuesto", d: "Un diagnóstico claro, la propuesta que más te conviene y un presupuesto cerrado. Sin compromiso." },
                ].map((st, i) => (
                    <div class="flex items-center gap-4 lg:gap-6">
                        {i > 0 && <div class="hidden lg:flex text-3xl text-accent font-black select-none">→</div>}
                        <div class="bg-white border border-black/5 rounded-2xl p-8 shadow-[0_15px_40px_rgba(0,0,0,0.06)] flex-1 text-center h-full">
                            <div class="w-12 h-12 rounded-full bg-accent/10 border border-accent/20 flex items-center justify-center mx-auto mb-4 text-accent font-black text-lg">{st.n}</div>
                            <h3 class="text-base font-black uppercase tracking-tight text-zinc-900 mb-3">{st.t}</h3>
                            <p class="text-sm text-zinc-500 font-light leading-relaxed">{st.d}</p>
                        </div>
                    </div>
                ))}
            </div>
            <p class="text-zinc-500 font-light text-sm sm:text-base leading-relaxed max-w-3xl mx-auto text-center mt-16 reveal">Nuestra auditoría web es el primer paso de cualquier proyecto de diseño o rediseño. Es gratuita y sin compromiso, porque preferimos que decidas con datos y no con promesas.</p>
            <div class="mt-12 text-center reveal">
                <a href="#contacto" class="contact-modal-trigger btn-mktg-v5 shadow-[0_10px_30px_rgba(37,211,102,0.3)] !py-4 sm:!py-5 !px-6 sm:!px-10 !text-[11px] !tracking-widest font-black">QUIERO MI AUDITORÍA WEB GRATIS</a>
            </div>
        </div>
    </section>

    <!-- ═══ PRECIOS ════════════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-zinc-50/50 px-4 sm:px-6 border-t border-black/5">
        <div class="max-w-7xl mx-auto">
            <div class="text-center mb-12 sm:mb-16 reveal">
                <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Tarifas claras</span>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.9]">Precios de diseño web para Ecommerce</h2>
                <p class="text-zinc-500 font-light text-sm sm:text-base leading-relaxed max-w-3xl mx-auto">Tarifas orientativas y sin letra pequeña. El precio depende del tamaño de la web y las funcionalidades que necesites, así que antes de empezar recibes un presupuesto cerrado por escrito. El coste no lleva sorpresas ni permanencias.</p>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-stretch">
                {[
