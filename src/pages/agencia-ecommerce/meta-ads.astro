---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { buildAlternates } from '../../lib/i18n';
import { localAgencySchema } from '../../lib/schema';
import { strapiClient } from '../../lib/strapi';
import LogoMarquee from '../../components/sections/LogoMarquee.astro';
import FaqHome from '../../components/sections/FaqHome.astro';
import CityPills from '../../components/global/CityPills.astro';
import GoogleReviews from '../../components/global/GoogleReviews.astro';

const SITE_URL = import.meta.env.PUBLIC_SITE_URL || 'https://novamarketing.es';
const alternates = buildAlternates('/agencia-ecommerce/meta-ads/', '/ca/agencia-ecommerce/meta-ads/', SITE_URL);

let allCases: any[] = [];
try {
  const casesRes = await strapiClient.getCaseStudies('es');
  allCases = casesRes.data.map((i: any) => i.attributes ?? i).filter((c: any) => {
    const cats = (c.categories || []).map((cat: any) => (cat.slug || cat.attributes?.slug || '').toLowerCase());
    return cats.some((s: string) => s === 'e-commerce' || s === 'marketing-digital');
  });
} catch {}

const faqs = [
  { question: "¿Qué incluye la gestión de Meta Ads para un ecommerce?", answer: "Incluye auditoría inicial, estrategia de embudo documentada y gestión semanal. Campañas de prospección y remarketing, catálogo conectado, producción y testing de creativos, píxel y API de conversiones bien configurados y un informe mensual con ventas, ROAS y margen." },
  { question: "¿Cuánto cuesta una agencia de Meta Ads?", answer: "La auditoría de tu cuenta cuesta 900 euros y la gestión mensual empieza en 150 euros al mes con fee fijo, sin porcentajes sobre tu inversión. A eso se suma tu presupuesto publicitario, que va íntegro a Meta. Presupuesto cerrado por escrito." },
  { question: "¿Cuánto presupuesto necesita mi tienda en Meta?", answer: "Como regla general, recomendamos partir de entre 500 y 1.000 euros al mes para que el algoritmo tenga datos de compra suficientes para optimizar. En la auditoría te damos la cifra concreta para tu caso y tu ticket medio." },
  { question: "¿Quién produce los creativos?", answer: "Nosotros, contigo. Definimos los ángulos de venta, producimos las piezas a partir de tu producto y tus materiales, y las renovamos según el testing. Si tienes equipo creativo propio, nos coordinamos con él." },
  { question: "¿Funciona Meta Ads para cualquier producto?", answer: "Funciona especialmente bien con producto visual y ticket de compra por impulso o consideración corta. Para productos muy técnicos o de búsqueda activa, solemos combinarlo con Google. La auditoría te dice qué mezcla conviene a tu tienda." },
  { question: "¿Cómo medís los resultados?", answer: "En ventas, ROAS y margen. Píxel y API de conversiones configurados desde el primer día para que cada compra quede atribuida con su valor real. Los datos y las cuentas son siempre tuyos." },
  { question: "¿Trabajáis con permanencia?", answer: "No, trabajamos mes a mes. Si el servicio no te aporta valor, puedes cancelarlo cuando quieras. Nuestra permanencia real es el resultado que ves en los informes cada mes." },
];

const pageSchema = localAgencySchema({
  pageUrl: `${SITE_URL}/agencia-ecommerce/meta-ads/`,
  lang: 'es',
  cityName: 'Barcelona',
  postalCode: '08035',
  geo: { lat: 41.4114, lng: 2.1526 },
  areaServed: ["España", "Barcelona", "Sabadell", "Sant Cugat del Vallès", "Terrassa", "Vallès Occidental"],
  title: "▷ Meta Ads para Ecommerce | Facebook e Instagram Ads",
  description: "Campañas de Meta Ads para ecommerce con creativos y catálogos conectados 💡 Resultados medidos en ROAS ✅ en Facebook e Instagram",
  datePublished: '2026-07-17',
  dateModified: '2026-07-17',
  streetAddress: 'Carrer del General Mendoza, 10',
  hasMap: 'https://maps.app.goo.gl/9fbB12UcK32bgjj89',
  aggregateRating: { ratingValue: '5.0', reviewCount: '8' },
  breadcrumbName: "Agencia Meta Ads para Ecommerce",
  faqs,
});
---

<BaseLayout
  title="▷ Meta Ads para Ecommerce | Facebook e Instagram Ads"
  description="Campañas de Meta Ads para ecommerce con creativos y catálogos conectados 💡 Resultados medidos en ROAS ✅ en Facebook e Instagram"
  locale="es"
  alternates={alternates}
  schemas={[pageSchema]}
>

    <!-- ═══ HERO / H1 ═══════════════════════════════════════════════════════ -->
    <section class="pt-24 sm:pt-40 pb-20 px-4 sm:px-6 relative overflow-hidden text-center bg-white border-b border-black/5">
        <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808008_1px,transparent_1px),linear-gradient(to_bottom,#80808008_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_40%,#000_75%,transparent_100%)]"></div>
        <div class="absolute -top-10 left-1/4 w-72 h-72 bg-accent/15 rounded-full blur-3xl opacity-30 animate-pulse"></div>
        <div class="absolute top-20 right-1/4 w-80 h-80 bg-purple-500/5 rounded-full blur-3xl opacity-20"></div>

        <div class="max-w-5xl mx-auto reveal">
            <span class="inline-flex items-center gap-2 bg-accent/5 backdrop-blur-sm px-4 py-2 border border-accent/10 rounded-full text-accent text-[8px] sm:text-[10px] font-black uppercase tracking-[0.3em] mb-8 shadow-sm">
                <span class="w-1.5 h-1.5 bg-accent rounded-full animate-ping"></span>
                Publicidad en Instagram y Facebook
            </span>
            <h1 class="text-3xl sm:text-5xl md:text-7xl lg:text-8xl uppercase font-extrabold tracking-tighter leading-[0.88] mb-8 text-gradient flex flex-col items-center text-center">
                <span class="lg:whitespace-nowrap">Agencia Meta Ads </span>
                <span class="lg:whitespace-nowrap text-mktg-gradient">para Ecommerce</span>
            </h1>
            <p class="text-lg sm:text-xl text-zinc-500 font-light leading-relaxed w-[75%] mx-auto mb-8">
                Tu producto en el feed de quien todavía no sabe que lo quiere. Campañas de Instagram y Facebook para tiendas online con creativos que venden y resultados medidos en ROAS.
            </p>
            <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3 mb-10">
                {['Sin permanencias', 'Trato directo con el consultor', 'Resultados medidos en ventas'].map(item => (
                    <span class="inline-flex items-center gap-2 text-[11px] sm:text-xs font-black uppercase tracking-widest text-zinc-700">
                        <svg class="w-4 h-4 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                        {item}
                    </span>
                ))}
            </div>
            <div class="flex justify-center mt-4">
                <a href="#contacto" class="contact-modal-trigger btn-mktg-v5 shadow-[0_10px_30px_rgba(0,0,0,0.1)] !py-4 sm:!py-5 !px-6 sm:!px-10 !text-[11px] !tracking-widest font-black">
                    HABLEMOS DE TU TIENDA
                </a>
            </div>
        </div>
    </section>

    <LogoMarquee />

    <!-- ═══ INTRO ═══════════════════════════════════════════════════════ -->
    <section class="py-16 sm:py-24 bg-white px-4 sm:px-6 border-b border-black/5">
        <div class="max-w-6xl mx-auto reveal grid md:grid-cols-[1.3fr_1fr] gap-10 md:gap-16 items-center">
            <div>
                <p class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4">¿Por qué Meta Ads?</p>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-8 text-zinc-900 leading-[0.9]">
                    La agencia de Meta Ads para tu tienda online
                </h2>
                <div class="space-y-6 text-zinc-600 font-light text-base sm:text-lg leading-relaxed">
                    <p>
                        <strong class="font-semibold text-zinc-900">En Google te compran quienes ya te buscan. En Meta descubres a quienes aún no saben que te necesitan</strong>. Instagram y Facebook son la máquina de demanda de un ecommerce, y el creativo es el 80% del resultado.
                    </p>
                    <p>
                        Nova es una <strong class="font-semibold text-zinc-900">agencia de Meta Ads especializada en ecommerce</strong>. Creativos que paran el scroll, catálogo conectado y una sola métrica que importa. <strong class="font-semibold text-zinc-900">Cuánto vende cada campaña y con qué margen</strong>.
                    </p>
                </div>
            </div>
            <div class="hidden md:block">
                <img src="/sergio-galos-agencia-ecommerce-meta-ads.webp" alt="Sergio Galo's, Consultor de Meta Ads para ecommerce" title="Sergio Galo's, Consultor de Meta Ads para ecommerce" class="w-full h-auto" loading="lazy" width="473" height="591" />
            </div>
        </div>
    </section>

    <!-- ═══ SERVICIOS ══════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-zinc-50 px-4 sm:px-6 border-t border-b border-black/5">
        <div class="max-w-7xl mx-auto text-center reveal">
            <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Qué hacemos</span>
            <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.9]">
                Servicio de Meta Ads para ecommerce
            </h2>
            <p class="text-zinc-500 font-light text-sm sm:text-base leading-relaxed max-w-3xl mx-auto mb-16">
                Vender en Instagram y Facebook no es hacer boost a publicaciones, es un sistema. Estas son las nueve piezas que trabajamos para que cada euro vuelva convertido en pedidos.
            </p>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 text-left">
                {[
                    { t: "Auditoría de la cuenta", d: "Radiografía de tus campañas, tus creativos y tu píxel antes de tocar nada. Dónde se pierde presupuesto y por qué." },
                    { t: "Estrategia de embudo", d: "Prospección para descubrir, remarketing para cerrar y recompra para repetir. Cada fase con su campaña y su mensaje." },
                    { t: "Creativos que venden", d: "El creativo es el 80% del resultado en Meta. Producimos y testamos imágenes y vídeos que paran el scroll y venden." },
                    { t: "Catálogo conectado", d: "Tu catálogo sincronizado con Meta para anuncios dinámicos que muestran el producto exacto que interesa a cada usuario." },
                    { t: "Remarketing dinámico", d: "Quien vio tu producto y no compró vuelve a verlo en su feed. Los pedidos más baratos están en la segunda visita." },
                    { t: "Segmentación y audiencias", d: "Audiencias amplias bien alimentadas con eventos de compra. Al algoritmo se le guía con datos, no con microsegmentos." },
                    { t: "Medición y API de conversiones", d: "Píxel y API de conversiones bien configurados para que Meta optimice con datos reales de compra." },
                    { t: "Testing continuo", d: "Cada semana se testan ángulos, creativos y ofertas. Lo que funciona escala, lo que no se corta sin piedad." },
                    { t: "Meta más Google", d: "Meta genera la demanda y Google la captura. Coordinamos ambos canales para que el presupuesto rinda más." },
                ].map((c: any) => (
                    <div class="bg-white border border-black/5 rounded-2xl p-6 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
                        <h3 class="text-sm font-black uppercase tracking-tight text-zinc-900 mb-3">
                            {c.t}
                            {c.b && <span class="block text-[11px] uppercase tracking-[0.2em] text-accent mt-1 font-semibold">{c.b}</span>}
                        </h3>
                        <p class="text-sm text-zinc-500 font-light leading-relaxed">{c.d}</p>
                    </div>
                ))}
            </div>
            <div class="mt-12 text-center reveal">
                <a href="#contacto" class="contact-modal-trigger btn-mktg-v5 shadow-[0_10px_30px_rgba(37,211,102,0.3)] !py-4 sm:!py-5 !px-6 sm:!px-10 !text-[11px] !tracking-widest font-black">HABLEMOS DE TU TIENDA</a>
            </div>
        </div>
    </section>

    <!-- ═══ ESTRATEGIA ════════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-white px-4 sm:px-6 relative overflow-hidden">
        <div class="max-w-5xl mx-auto">
            <div class="text-center mb-16 sm:mb-24 reveal">
                <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Cómo trabajamos</span>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.9]">
                    Estrategia de Meta Ads para tu ecommerce
                </h2>
                <p class="text-zinc-500 font-light text-sm sm:text-base leading-relaxed max-w-2xl mx-auto">
                    Una metodología documentada, paso a paso y sin humo.
                </p>
            </div>

            <div id="timeline-container" class="relative">
                <div class="hidden md:block absolute left-1/2 top-4 bottom-4 w-px bg-zinc-200 -translate-x-1/2"></div>
                <div id="progress-bar" class="hidden md:block absolute left-1/2 top-4 w-px bg-accent -translate-x-1/2 transition-all duration-100"></div>

                <div class="space-y-16 md:space-y-24 flex flex-col items-center">
                    {[
                        { title: "Auditoría de Cuenta y Píxel", desc: "Analizamos tus campañas, tus creativos y tu medición. Detectamos presupuesto desperdiciado, audiencias quemadas y eventos mal configurados." },
                        { title: "Estrategia de Embudo Documentada", desc: "Recibes un plan por escrito. Qué campañas lanzar en cada fase, qué creativos producir, qué presupuesto necesitas y qué ROAS es razonable." },
                        { title: "Creativos, Catálogo y Campañas", desc: "Producimos los creativos, conectamos el catálogo y montamos el embudo completo, de la prospección al remarketing dinámico." },
                        { title: "Testing y Optimización", desc: "Testamos ángulos y creativos cada semana. Escalamos lo que vende, cortamos lo que no y renovamos creativos antes de que se quemen." },
                        { title: "Medición y Escalado", desc: "Monitorizamos ventas, ROAS y margen por campaña. En el informe ves qué funciona, qué se corta y dónde va el presupuesto el mes siguiente." },
                    ].map((step, index) => (
                        <div class="flex flex-col md:flex-row items-center gap-6 md:gap-12 w-full relative reveal">
                            <div class:list={["flex-1 w-full", index % 2 === 0 ? "md:order-1 md:text-right" : "md:order-3 md:text-left"]}>
                                <div class="p-8 sm:p-10 bg-zinc-50 border border-black/5 rounded-3xl hover:border-accent/10 hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 relative overflow-hidden group">
                                    <h3 class="text-xl font-black uppercase tracking-tighter mb-2 text-zinc-900">{index + 1}. {step.title}</h3>
                                    <div class:list={["h-0.5 bg-accent w-full mb-4 opacity-80", index % 2 === 0 ? "md:ml-auto" : ""]}></div>
                                    <p class:list={["text-sm text-zinc-500 font-light max-w-md", index % 2 === 0 ? "md:ml-auto" : ""]}>{step.desc}</p>
                                    <div class="absolute -bottom-6 -right-5 text-8xl font-black text-black/[0.02] select-none z-0 group-hover:scale-105 transition-transform duration-500">0{index+1}</div>
                                </div>
                            </div>
                            <div class="md:order-2 w-12 h-12 rounded-full border-2 border-zinc-200 bg-white flex items-center justify-center font-black text-lg z-10 shrink-0 shadow-sm node-circle transition-all">
                                0{index + 1}
                            </div>
                            <div class:list={["hidden md:block md:flex-1", index % 2 === 0 ? "md:order-3" : "md:order-1"]}></div>
                        </div>
                    ))}
                </div>
            </div>
        </div>
    </section>

    <!-- ═══ AUDITORÍA ═════════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-zinc-50/50 px-4 sm:px-6 border-t border-black/5 overflow-hidden">
        <div class="max-w-7xl mx-auto grid lg:grid-cols-[6fr_4fr] gap-12 lg:gap-16 items-start">
            <div class="reveal lg:col-span-2">
                <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Punto de partida</span>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase text-zinc-900 leading-[0.9]">
                    Auditoría de Meta Ads para tu ecommerce
                </h2>
            </div>
            <div class="reveal">
                <div class="space-y-5 text-zinc-600 font-light text-base leading-relaxed mb-8">
                    <p>¿Sabes qué creativos te venden y cuáles solo consumen presupuesto? ¿Tu píxel registra las compras de verdad o Meta optimiza a ciegas? Casi ninguna tienda lo sabe con datos, y ahí empieza todo.</p>
                    <p>Nuestra <strong class="font-semibold text-zinc-900">auditoría de Meta Ads para ecommerce</strong> revisa tus campañas, tus creativos y tu medición, y termina con un plan de acción priorizado por ahorro e impacto en ventas.</p>
                    <p>Cada punto lo revisa un consultor senior con experiencia en tiendas online. El resultado es un diagnóstico de negocio que entiende cualquier gerente.</p>
                    <p>Si ya trabajas con otra agencia, la auditoría sirve como segunda opinión independiente antes de seguir invirtiendo.</p>
                </div>
                <ul class="space-y-3">
                    {["Estructura del embudo y las campañas","Salud del píxel y la API de conversiones","Rendimiento real de cada creativo","Audiencias quemadas o mal construidas","Catálogo y anuncios dinámicos","Plan de acción priorizado por ahorro"].map(item => (
                        <li class="flex items-start gap-3 text-sm text-zinc-700 font-light">
                            <svg class="w-4 h-4 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                            {item}
                        </li>
                    ))}
                </ul>
                <div class="mt-16">
                    <a href="#contacto" class="contact-modal-trigger btn-mktg-v5 shadow-[0_10px_30px_rgba(37,211,102,0.3)] !py-4 sm:!py-5 !px-6 sm:!px-10 !text-[11px] !tracking-widest font-black">
                        QUIERO MI AUDITORÍA DE META ADS
                    </a>
                </div>
            </div>
            <div class="reveal flex flex-col gap-4">
                {[
                    { bg: 'bg-purple-100', color: 'text-purple-600', t: "Revisión completa de la cuenta", d: "Campañas, conjuntos, pujas y configuración. Todo lo que encarece tus ventas, documentado." },
                    { bg: 'bg-green-100', color: 'text-green-600', t: "Plan de acción priorizado", d: "Un plan ordenado por ahorro e impacto. Sabrás qué cortar la primera semana y dónde reinvertir." },
                    { bg: 'bg-purple-100', color: 'text-purple-600', t: "Auditoría de creativos", d: "Qué ángulos y formatos venden y cuáles queman presupuesto. El creativo es el 80% del resultado." },
                    { bg: 'bg-amber-100', color: 'text-amber-600', t: "Medición y píxel", d: "Revisamos eventos, API de conversiones y valores de compra. Si Meta no ve las ventas, optimiza a ciegas." },
                    { bg: 'bg-blue-100', color: 'text-blue-600', t: "Benchmark de tu sector", d: "Comparamos tus anuncios con los de tus tres competidores directos en la biblioteca de anuncios." },
                ].map(card => (
                    <div class="bg-white rounded-2xl shadow-[0_15px_40px_rgba(0,0,0,0.08)] p-5 flex items-start gap-4">
                        <div class:list={["w-11 h-11 rounded-full flex items-center justify-center flex-shrink-0", card.bg]}>
                            <svg class:list={["w-5 h-5", card.color]} fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                        </div>
                        <div>
                            <h3 class="text-sm font-black text-zinc-900 mb-1">{card.t}</h3>
                            <p class="text-xs text-zinc-500 font-light leading-relaxed">{card.d}</p>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- ═══ QUÉ INCLUYE LA AUDITORÍA ═══════════════════════════ -->
    <section class="py-20 sm:py-28 bg-white px-4 sm:px-6 border-t border-black/5">
        <div class="max-w-7xl mx-auto">
            <div class="text-center mb-12 sm:mb-16 reveal">
                <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Paso a paso</span>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase text-zinc-900 leading-[0.9]">
                    Qué incluye la auditoría Meta Ads de nova
                </h2>
            </div>
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 items-stretch reveal">
                {[
                    { n: '1', t: "Radiografía de tu inversión", d: "Analizamos cuánto inviertes, qué campañas traen pedidos, a qué coste y qué parte del presupuesto se pierde." },
                    { n: '2', t: "Diagnóstico de creativos y embudo", d: "Cruzamos los datos con tus creativos y tu embudo para explicar qué encarece cada venta." },
                    { n: '3', t: "Hoja de ruta para rentabilizar", d: "Cierras la auditoría con acciones ordenadas por ahorro e impacto y una videollamada donde lo repasamos contigo." },
                ].map((st, i) => (
                    <div class="flex items-center gap-4 lg:gap-6">
                        {i > 0 && <div class="hidden lg:flex text-3xl text-accent font-black select-none">→</div>}
                        <div class="bg-white border border-black/5 rounded-2xl p-8 shadow-[0_15px_40px_rgba(0,0,0,0.06)] flex-1 text-center h-full">
                            <div class="w-12 h-12 rounded-full bg-accent/10 border border-accent/20 flex items-center justify-center mx-auto mb-4 text-accent font-black text-lg">{st.n}</div>
                            <h3 class="text-base font-black uppercase tracking-tight text-zinc-900 mb-3">{st.t}</h3>
                            <p class="text-sm text-zinc-500 font-light leading-relaxed">{st.d}</p>
                        </div>
                    </div>
                ))}
            </div>
            <p class="text-zinc-500 font-light text-sm sm:text-base leading-relaxed max-w-3xl mx-auto text-center mt-16 reveal">
                Nuestra auditoría de Meta Ads es el primer paso de cualquier estrategia de publicidad en redes para ecommerce. Analiza cómo trabaja hoy tu presupuesto, explica por qué tu competencia vende más barato y te deja una hoja de ruta clara. También puedes contratarla suelta como segunda opinión.
            </p>
            <div class="mt-12 text-center reveal">
                <a href="#contacto" class="contact-modal-trigger btn-mktg-v5 shadow-[0_10px_30px_rgba(37,211,102,0.3)] !py-4 sm:!py-5 !px-6 sm:!px-10 !text-[11px] !tracking-widest font-black">QUIERO MI AUDITORÍA DE META ADS</a>
            </div>
        </div>
    </section>

    <!-- ═══ PRECIOS ════════════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-zinc-50/50 px-4 sm:px-6 border-t border-black/5">
        <div class="max-w-7xl mx-auto">
            <div class="text-center mb-12 sm:mb-16 reveal">
                <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Tarifas claras</span>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.9]">
                    Precios de Meta Ads para ecommerce
