---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { buildAlternates } from '../../lib/i18n';
import { localAgencySchema } from '../../lib/schema';
import { strapiClient } from '../../lib/strapi';
import LogoMarquee from '../../components/sections/LogoMarquee.astro';
import FaqHome from '../../components/sections/FaqHome.astro';
import CityPills from '../../components/global/CityPills.astro';
import GoogleReviews from '../../components/global/GoogleReviews.astro';

const SITE_URL = import.meta.env.PUBLIC_SITE_URL || 'https://novamarketing.es';
const alternates = buildAlternates('/agencia-ecommerce/seo/', '/ca/agencia-ecommerce/seo/', SITE_URL);

let allCases: any[] = [];
try {
  const casesRes = await strapiClient.getCaseStudies('es');
  allCases = casesRes.data.map((i: any) => i.attributes ?? i).filter((c: any) => {
    const cats = (c.categories || []).map((cat: any) => (cat.slug || cat.attributes?.slug || '').toLowerCase());
    return cats.some((s: string) => s.includes('seo') || s === 'e-commerce');
  });
} catch {}

const faqs = [
  { question: "¿Qué incluye el SEO para un ecommerce?", answer: "Incluye auditoría inicial, estrategia documentada y ejecución mensual. Optimización técnica de la tienda, keyword research de producto, arquitectura de categorías, fichas optimizadas, contenidos, link building y un informe mensual con posiciones, tráfico y ventas orgánicas." },
  { question: "¿Cuánto cuesta el SEO para una tienda online?", answer: "La auditoría SEO cuesta 1.800 euros y los planes mensuales van desde 400 euros al mes para tiendas pequeñas y medianas y desde 900 para catálogos grandes o sectores muy competidos. Presupuesto cerrado por escrito y sin permanencias." },
  { question: "¿Cuánto tarda el SEO en un ecommerce?", answer: "Los primeros movimientos suelen verse entre el segundo y el tercer mes, y los resultados consolidados entre el sexto y el duodécimo. El plazo depende de tu punto de partida y de la competencia de tu sector. En la hoja de ruta te decimos qué esperar en cada fase." },
  { question: "¿Optimizáis las fichas de producto una a una?", answer: "Las más importantes sí, y para el resto del catálogo creamos reglas y plantillas optimizadas que escalan a miles de productos. La prioridad la marcan el margen y la demanda de cada producto." },
  { question: "¿El SEO funciona con catálogos que cambian mucho?", answer: "Sí, con la estrategia adecuada. La autoridad se concentra en categorías estables y las fichas heredan ese posicionamiento aunque roten. Así el SEO sobrevive a cambios de temporada y de stock." },
  { question: "¿Cómo medís los resultados?", answer: "En ventas orgánicas, no solo en posiciones. Cada pedido queda atribuido a su canal y en el informe mensual ves cuántas ventas llegan desde Google y qué keywords las traen. Los datos son siempre tuyos." },
  { question: "¿Trabajáis con permanencia?", answer: "No, trabajamos mes a mes. Si el servicio no te aporta valor, puedes cancelarlo cuando quieras. Nuestra permanencia real es el resultado que ves en los informes cada mes." },
];

const pageSchema = localAgencySchema({
  pageUrl: `${SITE_URL}/agencia-ecommerce/seo/`,
  lang: 'es',
  cityName: 'Barcelona',
  postalCode: '08035',
  geo: { lat: 41.4114, lng: 2.1526 },
  areaServed: ["España", "Barcelona", "Sabadell", "Sant Cugat del Vallès", "Terrassa", "Vallès Occidental"],
  title: "▷ SEO para Ecommerce | Posicionamiento en tiendas online",
  description: "SEO para ecommerce: optimización de arquitectura y fichas de producto ⭐ contenido alineado con búsquedas de compra ✅ Más información",
  datePublished: '2026-07-17',
  dateModified: '2026-07-17',
  streetAddress: 'Carrer del General Mendoza, 10',
  hasMap: 'https://maps.app.goo.gl/9fbB12UcK32bgjj89',
  aggregateRating: { ratingValue: '5.0', reviewCount: '8' },
  breadcrumbName: "Agencia SEO para Ecommerce",
  faqs,
});
---

<BaseLayout
  title="▷ SEO para Ecommerce | Posicionamiento en tiendas online"
  description="SEO para ecommerce: optimización de arquitectura y fichas de producto ⭐ contenido alineado con búsquedas de compra ✅ Más información"
  locale="es"
  alternates={alternates}
  schemas={[pageSchema]}
>

    <!-- ═══ HERO / H1 ═══════════════════════════════════════════════════════ -->
    <section class="pt-24 sm:pt-40 pb-20 px-4 sm:px-6 relative overflow-hidden text-center bg-white border-b border-black/5">
        <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808008_1px,transparent_1px),linear-gradient(to_bottom,#80808008_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_40%,#000_75%,transparent_100%)]"></div>
        <div class="absolute -top-10 left-1/4 w-72 h-72 bg-accent/15 rounded-full blur-3xl opacity-30 animate-pulse"></div>
        <div class="absolute top-20 right-1/4 w-80 h-80 bg-purple-500/5 rounded-full blur-3xl opacity-20"></div>

        <div class="max-w-5xl mx-auto reveal">
            <span class="inline-flex items-center gap-2 bg-accent/5 backdrop-blur-sm px-4 py-2 border border-accent/10 rounded-full text-accent text-[8px] sm:text-[10px] font-black uppercase tracking-[0.3em] mb-8 shadow-sm">
                <span class="w-1.5 h-1.5 bg-accent rounded-full animate-ping"></span>
                Posicionamiento SEO para Tiendas Online
            </span>
            <h1 class="text-3xl sm:text-5xl md:text-7xl lg:text-8xl uppercase font-extrabold tracking-tighter leading-[0.88] mb-8 text-gradient flex flex-col items-center text-center">
                <span class="lg:whitespace-nowrap">Agencia SEO </span>
                <span class="lg:whitespace-nowrap text-mktg-gradient">para Ecommerce</span>
            </h1>
            <p class="text-lg sm:text-xl text-zinc-500 font-light leading-relaxed w-[75%] mx-auto mb-8">
                Aparece cuando tus clientes buscan tu producto en Google. Posicionamiento SEO para tiendas online con estrategia a medida y resultados que se miden en ventas.
            </p>
            <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3 mb-10">
                {['Sin permanencias', 'Trato directo con el consultor', 'Resultados medidos en ventas'].map(item => (
                    <span class="inline-flex items-center gap-2 text-[11px] sm:text-xs font-black uppercase tracking-widest text-zinc-700">
                        <svg class="w-4 h-4 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                        {item}
                    </span>
                ))}
            </div>
            <div class="flex justify-center mt-4">
                <a href="#contacto" class="contact-modal-trigger btn-mktg-v5 shadow-[0_10px_30px_rgba(0,0,0,0.1)] !py-4 sm:!py-5 !px-6 sm:!px-10 !text-[11px] !tracking-widest font-black">
                    HABLEMOS DE TU TIENDA
                </a>
            </div>
        </div>
    </section>

    <LogoMarquee />

    <!-- ═══ INTRO ═══════════════════════════════════════════════════════ -->
    <section class="py-16 sm:py-24 bg-white px-4 sm:px-6 border-b border-black/5">
        <div class="max-w-6xl mx-auto reveal grid md:grid-cols-[1.3fr_1fr] gap-10 md:gap-16 items-center">
            <div>
                <p class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4">¿Por qué SEO?</p>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-8 text-zinc-900 leading-[0.9]">
                    La agencia de posicionamiento SEO para tu tienda online
                </h2>
                <div class="space-y-6 text-zinc-600 font-light text-base sm:text-lg leading-relaxed">
                    <p>
                        <strong class="font-semibold text-zinc-900">El SEO es el canal que sigue trayendo compradores cuando dejas de pagar por anuncios</strong>. Cada búsqueda de tu producto es un cliente con intención de compra, y quien aparece primero se lleva la venta. A diferencia de la publicidad, el posicionamiento es un activo que se acumula mes a mes.
                    </p>
                    <p>
                        Nova es una <strong class="font-semibold text-zinc-900">agencia SEO especializada en ecommerce</strong>. Arquitectura de categorías, fichas de producto y contenido pensados para una sola métrica que importa. <strong class="font-semibold text-zinc-900">Cuántas ventas llegan desde Google cada mes</strong>.
                    </p>
                </div>
            </div>
            <div class="hidden md:block">
                <img src="/sergio-galos-agencia-ecommerce-seo.webp" alt="Sergio Galo's, Consultor SEO para ecommerce" title="Sergio Galo's, Consultor SEO para ecommerce" class="w-full h-auto" loading="lazy" width="473" height="591" />
            </div>
        </div>
    </section>

    <!-- ═══ SERVICIOS ══════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-zinc-50 px-4 sm:px-6 border-t border-b border-black/5">
        <div class="max-w-7xl mx-auto text-center reveal">
            <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Qué hacemos</span>
            <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.9]">
                Servicio de posicionamiento SEO para ecommerce
            </h2>
            <p class="text-zinc-500 font-light text-sm sm:text-base leading-relaxed max-w-3xl mx-auto mb-16">
                El SEO de una tienda online no es una sola tarea, es un sistema. Estas son las nueve piezas que trabajamos para que tu ecommerce pase de ser invisible en Google a vender cada día desde el buscador.
            </p>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 text-left">
                {[
                    { t: "Auditoría SEO ecommerce", d: "Radiografía técnica, de contenido y de autoridad de tu tienda antes de tocar nada. El punto de partida de cualquier estrategia." },
                    { t: "SEO técnico", d: "Velocidad, indexación, Core Web Vitals y rastreo de miles de URLs de producto sin desperdiciar presupuesto de rastreo." },
                    { t: "Keyword research de producto", d: "Qué buscan tus compradores, con qué palabras y en qué momento de la decisión. Keywords que venden, no que solo traen visitas." },
                    { t: "Contenidos y categorías", d: "Arquitectura de categorías que posiciona y contenido que resuelve la duda de compra antes que tu competencia." },
                    { t: "Link building", d: "Enlaces de calidad en medios relevantes que aumentan la autoridad de tu dominio de forma orgánica y sostenida." },
                    { t: "SEO de fichas de producto", d: "Títulos, descripciones y datos estructurados de producto que posicionan y convierten. La ficha es tu página de venta." },
                    { t: "Analítica y Search Console", d: "Cada venta orgánica atribuida a su keyword y su página. Decisiones con datos, no con intuiciones." },
                    { t: "SEO más GEO", d: "Cada vez más compradores preguntan a la IA antes de comprar. Integramos posicionamiento en Google y en la IA en una sola estrategia." },
                    { t: "Migraciones de plataforma", d: "Cambios de plataforma o rediseños sin perder el posicionamiento que tanto ha costado conseguir." },
                ].map((c: any) => (
                    <div class="bg-white border border-black/5 rounded-2xl p-6 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
                        <h3 class="text-sm font-black uppercase tracking-tight text-zinc-900 mb-3">
                            {c.t}
                            {c.b && <span class="block text-[11px] uppercase tracking-[0.2em] text-accent mt-1 font-semibold">{c.b}</span>}
                        </h3>
                        <p class="text-sm text-zinc-500 font-light leading-relaxed">{c.d}</p>
                    </div>
                ))}
            </div>
            <div class="mt-12 text-center reveal">
                <a href="#contacto" class="contact-modal-trigger btn-mktg-v5 shadow-[0_10px_30px_rgba(37,211,102,0.3)] !py-4 sm:!py-5 !px-6 sm:!px-10 !text-[11px] !tracking-widest font-black">HABLEMOS DE TU TIENDA</a>
            </div>
        </div>
    </section>

    <!-- ═══ ESTRATEGIA ════════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-white px-4 sm:px-6 relative overflow-hidden">
        <div class="max-w-5xl mx-auto">
            <div class="text-center mb-16 sm:mb-24 reveal">
                <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Cómo trabajamos</span>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.9]">
                    Estrategia SEO para posicionar tu ecommerce en Google
                </h2>
                <p class="text-zinc-500 font-light text-sm sm:text-base leading-relaxed max-w-2xl mx-auto">
                    Una metodología documentada, paso a paso y sin humo.
                </p>
            </div>

            <div id="timeline-container" class="relative">
                <div class="hidden md:block absolute left-1/2 top-4 bottom-4 w-px bg-zinc-200 -translate-x-1/2"></div>
                <div id="progress-bar" class="hidden md:block absolute left-1/2 top-4 w-px bg-accent -translate-x-1/2 transition-all duration-100"></div>

                <div class="space-y-16 md:space-y-24 flex flex-col items-center">
                    {[
                        { title: "Auditoría SEO Completa", desc: "Analizamos tu tienda, tu visibilidad actual en Google y tu competencia directa. Detectamos errores técnicos, keywords rentables sin explotar y oportunidades de venta que tu competencia ya captura." },
                        { title: "Estrategia SEO Documentada", desc: "Recibes una hoja de ruta por escrito. Qué keywords atacar, qué categorías crear, qué arreglar en la tienda y qué resultados esperar en 3, 6 y 12 meses." },
                        { title: "Optimización Técnica y Contenidos", desc: "Arreglamos lo que impide a Google entender tu tienda y creamos el contenido que posiciona. Categorías, fichas y guías de compra pensadas para vender." },
                        { title: "Autoridad y Enlaces", desc: "Google posiciona a quien considera una referencia. Conseguimos enlaces de medios y directorios relevantes que empujan tus posiciones." },
                        { title: "Medición y Ajuste Continuo", desc: "Monitorizamos mes a mes posiciones, tráfico y ventas orgánicas. En el informe ves qué keywords suben y cuántos pedidos llegan desde Google." },
                    ].map((step, index) => (
                        <div class="flex flex-col md:flex-row items-center gap-6 md:gap-12 w-full relative reveal">
                            <div class:list={["flex-1 w-full", index % 2 === 0 ? "md:order-1 md:text-right" : "md:order-3 md:text-left"]}>
                                <div class="p-8 sm:p-10 bg-zinc-50 border border-black/5 rounded-3xl hover:border-accent/10 hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 relative overflow-hidden group">
                                    <h3 class="text-xl font-black uppercase tracking-tighter mb-2 text-zinc-900">{index + 1}. {step.title}</h3>
                                    <div class:list={["h-0.5 bg-accent w-full mb-4 opacity-80", index % 2 === 0 ? "md:ml-auto" : ""]}></div>
                                    <p class:list={["text-sm text-zinc-500 font-light max-w-md", index % 2 === 0 ? "md:ml-auto" : ""]}>{step.desc}</p>
                                    <div class="absolute -bottom-6 -right-5 text-8xl font-black text-black/[0.02] select-none z-0 group-hover:scale-105 transition-transform duration-500">0{index+1}</div>
                                </div>
                            </div>
                            <div class="md:order-2 w-12 h-12 rounded-full border-2 border-zinc-200 bg-white flex items-center justify-center font-black text-lg z-10 shrink-0 shadow-sm node-circle transition-all">
                                0{index + 1}
                            </div>
                            <div class:list={["hidden md:block md:flex-1", index % 2 === 0 ? "md:order-3" : "md:order-1"]}></div>
                        </div>
                    ))}
                </div>
            </div>
        </div>
    </section>

    <!-- ═══ AUDITORÍA ═════════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-zinc-50/50 px-4 sm:px-6 border-t border-black/5 overflow-hidden">
        <div class="max-w-7xl mx-auto grid lg:grid-cols-[6fr_4fr] gap-12 lg:gap-16 items-start">
            <div class="reveal lg:col-span-2">
                <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Punto de partida</span>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase text-zinc-900 leading-[0.9]">
                    Auditoría de posicionamiento SEO para tu ecommerce
                </h2>
            </div>
            <div class="reveal">
                <div class="space-y-5 text-zinc-600 font-light text-base leading-relaxed mb-8">
                    <p>¿Sabes en qué posición sale tu tienda cuando alguien busca tu producto? ¿Qué keywords te traen ventas y cuáles se lleva tu competencia? Casi ningún ecommerce lo sabe con datos, y ahí empieza todo.</p>
                    <p>Nuestra <strong class="font-semibold text-zinc-900">auditoría SEO para ecommerce</strong> mide tu visibilidad real en Google, revisa la salud técnica de la tienda y analiza a tu competencia directa, y termina con un plan de acción priorizado por impacto en ventas.</p>
                    <p>A diferencia de las auditorías automáticas que generan un PDF con cien errores irrelevantes, aquí cada punto lo revisa un consultor senior con experiencia en tiendas online.</p>
                    <p>Si ya trabajas con otra agencia, la auditoría también sirve como segunda opinión independiente antes de seguir invirtiendo.</p>
                </div>
                <ul class="space-y-3">
                    {["Salud técnica con indexación, velocidad y rastreo","Posiciones actuales para tus búsquedas de producto","Análisis de tu competencia directa en Google","Keywords rentables que aún no atacas","Arquitectura de categorías y canibalizaciones","Plan de acción SEO priorizado por impacto"].map(item => (
                        <li class="flex items-start gap-3 text-sm text-zinc-700 font-light">
                            <svg class="w-4 h-4 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                            {item}
                        </li>
                    ))}
                </ul>
                <div class="mt-16">
                    <a href="#contacto" class="contact-modal-trigger btn-mktg-v5 shadow-[0_10px_30px_rgba(37,211,102,0.3)] !py-4 sm:!py-5 !px-6 sm:!px-10 !text-[11px] !tracking-widest font-black">
                        QUIERO MI AUDITORÍA SEO
                    </a>
                </div>
            </div>
            <div class="reveal flex flex-col gap-4">
                {[
                    { bg: 'bg-purple-100', color: 'text-purple-600', t: "Revisión técnica completa", d: "Indexación, velocidad, datos estructurados de producto y errores de rastreo. Todo lo que frena tu tienda, documentado." },
                    { bg: 'bg-green-100', color: 'text-green-600', t: "Plan de acción priorizado", d: "Un plan ordenado por impacto y esfuerzo. Sabrás qué arreglar la primera semana y qué no merece ni un euro." },
                    { bg: 'bg-purple-100', color: 'text-purple-600', t: "Keywords de producto", d: "Las búsquedas que hacen tus compradores cuando quieren comprar, no solo las de más volumen." },
                    { bg: 'bg-amber-100', color: 'text-amber-600', t: "Arquitectura de categorías", d: "Qué categorías posicionan, cuáles canibalizan keywords entre sí y qué estructura falta para cubrir la demanda." },
                    { bg: 'bg-blue-100', color: 'text-blue-600', t: "Benchmark de tu sector", d: "Comparamos tu visibilidad con tus tres competidores directos. Qué keywords les traen ventas y qué puedes hacer mejor." },
                ].map(card => (
                    <div class="bg-white rounded-2xl shadow-[0_15px_40px_rgba(0,0,0,0.08)] p-5 flex items-start gap-4">
                        <div class:list={["w-11 h-11 rounded-full flex items-center justify-center flex-shrink-0", card.bg]}>
                            <svg class:list={["w-5 h-5", card.color]} fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                        </div>
                        <div>
                            <h3 class="text-sm font-black text-zinc-900 mb-1">{card.t}</h3>
                            <p class="text-xs text-zinc-500 font-light leading-relaxed">{card.d}</p>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- ═══ QUÉ INCLUYE LA AUDITORÍA ═══════════════════════════ -->
    <section class="py-20 sm:py-28 bg-white px-4 sm:px-6 border-t border-black/5">
        <div class="max-w-7xl mx-auto">
            <div class="text-center mb-12 sm:mb-16 reveal">
                <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Paso a paso</span>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase text-zinc-900 leading-[0.9]">
                    Qué incluye la auditoría SEO de nova
                </h2>
            </div>
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 items-stretch reveal">
                {[
                    { n: '1', t: "Radiografía de tu visibilidad en Google", d: "Analizamos en qué posición sales para las búsquedas de tus compradores, qué tráfico recibes y qué se lleva tu competencia." },
                    { n: '2', t: "Diagnóstico técnico y de contenidos", d: "Cruzamos los datos con la salud técnica de tu tienda y tus categorías para explicar exactamente qué te frena en el buscador." },
                    { n: '3', t: "Hoja de ruta para posicionar", d: "Cierras la auditoría con un documento de acciones ordenadas por impacto y una videollamada donde repasamos cada punto contigo." },
                ].map((st, i) => (
                    <div class="flex items-center gap-4 lg:gap-6">
                        {i > 0 && <div class="hidden lg:flex text-3xl text-accent font-black select-none">→</div>}
                        <div class="bg-white border border-black/5 rounded-2xl p-8 shadow-[0_15px_40px_rgba(0,0,0,0.06)] flex-1 text-center h-full">
                            <div class="w-12 h-12 rounded-full bg-accent/10 border border-accent/20 flex items-center justify-center mx-auto mb-4 text-accent font-black text-lg">{st.n}</div>
                            <h3 class="text-base font-black uppercase tracking-tight text-zinc-900 mb-3">{st.t}</h3>
                            <p class="text-sm text-zinc-500 font-light leading-relaxed">{st.d}</p>
                        </div>
                    </div>
                ))}
            </div>
            <p class="text-zinc-500 font-light text-sm sm:text-base leading-relaxed max-w-3xl mx-auto text-center mt-16 reveal">
                Nuestra auditoría SEO es el primer paso de cualquier estrategia de posicionamiento para ecommerce. Analiza cómo te ve hoy el buscador, explica por qué tu competencia sale antes que tú y te deja una hoja de ruta clara para empezar a vender desde las búsquedas. También puedes contratarla suelta como segunda opinión.
            </p>
            <div class="mt-12 text-center reveal">
                <a href="#contacto" class="contact-modal-trigger btn-mktg-v5 shadow-[0_10px_30px_rgba(37,211,102,0.3)] !py-4 sm:!py-5 !px-6 sm:!px-10 !text-[11px] !tracking-widest font-black">QUIERO MI AUDITORÍA SEO</a>
            </div>
        </div>
    </section>

    <!-- ═══ PRECIOS ════════════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-zinc-50/50 px-4 sm:px-6 border-t border-black/5">
        <div class="max-w-7xl mx-auto">
            <div class="text-center mb-12 sm:mb-16 reveal">
