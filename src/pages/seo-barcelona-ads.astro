---
import BaseLayout from '../layouts/BaseLayout.astro';
import { strapiClient, getStrapiImageUrl } from '../lib/strapi';

let caseStudies: any[] = [];
try {
  const res = await strapiClient.getCaseStudies('es', { limit: 50 });
  const allCases = res?.data?.map((i: any) => i.attributes ?? i) ?? [];
  const seoSlugs = ['seo', 'seo-local', 'consultoria-seo', 'posicionamiento-seo'];
  caseStudies = allCases
    .filter((cs: any) => {
      if (!cs.slug) return false;
      const cats: any[] = cs.categories || [];
      return cats.some((c: any) => {
        const name: string = (c.name || c.attributes?.name || '').toLowerCase();
        const slug: string = (c.slug || c.attributes?.slug || '').toLowerCase();
        return name.includes('seo') || seoSlugs.includes(slug);
      });
    })
    .slice(0, 3);
} catch (_) {}

const faqs = [
  {
    q: '¿En cuánto tiempo veré resultados?',
    a: 'Los primeros movimientos en posiciones suelen verse entre el 2.º y 3.er mes. Los resultados consolidados llegan entre el 4.º y 6.º mes. El SEO es una inversión a medio-largo plazo con resultados acumulativos.',
  },
  {
    q: '¿Qué incluye exactamente el servicio SEO en Barcelona?',
    a: 'Auditoría técnica completa, investigación de palabras clave locales, optimización on-page, link building de calidad, creación de contenido SEO, optimización de Google Business Profile y reportes mensuales con métricas reales.',
  },
  {
    q: '¿Necesito una web nueva o trabajáis con la que tengo?',
    a: 'Trabajamos con tu web actual. La auditoría inicial indica qué aspectos técnicos mejorar. Si la web tiene limitaciones graves, te lo decimos con claridad y podemos ayudarte también con el rediseño.',
  },
  {
    q: 'Probé SEO antes y no funcionó. ¿Por qué sería diferente?',
    a: 'El 80% de los casos en que el SEO "no funcionó" se debe a estrategias genéricas, falta de constancia o técnicas desactualizadas. Nuestra metodología se basa en auditoría real, competencia local de Barcelona y seguimiento mensual con KPIs de negocio.',
  },
  {
    q: '¿Cuál es el compromiso mínimo de permanencia?',
    a: 'Trabajamos con contratos de 6 meses porque el SEO necesita tiempo para dar resultados medibles. Pasado ese período, la relación se renueva mes a mes.',
  },
  {
    q: '¿Cómo sé que estáis trabajando realmente?',
    a: 'Cada mes recibes un informe detallado con posiciones, tráfico orgánico, conversiones y acciones realizadas. Tienes acceso a un panel de seguimiento y una reunión mensual de revisión.',
  },
];
---

<BaseLayout
  title="Agencia SEO en Barcelona — Más visitas, más clientes | nova."
  description="Posicionamiento SEO para pymes en Barcelona. Auditoría gratuita, estrategia local y resultados medibles. Primera consulta sin compromiso."
  noIndex={true}
  locale="es"
  hideHeader={true}
  hideFooter={true}
>

<!-- ─── Sending overlay ─── -->
<div id="lp-sending" class="fixed inset-0 z-[200] bg-white flex flex-col items-center justify-center hidden">
  <div class="flex flex-col items-center gap-8 px-8 max-w-sm w-full text-center">
    <div class="w-16 h-16 rounded-full border-4 border-zinc-100 border-t-accent animate-spin"></div>
    <div>
      <div class="text-2xl font-black uppercase tracking-tighter text-black mb-2">Enviando...</div>
      <p class="text-zinc-400 font-light text-sm">Procesando tu solicitud, un momento.</p>
    </div>
    <div class="w-full bg-zinc-100 rounded-full h-1 overflow-hidden">
      <div id="lp-progress" class="h-full bg-accent rounded-full" style="width:0%;transition:width 0.4s ease"></div>
    </div>
  </div>
</div>

<!-- ═══ NAV LANDING ═══════════════════════════════════════════════════ -->
<header class="fixed top-0 left-0 right-0 z-50 bg-white/90 backdrop-blur-md border-b border-black/5 py-2 sm:py-3 leading-none">
  <div class="relative w-full px-6 sm:px-12 md:px-24 lg:px-32 xl:px-44 flex items-center justify-between h-12 md:h-14 gap-6">
    <a href="/" class="flex items-center h-full flex-shrink-0">
      <div class="text-[2.8rem] sm:text-[3rem] font-heading font-black tracking-tighter leading-none flex items-center -translate-y-0.5">
        <span class="hover-animate-gradient">nova.</span>
      </div>
    </a>
    <nav class="hidden lg:flex items-center gap-6 xl:gap-8">
      {[
        { href: '#problema', label: '¿Cuál es tu problema?' },
        { href: '#seo-negocio', label: 'SEO que genera negocio' },
        { href: '#metodo', label: 'Método nova.' },
        { href: '#casos', label: 'Casos de éxito' },
        { href: '#resultados', label: 'Resultados' },
      ].map(l => (
        <a href={l.href} class="text-[11px] font-bold uppercase tracking-[0.15em] text-zinc-700 hover:text-accent transition-colors whitespace-nowrap">
          {l.label}
        </a>
      ))}
    </nav>
    <a href="#solicitar" class="btn-mktg-v5 !py-3 !px-6 !text-[11px] font-black flex-shrink-0">
      AUDITORÍA GRATIS
    </a>
  </div>
</header>

<!-- ═══ HERO ═══════════════════════════════════════════════════════════ -->
<section class="min-h-[100dvh] flex items-center px-4 sm:px-6 relative overflow-hidden bg-white border-b border-black/5 pt-16 pb-[220px] sm:pb-10">
  <!-- Background mesh -->
  <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808008_1px,transparent_1px),linear-gradient(to_bottom,#80808008_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_60%_60%_at_50%_40%,#000_70%,transparent_100%)]"></div>
  <div class="absolute -top-10 left-1/4 w-72 h-72 bg-accent/15 rounded-full blur-3xl opacity-30 animate-pulse"></div>
  <div class="absolute top-20 right-1/3 w-80 h-80 bg-purple-500/5 rounded-full blur-3xl opacity-20"></div>

  <div class="max-w-7xl mx-auto w-full">
    <div class="grid lg:grid-cols-[2fr_1fr] gap-10 lg:gap-14 items-center">

      <!-- Copy: 66% -->
      <div class="reveal">
        <div class="flex justify-center lg:justify-start mb-8">
          <h2 class="inline-flex items-center gap-2 bg-accent/10 backdrop-blur-sm px-4 py-2 border border-accent/25 rounded-full text-accent text-[10px] sm:text-[12px] font-black uppercase tracking-[0.25em] shadow-sm">
            <span class="w-2 h-2 bg-accent rounded-full animate-ping"></span>
            Agencia SEO en Barcelona
          </h2>
        </div>

        <h1 class="text-3xl sm:text-5xl lg:text-7xl uppercase font-black tracking-tighter leading-[0.9] mb-8 lg:mb-10 text-zinc-900 text-center sm:text-left">
          Aparece antes<br>
          <span class="sm:whitespace-nowrap">que tu competencia</span><br>
          <span class="text-mktg-gradient">en Google</span>
        </h1>

        <div class="flex flex-col gap-3 mb-8 lg:mb-12">
          {[
            'Auditoría SEO gratuita',
            'Más visitas orgánicas en Google',
            'Aumento de clientes potenciales',
          ].map(item => (
            <span class="inline-flex items-center gap-3 text-sm font-black uppercase tracking-widest text-zinc-800">
              <span class="w-7 h-7 bg-accent/10 border border-accent/20 rounded-full flex items-center justify-center flex-shrink-0">
                <svg class="w-3.5 h-3.5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                </svg>
              </span>
              {item}
            </span>
          ))}
        </div>

        <!-- Desktop claim (inline flow) -->
        <div class="hidden sm:inline-flex items-center gap-3 border-l-4 border-accent pl-4">
          <p class="font-black uppercase tracking-tight text-zinc-900 leading-none" style="font-size:clamp(0.95rem, 2.8vw, 2rem);">
            Somos la agencia SEO nº1 en Barcelona
          </p>
        </div>

      </div>

      <!-- Form: 33% — hidden on mobile -->
      <div id="solicitar" class="reveal hidden lg:block">
        <div class="bg-white rounded-3xl border-2 border-black/8 shadow-[0_20px_60px_rgba(0,0,0,0.1)] p-7">
          <span class="text-[9px] font-black uppercase tracking-[0.4em] text-accent block mb-2">Sin compromiso</span>
          <div class="text-2xl font-black uppercase tracking-tighter mb-5 leading-tight" style="font-weight:900;">Si contactas hoy,<br>Auditoría SEO Gratuita</div>

          <!-- Mobile CTA — opens modal -->
          <button class="contact-modal-trigger sm:hidden w-full btn-mktg-v5 !py-4 shadow-[0_8px_20px_rgba(37,211,102,0.3)] mb-2">
            SOLICITAR AUDITORÍA →
          </button>

          <form id="seo-barcelona-form" class="space-y-4 hidden sm:block">
            <div class="flex flex-col gap-1.5">
              <label class="text-[9px] font-black uppercase tracking-widest opacity-40">Nombre *</label>
              <input type="text" name="name" required class="border-b-2 border-zinc-200 py-2 focus:border-accent outline-none transition-colors bg-transparent text-sm" />
            </div>
            <div class="flex flex-col gap-1.5">
              <label class="text-[9px] font-black uppercase tracking-widest opacity-40">Email *</label>
              <input type="email" name="email" required class="border-b-2 border-zinc-200 py-2 focus:border-accent outline-none transition-colors bg-transparent text-sm" />
            </div>
            <div class="flex flex-col gap-1.5">
              <label class="text-[9px] font-black uppercase tracking-widest opacity-40">Teléfono</label>
              <input type="tel" name="phone" class="border-b-2 border-zinc-200 py-2 focus:border-accent outline-none transition-colors bg-transparent text-sm" />
            </div>
            <div class="flex flex-col gap-1.5">
              <label class="text-[9px] font-black uppercase tracking-widest opacity-40">Web de tu empresa</label>
              <input type="text" name="url" placeholder="www.tuempresa.com" class="border-b-2 border-zinc-200 py-2 focus:border-accent outline-none transition-colors bg-transparent text-sm" />
            </div>
            <div class="flex flex-col gap-1.5">
              <label class="text-[9px] font-black uppercase tracking-widest opacity-40">Mensaje</label>
              <textarea name="msg" rows="2" class="border-b-2 border-zinc-200 py-2 focus:border-accent outline-none transition-colors bg-transparent text-sm resize-none"></textarea>
            </div>

            <div class="flex items-start gap-2 pt-1">
              <input type="checkbox" id="lp-terms" name="terms" required class="mt-0.5 accent-accent flex-shrink-0" />
              <label for="lp-terms" class="text-[10px] text-zinc-400 font-light cursor-pointer select-none leading-tight">
                Acepto la <a href="/privacidad/" class="underline hover:text-accent transition-colors">política de privacidad</a>.
              </label>
            </div>

            <button type="submit" id="lp-submit-btn" class="w-full btn-mktg-v5 !py-4 shadow-[0_8px_20px_rgba(37,211,102,0.3)]">
              SOLICITAR AUDITORÍA →
            </button>
          </form>
        </div>
      </div>

    </div>
  </div>

  <!-- Mobile: tarjeta + claim fijados al fondo del hero -->
  <div class="sm:hidden absolute bottom-4 left-4 right-4 flex flex-col gap-5">
    <div class="bg-white rounded-3xl border-2 border-black/8 shadow-[0_20px_60px_rgba(0,0,0,0.1)] p-6">
      <span class="text-[9px] font-black uppercase tracking-[0.4em] text-accent block mb-2">Sin compromiso</span>
      <div class="text-xl font-black uppercase tracking-tighter mb-4 leading-tight" style="font-weight:900;">Si contactas hoy,<br>Auditoría SEO Gratuita</div>
      <button class="contact-modal-trigger w-full btn-mktg-v5 !py-4 shadow-[0_8px_20px_rgba(37,211,102,0.3)]">
        SOLICITAR AUDITORÍA →
      </button>
    </div>
    <p class="font-black uppercase tracking-tight text-zinc-900 leading-none text-center" style="font-size:0.95rem;">
      Somos la agencia SEO nº1 en Barcelona
    </p>
  </div>
</section>

<!-- ═══ PROBLEMAS ══════════════════════════════════════════════════════ -->
<section id="problema" class="py-20 sm:py-32 bg-zinc-50 border-y border-black/5 px-4 sm:px-6 relative overflow-hidden">
  <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808005_1px,transparent_1px),linear-gradient(to_bottom,#80808005_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_50%,#000_80%,transparent_100%)]"></div>
  <div class="max-w-7xl mx-auto relative z-10">
    <div class="text-center mb-16 sm:mb-24 reveal">
      <span class="text-[10px] font-black uppercase tracking-[0.3em] text-accent mb-4 block">El problema</span>
      <h2 class="text-3xl sm:text-5xl lg:text-7xl uppercase tracking-tighter font-black mb-4">
        ¿Te suena alguna<br class="hidden sm:inline" /> de estas situaciones?
      </h2>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {[
        { icon: `<svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>`, title: 'No apareces en Google', desc: 'Buscas tu empresa en Google y no apareces ni en la primera página. Tus competidores sí están ahí.' },
        { icon: `<svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>`, title: 'Tu web no genera clientes', desc: 'Tienes una web bonita pero no recibe visitas. El poco tráfico que llega no se convierte en contactos.' },
        { icon: `<svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>`, title: 'Dependes de publicidad de pago', desc: 'Inviertes en Google Ads cada mes pero en cuanto paras, el tráfico desaparece. Sin visibilidad propia.' },
        { icon: `<svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>`, title: 'No te encuentran en Barcelona', desc: 'Clientes potenciales cerca de ti buscan tus servicios pero acaban en la competencia.' },
        { icon: `<svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>`, title: 'Probaste SEO y no funcionó', desc: 'Ya invertiste en SEO antes y no viste resultados. No sabes qué hicieron ni por qué falló.' },
        { icon: `<svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`, title: 'No tienes tiempo para gestionarlo', desc: 'Sabes que el SEO es importante pero llevar el negocio no te deja tiempo para aprenderlo.' },
      ].map((p, i) => (
        <div class="group p-8 sm:p-10 bg-white border border-zinc-100/60 rounded-3xl hover:border-accent/20 hover:shadow-2xl hover:-translate-y-2 transition-all duration-500 relative overflow-hidden flex flex-col reveal" style={`transition-delay: ${i * 80}ms`}>
          <div class="absolute bottom-0 inset-x-0 h-1 bg-gradient-to-r from-accent via-accent/90 to-purple-600 w-0 group-hover:w-full transition-all duration-500"></div>
          <div class="p-3 bg-zinc-50 border border-black/5 w-fit rounded-xl mb-6 group-hover:bg-accent/5 group-hover:border-accent/10 transition-colors">
            <Fragment set:html={p.icon} />
          </div>
          <h3 class="text-lg sm:text-xl font-black uppercase tracking-tighter mb-3 text-zinc-900">{p.title}</h3>
          <p class="text-sm text-zinc-500 font-light leading-relaxed">{p.desc}</p>
        </div>
      ))}
    </div>

    <div class="mt-16 text-center reveal">
      <button class="contact-modal-trigger btn-mktg-v5 shadow-[0_10px_30px_rgba(37,211,102,0.3)]">
        QUIERO SOLUCIONARLO
      </button>
    </div>
  </div>
</section>

<!-- ═══ MÉTODO ════════════════════════════════════════════════════════ -->
<section id="seo-negocio" class="py-20 sm:py-32 bg-accent px-4 sm:px-6">
  <div class="max-w-7xl mx-auto grid md:grid-cols-2 gap-12 sm:gap-20 items-center">
    <div class="reveal text-white">
      <span class="text-[10px] font-black uppercase tracking-[0.5em] mb-6 sm:mb-10 block opacity-70">Nuestro enfoque</span>
      <div class="text-4xl sm:text-7xl lg:text-8xl font-black uppercase tracking-tighter leading-[0.82] mb-8 sm:mb-10">
        SEO que<br>genera<br>negocio
      </div>
      <p class="text-white/70 font-light text-base sm:text-xl max-w-md leading-relaxed mb-8">
        Muchas agencias se obsesionan con posiciones. Nosotros nos obsesionamos con los resultados: más contactos, más ventas, más clientes en Barcelona.
      </p>
      <ul class="text-[9px] sm:text-xs font-black tracking-widest space-y-3 uppercase opacity-90 text-white">
        <li>→ AUDITORÍA TÉCNICA COMPLETA</li>
        <li>→ ESTRATEGIA DE KEYWORDS LOCAL</li>
        <li>→ LINK BUILDING DE CALIDAD</li>
        <li>→ SEGUIMIENTO MENSUAL REAL</li>
      </ul>
    </div>

    <div class="reveal space-y-4">
      {[
        { num: '01', title: 'Auditoría técnica y de competencia', desc: 'Analizamos tu web desde cero y estudiamos qué están haciendo los primeros resultados de Google en tu sector y ciudad.' },
        { num: '02', title: 'Estrategia de keywords local', desc: 'Identificamos las búsquedas exactas que hacen tus clientes potenciales en Barcelona.' },
        { num: '03', title: 'Optimización técnica y de contenido', desc: 'Corregimos errores técnicos, optimizamos páginas existentes y creamos contenido que posiciona y convierte.' },
        { num: '04', title: 'Autoridad y resultados medibles', desc: 'Conseguimos enlaces de calidad e informes mensuales con posiciones, tráfico y conversiones reales.' },
      ].map(s => (
        <div class="bg-white/10 backdrop-blur-sm p-6 sm:p-8 rounded-3xl border border-white/10 hover:bg-white/15 transition-colors flex gap-6 items-start">
          <div class="text-white/40 font-black text-lg tracking-tighter flex-shrink-0 w-8">{s.num}</div>
          <div>
            <h3 class="text-sm font-black uppercase tracking-tight text-white mb-1">{s.title}</h3>
            <p class="text-white/60 font-light text-sm leading-relaxed">{s.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ═══ PROCESO ═══════════════════════════════════════════════════════ -->
<section id="metodo" class="py-20 sm:py-32 bg-white px-4 sm:px-6 relative overflow-hidden">
  <div class="absolute -top-40 right-1/4 w-96 h-96 bg-accent/10 rounded-full blur-3xl opacity-20 animate-pulse"></div>
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-16 sm:mb-24 reveal">
      <span class="text-[10px] font-black uppercase tracking-[0.3em] text-accent mb-4 block">El proceso</span>
      <h2 class="text-3xl sm:text-5xl lg:text-6xl uppercase tracking-tighter font-black mb-4">
        Así trabajamos contigo
      </h2>
      <p class="text-zinc-500 font-light text-base sm:text-lg max-w-xl mx-auto">
        Un proceso claro, sin sorpresas y con comunicación directa en todo momento.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {[
        { step: '01', title: 'Auditoría gratuita', desc: 'Analizamos tu web y te enviamos un informe con los puntos de mejora más importantes. Sin coste ni compromiso.' },
        { step: '02', title: 'Propuesta personalizada', desc: 'Elaboramos una estrategia SEO adaptada a tu sector, competencia y presupuesto en Barcelona.' },
        { step: '03', title: 'Onboarding y accesos', desc: 'Configuramos herramientas, accesos y establecemos los KPIs que seguiremos juntos desde el primer día.' },
        { step: '04', title: 'Optimización técnica', desc: 'Corregimos los errores técnicos de tu web que impiden que Google la indexe y posicione correctamente.' },
        { step: '05', title: 'Contenido y posicionamiento', desc: 'Creamos y optimizamos páginas que responden a las búsquedas de tus clientes en Barcelona y zona.' },
        { step: '06', title: 'Seguimiento mensual', desc: 'Informe mensual con posiciones, tráfico y conversiones. Reunión de revisión incluida cada mes.' },
      ].map((p, i) => (
        <div class="group p-8 sm:p-10 bg-white border border-zinc-100/60 rounded-3xl hover:border-accent/20 hover:shadow-2xl hover:-translate-y-2 transition-all duration-500 relative overflow-hidden flex flex-col reveal" style={`transition-delay: ${i * 80}ms`}>
          <div class="absolute bottom-0 inset-x-0 h-1 bg-gradient-to-r from-accent via-accent/90 to-purple-600 w-0 group-hover:w-full transition-all duration-500"></div>
          <div class="text-5xl font-black tracking-tighter text-black/5 group-hover:text-accent/10 transition-colors mb-4 select-none">{p.step}</div>
          <h3 class="text-lg sm:text-xl font-black uppercase tracking-tighter mb-3 text-zinc-900">{p.title}</h3>
          <p class="text-sm text-zinc-500 font-light leading-relaxed">{p.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ═══ CASOS DE ÉXITO ═════════════════════════════════════════════════ -->
{caseStudies.length > 0 && (
<section id="casos" class="py-20 sm:py-32 bg-zinc-50 border-y border-black/5 px-4 sm:px-6 relative overflow-hidden">
  <div class="max-w-7xl mx-auto">
    <div class="mb-16 sm:mb-24 reveal">
      <span class="text-[10px] font-black uppercase tracking-[0.3em] text-accent mb-4 block">Resultados probados</span>
      <h2 class="text-3xl sm:text-5xl lg:text-7xl uppercase tracking-tighter font-black mb-2">
        Casos de éxito SEO<br class="hidden md:inline" /> de pymes reales
      </h2>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {caseStudies.map((cs: any, i: number) => {
        const imageUrl = getStrapiImageUrl(cs.cover_image) || '/og-default.jpg';
        const caseUrl = `/casos-exito/${cs.slug}/`;
        const catName = (cs.categories || []).map((c: any) => c.name || c.attributes?.name).filter(Boolean)[0] || 'SEO';
        return (
          <a href={caseUrl} class="group bg-white border border-black/5 rounded-3xl overflow-hidden hover:shadow-2xl hover:-translate-y-2 transition-all duration-500 shadow-sm flex flex-col h-full reveal" style={`transition-delay: ${i * 100}ms`}>
            <div class="relative aspect-[4/3] overflow-hidden">
              <img src={imageUrl} alt={cs.title} class="w-full h-full object-cover grayscale group-hover:grayscale-0 group-hover:scale-105 transition-all duration-700" />
              <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent opacity-60 group-hover:opacity-40 transition-opacity"></div>
              <div class="absolute top-3 left-3 z-10">
                <span class="bg-white/95 backdrop-blur-sm border border-black/5 px-3 py-1 rounded-full text-[8px] font-black uppercase tracking-[0.2em] text-accent shadow-md">{catName}</span>
              </div>
              {cs.company && (
                <div class="absolute bottom-3 left-3 z-10 bg-white/10 backdrop-blur-md rounded-xl px-3 py-1.5 border border-white/20">
                  <span class="text-white font-black uppercase tracking-tighter text-[9px]">{cs.company}</span>
                </div>
              )}
            </div>
            <div class="p-6 flex flex-col flex-1">
              <div class="mb-3 flex-1">
                <h3 class="text-base font-black uppercase tracking-tight text-zinc-900 leading-tight group-hover:text-accent transition-colors line-clamp-2 mb-2">{cs.title}</h3>
                <p class="text-zinc-500 font-light text-xs line-clamp-2 leading-relaxed">{cs.description}</p>
              </div>
              {cs.results && cs.results.length > 0 && (
                <div class="grid grid-cols-2 gap-2 pt-3 border-t border-zinc-50 mb-3">
                  <div class="flex flex-col">
                    <span class="text-base font-black text-black leading-none">{cs.results[0].value}</span>
                    <span class="text-[7px] font-black uppercase tracking-wider text-accent">{cs.results[0].metric}</span>
                  </div>
                  {cs.results[1] && (
                    <div class="flex flex-col">
                      <span class="text-base font-black text-black leading-none">{cs.results[1].value}</span>
                      <span class="text-[7px] font-black uppercase tracking-wider text-accent">{cs.results[1].metric}</span>
                    </div>
                  )}
                </div>
              )}
              <div class="flex items-center pt-3 border-t border-zinc-50">
                <span class="text-[8px] font-black tracking-[0.25em] text-accent flex items-center gap-1.5 group-hover:gap-3 transition-all uppercase">
                  VER RESULTADOS <span class="text-sm">→</span>
                </span>
              </div>
            </div>
          </a>
        );
      })}
    </div>
  </div>
</section>
)}

