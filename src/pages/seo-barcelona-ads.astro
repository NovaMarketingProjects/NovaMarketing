<script>
  // FAQ accordion
  document.querySelectorAll('.faq-trigger').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.faq-item')!;
      const answer = item.querySelector('.faq-answer')!;
      const icon = btn.querySelector('.faq-icon') as SVGElement | null;
      const wrap = btn.querySelector('.faq-icon-wrap')!;
      const isOpen = !answer.classList.contains('hidden');

      document.querySelectorAll('.faq-answer').forEach(a => a.classList.add('hidden'));
      document.querySelectorAll('.faq-icon').forEach(i => (i as SVGElement).style.transform = '');
      document.querySelectorAll('.faq-icon-wrap').forEach(w => {
        w.classList.remove('bg-accent', 'border-accent');
        w.classList.add('bg-zinc-50', 'border-zinc-100');
      });
      document.querySelectorAll('.faq-icon svg, .faq-icon').forEach(i => (i as HTMLElement).style.color = '');
      document.querySelectorAll('.faq-trigger').forEach(b => b.setAttribute('aria-expanded', 'false'));

      if (!isOpen) {
        answer.classList.remove('hidden');
        if (icon) icon.style.transform = 'rotate(45deg)';
        wrap.classList.remove('bg-zinc-50', 'border-zinc-100');
        wrap.classList.add('bg-accent', 'border-accent');
        if (icon) icon.style.color = 'white';
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });

  // Form submission
  async function handleForm(formId: string, btnId: string) {
    const form = document.getElementById(formId) as HTMLFormElement | null;
    const btn = document.getElementById(btnId) as HTMLButtonElement | null;
    const overlay = document.getElementById('lp-sending');
    const bar = document.getElementById('lp-progress');

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (btn) btn.disabled = true;
      overlay?.classList.remove('hidden');
      if (bar) {
        setTimeout(() => { bar.style.width = '40%'; }, 50);
        setTimeout(() => { bar.style.width = '72%'; }, 700);
        setTimeout(() => { bar.style.width = '88%'; }, 1800);
      }
      const data = { ...Object.fromEntries(new FormData(form)), source: window.location.href };
      try {
        const res = await fetch('https://cms.novamarketing.es/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });
        if (res.ok) {
          if (bar) bar.style.width = '100%';
          setTimeout(() => { window.location.href = '/gracias/'; }, 400);
        } else { throw new Error(); }
      } catch {
        overlay?.classList.add('hidden');
        if (bar) bar.style.width = '0%';
        if (btn) {
          btn.disabled = false;
          btn.textContent = 'ERROR — INTÉNTALO DE NUEVO';
          (btn as HTMLElement).style.background = '#ef4444';
        }
      }
    });
  }

  handleForm('seo-barcelona-form', 'lp-submit-btn');
  handleForm('seo-barcelona-form-bottom', 'lp-submit-btn-2');
</script>
