---
import BaseLayout from '../layouts/BaseLayout.astro';
import { strapiClient, getStrapiImageUrl } from '../lib/strapi';
import LogoMarquee from '../components/sections/LogoMarquee.astro';

let caseStudies: any[] = [];
try {
  const res = await strapiClient.getCaseStudies('es', { limit: 50 });
  const allCases = res?.data?.map((i: any) => i.attributes ?? i) ?? [];
  const seoSlugs = ['seo', 'seo-local', 'consultoria-seo', 'posicionamiento-seo'];
  caseStudies = allCases
    .filter((cs: any) => {
      if (!cs.slug) return false;
      const cats: any[] = cs.categories || [];
      return cats.some((c: any) => {
        const name: string = (c.name || c.attributes?.name || '').toLowerCase();
        const slug: string = (c.slug || c.attributes?.slug || '').toLowerCase();
        return name.includes('seo') || seoSlugs.includes(slug);
      });
    });
} catch (_) {}

const faqs = [
  {
    q: '¿Cómo puede el SEO ayudar a mi negocio a destacar en un mercado tan competitivo como Barcelona?',
    a: 'Barcelona tiene miles de empresas compitiendo por los mismos clientes. La clave está en la hiperlocalización: posicionarse por barrios concretos como el Eixample, Gràcia o Sarrià en lugar de intentar competir con toda la ciudad a la vez. Identificamos las búsquedas con mayor intención de compra en tu zona y tu sector para que tu negocio aparezca primero cuando más importa.',
  },
  {
    q: '¿Qué diferencia al SEO en Barcelona del SEO en otras ciudades?',
    a: 'La competencia es mucho más alta y los volúmenes de búsqueda son mayores. Esto significa que una buena posición en Google en Barcelona puede generar un flujo muy importante de clientes. Pero también requiere una estrategia más robusta: más contenido de calidad, más autoridad de dominio y una arquitectura web más cuidada.',
  },
  {
    q: '¿El SEO local funciona para negocios en el Eixample o en el 22@?',
    a: 'Absolutamente. El Eixample es el distrito comercial más denso de Barcelona, y el 22@ concentra empresas tecnológicas y creativas. En ambos casos, el SEO local por barrio es muy efectivo porque los usuarios buscan proveedores cercanos. Optimizamos tu presencia en Google Maps y en las búsquedas orgánicas por zona.',
  },
  {
    q: '¿Cuánto tiempo tarda el SEO en posicionar en Barcelona?',
    a: 'Por la alta competencia, el horizonte habitual en Barcelona es de 4-8 meses para ver mejoras significativas en sectores competidos. En nichos más específicos puede ser más rápido. Lo importante es que el SEO construye un activo duradero: a diferencia de Google Ads, las posiciones ganadas no desaparecen cuando paras la inversión.',
  },
  {
    q: '¿Trabajáis el SEO para ecommerce y tiendas físicas de Barcelona?',
    a: 'Sí, para ambos modelos. Para tiendas físicas trabajamos el SEO local por barrio y la optimización del Google Business Profile. Para ecommerce, desarrollamos estrategias de posicionamiento de categorías y fichas de producto que generan tráfico orgánico cualificado y reducen la dependencia de la publicidad de pago.',
  },
];
---

<BaseLayout
  title="▷ Agencia SEO en Barcelona | Estrategias locales y auditoría"
  description="Posicionamos tu negocio en barrios de Barcelona con análisis detallado y auditoría gratuita ✅ Estrategia SEO local y resultados medibles 💡"
  noIndex={true}
  locale="es"
  hideHeader={true}
  hideFooter={true}
>

<!-- ─── Sending overlay ─── -->
<div id="lp-sending" class="fixed inset-0 z-[200] bg-white flex flex-col items-center justify-center hidden">
  <div class="flex flex-col items-center gap-8 px-8 max-w-sm w-full text-center">
    <div class="w-16 h-16 rounded-full border-4 border-zinc-100 border-t-accent animate-spin"></div>
    <div>
      <div class="text-2xl font-black uppercase tracking-tighter text-black mb-2">Enviando...</div>
      <p class="text-zinc-400 font-light text-sm">Procesando tu solicitud, un momento.</p>
    </div>
    <div class="w-full bg-zinc-100 rounded-full h-1 overflow-hidden">
      <div id="lp-progress" class="h-full bg-accent rounded-full"></div>
    </div>
  </div>
</div>

<!-- ═══ NAV LANDING ═══════════════════════════════════════════════════ -->
<header class="fixed top-0 left-0 right-0 z-50 bg-white/90 backdrop-blur-md border-b border-black/5 py-2 sm:py-3 leading-none">
  <div class="relative w-full px-6 sm:px-12 md:px-24 lg:px-32 xl:px-44 flex items-center justify-between h-12 md:h-14 gap-6">
    <a href="/" class="flex items-center h-full flex-shrink-0">
      <div class="text-[2.8rem] sm:text-[3rem] font-heading font-black tracking-tighter leading-none flex items-center -translate-y-0.5">
        <span class="hover-animate-gradient">nova.</span>
      </div>
    </a>
    <nav class="hidden lg:flex items-center gap-6 xl:gap-8">
      {[
        { href: '#auditoria', label: 'Auditoría y estrategia' },
        { href: '#metodo', label: 'Cómo trabajamos' },
        { href: '#resultados', label: 'Resultados' },
        { href: '#casos', label: 'Casos de éxito' },
        { href: '#faq', label: 'FAQ' },
      ].map(l => (
        <a href={l.href} class="text-[11px] font-bold uppercase tracking-[0.15em] text-zinc-700 hover:text-accent transition-colors whitespace-nowrap">
          {l.label}
        </a>
      ))}
    </nav>
    <a href="#solicitar" class="btn-mktg-v5 !py-3 !px-6 !text-[11px] font-black flex-shrink-0">
      AUDITORÍA GRATIS
    </a>
  </div>
</header>

<!-- ═══ HERO ═══════════════════════════════════════════════════════════ -->
<section class="min-h-[100dvh] flex items-center px-4 sm:px-6 relative overflow-hidden bg-white border-b border-black/5 pt-16 pb-[220px] sm:pb-10">
  <!-- Background mesh -->
  <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808008_1px,transparent_1px),linear-gradient(to_bottom,#80808008_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_60%_60%_at_50%_40%,#000_70%,transparent_100%)]"></div>
  <div class="absolute -top-10 left-1/4 w-72 h-72 bg-accent/15 rounded-full blur-3xl opacity-30 animate-pulse"></div>
  <div class="absolute top-20 right-1/3 w-80 h-80 bg-purple-500/5 rounded-full blur-3xl opacity-20"></div>

  <div class="max-w-7xl mx-auto w-full">
    <div class="grid lg:grid-cols-[2fr_1fr] gap-10 lg:gap-14 items-center">

      <!-- Copy: 66% -->
      <div class="reveal">
        <div class="flex justify-center lg:justify-start mb-8">
          <h2 class="inline-flex items-center gap-2 bg-accent/10 backdrop-blur-sm px-4 py-2 border border-accent/25 rounded-full text-accent text-[10px] sm:text-[12px] font-black uppercase tracking-[0.25em] shadow-sm">
            <span class="w-2 h-2 bg-accent rounded-full animate-ping"></span>
            Agencia SEO en Barcelona
          </h2>
        </div>

        <h1 class="text-3xl sm:text-5xl lg:text-7xl uppercase font-black tracking-tighter leading-[0.9] mb-8 lg:mb-10 text-zinc-900 text-center sm:text-left">
          Aparece antes<br>
          <span class="sm:whitespace-nowrap">que tu competencia</span><br>
          <span class="text-mktg-gradient">en Google</span>
        </h1>

        <div class="flex flex-col gap-3 mb-8 lg:mb-12">
          {[
            'Auditoría SEO gratuita',
            'Más visitas orgánicas en Google',
            'Aumento de clientes potenciales',
          ].map(item => (
            <span class="inline-flex items-center gap-3 text-sm font-black uppercase tracking-widest text-zinc-800">
              <span class="w-7 h-7 bg-accent/10 border border-accent/20 rounded-full flex items-center justify-center flex-shrink-0">
                <svg class="w-3.5 h-3.5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                </svg>
              </span>
              {item}
            </span>
          ))}
        </div>

        <!-- Desktop claim (inline flow) -->
        <div class="hidden sm:inline-flex items-center gap-3 border-l-4 border-accent pl-4">
          <p class="font-black uppercase tracking-tight text-zinc-900 leading-none text-[clamp(0.95rem,2.8vw,2rem)]">
            Somos la agencia SEO nº1 en Barcelona
          </p>
        </div>

      </div>

      <!-- Form: 33% — hidden on mobile -->
      <div id="solicitar" class="reveal hidden lg:block">
        <div class="bg-white rounded-3xl border-2 border-black/8 shadow-[0_20px_60px_rgba(0,0,0,0.1)] p-7">
          <span class="text-[9px] font-black uppercase tracking-[0.4em] text-accent block mb-2">Sin compromiso</span>
          <div class="text-2xl font-black uppercase tracking-tighter mb-5 leading-tight">Si contactas hoy,<br>Auditoría SEO Gratuita</div>

          <form id="seo-barcelona-form" class="space-y-4">
            <div class="flex flex-col gap-1.5">
              <label class="text-[9px] font-black uppercase tracking-widest opacity-40">Nombre *</label>
              <input type="text" name="name" required class="border-b-2 border-zinc-200 py-2 focus:border-accent outline-none transition-colors bg-transparent text-sm" />
            </div>
            <div class="flex flex-col gap-1.5">
              <label class="text-[9px] font-black uppercase tracking-widest opacity-40">Email *</label>
              <input type="email" name="email" required class="border-b-2 border-zinc-200 py-2 focus:border-accent outline-none transition-colors bg-transparent text-sm" />
            </div>
            <div class="flex flex-col gap-1.5">
              <label class="text-[9px] font-black uppercase tracking-widest opacity-40">Teléfono</label>
              <input type="tel" name="phone" aria-label="Teléfono" class="border-b-2 border-zinc-200 py-2 focus:border-accent outline-none transition-colors bg-transparent text-sm" />
            </div>
            <div class="flex flex-col gap-1.5">
              <label class="text-[9px] font-black uppercase tracking-widest opacity-40">Web de tu empresa</label>
              <input type="text" name="url" placeholder="www.tuempresa.com" class="border-b-2 border-zinc-200 py-2 focus:border-accent outline-none transition-colors bg-transparent text-sm" />
            </div>
            <div class="flex flex-col gap-1.5">
              <label class="text-[9px] font-black uppercase tracking-widest opacity-40">Mensaje</label>
              <textarea name="msg" rows="2" class="border-b-2 border-zinc-200 py-2 focus:border-accent outline-none transition-colors bg-transparent text-sm resize-none"></textarea>
            </div>

            <div class="flex items-start gap-2 pt-1">
              <input type="checkbox" id="lp-terms" name="terms" required class="mt-0.5 accent-accent flex-shrink-0" />
              <label for="lp-terms" class="text-[10px] text-zinc-400 font-light cursor-pointer select-none leading-tight">
                Acepto la <a href="/privacidad/" class="underline hover:text-accent transition-colors">política de privacidad</a>.
              </label>
            </div>

            <button type="submit" id="lp-submit-btn" class="w-full btn-mktg-v5 !py-4 shadow-[0_8px_20px_rgba(37,211,102,0.3)]">
              SOLICITAR AUDITORÍA →
            </button>
          </form>
        </div>
      </div>

    </div>
  </div>

  <!-- Mobile: tarjeta + claim fijados al fondo del hero -->
  <div class="sm:hidden absolute bottom-4 left-4 right-4 flex flex-col gap-5">
    <div class="bg-white rounded-3xl border-2 border-black/8 shadow-[0_20px_60px_rgba(0,0,0,0.1)] p-6">
      <span class="text-[9px] font-black uppercase tracking-[0.4em] text-accent block mb-2">Sin compromiso</span>
      <div class="text-xl font-black uppercase tracking-tighter mb-4 leading-tight">Si contactas hoy,<br>Auditoría SEO Gratuita</div>
      <button class="contact-modal-trigger w-full btn-mktg-v5 !py-4 shadow-[0_8px_20px_rgba(37,211,102,0.3)]">
        SOLICITAR AUDITORÍA →
      </button>
    </div>
    <p class="font-black uppercase tracking-tight text-zinc-900 leading-none text-center text-[0.95rem]">
      Somos la agencia SEO nº1 en Barcelona
    </p>
  </div>
</section>

<LogoMarquee />

<!-- ═══ AUDITORÍA Y ESTRATEGIA ════════════════════════════════════════ -->
<section id="auditoria" class="py-20 sm:py-32 bg-zinc-50 border-y border-black/5 px-4 sm:px-6 relative overflow-hidden">
  <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808005_1px,transparent_1px),linear-gradient(to_bottom,#80808005_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_50%,#000_80%,transparent_100%)]"></div>
  <div class="max-w-7xl mx-auto relative z-10">
    <div class="text-center mb-16 sm:mb-24 reveal">
      <span class="text-[10px] font-black uppercase tracking-[0.3em] text-accent mb-4 block">Nuestro enfoque</span>
      <h2 class="text-3xl sm:text-5xl lg:text-7xl uppercase tracking-tighter font-black mb-6">
        Auditoría y Estrategia<br class="hidden sm:inline" /> SEO en Barcelona
      </h2>
      <p class="text-zinc-500 font-light text-base sm:text-lg max-w-2xl mx-auto leading-relaxed">
        En Barcelona, improvisar en SEO es tirar el presupuesto. Analizamos tu competencia por barrio y sector para encontrar los huecos de oportunidad que otros no ven y posicionarte donde tus clientes te buscan.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 gap-6">
      {[
        { num: '01', title: 'Auditoría Técnica', desc: 'Detectamos los errores que frenan tu visibilidad en Barcelona: velocidad, indexación, Core Web Vitals y arquitectura de URLs para el mercado barcelonés.' },
        { num: '02', title: 'Keywords por Barrio', desc: 'Analizamos las búsquedas de cada zona de Barcelona para posicionar tu negocio donde está tu cliente ideal: Eixample, 22@, Gràcia, Poblenou o Sarrià.' },
        { num: '03', title: 'SEO On-Page', desc: 'Optimizamos contenidos y estructura para que Google entienda que eres la mejor opción en tu barrio y sector dentro de Barcelona.' },
        { num: '04', title: 'Linkbuilding Barcelonés', desc: 'Construimos autoridad con enlaces de medios digitales barceloneses, directorios locales y webs de referencia que potencian tu posición en Google.' },
      ].map((p, i) => (
        <div class="group p-8 sm:p-10 bg-white border border-zinc-100/60 rounded-3xl hover:border-accent/20 hover:shadow-2xl hover:-translate-y-2 transition-all duration-500 relative overflow-hidden flex gap-6 reveal" style={`transition-delay: ${i * 80}ms`}>
          <div class="absolute bottom-0 inset-x-0 h-1 bg-gradient-to-r from-accent via-accent/90 to-purple-600 w-0 group-hover:w-full transition-all duration-500"></div>
          <div class="text-4xl font-black tracking-tighter text-black/5 group-hover:text-accent/10 transition-colors select-none flex-shrink-0 leading-none mt-1">{p.num}</div>
          <div>
            <h3 class="text-lg sm:text-xl font-black uppercase tracking-tighter mb-3 text-zinc-900">{p.title}</h3>
            <p class="text-sm text-zinc-500 font-light leading-relaxed">{p.desc}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-16 text-center reveal">
      <button class="contact-modal-trigger btn-mktg-v5 shadow-[0_10px_30px_rgba(37,211,102,0.3)]">
        SOLICITAR AUDITORÍA GRATUITA
      </button>
    </div>
  </div>
</section>

<!-- ═══ CÓMO TRABAJAMOS ════════════════════════════════════════════════ -->
<section id="metodo" class="py-20 sm:py-32 bg-accent px-4 sm:px-6">
  <div class="max-w-7xl mx-auto grid md:grid-cols-2 gap-12 sm:gap-20 items-center">
    <div class="reveal text-white">
      <span class="text-[10px] font-black uppercase tracking-[0.5em] mb-6 sm:mb-10 block opacity-70">El proceso</span>
      <div class="text-4xl sm:text-7xl lg:text-8xl font-black uppercase tracking-tighter leading-[0.82] mb-8 sm:mb-10">
        Cómo<br>trabajamos<br>el SEO
      </div>
      <p class="text-white/70 font-light text-base sm:text-xl max-w-md leading-relaxed mb-8">
        Muchas agencias se obsesionan con posiciones. Nosotros nos obsesionamos con los resultados: más contactos, más ventas, más clientes en Barcelona.
      </p>
      <ul class="text-[9px] sm:text-xs font-black tracking-widest space-y-3 uppercase opacity-90 text-white">
        <li>→ AUDITORÍA TÉCNICA COMPLETA</li>
        <li>→ ESTRATEGIA DE KEYWORDS LOCAL</li>
        <li>→ LINK BUILDING DE CALIDAD</li>
        <li>→ SEGUIMIENTO MENSUAL REAL</li>
      </ul>
    </div>

    <div class="reveal space-y-4">
      {[
        { num: '01', title: 'Auditoría SEO en Barcelona', desc: 'Analizamos tu web en profundidad y evaluamos la competencia en tu sector dentro de Barcelona. Identificamos los errores técnicos y las oportunidades de posicionamiento por barrio y por keyword.' },
        { num: '02', title: 'Keyword Research por Barrios', desc: 'Barcelona se posiciona barrio a barrio. Identificamos las búsquedas con mayor intención de compra en tu zona — Eixample, Gràcia, Poblenou, Sarrià — para atraer el tráfico más cualificado.' },
        { num: '03', title: 'SEO On-Page y Contenidos', desc: 'Creamos y optimizamos contenidos que posicionan tu negocio en Barcelona. Desde landing pages de barrio hasta artículos de blog que construyen autoridad temática en tu sector.' },
        { num: '04', title: 'Linkbuilding en Medios Barcelona', desc: 'Conseguimos menciones y enlaces en medios digitales barceloneses, directorios locales y webs de referencia que trasladan autoridad a tu dominio y mejoran tu ranking.' },
        { num: '05', title: 'SEO Local y Google Maps', desc: 'Posicionamos tu ficha de Google Business Profile para que aparezcas en el pack local cuando alguien busca tu servicio en tu barrio de Barcelona. Más reseñas, más visibilidad, más clientes.' },
      ].map(s => (
        <div class="bg-white/10 backdrop-blur-sm p-6 sm:p-8 rounded-3xl border border-white/10 hover:bg-white/15 transition-colors flex gap-6 items-start">
          <div class="text-white/40 font-black text-lg tracking-tighter flex-shrink-0 w-8">{s.num}</div>
          <div>
            <h3 class="text-sm font-black uppercase tracking-tight text-white mb-1">{s.title}</h3>
            <p class="text-white/60 font-light text-sm leading-relaxed">{s.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ═══ CONSULTOR SEO + STATS ══════════════════════════════════════════ -->
<section id="resultados" class="py-20 sm:py-32 bg-white px-4 sm:px-6 relative overflow-hidden">
  <div class="absolute -top-40 right-1/4 w-96 h-96 bg-accent/10 rounded-full blur-3xl opacity-20 animate-pulse"></div>
  <div class="max-w-7xl mx-auto">

    <div class="grid md:grid-cols-2 gap-12 sm:gap-20 items-center mb-20 sm:mb-32">
      <div class="reveal">
        <span class="text-[10px] font-black uppercase tracking-[0.3em] text-accent mb-4 block">Estrategia SEO</span>
        <h2 class="text-3xl sm:text-5xl lg:text-6xl uppercase tracking-tighter font-black mb-6">
          Consultor de posicionamiento SEO en Barcelona
        </h2>
        <p class="text-zinc-500 font-light text-base sm:text-lg leading-relaxed mb-8">
          Como consultor experto en SEO en Barcelona, diseño estrategias hipersegmentadas por barrio para que tu empresa aparezca cuando tus clientes te buscan en Google. Conozco la realidad del mercado barcelonés —desde el Eixample comercial y el 22@ tecnológico hasta el Born, Poblenou y Sarrià— y construyo visibilidad orgánica duradera donde está tu cliente ideal.
        </p>
        <button class="contact-modal-trigger btn-mktg-v5 shadow-[0_10px_30px_rgba(37,211,102,0.3)]">
          QUIERO POSICIONAR MI EMPRESA
        </button>
      </div>
      <div class="reveal space-y-4">
        {[
          { icon: `<svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><circle cx="12" cy="12" r="3"/></svg>`, title: 'SEO Técnico', desc: 'Arquitectura y velocidad optimizadas para que Google pueda rastrear e indexar tu web correctamente.' },
          { icon: `<svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`, title: 'Tráfico Local', desc: 'Clientes de Barcelona con intención de compra real. No visitas genéricas, sino potenciales contactos por barrio.' },
          { icon: `<svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>`, title: 'Account Manager Dedicado', desc: 'Un consultor exclusivo para tu proyecto. Sin intermediarios, comunicación directa y respuesta rápida.' },
          { icon: `<svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>`, title: 'Orientado a Conversión', desc: 'No optimizamos para tráfico vacío. Cada decisión está tomada para generar contactos y ventas reales.' },
        ].map((f, i) => (
          <div class="group p-6 bg-white border border-zinc-100/60 rounded-2xl hover:border-accent/20 hover:shadow-lg transition-all duration-300 flex gap-4 items-start reveal" style={`transition-delay: ${i * 80}ms`}>
            <div class="p-2.5 bg-zinc-50 border border-black/5 rounded-xl flex-shrink-0 group-hover:bg-accent/5 group-hover:border-accent/10 transition-colors">
              <Fragment set:html={f.icon} />
            </div>
