---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { buildAlternates } from '../../lib/i18n';
import { localAgencySchema } from '../../lib/schema';
import { strapiClient } from '../../lib/strapi';
import LogoMarquee from '../../components/sections/LogoMarquee.astro';
import FaqHome from '../../components/sections/FaqHome.astro';
import CityPills from '../../components/global/CityPills.astro';
import GoogleReviews from '../../components/global/GoogleReviews.astro';

const SITE_URL = import.meta.env.PUBLIC_SITE_URL || 'https://novamarketing.es';
const alternates = buildAlternates('/agencia-geo-para-pymes/sant-cugat/', '/ca/agencia-geo-per-pimes/sant-cugat/', SITE_URL);

let allCases: any[] = [];
try {
  const casesRes = await strapiClient.getCaseStudies('es');
  allCases = casesRes.data.map((i: any) => i.attributes ?? i).filter((c: any) => {
    const cats = (c.categories || []).map((cat: any) => (cat.slug || cat.attributes?.slug || '').toLowerCase());
    return cats.some((s: string) => s.includes('seo'));
  });
} catch {}

const steps = [
  { title: "Visibilidad en IA de tu empresa en Sant Cugat", desc: "Preguntamos a ChatGPT, Gemini, Claude y Perplexity lo mismo que preguntarían tus clientes. Medimos si apareces, cómo te describen y a qué competidores recomiendan antes que a ti. Ese es tu punto de partida real." },
  { title: "Hoja de ruta GEO documentada", desc: "Recibes una hoja de ruta por escrito. Qué preguntas de cliente atacar, qué contenido crear, qué señales de autoridad reforzar y qué resultados esperar en 3, 6 y 12 meses. Sabes en qué se invierte cada euro antes de invertirlo." },
  { title: "Optimización para motores generativos", desc: "Reestructuramos tu contenido para que la IA pueda citarlo. Respuestas directas, datos verificables, marcado estructurado y una entidad de marca coherente en toda la web. Lo que no se puede citar no se recomienda." },
  { title: "Autoridad corporativa y citabilidad", desc: "Los modelos de IA recomiendan lo que encuentran en fuentes fiables. Menciones en medios, reseñas, directorios y contenido experto. Construimos esas señales para que tu empresa sea la respuesta y no una opción más." },
  { title: "Medición y ajuste continuo", desc: "Monitorizamos mes a mes tus menciones en ChatGPT, Gemini, Perplexity y Google AI Overviews. En el informe ves en qué preguntas apareces, cómo evolucionas frente a tu competencia y qué toca ajustar." }
];

const criteria = [
  { title: "Pide resultados verificables en la IA", desc: "Cualquiera puede llamarse experto en GEO porque es una disciplina nueva. Pide una demostración en directo. Que pregunten a ChatGPT o Perplexity por sus propios clientes y te enseñen dónde aparecen. Si no pueden enseñarte ni un caso, sigue buscando." },
  { title: "Pregunta quién llevará tu cuenta", desc: "En muchas agencias vende un director y ejecuta un junior con 30 cuentas. Exige conocer a la persona que trabajará tu proyecto antes de firmar. En nova hablas siempre con el consultor que ejecuta tu estrategia GEO, presencialmente o por videollamada." },
  { title: "Exige propiedad de tus activos", desc: "La web, el contenido, los datos estructurados y la analítica deben estar a tu nombre. Si la agencia retiene tus activos no estás contratando un servicio de posicionamiento GEO, estás firmando una dependencia." },
  { title: "Desconfía de quien garantiza aparecer en ChatGPT", desc: "Nadie controla qué responde un modelo de IA. No hay anuncios que comprar ni posiciones garantizadas. Quien te promete aparecer siempre en las respuestas de la IA, miente. Lo serio es garantizar método, señales medibles y trabajo verificable." },
  { title: "Revisa qué mide el informe mensual", desc: "Si el informe no incluye en qué preguntas apareces, cómo te describe la IA y qué menciones has ganado, la agencia está midiendo su actividad y no tu visibilidad. El GEO se mide en menciones, citas y clientes que llegan diciendo que los ha enviado ChatGPT." },
  { title: "Huye de las permanencias largas", desc: "Una permanencia de 12 meses protege a la agencia, no a ti. El trabajo bien hecho retiene clientes sin necesidad de contratos que los aten. Por eso en nova trabajamos mes a mes." },
  { title: "Que combine GEO con SEO", desc: "El GEO no sustituye al SEO, se alimenta de él. Los modelos de IA citan contenido que ya es visible, estructurado y con autoridad. Una consultoría GEO que ignora tu posicionamiento en Google está construyendo sobre arena." }
];

const faqs = [
  { question: "¿Qué es el GEO y por qué importa en Sant Cugat?", answer: "El GEO (Generative Engine Optimization) hace que los asistentes de IA recomienden tu empresa en sus respuestas. En un mercado como Sant Cugat, con un cliente digitalizado y de renta alta que ya usa ChatGPT para elegir, no aparecer en esas respuestas es regalar clientes a quien sí aparece." },
  { question: "¿Por qué la IA recomienda a mi competencia y a mí no?", answer: "Porque los modelos deciden con señales concretas. Reseñas, coherencia de marca, contenido citable y menciones en fuentes fiables. La auditoría GEO te dice exactamente qué señales tiene tu competencia que tú no, y qué hace falta para darle la vuelta." },
  { question: "¿Funciona el GEO para empresas corporativas y tecnológicas?", answer: "Sí, y es donde antes se nota. Los decisores del parque empresarial de Sant Cugat validan proveedores preguntando a la IA antes de contactar. Contenido con autoridad técnica y una entidad de marca bien definida te meten en esa lista corta." },
  { question: "¿Cuánto cuesta el posicionamiento GEO en Sant Cugat?", answer: "La auditoría GEO cuesta 1.800 euros y los planes mensuales van desde 400 euros al mes para pymes y desde 900 para empresas medianas. Presupuesto cerrado por escrito, sin permanencias y sin sorpresas." },
  { question: "¿Cuánto se tarda en salir en las respuestas de la IA?", answer: "Con una base de presencia digital cuidada, algo habitual en los negocios de Sant Cugat, los primeros cambios pueden verse en semanas. Partiendo de cero, lo normal es ganar menciones entre el tercer y el sexto mes." },
  { question: "¿Cómo medís los resultados?", answer: "Con un panel mensual de preguntas reales en ChatGPT, Gemini, Claude y Perplexity. Ves en qué preguntas apareces, cómo te describe cada modelo y cómo evolucionas frente a tu competencia, además de los leads que llegan citando a la IA." },
  { question: "¿Necesito tener el SEO hecho antes de empezar con GEO?", answer: "Ayuda pero no es imprescindible. La IA cita contenido visible y con autoridad, así que un buen SEO acelera el GEO. Si aún no lo trabajas, integramos las dos disciplinas en una sola estrategia y cada acción suma en los dos frentes." },
];

const sectors = [
  { icon: '🛒', title: 'GEO para ecommerce', href: '/agencia-ecommerce/posicionamiento-geo/', desc: 'Cuando alguien pregunta a la IA qué producto comprar, quien aparece en la respuesta se lleva la venta. Optimizamos fichas, comparativas y reseñas para que tu tienda sea la recomendada.' },
  { icon: '🏠', title: 'GEO para inmobiliarias', href: '/agencia-inmobiliarias/posicionamiento-geo/', desc: 'Los compradores ya preguntan a ChatGPT por agencias de confianza en su zona. Construimos la autoridad y las señales locales para que la IA te ponga en la respuesta.' },
  { icon: '🍽️', title: 'GEO para restaurantes', href: '/agencia-restaurantes/posicionamiento-geo/', desc: 'La pregunta de dónde comer bien cerca ya se le hace a la IA. Reseñas, ficha impecable y contenido citable para que tu restaurante salga en la recomendación.' },
  { icon: '🧠', title: 'GEO para psicólogos', desc: 'Las consultas de salud mental empiezan cada vez más en un chat de IA. Contenido con autoridad clínica y señales de confianza para que la IA derive pacientes a tu consulta.' },
  { icon: '🌿', title: 'GEO para terapeutas', desc: 'Un sector donde casi nadie trabaja el posicionamiento en IA todavía: ser el primero de tu especialidad en tu zona es más fácil que en Google. Aprovecha la ventana.' },
  { icon: '🦷', title: 'GEO para dentistas', desc: 'Qué dentista me recomiendas en mi ciudad es una pregunta diaria en ChatGPT. Autoridad clínica, reseñas y entidad bien definida para ser la respuesta.' },
  { icon: '💪', title: 'GEO para gimnasios', desc: 'La IA compara gimnasios por reseñas, servicios y cercanía. Optimizamos esas señales para que te recomiende a ti en enero... y el resto del año.' },
  { icon: '🏗️', title: 'GEO para constructoras', desc: 'Leads de valor alto que ya validan proveedores preguntando a la IA. Casos documentados y autoridad verificable para entrar en la lista corta.' },
  { icon: '⚖️', title: 'GEO para abogados', desc: 'Las dudas legales son de las consultas más frecuentes en la IA. Quien resuelve la duda con autoridad se lleva la consulta. Contenido citable por especialidad.' },
  { icon: '🏨', title: 'GEO para hoteles', desc: 'Los viajeros planifican con ChatGPT y Perplexity. Señales de marca, reseñas y contenido estructurado para aparecer en el itinerario antes que las OTAs.' },
  { icon: '🏭', title: 'GEO para B2B', desc: 'El responsable de compras pregunta a la IA por proveedores antes de buscar en Google. Fichas técnicas citables y autoridad sectorial para estar en esa respuesta.' },
  { icon: '🎓', title: 'GEO para escuelas', desc: 'Las familias comparan centros preguntando a la IA. Proyecto educativo bien explicado, reseñas y datos estructurados para salir en la comparativa.' },
];

const pageSchema = localAgencySchema({
  pageUrl: `${SITE_URL}/agencia-geo-para-pymes/sant-cugat/`,
  lang: 'es',
  cityName: 'Sant Cugat',
  postalCode: '08172',
  geo: { lat: 41.4736, lng: 2.0861 },
  areaServed: ["Sant Cugat del Vallès", "Vallès Occidental", "Barcelona", "España"],
  title: "Agencia GEO en Sant Cugat | Posicionamiento en IA para PYMEs",
  description: "Agencia GEO en Sant Cugat. Posicionamiento en IA (GEO/AEO) para que ChatGPT, Gemini, Perplexity y Google AI Overviews recomienden tu empresa a los clientes de Sant Cugat y su comarca.",
  datePublished: '2026-07-15',
  dateModified: '2026-07-15',
  breadcrumbName: 'Agencia GEO en Sant Cugat',
  faqs,
});
---

<BaseLayout
  title="Agencia GEO en Sant Cugat | Posicionamiento en IA para PYMEs"
  description="Agencia GEO en Sant Cugat. Posicionamiento en IA (GEO/AEO) para que ChatGPT, Gemini, Perplexity y Google AI Overviews recomienden tu empresa a los clientes de Sant Cugat y su comarca."
  locale="es"
  alternates={alternates}
  schemas={[pageSchema]}
>

    <!-- ═══ HERO / H1 ═══════════════════════════════════════════════════════ -->
    <section class="pt-24 sm:pt-40 pb-20 px-4 sm:px-6 relative overflow-hidden text-center bg-white border-b border-black/5">
        <!-- Background Grid Mesh -->
        <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808008_1px,transparent_1px),linear-gradient(to_bottom,#80808008_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_40%,#000_75%,transparent_100%)]"></div>

        <!-- Glow Orbs -->
        <div class="absolute -top-10 left-1/4 w-72 h-72 bg-accent/15 rounded-full blur-3xl opacity-30 animate-pulse"></div>
        <div class="absolute top-20 right-1/4 w-80 h-80 bg-purple-500/5 rounded-full blur-3xl opacity-20"></div>

        <div class="max-w-5xl mx-auto reveal">
            <span class="inline-flex items-center gap-2 bg-accent/5 backdrop-blur-sm px-4 py-2 border border-accent/10 rounded-full text-accent text-[8px] sm:text-[10px] font-black uppercase tracking-[0.3em] mb-8 shadow-sm">
                <span class="w-1.5 h-1.5 bg-accent rounded-full animate-ping"></span>
                Optimización para Motores Generativos
            </span>
            <h1 class="text-3xl sm:text-5xl md:text-7xl lg:text-8xl uppercase font-extrabold tracking-tighter leading-[0.88] mb-8 text-gradient flex flex-col items-center text-center">
                <span class="lg:whitespace-nowrap">Agencia GEO </span>
                <span class="lg:whitespace-nowrap">Posicionamiento </span>
                <span class="lg:whitespace-nowrap text-mktg-gradient">en IA en Sant Cugat</span>
            </h1>
            <p class="text-lg sm:text-xl text-zinc-500 font-light leading-relaxed w-[75%] mx-auto mb-8">
                Haz que ChatGPT, Gemini, Claude y Perplexity recomienden tu empresa. Servicio de posicionamiento GEO para PYMEs de Sant Cugat con estrategia a medida, precios claros y resultados que se miden en menciones y clientes.
            </p>
            <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3 mb-10">
                {['Sin permanencias', 'Trato directo con el consultor', 'Informes de negocio'].map(item => (
                    <span class="inline-flex items-center gap-2 text-[11px] sm:text-xs font-black uppercase tracking-widest text-zinc-700">
                        <svg class="w-4 h-4 text-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                        </svg>
                        {item}
                    </span>
                ))}
            </div>
            <div class="flex justify-center mt-4">
                <a href="#contacto" class="contact-modal-trigger btn-mktg-v5 shadow-[0_10px_30px_rgba(0,0,0,0.1)] !py-4 sm:!py-5 !px-6 sm:!px-10 !text-[11px] !tracking-widest font-black">
                    HABLEMOS DE TU NEGOCIO
                </a>
            </div>
        </div>
    </section>

    <LogoMarquee />

    <!-- ═══ INTRO: QUÉ ES EL GEO ═══════════════════════════════════════════ -->
    <section class="py-16 sm:py-24 bg-white px-4 sm:px-6 border-b border-black/5">
        <div class="max-w-6xl mx-auto reveal grid md:grid-cols-[1.3fr_1fr] gap-10 md:gap-16 items-center">
            <div>
                <p class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4">¿Qué es el GEO?</p>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-8 text-zinc-900 leading-[0.9]">
                    La agencia de posicionamiento en IA para tu pyme en Sant Cugat
                </h2>
                <div class="space-y-6 text-zinc-600 font-light text-base sm:text-lg leading-relaxed">
                    <p>
                        <strong class="font-semibold text-zinc-900">El GEO (Generative Engine Optimization) es la optimización para motores generativos</strong>. Es el conjunto de técnicas que hacen que los asistentes de IA como ChatGPT, Gemini, Claude, Perplexity o Google AI Overviews mencionen y recomienden tu empresa en sus respuestas. También lo verás llamado AEO, answer engine optimization.
                    </p>
                    <p>
                        Cada día más clientes ya no buscan en Google. Le preguntan directamente a la IA qué empresa contratar. Nova es una <strong class="font-semibold text-zinc-900">agencia GEO especializada en PYMEs</strong>: trabajamos con un número limitado de clientes, cada cuenta la lleva directamente el consultor fundador y toda la estrategia se orienta a una sola métrica que importa. <strong class="font-semibold text-zinc-900">Que la IA recomiende tu negocio antes que a tu competencia</strong>.
                    </p>
                </div>
            </div>
            <div class="hidden md:block">
                <img src="/sergio-galos-agencia-geo-para-pymes-sant-cugat.webp" alt="Sergio Galo's, experto en GEO y posicionamiento en IA en Sant Cugat" title="Sergio Galo's, experto en GEO y posicionamiento en IA en Sant Cugat" class="w-full h-auto" loading="lazy" />
            </div>
        </div>
    </section>

    <!-- ═══ SERVICIOS GEO ══════════════════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-zinc-50 border-b border-black/5 px-4 sm:px-6">
        <div class="max-w-7xl mx-auto text-center reveal">
            <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Qué hacemos</span>
            <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.9]">
                Servicio de posicionamiento GEO para PYMEs en Sant Cugat
            </h2>
            <div class="text-zinc-500 font-light text-sm sm:text-base leading-relaxed max-w-3xl mx-auto mb-16 space-y-4">
                <p>
                    El <strong class="font-semibold text-zinc-700">posicionamiento GEO</strong> no es una sola tarea, es un sistema. Estas son las nueve piezas que trabajamos para que tu pyme pase de ser invisible para la IA a ser la empresa que aparece en sus respuestas.
                </p>
                <p>
                    Cada pieza se activa según lo que diga tu auditoría. No pagas por un paquete cerrado de acciones, pagas por las que tu negocio necesita.
                </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                <div class="bg-white border border-black/5 rounded-2xl p-6 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 text-left">
                    <div class="flex items-center gap-3 mb-3">
                        <div class="w-10 h-10 rounded-full bg-accent/10 border border-accent/20 flex items-center justify-center flex-shrink-0"><svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg></div>
                        <h3 class="text-sm font-black uppercase tracking-tight text-zinc-900">Auditoría GEO en Sant Cugat</h3>
                    </div>
                    <p class="text-sm text-zinc-500 font-light leading-relaxed">Radiografía de tu visibilidad en ChatGPT, Gemini, Claude y Perplexity antes de tocar nada.</p>
                </div>
                <div class="bg-white border border-black/5 rounded-2xl p-6 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 text-left">
                    <div class="flex items-center gap-3 mb-3">
                        <div class="w-10 h-10 rounded-full bg-accent/10 border border-accent/20 flex items-center justify-center flex-shrink-0"><svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="4"/></svg></div>
                        <h3 class="text-sm font-black uppercase tracking-tight text-zinc-900">Entidad de marca a la altura de Sant Cugat</h3>
                    </div>
                    <p class="text-sm text-zinc-500 font-light leading-relaxed">Hacemos que la IA entienda sin dudas quién eres, qué haces y dónde. Una sola identidad en toda la red.</p>
                </div>
                <div class="bg-white border border-black/5 rounded-2xl p-6 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 text-left">
                    <div class="flex items-center gap-3 mb-3">
                        <div class="w-10 h-10 rounded-full bg-accent/10 border border-accent/20 flex items-center justify-center flex-shrink-0"><svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M9 12h6m-6 4h6M9 8h2m8-3v14a2 2 0 01-2 2H7a2 2 0 01-2-2V5a2 2 0 012-2h6l4 4z"/></svg></div>
                        <h3 class="text-sm font-black uppercase tracking-tight text-zinc-900">Contenido citable para un cliente exigente</h3>
                    </div>
                    <p class="text-sm text-zinc-500 font-light leading-relaxed">Páginas pensadas para que un modelo las extraiga y las cite al responder las preguntas de tus clientes.</p>
                </div>
                <div class="bg-white border border-black/5 rounded-2xl p-6 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 text-left">
                    <div class="flex items-center gap-3 mb-3">
                        <div class="w-10 h-10 rounded-full bg-accent/10 border border-accent/20 flex items-center justify-center flex-shrink-0"><svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg></div>
                        <h3 class="text-sm font-black uppercase tracking-tight text-zinc-900">Datos estructurados de tu empresa</h3>
                    </div>
                    <p class="text-sm text-zinc-500 font-light leading-relaxed">Traducimos tu negocio al lenguaje que leen las máquinas con marcado schema en toda la web.</p>
                </div>
                <div class="bg-white border border-black/5 rounded-2xl p-6 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 text-left">
                    <div class="flex items-center gap-3 mb-3">
                        <div class="w-10 h-10 rounded-full bg-accent/10 border border-accent/20 flex items-center justify-center flex-shrink-0"><svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M12 3l2.6 5.3 5.9.9-4.2 4.1 1 5.8L12 16.3 6.7 19l1-5.8L3.5 9.2l5.9-.9L12 3z"/></svg></div>
                        <h3 class="text-sm font-black uppercase tracking-tight text-zinc-900">Autoridad y reseñas de nivel corporativo</h3>
                    </div>
                    <p class="text-sm text-zinc-500 font-light leading-relaxed">Trabajamos las fuentes en las que confía la IA. Medios, directorios y reseñas que avalan tu marca.</p>
                </div>
                <div class="bg-white border border-black/5 rounded-2xl p-6 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 text-left">
                    <div class="flex items-center gap-3 mb-3">
                        <div class="w-10 h-10 rounded-full bg-accent/10 border border-accent/20 flex items-center justify-center flex-shrink-0"><svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M17.657 16.657L13.414 20.9a2 2 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><circle cx="12" cy="11" r="3"/></svg></div>
                        <h3 class="text-sm font-black uppercase tracking-tight text-zinc-900">GEO local para Mira-sol, Valldoreix y el centro</h3>
                    </div>
                    <p class="text-sm text-zinc-500 font-light leading-relaxed">Para negocios con clientes cerca. Que la IA te recomiende cuando alguien pregunta por tu servicio en tu zona.</p>
                </div>
                <div class="bg-white border border-black/5 rounded-2xl p-6 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 text-left">
                    <div class="flex items-center gap-3 mb-3">
                        <div class="w-10 h-10 rounded-full bg-accent/10 border border-accent/20 flex items-center justify-center flex-shrink-0"><svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm8 0V5a2 2 0 012-2h0a2 2 0 012 2v14a2 2 0 01-2 2h0a2 2 0 01-2-2zm-8 0a2 2 0 002 2h2a2 2 0 002-2V9a2 2 0 00-2-2h-2a2 2 0 00-2 2v10z"/></svg></div>
                        <h3 class="text-sm font-black uppercase tracking-tight text-zinc-900">Monitorización de menciones y competencia</h3>
                    </div>
                    <p class="text-sm text-zinc-500 font-light leading-relaxed">Seguimiento mensual de qué responde cada modelo sobre tu marca y sobre tu competencia.</p>
                </div>
