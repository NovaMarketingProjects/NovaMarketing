<script>
  // FAQ accordion
  document.querySelectorAll('.faq-trigger').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.faq-item')!;
      const answer = item.querySelector('.faq-answer')!;
      const icon = btn.querySelector('.faq-icon')!;
      const isOpen = !answer.classList.contains('hidden');

      // Close all
      document.querySelectorAll('.faq-answer').forEach(a => a.classList.add('hidden'));
      document.querySelectorAll('.faq-icon').forEach(i => i.classList.remove('rotate-45'));
      document.querySelectorAll('.faq-trigger').forEach(b => b.setAttribute('aria-expanded', 'false'));

      if (!isOpen) {
        answer.classList.remove('hidden');
        icon.classList.add('rotate-45');
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });

  // Form submission
  const form = document.getElementById('seo-sabadell-form') as HTMLFormElement | null;
  const sendingOverlay = document.getElementById('lp-sending');
  const progressBar = document.getElementById('lp-progress');
  const submitBtn = document.getElementById('lp-submit-btn') as HTMLButtonElement | null;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (submitBtn) submitBtn.disabled = true;

    // Show sending overlay + animate progress
    sendingOverlay?.classList.remove('hidden');
    if (progressBar) {
      setTimeout(() => { progressBar.style.width = '40%'; }, 50);
      setTimeout(() => { progressBar.style.width = '70%'; }, 600);
      setTimeout(() => { progressBar.style.width = '85%'; }, 1800);
    }

    const data = {
      ...Object.fromEntries(new FormData(form)),
      source: window.location.href,
    };

    try {
      const res = await fetch('https://cms.novamarketing.es/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      if (res.ok) {
        if (progressBar) progressBar.style.width = '100%';
        setTimeout(() => { window.location.href = '/gracias/'; }, 400);
      } else {
        throw new Error('Server error');
      }
    } catch {
      sendingOverlay?.classList.add('hidden');
      if (progressBar) progressBar.style.width = '0%';
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = 'ERROR — INTÉNTALO DE NUEVO';
        submitBtn.style.background = '#ef4444';
      }
    }
  });
</script>
