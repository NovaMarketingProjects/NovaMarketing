---
import BaseLayout from '../layouts/BaseLayout.astro';
import { strapiClient } from '../lib/strapi';
import { getStrapiImageUrl } from '../lib/strapi';

let caseStudies: any[] = [];
try {
  const res = await strapiClient.getCaseStudies('es', { category: 'seo', limit: 3 });
  caseStudies = res?.data || [];
} catch (_) {}

const faqs = [
  {
    q: '¿En cuánto tiempo veré resultados con el SEO?',
    a: 'Los primeros movimientos en posiciones suelen verse entre el 2º y 3er mes. Los resultados consolidados y el aumento de tráfico orgánico constante llegan entre el 4º y 6º mes. El SEO es una inversión a medio-largo plazo con resultados acumulativos.',
  },
  {
    q: '¿Qué incluye exactamente el servicio SEO para Sabadell?',
    a: 'Auditoría técnica completa, investigación de palabras clave locales y de nicho, optimización on-page, link building de calidad, creación de contenido SEO, optimización de Google Business Profile y reportes mensuales con métricas reales.',
  },
  {
    q: '¿Trabajáis solo con empresas de Sabadell?',
    a: 'Nos especializamos en pymes del Vallès Occidental, pero trabajamos con empresas de toda Cataluña. Conocemos el mercado local de Sabadell, sus competidores y las búsquedas de tu público objetivo.',
  },
  {
    q: '¿Necesito tener una web nueva o podéis trabajar con la que tengo?',
    a: 'Trabajamos con tu web actual. La auditoría inicial nos indica qué aspectos técnicos hay que mejorar. Si la web tiene limitaciones graves, te lo decimos con claridad y podemos ayudarte también con el rediseño.',
  },
  {
    q: '¿Cuál es el compromiso mínimo de permanencia?',
    a: 'Trabajamos con contratos de 6 meses porque el SEO necesita tiempo para dar resultados medibles. Pasado ese período, la relación se renueva mes a mes.',
  },
  {
    q: '¿Cómo sé que estáis trabajando realmente?',
    a: 'Cada mes recibes un informe detallado con posiciones, tráfico orgánico, conversiones y acciones realizadas. También tienes acceso a un panel de seguimiento en tiempo real y una reunión mensual de revisión.',
  },
];
---

<BaseLayout
  title="Agencia SEO en Sabadell — Más visitas, más clientes | nova."
  description="Posicionamiento SEO para pymes en Sabadell. Auditoría gratuita, estrategia local y resultados medibles. Primera consulta sin compromiso."
  noIndex={true}
  locale="es"
>

<!-- ─── Sending overlay ─── -->
<div id="lp-sending" class="fixed inset-0 z-[200] bg-white flex flex-col items-center justify-center hidden">
  <div class="flex flex-col items-center gap-8 px-8 max-w-sm w-full text-center">
    <div class="w-16 h-16 rounded-full border-4 border-zinc-100 border-t-accent animate-spin"></div>
    <div>
      <div class="text-2xl font-black uppercase tracking-tighter text-black mb-2">Enviando...</div>
      <p class="text-zinc-400 font-light text-sm">Procesando tu solicitud,<br>un momento por favor.</p>
    </div>
    <div class="w-full bg-zinc-100 rounded-full h-1 overflow-hidden">
      <div id="lp-progress" class="h-full bg-[#25D366] rounded-full" style="width:0%;transition:width 0.4s ease"></div>
    </div>
  </div>
</div>

<!-- ─── Minimal Header ─── -->
<header class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-sm border-b border-black/5">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-3 flex items-center justify-between">
    <a href="/" class="font-black text-2xl tracking-tighter leading-none">nova.</a>
    <a
      href="#solicitar"
      class="btn-mktg-v5 !py-2.5 !px-5 !text-[10px] !tracking-[0.15em]"
    >
      AUDITORÍA GRATIS
    </a>
  </div>
</header>

<!-- ─── Hero + Form ─── -->
<section class="pt-28 pb-16 sm:pt-32 sm:pb-20 bg-white relative overflow-hidden">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-start">

      <!-- Left: copy -->
      <div class="pt-4">
        <span class="inline-block text-[10px] font-black uppercase tracking-[0.3em] text-[#25D366] mb-6">
          Agencia SEO · Sabadell
        </span>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black uppercase tracking-tighter leading-[0.9] text-black mb-6">
          Tu empresa,<br>
          <span class="text-gradient">en los primeros<br>resultados de Google</span>
        </h1>
        <p class="text-zinc-500 font-light text-lg leading-relaxed mb-8">
          Ayudamos a pymes de Sabadell a conseguir más visitas orgánicas, más llamadas y más clientes a través del posicionamiento SEO local y de nicho.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 mb-10">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-[#25D366]/10 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-[#25D366]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
              </svg>
            </div>
            <span class="text-sm font-medium text-zinc-700">Auditoría SEO gratuita</span>
          </div>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-[#25D366]/10 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-[#25D366]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
              </svg>
            </div>
            <span class="text-sm font-medium text-zinc-700">Sin permanencia mínima inicial</span>
          </div>
        </div>

        <!-- Social proof bar -->
        <div class="flex items-center gap-6 pt-8 border-t border-zinc-100">
          <div class="text-center">
            <div class="text-3xl font-black text-black tracking-tighter">+80</div>
            <div class="text-[9px] font-black uppercase tracking-[0.2em] text-accent">clientes activos</div>
          </div>
          <div class="w-px h-10 bg-zinc-100"></div>
          <div class="text-center">
            <div class="text-3xl font-black text-black tracking-tighter">+340%</div>
            <div class="text-[9px] font-black uppercase tracking-[0.2em] text-accent">tráfico medio</div>
          </div>
          <div class="w-px h-10 bg-zinc-100"></div>
          <div class="text-center">
            <div class="text-3xl font-black text-black tracking-tighter">8 años</div>
            <div class="text-[9px] font-black uppercase tracking-[0.2em] text-accent">experiencia</div>
          </div>
        </div>
      </div>

      <!-- Right: form -->
      <div id="solicitar" class="bg-black rounded-2xl p-7 sm:p-9 shadow-2xl">
        <span class="text-[9px] font-black uppercase tracking-[0.4em] text-[#25D366] block mb-3">Paso 1 de 1</span>
        <h2 class="text-xl font-black uppercase tracking-tighter text-white mb-1">
          Solicita tu auditoría SEO gratuita
        </h2>
        <p class="text-zinc-400 font-light text-sm mb-7">
          Analizamos tu web, tu competencia y te decimos exactamente por dónde empezar.
        </p>

        <form id="seo-sabadell-form" class="space-y-4">
          <div class="grid sm:grid-cols-2 gap-4">
            <div class="flex flex-col gap-1.5">
              <label class="text-[9px] font-black uppercase tracking-[0.2em] text-zinc-500">Nombre *</label>
              <input
                type="text"
                name="name"
                required
                placeholder="Tu nombre"
                class="bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-white placeholder-zinc-600 text-sm focus:border-[#25D366] focus:outline-none transition-colors"
              />
            </div>
            <div class="flex flex-col gap-1.5">
              <label class="text-[9px] font-black uppercase tracking-[0.2em] text-zinc-500">Email *</label>
              <input
                type="email"
                name="email"
                required
                placeholder="tu@empresa.com"
                class="bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-white placeholder-zinc-600 text-sm focus:border-[#25D366] focus:outline-none transition-colors"
              />
            </div>
          </div>

          <div class="grid sm:grid-cols-2 gap-4">
            <div class="flex flex-col gap-1.5">
              <label class="text-[9px] font-black uppercase tracking-[0.2em] text-zinc-500">Teléfono</label>
              <input
                type="tel"
                name="phone"
                placeholder="600 000 000"
                class="bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-white placeholder-zinc-600 text-sm focus:border-[#25D366] focus:outline-none transition-colors"
              />
            </div>
            <div class="flex flex-col gap-1.5">
              <label class="text-[9px] font-black uppercase tracking-[0.2em] text-zinc-500">Web de tu empresa</label>
              <input
                type="text"
                name="url"
                placeholder="www.tuempresa.com"
                class="bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-white placeholder-zinc-600 text-sm focus:border-[#25D366] focus:outline-none transition-colors"
              />
            </div>
          </div>

          <div class="flex flex-col gap-1.5">
            <label class="text-[9px] font-black uppercase tracking-[0.2em] text-zinc-500">¿Qué necesitas? (opcional)</label>
            <textarea
              name="msg"
              rows="3"
              placeholder="Cuéntanos brevemente tu situación actual..."
              class="bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-white placeholder-zinc-600 text-sm focus:border-[#25D366] focus:outline-none transition-colors resize-none"
            ></textarea>
          </div>

          <div class="flex items-start gap-2 pt-1">
            <input type="checkbox" id="lp-terms" name="terms" required class="mt-1 accent-[#25D366]" />
            <label for="lp-terms" class="text-xs text-zinc-500 font-light cursor-pointer select-none">
              Acepto la <a href="/politica-de-privacidad/" class="underline hover:text-white transition-colors">política de privacidad</a> y los términos y condiciones.
            </label>
          </div>

          <button
            type="submit"
            id="lp-submit-btn"
            class="w-full bg-[#25D366] hover:bg-[#128C7E] text-white font-black uppercase tracking-widest text-[11px] py-4 rounded-lg transition-colors duration-200 shadow-lg shadow-[#25D366]/20"
          >
            SOLICITAR AUDITORÍA GRATIS →
          </button>

          <p class="text-[10px] text-zinc-600 text-center font-light">
            Sin compromiso · Respuesta en menos de 24h
          </p>
        </form>
      </div>

    </div>
  </div>
</section>

<!-- ─── Logos / Trust bar ─── -->
<section class="py-8 bg-zinc-50 border-y border-zinc-100">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <p class="text-center text-[9px] font-black uppercase tracking-[0.4em] text-zinc-400 mb-6">
      Empresas de Sabadell y el Vallès que confían en nova.
    </p>
    <div class="flex flex-wrap justify-center items-center gap-8 opacity-40 grayscale">
      <span class="text-lg font-black tracking-tighter text-zinc-600">Restaurante Loremar</span>
      <span class="text-lg font-black tracking-tighter text-zinc-600">Clínica Dental</span>
      <span class="text-lg font-black tracking-tighter text-zinc-600">Constructora</span>
      <span class="text-lg font-black tracking-tighter text-zinc-600">E-commerce</span>
      <span class="text-lg font-black tracking-tighter text-zinc-600">Despacho Legal</span>
    </div>
  </div>
</section>

<!-- ─── Problems ─── -->
<section class="py-20 bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-14">
      <span class="text-[10px] font-black uppercase tracking-[0.3em] text-accent block mb-4">El problema</span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-black uppercase tracking-tighter leading-tight">
        ¿Te suena alguna<br>de estas situaciones?
      </h2>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {[
        {
          icon: '🔍',
          title: 'No apareces en Google',
          desc: 'Buscas tu empresa o tus servicios en Google y no apareces ni en la primera página. Tus competidores sí están.',
        },
        {
          icon: '📉',
          title: 'Tu web no genera clientes',
          desc: 'Tienes una web bonita pero no recibe visitas. El poco tráfico que llega no se convierte en contactos ni ventas.',
        },
        {
          icon: '💸',
          title: 'Dependes de publicidad de pago',
          desc: 'Inviertes en Google Ads cada mes pero si paras la inversión, el tráfico desaparece. No tienes visibilidad orgánica.',
        },
        {
          icon: '🏙️',
          title: 'No te encuentran en Sabadell',
          desc: 'Clientes potenciales cerca de ti buscan tus servicios pero acaban en la competencia porque no te encuentran localmente.',
        },
        {
          icon: '😤',
          title: 'Probaste SEO y no funcionó',
          desc: 'Ya invertiste en SEO antes y no viste resultados. No sabes qué hicieron ni por qué no funcionó.',
        },
        {
          icon: '⏱️',
          title: 'No tienes tiempo para gestionarlo',
          desc: 'Sabes que el SEO es importante pero llevar el negocio no te deja tiempo para aprender y aplicarlo correctamente.',
        },
      ].map(p => (
        <div class="bg-zinc-50 border border-zinc-100 rounded-2xl p-6 hover:border-accent/30 transition-colors">
          <div class="text-3xl mb-4">{p.icon}</div>
          <h3 class="text-sm font-black uppercase tracking-tight text-black mb-2">{p.title}</h3>
          <p class="text-zinc-500 font-light text-sm leading-relaxed">{p.desc}</p>
        </div>
      ))}
    </div>

    <div class="mt-12 text-center">
      <p class="text-zinc-500 font-light text-lg">
        Si te has reconocido en alguno, <strong class="text-black font-black">podemos ayudarte</strong>.
      </p>
    </div>
  </div>
</section>

<!-- ─── Method / Why Nova ─── -->
<section class="py-20 bg-black text-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <div>
        <span class="text-[10px] font-black uppercase tracking-[0.3em] text-[#25D366] block mb-4">Nuestro enfoque</span>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-black uppercase tracking-tighter leading-tight mb-6">
          SEO que genera<br>negocio, no solo<br>visitas
        </h2>
        <p class="text-zinc-400 font-light text-lg leading-relaxed mb-8">
          Muchas agencias se obsesionan con las posiciones. Nosotros nos obsesionamos con los resultados de negocio: más contactos, más ventas, más clientes en Sabadell.
        </p>
        <a href="#solicitar" class="btn-mktg-v5 inline-block">
          QUIERO RESULTADOS →
        </a>
      </div>

      <div class="space-y-5">
        {[
          {
            num: '01',
            title: 'Auditoría técnica y de competencia',
            desc: 'Analizamos tu web desde cero y estudiamos qué están haciendo los primeros resultados de Google en tu sector en Sabadell.',
          },
          {
            num: '02',
            title: 'Estrategia de palabras clave local',
            desc: 'Identificamos las búsquedas exactas que hacen tus clientes potenciales en Sabadell y el Vallès Occidental.',
          },
          {
            num: '03',
            title: 'Optimización técnica y de contenido',
            desc: 'Corregimos errores técnicos, optimizamos páginas existentes y creamos contenido que posiciona y convierte.',
          },
          {
            num: '04',
            title: 'Autoridad y link building',
            desc: 'Conseguimos menciones y enlaces de calidad que incrementan la autoridad de tu web ante Google.',
          },
        ].map(s => (
          <div class="flex gap-5 p-5 bg-white/5 rounded-xl border border-white/5 hover:border-[#25D366]/30 transition-colors">
            <div class="text-[#25D366] font-black text-xl tracking-tighter flex-shrink-0 w-8">{s.num}</div>
            <div>
              <h3 class="text-sm font-black uppercase tracking-tight text-white mb-1">{s.title}</h3>
              <p class="text-zinc-400 font-light text-sm leading-relaxed">{s.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- ─── Process ─── -->
<section class="py-20 bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-14">
      <span class="text-[10px] font-black uppercase tracking-[0.3em] text-accent block mb-4">El proceso</span>
      <h2 class="text-3xl sm:text-4xl font-black uppercase tracking-tighter leading-tight">
        Así trabajamos contigo
      </h2>
      <p class="text-zinc-500 font-light text-lg mt-4 max-w-xl mx-auto">
        Un proceso claro, sin sorpresas, con comunicación constante.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {[
        { step: '1', title: 'Auditoría gratuita', desc: 'Analizamos tu web y te enviamos un informe con los puntos de mejora más importantes. Sin coste, sin compromiso.' },
        { step: '2', title: 'Propuesta personalizada', desc: 'Elaboramos una estrategia SEO adaptada a tu sector, tu competencia y tu presupuesto en Sabadell.' },
        { step: '3', title: 'Onboarding y accesos', desc: 'Configuramos herramientas, accesos y establecemos los KPIs que vamos a seguir juntos.' },
        { step: '4', title: 'Optimización técnica', desc: 'Corregimos los errores técnicos de tu web que impiden que Google la indexe correctamente.' },
        { step: '5', title: 'Contenido y posicionamiento', desc: 'Creamos y optimizamos páginas y artículos que responden a las búsquedas de tus clientes.' },
        { step: '6', title: 'Seguimiento mensual', desc: 'Cada mes recibes un informe con posiciones, tráfico y conversiones. Reunión de revisión incluida.' },
      ].map(p => (
        <div class="relative group">
          <div class="bg-zinc-50 border border-zinc-100 rounded-2xl p-6 h-full hover:border-accent/30 hover:shadow-lg transition-all duration-300">
            <div class="w-10 h-10 rounded-full bg-black text-white flex items-center justify-center font-black text-sm mb-4">
              {p.step}
            </div>
            <h3 class="text-sm font-black uppercase tracking-tight text-black mb-2">{p.title}</h3>
            <p class="text-zinc-500 font-light text-sm leading-relaxed">{p.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ─── Case Studies ─── -->
{caseStudies.length > 0 && (
<section class="py-20 bg-zinc-50 border-y border-zinc-100">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-14">
      <span class="text-[10px] font-black uppercase tracking-[0.3em] text-accent block mb-4">Casos de éxito</span>
      <h2 class="text-3xl sm:text-4xl font-black uppercase tracking-tighter leading-tight">
        Resultados reales<br>de SEO en pymes
      </h2>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {caseStudies.map((cs: any) => {
        const imageUrl = getStrapiImageUrl(cs.cover_image) || '/og-default.jpg';
        const caseUrl = `/casos-exito/${cs.slug}/`;
        return (
          <a href={caseUrl} class="group bg-white border border-black/5 rounded-2xl overflow-hidden hover:shadow-xl hover:-translate-y-1 transition-all duration-500 shadow-sm flex flex-col h-full">
            <div class="relative aspect-[4/3] overflow-hidden">
              <img
                src={imageUrl}
                alt={cs.title}
                class="w-full h-full object-cover grayscale group-hover:grayscale-0 group-hover:scale-105 transition-all duration-700"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent opacity-60 group-hover:opacity-40 transition-opacity"></div>
              {cs.company && (
                <div class="absolute bottom-3 left-3 z-10 bg-white/10 backdrop-blur-md rounded-lg px-3 py-1.5 border border-white/20">
                  <span class="text-white font-black uppercase tracking-tighter text-[9px]">{cs.company}</span>
                </div>
              )}
            </div>
            <div class="p-5 flex flex-col flex-1 bg-white">
              <div class="mb-3 flex-1">
                <h3 class="text-sm font-black uppercase tracking-tight text-zinc-900 leading-tight group-hover:text-accent transition-colors line-clamp-2">
                  {cs.title}
                </h3>
                <p class="text-zinc-500 font-light text-xs line-clamp-2 mt-2 leading-relaxed">{cs.description}</p>
              </div>
              {cs.results && cs.results.length > 0 && (
                <div class="grid grid-cols-2 gap-2 pt-3 border-t border-zinc-50 mb-3">
                  <div class="flex flex-col">
                    <span class="text-base font-black text-black leading-none">{cs.results[0].value}</span>
                    <span class="text-[7px] font-black uppercase tracking-wider text-accent">{cs.results[0].metric}</span>
                  </div>
                  {cs.results[1] && (
                    <div class="flex flex-col">
                      <span class="text-base font-black text-black leading-none">{cs.results[1].value}</span>
                      <span class="text-[7px] font-black uppercase tracking-wider text-accent">{cs.results[1].metric}</span>
                    </div>
                  )}
                </div>
              )}
              <div class="flex items-center justify-between pt-3 border-t border-zinc-50">
                <span class="text-[8px] font-black tracking-[0.25em] text-accent flex items-center gap-1.5 group-hover:gap-3 transition-all uppercase">
                  VER RESULTADOS <span class="text-sm">→</span>
                </span>
              </div>
            </div>
          </a>
        );
      })}
    </div>
  </div>
</section>
)}

<!-- ─── Comparison table ─── -->
<section class="py-20 bg-white">
  <div class="max-w-4xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-14">
      <span class="text-[10px] font-black uppercase tracking-[0.3em] text-accent block mb-4">La diferencia</span>
      <h2 class="text-3xl sm:text-4xl font-black uppercase tracking-tighter leading-tight">
        Con nova. vs sin SEO
      </h2>
    </div>

    <div class="overflow-x-auto rounded-2xl border border-zinc-100 shadow-sm">
      <table class="w-full">
        <thead>
          <tr>
            <th class="text-left p-5 text-[10px] font-black uppercase tracking-[0.2em] text-zinc-400 bg-zinc-50 border-b border-zinc-100 w-1/2">Situación</th>
            <th class="text-center p-5 text-[10px] font-black uppercase tracking-[0.2em] text-zinc-400 bg-zinc-50 border-b border-zinc-100">Sin SEO</th>
            <th class="text-center p-5 text-[10px] font-black uppercase tracking-[0.2em] text-white bg-black border-b border-black w-1/4">Con nova.</th>
          </tr>
        </thead>
        <tbody>
          {[
            ['Visibilidad en Google', '❌ Invisible', '✅ Top 3-10'],
            ['Tráfico orgánico', '❌ Casi nulo', '✅ Crecimiento constante'],
            ['Clientes de Sabadell', '❌ Solo por referidos', '✅ Canal predecible'],
