                            <input type="email" name="email" aria-label="Correu electrònic" required class="border-b border-black/10 py-2 focus:border-accent outline-none">
                        </div>
                        <div class="flex flex-col gap-3 text-[10px] font-black tracking-widest uppercase">
                            <label class="opacity-30">CONSULTA</label>
                            <textarea name="msg" aria-label="Missatge" rows="3" class="border-b border-black/10 py-2 focus:border-accent outline-none resize-none" placeholder="Què necessita el teu restaurant?"></textarea>
                        </div>
                        <button type="submit" class="w-full btn-mktg-v5 !py-6">VULL MÉS RESERVES</button>
                    </form>
                </div>
            </div>
        </div>
    </section>

</BaseLayout>

<script>
    document.getElementById('contact-form')?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const form = e.target;
        const btn = form.querySelector('button');
        if (btn) { btn.innerHTML = 'ENVIANT...'; btn.disabled = true; }
        const data = Object.fromEntries(new FormData(form));
        try {
            const res = await fetch('https://cms.novamarketing.es/api/contact', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data),
            });
            if (res.ok) {
                window.location.href = '/ca/gracies/';
            } else { throw new Error(); }
        } catch {
            if (btn) { btn.innerHTML = 'ERROR — TORNA-HO A PROVAR'; btn.disabled = false; btn.style.background = '#ef4444'; }
        }
    });
function initTimeline() {
        const progressBar = document.getElementById('progress-bar');
        const timeline = document.getElementById('timeline-container');
        if (!progressBar || !timeline) return;

        function updateProgress() {
            // lecturas primero (evita reflows forzados intercalando lectura/escritura)
            const rect = timeline.getBoundingClientRect();
            const winHeight = window.innerHeight;
            const nodes = timeline.querySelectorAll('.node-circle');
            const nodeTops = Array.from(nodes, (node) => node.getBoundingClientRect().top);
            // escrituras después
            const topPassed = (winHeight / 2) - rect.top;
            let percentage = (topPassed / rect.height) * 100;
            percentage = Math.max(0, Math.min(100, percentage));
            progressBar.style.height = `${percentage}%`;
            nodes.forEach((node, i) => {
                if (nodeTops[i] < winHeight / 2) {
                    node.classList.add('!border-accent', '!bg-accent', '!text-white');
                } else {
                    node.classList.remove('!border-accent', '!bg-accent', '!text-white');
                }
            });
        }

        let progressTick = false;
        function onProgressScroll() {
            if (progressTick) return;
            progressTick = true;
            requestAnimationFrame(() => { updateProgress(); progressTick = false; });
        }
        window.addEventListener('scroll', onProgressScroll, { passive: true });
        document.addEventListener('astro:page-load', updateProgress);
        updateProgress();
    }
    document.addEventListener('DOMContentLoaded', initTimeline);
    document.addEventListener('astro:page-load', initTimeline);
</script>
