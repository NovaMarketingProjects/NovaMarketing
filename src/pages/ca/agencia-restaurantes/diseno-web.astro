---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { buildAlternates } from '../../../lib/i18n';
import { localAgencySchema } from '../../../lib/schema';
import { strapiClient } from '../../../lib/strapi';
import LogoMarquee from '../../../components/sections/LogoMarquee.astro';
import FaqHome from '../../../components/sections/FaqHome.astro';
import CityPills from '../../../components/global/CityPills.astro';
import GoogleReviews from '../../../components/global/GoogleReviews.astro';

const SITE_URL = import.meta.env.PUBLIC_SITE_URL || 'https://novamarketing.es';
const alternates = buildAlternates('/agencia-restaurantes/diseno-web/', '/ca/agencia-restaurantes/diseno-web/', SITE_URL);

let allCases: any[] = [];
try {
  const casesRes = await strapiClient.getCaseStudies('ca');
  allCases = casesRes.data.map((i: any) => i.attributes ?? i).filter((c: any) => {
    const cats = (c.categories || []).map((cat: any) => (cat.slug || cat.attributes?.slug || '').toLowerCase());
    return cats.some((s: string) => s === 'diseno-web' || s === 'marketing-digital');
  });
} catch {}

const faqs = [
  { question: "Quant costa una web per a un restaurant?", answer: "Una landing parteix de 400 euros i una web a mida des de 120 euros al mes en 12 quotes. El preu depèn de la mida i les funcionalitats. Abans de començar reps un pressupost tancat per escrit, sense permanències." },
  { question: "La web inclou SEO?", answer: "Tota web que surt de nova inclou la base SEO de sèrie: arquitectura, velocitat, dades estructurades i indexació. Si després vols competir per posicions, el nostre SEO per a restaurants continua des d'aquesta base." },
  { question: "La web i el domini seran meus?", answer: "Sí, sempre. El domini es registra al teu nom, els continguts són teus i tens accés complet a tot. Si algun dia deixes de treballar amb nosaltres, t'emportes la teva web sencera." },
  { question: "Amb quina tecnologia la feu?", answer: "La que més convingui al teu projecte. Treballem WordPress, Desenvolupament Propi segons el que necessitis. La tecnologia és un mitjà, el criteri és què converteix millor per al teu negoci." },
  { question: "Quant es triga?", answer: "Una web corporativa sol estar llesta en 3 a 5 setmanes comptant des que rebem els continguts. Al briefing inicial et donem un calendari amb dates concretes." },
  { question: "Què passa després del llançament?", answer: "Tens un període d'ajustos inclòs i després pots contractar manteniment mensual o demanar canvis puntuals amb pressupost tancat. Mai no et quedes sol amb la web." },
  { question: "Treballeu amb permanència?", answer: "No. Pagues per la feina lliurada, en pagament únic o en 12 quotes, sense permanències ni quotes ocultes. La nostra permanència real és que la web et generi clients." },
];

const pageSchema = localAgencySchema({
  pageUrl: `${SITE_URL}/ca/agencia-restaurantes/diseno-web/`,
  lang: 'ca',
  cityName: 'Barcelona',
  postalCode: '08035',
  geo: { lat: 41.4114, lng: 2.1526 },
  areaServed: ["España", "Barcelona", "Sabadell", "Sant Cugat del Vallès", "Terrassa", "Vallès Occidental"],
  title: "▷ Disseny Web per a Restaurants | Webs Ràpides i Optimitzades",
  description: "Disseny web per a restaurants amb webs ràpides ✅ optimitzades per a Google 💡 que maximitzen la probabilitat d’omplir taules.",
  datePublished: '2026-07-17',
  dateModified: '2026-07-17',
  streetAddress: 'Carrer del General Mendoza, 10',
  hasMap: 'https://maps.app.goo.gl/9fbB12UcK32bgjj89',
  aggregateRating: { ratingValue: '5.0', reviewCount: '8' },
  breadcrumbName: "Disseny Web per a Restaurants",
  faqs,
});
---

<BaseLayout
  title="▷ Disseny Web per a Restaurants | Webs Ràpides i Optimitzades"
  description="Disseny web per a restaurants amb webs ràpides ✅ optimitzades per a Google 💡 que maximitzen la probabilitat d’omplir taules."
  locale="ca"
  alternates={alternates}
  schemas={[pageSchema]}
>

    <!-- ═══ HERO / H1 ═══════════════════════════════════════════════════════ -->
    <section class="pt-24 sm:pt-40 pb-20 px-4 sm:px-6 relative overflow-hidden text-center bg-white border-b border-black/5">
        <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808008_1px,transparent_1px),linear-gradient(to_bottom,#80808008_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_40%,#000_75%,transparent_100%)]"></div>
        <div class="absolute -top-10 left-1/4 w-72 h-72 bg-accent/15 rounded-full blur-3xl opacity-30 animate-pulse"></div>
        <div class="absolute top-20 right-1/4 w-80 h-80 bg-purple-500/5 rounded-full blur-3xl opacity-20"></div>

        <div class="max-w-5xl mx-auto reveal">
            <span class="inline-flex items-center gap-2 bg-accent/5 backdrop-blur-sm px-4 py-2 border border-accent/10 rounded-full text-accent text-[8px] sm:text-[10px] font-black uppercase tracking-[0.3em] mb-8 shadow-sm">
                <span class="w-1.5 h-1.5 bg-accent rounded-full animate-ping"></span>
                Disseny Web per a Restaurants
            </span>
            <h1 class="text-3xl sm:text-5xl md:text-7xl lg:text-8xl uppercase font-extrabold tracking-tighter leading-[0.88] mb-8 text-gradient flex flex-col items-center text-center">
                <span class="lg:whitespace-nowrap">Disseny Web </span>
                <span class="lg:whitespace-nowrap text-mktg-gradient">per a Restaurants</span>
            </h1>
            <p class="text-lg sm:text-xl text-zinc-500 font-light leading-relaxed w-[75%] mx-auto mb-8">
                La teva web és el teu millor comercial o el teu pitjor enemic. Dissenyem webs per a restaurants ràpides, optimitzades per a Google i pensades per omplir taules.
            </p>
            <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3 mb-10">
                {['Sense permanències', 'Tracte directe amb el consultor', 'Resultats mesurats en reserves'].map(item => (
                    <span class="inline-flex items-center gap-2 text-[11px] sm:text-xs font-black uppercase tracking-widest text-zinc-700">
                        <svg class="w-4 h-4 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                        {item}
                    </span>
                ))}
            </div>
            <div class="flex justify-center mt-4">
                <a href="#contacto" class="contact-modal-trigger btn-mktg-v5 shadow-[0_10px_30px_rgba(0,0,0,0.1)] !py-4 sm:!py-5 !px-6 sm:!px-10 !text-[11px] !tracking-widest font-black">
                    PARLEM DEL TEU RESTAURANT
                </a>
            </div>
        </div>
    </section>

    <LogoMarquee />

    <!-- ═══ INTRO ═══════════════════════════════════════════════════════ -->
    <section class="py-16 sm:py-24 bg-white px-4 sm:px-6 border-b border-black/5">
        <div class="max-w-6xl mx-auto reveal grid md:grid-cols-[1.3fr_1fr] gap-10 md:gap-16 items-center">
            <div>
                <p class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4">Per què la teva web importa?</p>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-8 text-zinc-900 leading-[0.9]">
                    L'agència de disseny web per a la teva restaurant
                </h2>
                <div class="space-y-6 text-zinc-600 font-light text-base sm:text-lg leading-relaxed">
                    <p>
                        <strong class="font-semibold text-zinc-900">El teu client entra a la teva web abans de decidir</strong>. En segons jutja si ets de fiar. Una web lenta o antiquada l'envia directe a la teva competència.
                    </p>
                    <p>
                        Nova és una <strong class="font-semibold text-zinc-900">agència de disseny web especialitzada en restaurants</strong>. No fem webs boniques, fem webs amb un objectiu mesurable. <strong class="font-semibold text-zinc-900">Que cada visita tingui la màxima probabilitat de omplir taules</strong>.
                    </p>
                </div>
            </div>
            <div class="hidden md:block">
                <img src="/sergio-galos-agencia-restaurantes-diseno-web.webp" alt="Sergio Galo's, consultor de disseny web gastronòmic" title="Sergio Galo's, consultor de disseny web gastronòmic" class="w-full h-auto" loading="lazy" width="473" height="591" />
            </div>
        </div>
    </section>

    <!-- ═══ SERVICIOS ══════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-zinc-50 px-4 sm:px-6 border-t border-b border-black/5">
        <div class="max-w-7xl mx-auto text-center reveal">
            <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Què fem</span>
            <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.9]">
                Servei de disseny web per a Restaurants
            </h2>
            <p class="text-zinc-500 font-light text-sm sm:text-base leading-relaxed max-w-3xl mx-auto mb-16">
                Una web que converteix no és només disseny, és un sistema. Aquestes són les nou peces que treballem.
            </p>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 text-left">
                {[
                    { t: "Disseny de web de restaurant", d: "Una web que fa gana i porta la visita a la reserva o la comanda sense giragonses." },
                    { t: "Carta visible i ràpida", d: "La pàgina més visitada de la teva web. Com a text que posiciona, no un PDF que ningú obre." },
                    { t: "Reserva a un toc", d: "El botó de reservar visible a cada pantalla, integrat amb el teu sistema. Menys passos, més taules." },
                    { t: "Comanda online directa", d: "Si fas delivery, la comanda a la teva web sense regalar comissió a les apps." },
                    { t: "Velocitat i Core Web Vitals", d: "Fotos de plats que carreguen a l'instant des del mòbil d'algú amb gana i pressa." },
                    { t: "SEO local de sèrie", d: "Connectat a la teva fitxa de Google, amb dades estructurades de restaurant que posicionen la teva zona." },
                    { t: "Fotos que venen", d: "La gana entra pels ulls. Optimitzem els teus plats per carregar ràpid i convertir." },
                    { t: "Disseny responsive real", d: "Gairebé tothom et busca des del mòbil. Dissenyem allà primer, no com un afegit." },
                    { t: "Manteniment i suport", d: "Menús, esdeveniments i canvis de temporada actualitzats sense esperes. La teva web sempre al dia." },
                ].map((c: any) => (
                    <div class="bg-white border border-black/5 rounded-2xl p-6 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
                        <h3 class="text-sm font-black uppercase tracking-tight text-zinc-900 mb-3">
                            {c.href ? <a href={c.href} class="hover:text-accent transition-colors">{c.t}</a> : c.t}
                            {c.b && <span class="block text-[11px] uppercase tracking-[0.2em] text-accent mt-1 font-semibold">{c.b}</span>}
                        </h3>
                        <p class="text-sm text-zinc-500 font-light leading-relaxed mb-2">{c.d}</p>
                        {c.href && <a href={c.href} class="text-[11px] font-black tracking-widest text-accent hover:underline">SABER MÉS →</a>}
                    </div>
                ))}
            </div>
            <div class="mt-12 text-center reveal">
                <a href="#contacto" class="contact-modal-trigger btn-mktg-v5 shadow-[0_10px_30px_rgba(37,211,102,0.3)] !py-4 sm:!py-5 !px-6 sm:!px-10 !text-[11px] !tracking-widest font-black">PARLEM DEL TEU RESTAURANT</a>
            </div>
        </div>
    </section>

    <!-- ═══ ESTRATÈGIA ════════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-white px-4 sm:px-6 relative overflow-hidden">
        <div class="max-w-5xl mx-auto">
            <div class="text-center mb-16 sm:mb-24 reveal">
                <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Com treballem</span>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.9]">
                    Així creem la web que omple taules
                </h2>
                <p class="text-zinc-500 font-light text-sm sm:text-base leading-relaxed max-w-2xl mx-auto">
                    Una metodologia documentada, pas a pas i sense fum.
                </p>
            </div>

            <div id="timeline-container" class="relative">
                <div class="hidden md:block absolute left-1/2 top-4 bottom-4 w-px bg-zinc-200 -translate-x-1/2"></div>
                <div id="progress-bar" class="hidden md:block absolute left-1/2 top-4 w-px bg-accent -translate-x-1/2 transition-all duration-100"></div>

                <div class="space-y-16 md:space-y-24 flex flex-col items-center">
                    {[
                        { title: "Briefing i Objectius", desc: "Entenem la teva restaurant, el teu client i què ha d'aconseguir la web abans de dissenyar res." },
                        { title: "Arquitectura i Continguts", desc: "Definim quines pàgines necessites i com s'organitzen, amb les keywords del teu sector integrades de sèrie." },
                        { title: "Disseny i Desenvolupament", desc: "Dissenyem una web que transmet confiança en tres segons i la desenvolupem ràpida i adaptada a mòbil." },
                        { title: "SEO Tècnic i Velocitat", desc: "Core Web Vitals en verd, dades estructurades i indexació correcta. El que altres venen com a extra, aquí és l'estàndard." },
                        { title: "Llançament i Manteniment", desc: "Publiquem, mesurem i no desapareixem. Analítica, seguretat, còpies i suport directe." },
                    ].map((step, index) => (
                        <div class="flex flex-col md:flex-row items-center gap-6 md:gap-12 w-full relative reveal">
                            <div class:list={["flex-1 w-full", index % 2 === 0 ? "md:order-1 md:text-right" : "md:order-3 md:text-left"]}>
                                <div class="p-8 sm:p-10 bg-zinc-50 border border-black/5 rounded-3xl hover:border-accent/10 hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 relative overflow-hidden group">
                                    <h3 class="text-xl font-black uppercase tracking-tighter mb-2 text-zinc-900">{index + 1}. {step.title}</h3>
                                    <div class:list={["h-0.5 bg-accent w-full mb-4 opacity-80", index % 2 === 0 ? "md:ml-auto" : ""]}></div>
                                    <p class:list={["text-sm text-zinc-500 font-light max-w-md", index % 2 === 0 ? "md:ml-auto" : ""]}>{step.desc}</p>
                                    <div class="absolute -bottom-6 -right-5 text-8xl font-black text-black/[0.02] select-none z-0 group-hover:scale-105 transition-transform duration-500">0{index+1}</div>
                                </div>
                            </div>
                            <div class="md:order-2 w-12 h-12 rounded-full border-2 border-zinc-200 bg-white flex items-center justify-center font-black text-lg z-10 shrink-0 shadow-sm node-circle transition-all">
                                0{index + 1}
                            </div>
                            <div class:list={["hidden md:block md:flex-1", index % 2 === 0 ? "md:order-3" : "md:order-1"]}></div>
                        </div>
                    ))}
                </div>
            </div>
        </div>
    </section>

    <!-- ═══ AUDITORIA ═════════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-zinc-50/50 px-4 sm:px-6 border-t border-black/5 overflow-hidden">
        <div class="max-w-7xl mx-auto grid lg:grid-cols-[6fr_4fr] gap-12 lg:gap-16 items-start">
            <div class="reveal lg:col-span-2">
                <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Punt de partida</span>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase text-zinc-900 leading-[0.9]">
                    Auditoria web gratuïta per a la teva restaurant
                </h2>
            </div>
            <div class="reveal">
                <div class="space-y-5 text-zinc-600 font-light text-base leading-relaxed mb-8">
                    <p>Saps quants segons triga la teva web a carregar des d'un mòbil? Quantes visites acaben en reserves? Gairebé ningú ho sap amb dades, i aquí comença tot.</p>
                    <p>La nostra <strong class="font-semibold text-zinc-900">auditoria web gratuïta</strong> revisa la teva pàgina actual amb ulls de client i de consultor. Velocitat, disseny, textos, SEO i conversió, i acaba amb un diagnòstic clar.</p>
                    <p>A diferència de les anàlisis automàtiques, aquí cada punt el revisa un consultor sènior. El resultat és un diagnòstic de negoci, no un llistat tècnic.</p>
                </div>
                <ul class="space-y-3">
                    {["Velocitat de càrrega des del mòbil","Primera impressió i confiança que transmet","Textos i crides a l'acció","Salut SEO i indexació a Google","Punts de fuga en el camí a la conversió","Diagnòstic prioritzat per impacte"].map(item => (
                        <li class="flex items-start gap-3 text-sm text-zinc-700 font-light">
                            <svg class="w-4 h-4 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                            {item}
                        </li>
                    ))}
                </ul>
                <div class="mt-16">
                    <a href="#contacto" class="contact-modal-trigger btn-mktg-v5 shadow-[0_10px_30px_rgba(37,211,102,0.3)] !py-4 sm:!py-5 !px-6 sm:!px-10 !text-[11px] !tracking-widest font-black">
                        VULL LA MEVA AUDITORIA WEB GRATIS
                    </a>
                </div>
            </div>
            <div class="reveal flex flex-col gap-4">
                {[
                    { bg: 'bg-purple-100', color: 'text-purple-600', t: "Test de velocitat real", d: "Quant triga la teva web des d'un mòbil amb connexió normal, que és com arriba el teu client." },
                    { bg: 'bg-green-100', color: 'text-green-600', t: "Revisió amb ulls de client", d: "Què entén en tres segons, què li genera dubtes i per què marxa sense convertir." },
                    { bg: 'bg-purple-100', color: 'text-purple-600', t: "Salut SEO de la teva web", d: "Si Google entén la teva pàgina i quina visibilitat estàs deixant escapar." },
                    { bg: 'bg-amber-100', color: 'text-amber-600', t: "Anàlisi de conversió", d: "On perd clients la teva web i quin canvi tindria més impacte." },
                    { bg: 'bg-blue-100', color: 'text-blue-600', t: "Comparativa amb la teva competència", d: "La teva web al costat dels teus tres competidors directes. On hi ha l'oportunitat." },
                ].map(card => (
                    <div class="bg-white rounded-2xl shadow-[0_15px_40px_rgba(0,0,0,0.08)] p-5 flex items-start gap-4">
                        <div class:list={["w-11 h-11 rounded-full flex items-center justify-center flex-shrink-0", card.bg]}>
                            <svg class:list={["w-5 h-5", card.color]} fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                        </div>
                        <div>
                            <h3 class="text-sm font-black text-zinc-900 mb-1">{card.t}</h3>
                            <p class="text-xs text-zinc-500 font-light leading-relaxed">{card.d}</p>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- ═══ QUÈ INCLOU L'AUDITORIA ═══════════════════════════ -->
    <section class="py-20 sm:py-28 bg-white px-4 sm:px-6 border-t border-black/5">
        <div class="max-w-7xl mx-auto">
            <div class="text-center mb-12 sm:mb-16 reveal">
                <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Pas a pas</span>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase text-zinc-900 leading-[0.9]">
                    Què inclou l'auditoria web de nova
                </h2>
            </div>
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 items-stretch reveal">
                {[
                    { n: '1', t: "Radiografia de la teva web actual", d: "Velocitat, disseny, continguts i SEO tal com els veu avui el teu client i Google." },
                    { n: '2', t: "Diagnòstic de conversió", d: "On i per què la teva web perd clients, creuant dades amb el recorregut real de l'usuari." },
                    { n: '3', t: "Full de ruta amb pressupost", d: "Un diagnòstic clar, la proposta que més et convé i un pressupost tancat. Sense compromís." },
                ].map((st, i) => (
                    <div class="flex items-center gap-4 lg:gap-6">
                        {i > 0 && <div class="hidden lg:flex text-3xl text-accent font-black select-none">→</div>}
                        <div class="bg-white border border-black/5 rounded-2xl p-8 shadow-[0_15px_40px_rgba(0,0,0,0.06)] flex-1 text-center h-full">
                            <div class="w-12 h-12 rounded-full bg-accent/10 border border-accent/20 flex items-center justify-center mx-auto mb-4 text-accent font-black text-lg">{st.n}</div>
                            <h3 class="text-base font-black uppercase tracking-tight text-zinc-900 mb-3">{st.t}</h3>
                            <p class="text-sm text-zinc-500 font-light leading-relaxed">{st.d}</p>
                        </div>
                    </div>
                ))}
            </div>
            <p class="text-zinc-500 font-light text-sm sm:text-base leading-relaxed max-w-3xl mx-auto text-center mt-16 reveal">
                La nostra auditoria web és el primer pas de qualsevol projecte de disseny o redisseny. És gratuïta i sense compromís, perquè preferim que decideixis amb dades i no amb promeses.
            </p>
            <div class="mt-12 text-center reveal">
                <a href="#contacto" class="contact-modal-trigger btn-mktg-v5 shadow-[0_10px_30px_rgba(37,211,102,0.3)] !py-4 sm:!py-5 !px-6 sm:!px-10 !text-[11px] !tracking-widest font-black">VULL LA MEVA AUDITORIA WEB GRATIS</a>
            </div>
        </div>
    </section>

    <!-- ═══ PREUS ════════════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-zinc-50/50 px-4 sm:px-6 border-t border-black/5">
        <div class="max-w-7xl mx-auto">
            <div class="text-center mb-12 sm:mb-16 reveal">
                <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Tarifes clares</span>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.9]">
                    Preus de disseny web per a Restaurants
                </h2>
                <p class="text-zinc-500 font-light text-sm sm:text-base leading-relaxed max-w-3xl mx-auto">
