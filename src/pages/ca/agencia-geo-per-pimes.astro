---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { buildAlternates } from '../../lib/i18n';
import { localAgencySchema } from '../../lib/schema';
import { strapiClient } from '../../lib/strapi';
import LogoMarquee from '../../components/sections/LogoMarquee.astro';
import FaqHome from '../../components/sections/FaqHome.astro';
import GoogleReviews from '../../components/global/GoogleReviews.astro';

const SITE_URL = import.meta.env.PUBLIC_SITE_URL || 'https://novamarketing.es';
const alternates = buildAlternates('/agencia-geo-para-pymes/', '/ca/agencia-geo-per-pimes/', SITE_URL);

let allCases: any[] = [];
try {
  const casesRes = await strapiClient.getCaseStudies('ca');
  allCases = casesRes.data.map((i: any) => i.attributes ?? i);
} catch {}

const steps = [
  { title: "Auditoria de Visibilitat en IA", desc: "Preguntem a ChatGPT, Gemini, Claude i Perplexity el mateix que preguntarien els teus clients. Mesurem si apareixes, com et descriuen i quins competidors recomanen abans que a tu. Aquest és el teu punt de partida real." },
  { title: "Estratègia GEO Documentada", desc: "Reps un full de ruta per escrit. Quines preguntes de client atacar, quin contingut crear, quins senyals d'autoritat reforçar i quins resultats esperar en 3, 6 i 12 mesos. Saps en què s'inverteix cada euro abans d'invertir-lo." },
  { title: "Optimització per a Motors Generatius", desc: "Reestructurem el teu contingut perquè la IA pugui citar-lo. Respostes directes, dades verificables, marcatge estructurat i una entitat de marca coherent a tota la web. El que no es pot citar no es recomana." },
  { title: "Autoritat i Citabilitat", desc: "Els models d'IA recomanen el que troben en fonts fiables. Mencions en mitjans, ressenyes, directoris i contingut expert. Construïm aquests senyals perquè la teva empresa sigui la resposta i no una opció més." },
  { title: "Mesura i Ajust Continu", desc: "Monitoritzem mes a mes les teves mencions a ChatGPT, Gemini, Perplexity i Google AI Overviews. A l'informe veus en quines preguntes apareixes, com evoluciones davant la teva competència i què toca ajustar." }
];

const criteria = [
  { title: "Demana resultats verificables en la IA", desc: "Qualsevol pot dir-se expert en GEO perquè és una disciplina nova. Demana una demostració en directe. Que preguntin a ChatGPT o Perplexity pels seus propis clients i t'ensenyin on apareixen. Si no poden ensenyar-te ni un cas, segueix buscant." },
  { title: "Pregunta qui portarà el teu compte", desc: "En moltes agències ven un director i executa un júnior amb 30 comptes. Exigeix conèixer la persona que treballarà el teu projecte abans de signar. A nova parles sempre amb el consultor que executa la teva estratègia GEO, presencialment o per videotrucada." },
  { title: "Exigeix la propietat dels teus actius", desc: "La web, el contingut, les dades estructurades i l'analítica han d'estar al teu nom. Si l'agència reté els teus actius no estàs contractant un servei de posicionament GEO, estàs signant una dependència." },
  { title: "Desconfia de qui garanteix aparèixer a ChatGPT", desc: "Ningú controla què respon un model d'IA. No hi ha anuncis per comprar ni posicions garantides. Qui et promet aparèixer sempre a les respostes de la IA, menteix. El que és seriós és garantir mètode, senyals mesurables i feina verificable." },
  { title: "Revisa què mesura l'informe mensual", desc: "Si l'informe no inclou en quines preguntes apareixes, com et descriu la IA i quines mencions has guanyat, l'agència està mesurant la seva activitat i no la teva visibilitat. El GEO es mesura en mencions, cites i clients que arriben dient que els ha enviat ChatGPT." },
  { title: "Fuig de les permanències llargues", desc: "Una permanència de 12 mesos protegeix l'agència, no a tu. La feina ben feta reté clients sense necessitat de contractes que els lliguin. Per això a nova treballem mes a mes." },
  { title: "Que combini GEO amb SEO", desc: "El GEO no substitueix el SEO, se n'alimenta. Els models d'IA citen contingut que ja és visible, estructurat i amb autoritat. Una consultoria GEO que ignora el teu posicionament a Google està construint sobre sorra." }
];

const faqs = [
  { question: "Què és el GEO (optimització per a motors generatius)?", answer: "El GEO (Generative Engine Optimization) és la disciplina que optimitza la teva presència digital perquè els assistents d'IA com ChatGPT, Gemini, Claude, Perplexity o Google AI Overviews mencionin i recomanin la teva empresa a les seves respostes. També se l'anomena AEO (Answer Engine Optimization). Igual que el SEO et posiciona a Google, el GEO et posiciona a les respostes de la intel·ligència artificial." },
  { question: "Quina és la diferència entre SEO i GEO?", answer: "El SEO optimitza per aparèixer als resultats de cerca de Google, on l'usuari tria entre diversos enllaços. El GEO optimitza per aparèixer dins de la resposta que genera la IA, on l'assistent recomana directament una o dues opcions. Es complementen. La IA s'alimenta de contingut ben posicionat i amb autoritat, així que un bon SEO és la base d'un bon GEO." },
  { question: "Com puc aparèixer a ChatGPT o fer que la IA recomani la meva empresa?", answer: "Treballant els senyals que els models fan servir per decidir. Contingut que respon preguntes concretes de manera citable, dades estructurades que defineixen la teva entitat de marca, mencions en mitjans i directoris fiables, ressenyes verificables i coherència entre el que diu la teva web i el que diu la resta d'internet sobre tu. No es pot pagar per sortir, cal guanyar-s'ho amb mètode." },
  { question: "Quant costa un servei de posicionament GEO?", answer: "L'auditoria GEO costa 1.800 euros i els plans mensuals de posicionament en IA van des de 400 euros al mes per a pimes i des de 900 euros al mes per a empreses mitjanes o sectors molt competits. A nova treballem amb pressupostos tancats a mida. Abans de signar saps exactament què es fa, qui ho fa i quin resultat es persegueix." },
  { question: "Quant es triga a posicionar en IA?", answer: "Els models d'IA actualitzen les seves fonts constantment, així que els primers canvis poden veure's en setmanes quan ja existeix una base de contingut i autoritat. Partint de zero, l'habitual és començar a guanyar mencions entre el tercer i el sisè mes. Al full de ruta inicial et diem què esperar a cada fase, amb terminis realistes i sense promeses de fum." },
  { question: "Com es mesura el posicionament en intel·ligència artificial?", answer: "Monitoritzem un panell de preguntes reals de client a ChatGPT, Gemini, Claude, Perplexity i Google AI Overviews, i registrem si apareixes, en quina posició de la resposta, com et descriu la IA i davant quins competidors. A més mesurem el trànsit i els leads que arriben citant la IA com a origen. Tot en un informe mensual de negoci." },
  { question: "El GEO serveix per a negocis locals i pimes?", answer: "Sí, i és on més oportunitat hi ha ara mateix. La majoria de pimes i negocis locals encara no treballen el seu posicionament en IA, així que ser el primer del teu sector a la teva zona és més assolible que en el SEO tradicional. Quan algú pregunta a ChatGPT quin dentista li recomanen a Sabadell, la IA recomana qui té els senyals correctes." }
];

const sectors = [
  { icon: '🛒', title: 'GEO per a ecommerce', desc: 'Quan algú pregunta a la IA quin producte comprar, qui apareix a la resposta s\'emporta la venda. Optimitzem fitxes, comparatives i ressenyes perquè la teva botiga sigui la recomanada.' },
  { icon: '🏠', title: 'GEO per a immobiliàries', desc: 'Els compradors ja pregunten a ChatGPT per agències de confiança a la seva zona. Construïm l\'autoritat i els senyals locals perquè la IA et posi a la resposta.' },
  { icon: '🍽️', title: 'GEO per a restaurants', desc: 'La pregunta d\'on menjar bé a prop ja se li fa a la IA. Ressenyes, fitxa impecable i contingut citable perquè el teu restaurant surti a la recomanació.' },
  { icon: '🧠', title: 'GEO per a psicòlegs', desc: 'Les consultes de salut mental comencen cada cop més en un xat d\'IA. Contingut amb autoritat clínica i senyals de confiança perquè la IA derivi pacients a la teva consulta.' },
  { icon: '🌿', title: 'GEO per a terapeutes', desc: 'Un sector on gairebé ningú treballa el posicionament en IA encara. Ser el primer de la teva especialitat a la teva zona és més fàcil que a Google. Aprofita la finestra.' },
  { icon: '🦷', title: 'GEO per a dentistes', desc: 'Quin dentista em recomanes a la meva ciutat és una pregunta diària a ChatGPT. Autoritat clínica, ressenyes i entitat ben definida per ser la resposta.' },
  { icon: '💪', title: 'GEO per a gimnasos', desc: 'La IA compara gimnasos per ressenyes, serveis i proximitat. Optimitzem aquests senyals perquè et recomani a tu al gener... i la resta de l\'any.' },
  { icon: '🏗️', title: 'GEO per a constructores', desc: 'Leads de valor alt que ja validen proveïdors preguntant a la IA. Casos documentats i autoritat verificable per entrar a la llista curta.' },
  { icon: '⚖️', title: 'GEO per a advocats', desc: 'Els dubtes legals són de les consultes més freqüents a la IA. Qui resol el dubte amb autoritat s\'emporta la consulta. Contingut citable per especialitat.' },
  { icon: '🏨', title: 'GEO per a hotels', desc: 'Els viatgers planifiquen amb ChatGPT i Perplexity. Senyals de marca, ressenyes i contingut estructurat per aparèixer a l\'itinerari abans que les OTAs.' },
  { icon: '🏭', title: 'GEO per a B2B', desc: 'El responsable de compres pregunta a la IA per proveïdors abans de buscar a Google. Fitxes tècniques citables i autoritat sectorial per ser en aquesta resposta.' },
  { icon: '🎓', title: 'GEO per a escoles', desc: 'Les famílies comparen centres preguntant a la IA. Projecte educatiu ben explicat, ressenyes i dades estructurades per sortir a la comparativa.' },
];

const pageSchema = localAgencySchema({
  pageUrl: `${SITE_URL}/ca/agencia-geo-per-pimes/`,
  lang: 'ca',
  cityName: 'Barcelona',
  postalCode: '08035',
  geo: { lat: 41.4114, lng: 2.1526 },
  areaServed: ["España", "Barcelona", "Sabadell", "Sant Cugat del Vallès", "Terrassa", "Vallès Occidental"],
  title: "Agència GEO de Posicionament en IA per a Pimes | Nova Marketing",
  description: "Agència de posicionament en IA (GEO/AEO). Fes que ChatGPT, Gemini, Perplexity i Google AI Overviews recomanin la teva empresa. Servei de posicionament GEO per a pimes.",
  datePublished: '2026-07-15',
  dateModified: '2026-07-15',
  streetAddress: 'Carrer del General Mendoza, 10',
  hasMap: 'https://maps.app.goo.gl/9fbB12UcK32bgjj89',
  aggregateRating: { ratingValue: '5.0', reviewCount: '7' },
  breadcrumbName: 'Agència GEO per a pimes',
  faqs,
});
---

<BaseLayout
  title="Agència GEO de Posicionament en IA per a Pimes | Nova Marketing"
  description="Agència de posicionament en IA (GEO/AEO). Fes que ChatGPT, Gemini, Perplexity i Google AI Overviews recomanin la teva empresa. Servei de posicionament GEO per a pimes."
  locale="ca"
  alternates={alternates}
  schemas={[pageSchema]}
>

    <!-- ═══ HERO / H1 ═══════════════════════════════════════════════════════ -->
    <section class="pt-24 sm:pt-40 pb-20 px-4 sm:px-6 relative overflow-hidden text-center bg-white border-b border-black/5">
        <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808008_1px,transparent_1px),linear-gradient(to_bottom,#80808008_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_40%,#000_75%,transparent_100%)]"></div>
        <div class="absolute -top-10 left-1/4 w-72 h-72 bg-accent/15 rounded-full blur-3xl opacity-30 animate-pulse"></div>
        <div class="absolute top-20 right-1/4 w-80 h-80 bg-purple-500/5 rounded-full blur-3xl opacity-20"></div>

        <div class="max-w-5xl mx-auto reveal">
            <span class="inline-flex items-center gap-2 bg-accent/5 backdrop-blur-sm px-4 py-2 border border-accent/10 rounded-full text-accent text-[8px] sm:text-[10px] font-black uppercase tracking-[0.3em] mb-8 shadow-sm">
                <span class="w-1.5 h-1.5 bg-accent rounded-full animate-ping"></span>
                Optimització per a Motors Generatius
            </span>
            <h1 class="text-3xl sm:text-5xl md:text-7xl lg:text-8xl uppercase font-extrabold tracking-tighter leading-[0.88] mb-8 text-gradient flex flex-col items-center text-center">
                <span class="lg:whitespace-nowrap">Agència GEO </span>
                <span class="lg:whitespace-nowrap">Posicionament </span>
                <span class="lg:whitespace-nowrap text-mktg-gradient">en IA</span>
            </h1>
            <p class="text-lg sm:text-xl text-zinc-500 font-light leading-relaxed w-[75%] mx-auto mb-8">
                Fes que ChatGPT, Gemini, Claude i Perplexity recomanin la teva empresa. Servei de posicionament GEO per a pimes amb estratègia a mida, preus clars i resultats que es mesuren en mencions i clients.
            </p>
            <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3 mb-10">
                {['Sense permanències', 'Tracte directe amb el consultor', 'Informes de negoci'].map(item => (
                    <span class="inline-flex items-center gap-2 text-[11px] sm:text-xs font-black uppercase tracking-widest text-zinc-700">
                        <svg class="w-4 h-4 text-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                        </svg>
                        {item}
                    </span>
                ))}
            </div>
            <div class="flex justify-center mt-4">
                <a href="#contacto" class="contact-modal-trigger btn-mktg-v5 shadow-[0_10px_30px_rgba(0,0,0,0.1)] !py-4 sm:!py-5 !px-6 sm:!px-10 !text-[11px] !tracking-widest font-black">
                    PARLEM DEL TEU NEGOCI
                </a>
            </div>
        </div>
    </section>

    <LogoMarquee />

    <!-- ═══ INTRO: QUÈ ÉS EL GEO ═══════════════════════════════════════════ -->
    <section class="py-16 sm:py-24 bg-white px-4 sm:px-6 border-b border-black/5">
        <div class="max-w-6xl mx-auto reveal grid md:grid-cols-[1.3fr_1fr] gap-10 md:gap-16 items-center">
            <div>
                <p class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4">Què és el GEO?</p>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-8 text-zinc-900 leading-[0.9]">
                    L'agència de posicionament en IA per a la teva pime
                </h2>
                <div class="space-y-6 text-zinc-600 font-light text-base sm:text-lg leading-relaxed">
                    <p>
                        <strong class="font-semibold text-zinc-900">El GEO (Generative Engine Optimization) és l'optimització per a motors generatius</strong>. És el conjunt de tècniques que fan que els assistents d'IA com ChatGPT, Gemini, Claude, Perplexity o Google AI Overviews mencionin i recomanin la teva empresa a les seves respostes. També el veuràs anomenat AEO, answer engine optimization.
                    </p>
                    <p>
                        Cada dia més clients ja no busquen a Google. Li pregunten directament a la IA quina empresa contractar. Nova és una <strong class="font-semibold text-zinc-900">agència GEO especialitzada en pimes</strong>. Treballem amb un nombre limitat de clients, cada compte el porta directament el consultor fundador i tota l'estratègia s'orienta a una sola mètrica que importa. <strong class="font-semibold text-zinc-900">Que la IA recomani el teu negoci abans que la teva competència</strong>.
                    </p>
                </div>
            </div>
            <div class="hidden md:block">
                <img src="/consultor-marketing-digital.webp" alt="Sergio Galo's, expert en GEO i posicionament en IA" class="w-full h-auto" loading="lazy" />
            </div>
        </div>
    </section>

    <!-- ═══ SERVEIS GEO ══════════════════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-zinc-50 border-b border-black/5 px-4 sm:px-6">
        <div class="max-w-7xl mx-auto text-center reveal">
            <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Què fem</span>
            <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.9]">
                Servei de posicionament GEO per a pimes
            </h2>
            <div class="text-zinc-500 font-light text-sm sm:text-base leading-relaxed max-w-3xl mx-auto mb-16 space-y-4">
                <p>
                    El <strong class="font-semibold text-zinc-700">posicionament GEO</strong> no és una sola tasca, és un sistema. Aquestes són les nou peces que treballem perquè la teva pime passi de ser invisible per a la IA a ser l'empresa que apareix a les seves respostes.
                </p>
                <p>
                    Cada peça s'activa segons el que digui la teva auditoria. No pagues per un paquet tancat d'accions, pagues per les que el teu negoci necessita.
                </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                {[
                    { icon: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z', t: 'Auditoria GEO', d: 'Radiografia de la teva visibilitat a ChatGPT, Gemini, Claude i Perplexity abans de tocar res.' },
                    { icon: 'M12 3a9 9 0 100 18 9 9 0 000-18zm0 5a4 4 0 100 8 4 4 0 000-8z', t: 'Optimització d\'entitat', d: 'Fem que la IA entengui sense dubtes qui ets, què fas i on. Una sola identitat a tota la xarxa.' },
                    { icon: 'M9 12h6m-6 4h6M9 8h2m8-3v14a2 2 0 01-2 2H7a2 2 0 01-2-2V5a2 2 0 012-2h6l4 4z', t: 'Contingut citable', d: 'Pàgines pensades perquè un model les extregui i les citi en respondre les preguntes dels teus clients.' },
                    { icon: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4', t: 'Dades estructurades', d: 'Traduïm el teu negoci al llenguatge que llegeixen les màquines amb marcatge schema a tota la web.' },
                    { icon: 'M12 3l2.6 5.3 5.9.9-4.2 4.1 1 5.8L12 16.3 6.7 19l1-5.8L3.5 9.2l5.9-.9L12 3z', t: 'Autoritat i mencions', d: 'Treballem les fonts en què confia la IA. Mitjans, directoris i ressenyes que avalen la teva marca.' },
                    { icon: 'M17.657 16.657L13.414 20.9a2 2 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0zM15 11a3 3 0 11-6 0 3 3 0 016 0z', t: 'GEO local', d: 'Per a negocis amb clients a prop. Que la IA et recomani quan algú pregunta pel teu servei a la teva zona.' },
                    { icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm8 0V5a2 2 0 012-2h0a2 2 0 012 2v14a2 2 0 01-2 2h0a2 2 0 01-2-2zm-8 0a2 2 0 002 2h2a2 2 0 002-2V9a2 2 0 00-2-2h-2a2 2 0 00-2 2v10z', t: 'Monitorització de mencions', d: 'Seguiment mensual de què respon cada model sobre la teva marca i sobre la teva competència.' },
                    { icon: 'M13.828 10.172a4 4 0 010 5.656l-3 3a4 4 0 01-5.656-5.656l1.5-1.5m7.328-1.672a4 4 0 000-5.656 4 4 0 00-5.656 0l-1.5 1.5', t: 'SEO més GEO', d: 'Una sola estratègia que posiciona a Google i a la IA alhora. Cada acció suma en els dos fronts.' },
                    { icon: 'M8 12h.01M12 12h.01M16 12h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z', t: 'AEO i motors de resposta', d: 'Preparem el teu contingut per a Google AI Overviews i els cercadors amb IA. La meta és ser la resposta.' },
                ].map(c => (
                    <div class="bg-white border border-black/5 rounded-2xl p-6 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 text-left">
                        <div class="flex items-center gap-3 mb-3">
                            <div class="w-10 h-10 rounded-full bg-accent/10 border border-accent/20 flex items-center justify-center flex-shrink-0">
                                <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d={c.icon}/></svg>
                            </div>
                            <h3 class="text-sm font-black uppercase tracking-tight text-zinc-900">{c.t}</h3>
                        </div>
                        <p class="text-sm text-zinc-500 font-light leading-relaxed">{c.d}</p>
                    </div>
                ))}
            </div>

            <div class="mt-12 text-center reveal">
                <a href="#contacto" class="contact-modal-trigger btn-mktg-v5 shadow-[0_10px_30px_rgba(37,211,102,0.3)] !py-4 sm:!py-5 !px-6 sm:!px-10 !text-[11px] !tracking-widest font-black">
                    PARLEM DEL TEU NEGOCI
                </a>
            </div>
        </div>
    </section>

    <!-- ═══ ESTRATÈGIA GEO ════════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-white px-4 sm:px-6 relative overflow-hidden">
        <div class="max-w-5xl mx-auto">
            <div class="text-center mb-16 sm:mb-24 reveal">
                <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Com treballem</span>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.9]">
                    Estratègia GEO per posicionar la teva pime en la IA
                </h2>
                <p class="text-zinc-500 font-light text-sm sm:text-base leading-relaxed max-w-2xl mx-auto">
                    Una metodologia documentada per passar de ser invisible per a la IA a ser l'empresa que recomana, pas a pas i sense fum.
                </p>
            </div>

            <div id="timeline-container" class="relative">
                <div class="hidden md:block absolute left-1/2 top-4 bottom-4 w-px bg-zinc-200 -translate-x-1/2"></div>
                <div id="progress-bar" class="hidden md:block absolute left-1/2 top-4 w-px bg-accent -translate-x-1/2 transition-all duration-100"></div>

                <div class="space-y-16 md:space-y-24 flex flex-col items-center">
                    {steps.map((step, index) => (
                        <div class="flex flex-col md:flex-row items-center gap-6 md:gap-12 w-full relative reveal">
                            <div class:list={["flex-1 w-full", index % 2 === 0 ? "md:order-1 md:text-right" : "md:order-3 md:text-left"]}>
                                <div class="p-8 sm:p-10 bg-zinc-50 border border-black/5 rounded-3xl hover:border-accent/10 hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 relative overflow-hidden group">
                                    <h3 class="text-xl font-black uppercase tracking-tighter mb-2 text-zinc-900">{index + 1}. {step.title}</h3>
                                    <div class:list={["h-0.5 bg-accent w-full mb-4 opacity-80", index % 2 === 0 ? "md:ml-auto" : ""]}></div>
