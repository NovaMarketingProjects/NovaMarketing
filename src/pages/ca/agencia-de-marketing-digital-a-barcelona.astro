---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { buildAlternates } from '../../lib/i18n';
import LogoMarquee from '../../components/sections/LogoMarquee.astro';
import FaqHome from '../../components/sections/FaqHome.astro';

const SITE_URL = import.meta.env.PUBLIC_SITE_URL || 'https://novamarketing.es';
const alternates = buildAlternates('/agencia-de-marketing-digital-en-barcelona/', '/ca/agencia-de-marketing-digital-a-barcelona/', SITE_URL);

const steps = [
  { title: "Diagnòstic Local", desc: "Auditem la teva web, la teva visibilitat actual i la teva competència directa a Barcelona i l'àrea metropolitana. Detectem fugues de trànsit, keywords rendibles sense explotar i oportunitats de venda que la teva competència ja està capturant." },
  { title: "Estratègia Documentada", desc: "Reps un full de ruta per escrit: quins canals fer servir, quines keywords atacar, quina inversió necessita cada fase i quins resultats esperar en 3, 6 i 12 mesos. Saps en què s'inverteix cada euro abans d'invertir-lo." },
  { title: "Execució Multicanal", desc: "Coordinem SEO, Google Ads, continguts i analítica perquè la inversió generi leads de qualitat des del primer mes. Ads accelera el curt termini mentre el SEO construeix el teu actiu a mitjà termini." },
  { title: "Mesura Sense Fum", desc: "Configurem l'analítica per atribuir cada lead al seu canal. A l'informe mensual veuràs trucades, formularis i vendes generades, no mètriques de vanitat. Reunió mensual amb el consultor per revisar números." },
  { title: "Optimització Contínua", desc: "Espremem cada euro adaptant campanyes i continguts als pics de demanda de Barcelona: estacionalitat del sector, canvis d'algoritme i moviments de la teva competència." }
];

const districts = [
  { title: "Eixample i Centre de Barcelona", desc: "La zona més disputada de la ciutat: clíniques, despatxos professionals i retail competint per les mateixes cerques. Aquí el posicionament es guanya amb SEO local quirúrgic, una fitxa de Google Business Profile impecable i ressenyes que et diferenciïn del veí del mateix carrer." },
  { title: "22@, Poblenou i Sant Martí", desc: "El node tecnològic de Barcelona. Per a startups, SaaS i B2B que operen aquí, la captació passa per keywords de nínxol amb alta intenció, contingut que demostri autoritat tècnica i campanyes segmentades a decisors, no a curiosos." },
  { title: "Gràcia, Sants, Les Corts i Sarrià", desc: "Barris de negoci de proximitat on el client busca \"a prop meu\" des del mòbil. Treballem el pack local complet: Google Business Profile, ressenyes, landings per zona i anuncis geolocalitzats a pocs minuts del teu local." },
];

const criteria = [
  { title: "Demana casos d'èxit verificables a Barcelona", desc: "Un mur de logos no demostra res. Demana casos de negocis de Barcelona amb dades concretes: quina keyword local, quina posició va assolir, en quant de temps i amb quina inversió. Una agència que treballa el mercat barceloní hauria de poder ensenyar-te resultats a la teva ciutat, o fins i tot al teu sector. Si no poden ensenyar-te'n ni un, segueix buscant." },
  { title: "Pregunta qui portarà el teu compte", desc: "En moltes agències de Barcelona ven un director i executa un júnior amb 30 comptes. Exigeix conèixer la persona que treballarà el teu projecte abans de signar, i pregunta si podràs reunir-te amb ella cara a cara: a nova les reunions amb clients de Barcelona i la seva àrea metropolitana poden ser presencials." },
  { title: "Exigeix la propietat dels teus actius", desc: "La web, el compte de Google Ads, la fitxa de Google Business Profile i l'analítica han d'estar al teu nom. És més habitual del que sembla: pimes de Barcelona que porten anys pagant i descobreixen en voler canviar d'agència que no són propietàries ni del seu propi domini. Si l'agència reté els teus actius, no estàs contractant un servei: estàs signant una dependència." },
  { title: "Desconfia de qui garanteix la posició 1 a Google a Barcelona", desc: "Ningú pot garantir la posició 1 a Google, i menys en un mercat tan disputat com el de Barcelona, on cada keyword local la lluiten desenes de competidors. Qui ho promet, o menteix o fa servir tècniques que acabaran penalitzant la teva web. El que és seriós és garantir mètode, transparència i feina verificable." },
  { title: "Revisa què mesura l'informe mensual", desc: "Si l'informe parla d'impressions i abast però no de trucades, formularis i vendes de clients de Barcelona, l'agència està mesurant la seva activitat, no el teu negoci. El posicionament local a Barcelona es mesura en visites a la teva fitxa, rutes al teu local i pressupostos sol·licitats, no en likes." },
  { title: "Fuig de les agències de marketing amb permanències llargues", desc: "Una permanència de 12 mesos protegeix l'agència, no a tu. En una ciutat amb tanta oferta d'agències de marketing digital com Barcelona, la feina ben feta reté clients sense necessitat de contractes que els lliguin. Per això a nova treballem mes a mes." },
  { title: "Coneixement del negoci local", desc: "No és el mateix posicionar una clínica a l'Eixample que una indústria al Vallès o un ecommerce que ven a tota Espanya. Una agència que coneix el mercat de Barcelona sap què busca el client de cada zona, quina competència hi ha a cada sector i quines keywords locals converteixen. Pregunta què sap l'agència del teu barri, del teu sector i del teu client abans de signar." }
];

const faqs = [
  { question: "Quant costa una agència de marketing digital a Barcelona?", answer: "Depèn molt dels serveis que necessitis i de si és un projecte puntual o una feina recurrent. No costa el mateix una auditoria o el llançament d'una web que una estratègia mensual de posicionament i captació. Per això a nova no treballem amb tarifes genèriques sinó amb pressupostos tancats a mida: abans de signar saps exactament què es fa, qui ho fa i quin resultat es persegueix." },
  { question: "Què inclou una estratègia de marketing digital per a una pime a Barcelona?", answer: "Inclou una auditoria inicial, un full de ruta documentat i l'execució i mesura mensual de cada acció. Analitzem la teva situació actual i la teva competència a Barcelona, definim quins canals fer servir, quina inversió necessita cada fase i quins resultats esperar a 3, 6 i 12 mesos. No apliquem plantilles: cada sector i cada zona de Barcelona competeix de manera diferent." },
  { question: "Qui portarà el meu compte?", answer: "El teu compte el porta directament Sergio Galo's, consultor de marketing digital a Barcelona i fundador de Nova Marketing. Sense gestors júnior ni intermediaris: la persona que dissenya la teva estratègia és la mateixa que l'executa i la que et respon a la reunió mensual." },
  { question: "Quant trigaré a veure resultats?", answer: "Hi ha accions que generen clients en setmanes i d'altres que consoliden resultats entre el sisè i el dotzè mes. El termini exacte depèn del punt de partida del teu negoci i de la competència del teu sector a Barcelona. Al full de ruta inicial et diem què esperar a cada fase, amb terminis realistes i sense promeses de fum." },
  { question: "Com mesureu els resultats de l'estratègia?", answer: "Mesurem leads i vendes: cada trucada, formulari o comanda queda atribuïda al seu canal d'origen. Configurem l'analítica des del primer dia i a l'informe mensual veus resultats de negoci, no mètriques de vanitat. A més tens accés total als teus comptes i eines: les dades són teves." },
  { question: "Treballeu amb permanència?", answer: "No, treballem mes a mes. Si el servei no t'aporta valor, pots cancel·lar-lo quan vulguis. La nostra permanència real és el resultat que veus als informes cada mes." },
  { question: "Ateneu només empreses de Barcelona ciutat?", answer: "No: tenim la seu a Barcelona, però treballem amb clients a tota Espanya. La major part dels nostres projectes són a Barcelona i la seva àrea metropolitana (Sabadell, Sant Cugat, Terrassa), on les reunions poden ser presencials, i amb la resta de clients treballem per videotrucada amb el mateix nivell de seguiment." }
];

---

<BaseLayout
  title="Marketing Digital a Barcelona | Nova Marketing"
  description="Estratègies de creixement digital per a pimes a Barcelona. SEO, Google Ads i Disseny Web enfocats a captar clients i competir al mercat actual."
  locale="ca"
  alternates={alternates}
>

    <!-- ═══ HERO / H1 ═══════════════════════════════════════════════════════ -->
    <section class="pt-24 sm:pt-40 pb-20 px-4 sm:px-6 relative overflow-hidden text-center bg-white border-b border-black/5">
        <!-- Background Grid Mesh -->
        <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808008_1px,transparent_1px),linear-gradient(to_bottom,#80808008_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_40%,#000_75%,transparent_100%)]"></div>

        <!-- Glow Orbs -->
        <div class="absolute -top-10 left-1/4 w-72 h-72 bg-accent/15 rounded-full blur-3xl opacity-30 animate-pulse"></div>
        <div class="absolute top-20 right-1/4 w-80 h-80 bg-purple-500/5 rounded-full blur-3xl opacity-20"></div>

        <div class="max-w-5xl mx-auto reveal">
            <span class="inline-flex items-center gap-2 bg-accent/5 backdrop-blur-sm px-4 py-2 border border-accent/10 rounded-full text-accent text-[8px] sm:text-[10px] font-black uppercase tracking-[0.3em] mb-8 shadow-sm">
                <span class="w-1.5 h-1.5 bg-accent rounded-full animate-ping"></span>
                Impuls Digital per a Pimes
            </span>
            <h1 class="text-3xl sm:text-5xl md:text-7xl lg:text-8xl uppercase font-extrabold tracking-tighter leading-[0.88] mb-8 text-gradient flex flex-col items-center text-center">
                <span class="lg:whitespace-nowrap">Agència de Marketing </span>
                <span class="lg:whitespace-nowrap">Digital a Barcelona</span>
            </h1>
            <p class="text-lg sm:text-xl text-zinc-500 font-light leading-relaxed w-[75%] mx-auto mb-10">
                A nova ajudem pimes i autònoms de Barcelona a captar clients amb SEO, Google Ads i disseny web. Estratègia a mida, preus clars i resultats que es mesuren en vendes, no en likes.
            </p>
            <div class="flex justify-center mt-4">
                <a href="#contacto" class="contact-modal-trigger btn-mktg-v5 shadow-[0_10px_30px_rgba(0,0,0,0.1)] !py-4 sm:!py-5 !px-6 sm:!px-10 !text-[11px] !tracking-widest font-black">
                    PARLEM DEL TEU NEGOCI
                </a>
            </div>
        </div>
    </section>

    <LogoMarquee />

    <!-- ═══ INTRO: QUI SOM ═════════════════════════════════════════════════ -->
    <section class="py-16 sm:py-24 bg-white px-4 sm:px-6 border-b border-black/5">
        <div class="max-w-3xl mx-auto reveal space-y-6 text-zinc-600 font-light text-base sm:text-lg leading-relaxed">
            <p>
                <strong class="font-semibold text-zinc-900">Nova Marketing és una agència de marketing digital especialitzada en pimes</strong> que opera a Barcelona i la seva àrea metropolitana, amb serveis de posicionament SEO, Google Ads, disseny web i consultoria de marketing.
            </p>
            <p>
                El nostre enfocament és diferent: treballem amb un nombre limitat de clients, cada compte el porta directament el consultor fundador i tota l'estratègia s'orienta a una sola mètrica que importa: <strong class="font-semibold text-zinc-900">quants clients nous genera la teva inversió cada mes</strong>.
            </p>
        </div>
    </section>

    <!-- ═══ SECCIÓ 1: SERVEIS ══════════════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-zinc-50 border-b border-black/5 px-4 sm:px-6">
        <div class="max-w-7xl mx-auto text-center reveal">
            <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Què fem</span>
            <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.9]">
                Serveis de Marketing Online a Barcelona
            </h2>
            <p class="text-zinc-500 font-light text-sm sm:text-base leading-relaxed max-w-2xl mx-auto mb-16">
                Quatre serveis, un mateix objectiu: que la teva empresa aparegui on busquen els teus clients a Barcelona i converteixi aquest trànsit en facturació.
            </p>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 text-left">
                <!-- SEO -->
                <div class="service-card p-8 bg-white rounded-2xl border border-zinc-100/80 shadow-sm hover:shadow-2xl hover:-translate-y-2 hover:border-accent/10 transition-all duration-500 relative overflow-hidden flex flex-col justify-between">
        <!-- Hover Gradient Overlay -->
        <div class="absolute inset-x-0 h-1 bottom-0 bg-gradient-to-r from-accent via-accent/90 to-purple-600 w-0 group-hover:w-full transition-all duration-500"></div>
                    <h3 class="text-xl font-black uppercase tracking-tighter mb-4 text-zinc-900">
                        <a href="/ca/agencia-seo-a-barcelona/" class="hover:text-accent transition-colors">Agència de Posicionament SEO a Barcelona</a>
                    </h3>
                    <p class="text-sm text-zinc-500 font-light leading-relaxed mb-4">
                        Apareix als primers resultats de Google quan els teus clients busquen els teus serveis a Barcelona. Optimitzem la teva fitxa de Google Business Profile, la teva web i els teus continguts per dominar les cerques locals del teu sector, des de l'Eixample fins a l'àrea metropolitana.
                    </p>
                    <a href="/ca/agencia-seo-a-barcelona/" class="text-[11px] font-black tracking-widest text-accent hover:underline">SABER MÉS →</a>
                </div>

                <!-- Google Ads -->
                <div class="service-card p-8 bg-white rounded-2xl border border-zinc-100/80 shadow-sm hover:shadow-2xl hover:-translate-y-2 hover:border-accent/10 transition-all duration-500 relative overflow-hidden flex flex-col justify-between">
        <!-- Hover Gradient Overlay -->
        <div class="absolute inset-x-0 h-1 bottom-0 bg-gradient-to-r from-accent via-accent/90 to-purple-600 w-0 group-hover:w-full transition-all duration-500"></div>
                    <h3 class="text-xl font-black uppercase tracking-tighter mb-4 text-zinc-900">
                        <a href="/ca/agencia-google-ads-barcelona/" class="hover:text-accent transition-colors">Agència de Google Ads a Barcelona</a>
                    </h3>
                    <p class="text-sm text-zinc-500 font-light leading-relaxed mb-4">
                        Anuncis hipersegmentats per captar clients des de la primera setmana. No llancis els diners en clics buits: dirigim les teves campanyes a usuaris de Barcelona amb intenció real de compra i optimitzem el CPC per maximitzar el retorn de cada euro invertit.
                    </p>
                    <a href="/ca/agencia-google-ads-barcelona/" class="text-[11px] font-black tracking-widest text-accent hover:underline">SABER MÉS →</a>
                </div>

                <!-- Disseny Web -->
                <div class="service-card p-8 bg-white rounded-2xl border border-zinc-100/80 shadow-sm hover:shadow-2xl hover:-translate-y-2 hover:border-accent/10 transition-all duration-500 relative overflow-hidden flex flex-col justify-between">
        <!-- Hover Gradient Overlay -->
        <div class="absolute inset-x-0 h-1 bottom-0 bg-gradient-to-r from-accent via-accent/90 to-purple-600 w-0 group-hover:w-full transition-all duration-500"></div>
                    <h3 class="text-xl font-black uppercase tracking-tighter mb-4 text-zinc-900">
                        <a href="/ca/agencia-disseny-web-barcelona/" class="hover:text-accent transition-colors">Agència de Disseny Web a Barcelona</a>
                    </h3>
                    <p class="text-sm text-zinc-500 font-light leading-relaxed mb-4">
                        Dissenyem l'aparador digital 24/7 que la teva empresa necessita: pàgines web ultraràpides, adaptades a mòbil i 100% enfocades a la conversió, amb l'autoritat que exigeix un mercat internacional com el de Barcelona.
                    </p>
                    <a href="/ca/agencia-disseny-web-barcelona/" class="text-[11px] font-black tracking-widest text-accent hover:underline">SABER MÉS →</a>
                </div>

                <!-- Consultoria -->
                <div class="service-card p-8 bg-white rounded-2xl border border-zinc-100/80 shadow-sm hover:shadow-2xl hover:-translate-y-2 hover:border-accent/10 transition-all duration-500 relative overflow-hidden flex flex-col justify-between">
        <!-- Hover Gradient Overlay -->
        <div class="absolute inset-x-0 h-1 bottom-0 bg-gradient-to-r from-accent via-accent/90 to-purple-600 w-0 group-hover:w-full transition-all duration-500"></div>
                    <h3 class="text-xl font-black uppercase tracking-tighter mb-4 text-zinc-900">
                        <a href="/ca/consultoria-marketing-digital-barcelona/" class="hover:text-accent transition-colors">Consultoria de Marketing a Barcelona</a>
                    </h3>
                    <p class="text-sm text-zinc-500 font-light leading-relaxed mb-4">
                        El teu marketing no dona resultats? Auditem els teus processos de captació, detectem on es perd el pressupost i tracem un full de ruta amb embuts de venda sòlids per escalar el teu negoci a Barcelona.
                    </p>
                    <a href="/ca/consultoria-marketing-digital-barcelona/" class="text-[11px] font-black tracking-widest text-accent hover:underline">SABER MÉS →</a>
                </div>
            </div>
        </div>
    </section>

    <!-- ═══ SECCIÓ 2: COM TREBALLEM ═══════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-white px-4 sm:px-6 relative overflow-hidden">
        <div class="max-w-5xl mx-auto">
            <div class="text-center mb-16 sm:mb-24 reveal">
                <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Com treballem</span>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.9]">
                    Estratègies de marketing digital per a pimes a Barcelona
                </h2>
                <p class="text-zinc-500 font-light text-sm sm:text-base leading-relaxed max-w-2xl mx-auto">
                    Una metodologia provada en més de 20 projectes perquè competeixis amb garanties al mercat barceloní, pas a pas i sense fum.
                </p>
            </div>

            <div id="timeline-container" class="relative">
                <div class="hidden md:block absolute left-1/2 top-4 bottom-4 w-px bg-zinc-200 -translate-x-1/2"></div>
                <div id="progress-bar" class="hidden md:block absolute left-1/2 top-4 w-px bg-accent -translate-x-1/2 transition-all duration-100" style="height: 0%;"></div>

                <div class="space-y-16 md:space-y-24 flex flex-col items-center">
                    {steps.map((step, index) => (
                        <div class="flex flex-col md:flex-row items-center gap-6 md:gap-12 w-full relative reveal">
                            <div class:list={["flex-1 w-full", index % 2 === 0 ? "md:order-1 md:text-right" : "md:order-3 md:text-left"]}>
                                <div class="p-8 sm:p-10 bg-zinc-50 border border-black/5 rounded-3xl hover:border-accent/10 hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 relative overflow-hidden group">
                                    <h3 class="text-xl font-black uppercase tracking-tighter mb-2 text-zinc-900">{index + 1}. {step.title}</h3>
                                    <div class:list={["h-0.5 bg-accent w-full mb-4 opacity-80", index % 2 === 0 ? "md:ml-auto" : ""]}></div>
                                    <p class:list={["text-sm text-zinc-500 font-light max-w-md", index % 2 === 0 ? "md:ml-auto" : ""]}>{step.desc}</p>
                                    <div class="absolute -bottom-6 -right-5 text-8xl font-black text-black/[0.02] select-none z-0 group-hover:scale-105 transition-transform duration-500">0{index+1}</div>
                                </div>
                            </div>
                            <div class="md:order-2 w-12 h-12 rounded-full border-2 border-zinc-200 bg-white flex items-center justify-center font-black text-lg z-10 shrink-0 shadow-sm node-circle transition-all">
                                0{index + 1}
                            </div>
                            <div class:list={["hidden md:block md:flex-1", index % 2 === 0 ? "md:order-3" : "md:order-1"]}></div>
                        </div>
                    ))}
                </div>
            </div>
        </div>
    </section>

    <!-- ═══ SECCIÓ 3: DISTRICTES ══════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-zinc-50/50 px-4 sm:px-6 relative overflow-hidden border-t border-black/5">
        <!-- Deco meshes -->
        <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808005_1px,transparent_1px),linear-gradient(to_bottom,#80808005_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_50%,#000_80%,transparent_100%)]"></div>
        <div class="absolute -top-40 right-1/4 w-96 h-96 bg-accent/10 rounded-full blur-3xl opacity-20 animate-pulse"></div>
        <div class="absolute -bottom-40 left-1/4 w-96 h-96 bg-purple-500/10 rounded-full blur-3xl opacity-10"></div>
        <div class="max-w-7xl mx-auto relative z-10">
            <div class="text-center mb-16 sm:mb-24 reveal">
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-4 text-zinc-900 leading-[0.9]">
                    Marketing Digital a Tots els Districtes de Barcelona
                </h2>
                <p class="text-zinc-500 font-light text-sm sm:text-base leading-relaxed max-w-2xl mx-auto">
                    Barcelona no és un sol mercat: cada districte té la seva competència, el seu tipus de client i la seva manera de buscar a Google. Adaptem l'estratègia a la zona on competeix el teu negoci.
                </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                {districts.map((d) => (
                    <div class="group p-8 border border-black/5 bg-white rounded-2xl hover:border-black/20 hover:shadow-[0_20px_50px_rgba(0,0,0,0.03)] transition-all duration-500 reveal">
                        <div class="h-1 bg-black w-12 group-hover:w-full transition-all duration-500 mb-6"></div>
                        <h3 class="text-xl font-black uppercase tracking-tighter mb-4 text-zinc-900">{d.title}</h3>
                        <p class="text-sm text-zinc-500 font-light leading-relaxed">{d.desc}</p>
                    </div>
                ))}
                <div class="group p-8 border border-black/5 bg-white rounded-2xl hover:border-black/20 hover:shadow-[0_20px_50px_rgba(0,0,0,0.03)] transition-all duration-500 reveal">
                    <div class="h-1 bg-black w-12 group-hover:w-full transition-all duration-500 mb-6"></div>
                    <h3 class="text-xl font-black uppercase tracking-tighter mb-4 text-zinc-900">Àrea Metropolitana de Barcelona</h3>
                    <p class="text-sm text-zinc-500 font-light leading-relaxed">
                        Molts dels teus clients busquen des de fora de la ciutat. Cobrim també el Vallès i el Baix Llobregat amb estratègies locals pròpies a <a href="/ca/agencia-de-marketing-digital-a-sabadell/" class="underline hover:text-accent transition-colors">Sabadell</a>, <a href="/ca/agencia-de-marketing-digital-a-sant-cugat/" class="underline hover:text-accent transition-colors">Sant Cugat</a> i <a href="/ca/agencia-de-marketing-digital-a-terrassa/" class="underline hover:text-accent transition-colors">Terrassa</a>.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- ═══ SECCIÓ: PER QUÈ NOVA (COMPARATIVA) ═════════════════════ -->
    <section class="py-20 sm:py-32 bg-white px-4 sm:px-6 border-t border-black/5">
        <div class="max-w-5xl mx-auto">
            <div class="text-center mb-12 sm:mb-16 reveal">
                <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Per què nova</span>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.9]">
                    Què diferencia nova d'una altra agència de marketing digital
                </h2>
                <p class="text-zinc-500 font-light text-sm sm:text-base leading-relaxed max-w-2xl mx-auto">
