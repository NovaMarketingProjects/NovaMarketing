---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { buildAlternates } from '../../../lib/i18n';
import { localAgencySchema } from '../../../lib/schema';
import { strapiClient } from '../../../lib/strapi';
import LogoMarquee from '../../../components/sections/LogoMarquee.astro';
import FaqHome from '../../../components/sections/FaqHome.astro';
import CityPills from '../../../components/global/CityPills.astro';
import GoogleReviews from '../../../components/global/GoogleReviews.astro';

const SITE_URL = import.meta.env.PUBLIC_SITE_URL || 'https://novamarketing.es';
const alternates = buildAlternates('/diseno-web-para-pymes/sant-cugat/', '/ca/disseny-web-per-pimes/sant-cugat/', SITE_URL);

let allCases: any[] = [];
try {
  const casesRes = await strapiClient.getCaseStudies('ca');
  allCases = casesRes.data.map((i: any) => i.attributes ?? i).filter((c: any) => {
    const cats = (c.categories || []).map((cat: any) => (cat.slug || cat.attributes?.slug || '').toLowerCase());
    return cats.some((s: string) => s === 'diseno-web');
  });
} catch {}

const steps = [
  { title: "Briefing amb la teva empresa de Sant Cugat", desc: "Abans de dissenyar res, entenem el teu negoci. Què vens, a qui, què fa la teva competència i què ha d'aconseguir la web. Una web sense objectiu és un fulletó car. La teva neix amb una missió concreta, convertir visites en clients." },
  { title: "Arquitectura per a un client que compara", desc: "Definim quines pàgines necessita la teva web, com s'organitzen i què diu cadascuna. L'estructura es pensa per a l'usuari i per a Google alhora, amb les keywords del teu sector integrades des del primer esbós." },
  { title: "Disseny i desenvolupament", desc: "Dissenyem una web que transmet confiança en tres segons i la desenvolupem amb codi net i ràpid. Adaptada a mòbil des del primer píxel, perquè allà hi ha la majoria de les teves visites." },
  { title: "SEO tècnic i velocitat", desc: "Cada web surt optimitzada de sèrie. Core Web Vitals en verd, dades estructurades, indexació correcta i temps de càrrega que no espanten ni els teus clients ni Google. El que altres venen com a extra, aquí és l'estàndard." },
  { title: "Llançament i manteniment", desc: "Publiquem, mesurem i no desapareixem. Analítica configurada des del dia u, còpies de seguretat, actualitzacions i suport directe. La teva web és un actiu viu que millora cada mes, no un projecte que es lliura i s'oblida." }
];

const criteria = [
  { title: "Demana webs reals que puguis visitar", desc: "Un portfolio de captures boniques no demostra res. Demana adreces de webs vives, entra des del mòbil i comprova com carreguen. Una agència de disseny web seriosa hauria de poder ensenyar-te projectes de negocis com el teu funcionant avui." },
  { title: "Pregunta qui farà la teva web", desc: "En moltes agències ven un comercial i executa una plantilla comprada. Exigeix saber qui dissenya, qui desenvolupa i amb qui parlaràs durant el projecte. A nova parles sempre amb el consultor que porta el teu projecte." },
  { title: "Exigeix la propietat de la teva web i el teu domini", desc: "El domini, el hosting, la web i els seus continguts han d'estar al teu nom. Hi ha pimes que porten anys pagant i descobreixen en voler canviar d'agència que no són propietàries ni del seu propi domini. Això no és un servei, és una dependència." },
  { title: "Desconfia de les webs a 300 euros", desc: "Una web tirada de preu sol ser una plantilla clonada, lenta i sense cap feina de SEO. L'acabes pagant dues vegades, la segona quan algú ha de refer-la perquè funcioni. El que és barat en disseny web és el que no genera clients." },
  { title: "Revisa què passa després del llançament", desc: "Una web sense manteniment envelleix malament. Actualitzacions, seguretat, còpies i petits canvis formen part del servei. Pregunta què inclou el suport i quant costa cada canvi abans de signar, no després." },
  { title: "Fuig de les permanències llargues", desc: "Una permanència de 24 mesos protegeix l'agència, no a tu. La feina ben feta reté clients sense contractes que els lliguin. Per això a nova treballem sense permanències." },
  { title: "Que la web neixi preparada per al SEO i per a la IA", desc: "Una web bonica que Google no entén és invisible. I cada cop més clients pregunten a ChatGPT abans de buscar. Exigeix dades estructurades, contingut citable i velocitat de sèrie. Nosaltres dissenyem cada web per posicionar a Google i a la IA des del primer dia." }
];

const faqs = [
  { question: "Quant costa una pàgina web a Sant Cugat?", answer: "Una landing page per a campanyes parteix de 400 euros, una web a mida des de 120 euros al mes en 12 quotes i una botiga online des de 130 euros al mes en 12 quotes. Amb el tiquet mitjà dels negocis de Sant Cugat, la web s'amortitza amb els primers clients que genera." },
  { question: "El client de Sant Cugat exigeix res diferent en una web?", answer: "Sí. És un client informat, amb expectatives altes i que compara diverses opcions abans de contactar. Una web lenta o amb aspecte de plantilla et descarta abans que puguis parlar. Per això aquí cuidem especialment el disseny, la velocitat i els senyals de confiança." },
  { question: "Feu webs per a empreses del parc empresarial?", answer: "Sí. Les seus corporatives i tecnològiques de Sant Cugat necessiten webs B2B amb autoritat tècnica, casos documentats i formularis pensats per a decisors. Dissenyem per a aquest cicle de decisió llarg." },
  { question: "I per a serveis a Mira-sol o Valldoreix?", answer: "També. El client residencial busca des del mòbil serveis de reformes, salut, llar o educació. La web ha de carregar ràpida, respondre el que busca i posar el contacte a un toc." },
  { question: "Quant es triga a tenir la web llesta?", answer: "Una web corporativa sol estar llesta en 3 a 5 setmanes i una botiga online en 6 a 8, comptant des que rebem els continguts. Al briefing inicial et donem un calendari amb dates concretes." },
  { question: "La web inclou SEO per posicionar a Sant Cugat?", answer: "Tota web que surt de nova inclou la base SEO de sèrie, amb les cerques locals de Sant Cugat integrades a l'estructura i els textos. Si després vols competir per posicions, el nostre servei de SEO continua des d'aquesta base." },
  { question: "La web i el domini seran meus?", answer: "Sí, sempre. El domini es registra al teu nom, els continguts són teus i tens accés complet a tot. Si algun dia deixes de treballar amb nosaltres, t'emportes la teva web sencera." },
];

const sectors = [
  { icon: '🛒', title: 'Disseny web per a ecommerce', href: '/ca/agencia-ecommerce/diseno-web/', desc: 'Botigues online ràpides, amb fitxes que venen i un procés de compra sense friccions. El disseny treballa per al carret, no en contra.' },
  { icon: '🏠', title: 'Disseny web per a immobiliàries', href: '/ca/agencia-inmobiliarias/diseno-web/', desc: 'Cercadors de propietats clars, fitxes amb la informació que decideix i formularis que converteixen visites en visites al pis.' },
  { icon: '🍽️', title: 'Disseny web per a restaurants', href: '/ca/agencia-restaurantes/diseno-web/', desc: 'Carta llegible des del mòbil, reserves en dos tocs i una web connectada amb la teva fitxa de Google. El comensal decideix en segons.' },
  { icon: '🧠', title: 'Disseny web per a psicòlegs', desc: 'El pacient busca confiança abans que preu. Webs serenes, amb autoritat clínica i una primera cita a un clic de distància.' },
  { icon: '🌿', title: 'Disseny web per a terapeutes', desc: 'La teva web és la teva consulta abans de la consulta. Disseny que transmet el que fas i contingut que converteix dubtes en primeres visites.' },
  { icon: '🦷', title: 'Disseny web per a dentistes', desc: 'Sector saturat on la web decideix. Casos reals, ressenyes visibles i cita online per convertir la cerca en pacient.' },
  { icon: '💪', title: 'Disseny web per a gimnasos', desc: 'Horaris clars, tarifes sense lletra petita i alta online. Una web que omple classes al gener i les manté la resta de l\'any.' },
  { icon: '🏗️', title: 'Disseny web per a constructores', desc: 'Projectes documentats amb fotos reals i formularis que filtren curiosos. La web que converteix visites en pressupostos.' },
  { icon: '⚖️', title: 'Disseny web per a advocats', desc: 'Autoritat i claredat. Webs per especialitat que resolen el dubte legal del client i el porten a la consulta.' },
  { icon: '🏨', title: 'Disseny web per a hotels', desc: 'Reserva directa sense dependre de les OTAs. Webs amb motor de reserves, fotos que venen i velocitat de càrrega impecable.' },
  { icon: '🏭', title: 'Disseny web per a B2B', desc: 'Fitxes tècniques descarregables, casos d\'èxit i formularis pensats per al responsable de compres. Webs que generen pressupostos.' },
  { icon: '🎓', title: 'Disseny web per a escoles', desc: 'Projecte educatiu ben explicat, visites al centre a un clic i matrícula online. La web que les famílies comparen abans de decidir.' },
];

const pageSchema = localAgencySchema({
  pageUrl: `${SITE_URL}/ca/disseny-web-per-pimes/sant-cugat/`,
  lang: 'ca',
  cityName: 'Sant Cugat',
  postalCode: '08172',
  geo: { lat: 41.4736, lng: 2.0861 },
  areaServed: ["Sant Cugat del Vallès", "Vallès Occidental", "Barcelona", "España"],
  title: "▷ Disseny Web a Sant Cugat | Webs Optimitzades per a Pimes",
  description: "Dissenyem webs per a pimes a Sant Cugat ràpides i optimitzades per a Google ✅ Webs que converteixen visites en clients amb criteri professional 💡",
  datePublished: '2026-07-16',
  dateModified: '2026-07-16',
  breadcrumbName: 'Disseny Web a Sant Cugat',
  faqs,
});
---

<BaseLayout
  title="▷ Disseny Web a Sant Cugat | Webs Optimitzades per a Pimes"
  description="Dissenyem webs per a pimes a Sant Cugat ràpides i optimitzades per a Google ✅ Webs que converteixen visites en clients amb criteri professional 💡"
  locale="ca"
  alternates={alternates}
  schemas={[pageSchema]}
>

    <!-- ═══ HERO / H1 ═══════════════════════════════════════════════════════ -->
    <section class="pt-24 sm:pt-40 pb-20 px-4 sm:px-6 relative overflow-hidden text-center bg-white border-b border-black/5">
        <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808008_1px,transparent_1px),linear-gradient(to_bottom,#80808008_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_40%,#000_75%,transparent_100%)]"></div>
        <div class="absolute -top-10 left-1/4 w-72 h-72 bg-accent/15 rounded-full blur-3xl opacity-30 animate-pulse"></div>
        <div class="absolute top-20 right-1/4 w-80 h-80 bg-purple-500/5 rounded-full blur-3xl opacity-20"></div>

        <div class="max-w-5xl mx-auto reveal">
            <span class="inline-flex items-center gap-2 bg-accent/5 backdrop-blur-sm px-4 py-2 border border-accent/10 rounded-full text-accent text-[8px] sm:text-[10px] font-black uppercase tracking-[0.3em] mb-8 shadow-sm">
                <span class="w-1.5 h-1.5 bg-accent rounded-full animate-ping"></span>
                Disseny Web per a Pimes
            </span>
            <h1 class="text-3xl sm:text-5xl md:text-7xl lg:text-8xl uppercase font-extrabold tracking-tighter leading-[0.88] mb-8 text-gradient flex flex-col items-center text-center">
                <span class="lg:whitespace-nowrap">Disseny Pàgines Web </span>
                <span class="lg:whitespace-nowrap text-mktg-gradient">a Sant Cugat</span>
            </h1>
            <p class="text-lg sm:text-xl text-zinc-500 font-light leading-relaxed w-[75%] mx-auto mb-8">
                La teva web és el teu millor comercial o el teu pitjor enemic. Dissenyem pàgines web per a pimes de Sant Cugat ràpides, optimitzades per a Google i pensades per convertir visites en clients.
            </p>
            <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3 mb-10">
                {['Sense permanències', 'La web i el domini són teus', 'SEO inclòs de sèrie'].map(item => (
                    <span class="inline-flex items-center gap-2 text-[11px] sm:text-xs font-black uppercase tracking-widest text-zinc-700">
                        <svg class="w-4 h-4 text-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                        </svg>
                        {item}
                    </span>
                ))}
            </div>
            <div class="flex justify-center mt-4">
                <a href="#contacto" class="contact-modal-trigger btn-mktg-v5 shadow-[0_10px_30px_rgba(0,0,0,0.1)] !py-4 sm:!py-5 !px-6 sm:!px-10 !text-[11px] !tracking-widest font-black">
                    PARLEM DEL TEU NEGOCI
                </a>
            </div>
        </div>
    </section>

    <LogoMarquee />

    <!-- ═══ INTRO: PER QUÈ LA TEVA WEB ═══════════════════════════════════ -->
    <section class="py-16 sm:py-24 bg-white px-4 sm:px-6 border-b border-black/5">
        <div class="max-w-6xl mx-auto reveal grid md:grid-cols-[1.3fr_1fr] gap-10 md:gap-16 items-center">
            <div>
                <p class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4">Per què la teva web importa?</p>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-8 text-zinc-900 leading-[0.9]">
                    L'agència de disseny web per a la teva pime a Sant Cugat
                </h2>
                <div class="space-y-6 text-zinc-600 font-light text-base sm:text-lg leading-relaxed">
                    <p>
                        <strong class="font-semibold text-zinc-900">La teva web treballa les 24 hores, la pregunta és si treballa a favor o en contra</strong>. Abans de trucar-te, el teu client t'ha buscat, ha entrat a la teva pàgina des del mòbil i ha decidit en segons si ets de fiar. Una web lenta o antiquada l'envia directe a la teva competència.
                    </p>
                    <p>
                        Nova és una <strong class="font-semibold text-zinc-900">agència de disseny web especialitzada en pimes</strong> que treballa amb negocis de Sant Cugat i tota la seva comarca. No fem webs per guanyar premis de disseny, les fem amb un objectiu mesurable. <strong class="font-semibold text-zinc-900">Que cada visita tingui la màxima probabilitat de convertir-se en un client</strong>.
                    </p>
                </div>
            </div>
            <div class="hidden md:block">
                <img src="/sergio-galos-disseny-web-per-pimes-sant-cugat.webp" alt="Sergio Galo's, consultor de disseny web per a pimes a Sant Cugat" title="Sergio Galo's, consultor de disseny web per a pimes a Sant Cugat" class="w-full h-auto" loading="lazy" width="473" height="591" />
            </div>
        </div>
    </section>

    <!-- ═══ SERVEIS WEB ══════════════════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-zinc-50 border-b border-black/5 px-4 sm:px-6">
        <div class="max-w-7xl mx-auto text-center reveal">
            <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Què fem</span>
            <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.9]">
                Servei de disseny web per a pimes a Sant Cugat
            </h2>
            <div class="text-zinc-500 font-light text-sm sm:text-base leading-relaxed max-w-3xl mx-auto mb-16 space-y-4">
                <p>
                    Una <strong class="font-semibold text-zinc-700">pàgina web que ven</strong> no és només disseny, és un sistema. Aquestes són les nou peces que treballem perquè la teva web deixi de ser una targeta de visita i es converteixi en el teu millor canal de captació.
                </p>
                <p>
                    Cada peça s'activa segons el que necessiti el teu projecte. No pagues per un paquet tancat d'accions, pagues per les que el teu negoci necessita.
                </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                {[
                    { icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', t: 'Webs corporatives a Sant Cugat', d: 'La web d\'empresa que presenta el teu negoci, transmet confiança i converteix. Estructura pensada per al client i per a Google.' },
                    { icon: 'M13 10V3L4 14h7v7l9-11h-7z', t: 'Landing pages per a les teves campanyes', d: 'Pàgines d\'aterratge per a les teves campanyes amb un sol objectiu. Que el clic acabi en trucada o formulari, sense distraccions.' },
                    { icon: 'M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z', t: 'Botigues online', d: 'Ecommerce ràpid amb fitxes optimitzades, passarel·la de pagament fiable i un procés de compra que no perd carrets pel camí.' },
                    { icon: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15', t: 'Redisseny sense perdre posicions', d: 'Renovem webs antiquades sense perdre el posicionament aconseguit. Migració acurada, redireccions i millora mesurable.' },
                    { icon: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4', t: 'WordPress i a mida', d: 'WordPress quan necessites autonomia per editar i desenvolupament a mida quan velocitat i SEO són crítics. El criteri mana.' },
                    { icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6', t: 'Velocitat i Core Web Vitals', d: 'Webs que carreguen en verd. La velocitat decideix si el visitant es queda i és factor de posicionament a Google.' },
                    { icon: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z', t: 'SEO local des del disseny', d: 'Arquitectura, keywords, dades estructurades i indexació integrats des del primer esbós, no apedaçats després.' },
                    { icon: 'M9 12h6m-6 4h6M9 8h2m8-3v14a2 2 0 01-2 2H7a2 2 0 01-2-2V5a2 2 0 012-2h6l4 4z', t: 'Textos per a un client exigent', d: 'Redactem els continguts de la teva web orientats al que busca el teu client. El disseny atrau i el text converteix.' },
                    { icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm8 0V5a2 2 0 012-2h0a2 2 0 012 2v14a2 2 0 01-2 2h0a2 2 0 01-2-2zm-8 0a2 2 0 002 2h2a2 2 0 002-2V9a2 2 0 00-2-2h-2a2 2 0 00-2 2v10z', t: 'Manteniment i suport directe', d: 'Actualitzacions, seguretat, còpies diàries i canvis sense esperes. La teva web sempre al dia i tu al que és teu, el teu negoci.' },
                ].map(c => (
                    <div class="bg-white border border-black/5 rounded-2xl p-6 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 text-left">
                        <div class="flex items-center gap-3 mb-3">
                            <div class="w-10 h-10 rounded-full bg-accent/10 border border-accent/20 flex items-center justify-center flex-shrink-0">
                                <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d={c.icon}/></svg>
                            </div>
                            <h3 class="text-sm font-black uppercase tracking-tight text-zinc-900">{c.t}</h3>
                        </div>
                        <p class="text-sm text-zinc-500 font-light leading-relaxed">{c.d}</p>
                    </div>
                ))}
            </div>

            <div class="mt-12 text-center reveal">
                <a href="#contacto" class="contact-modal-trigger btn-mktg-v5 shadow-[0_10px_30px_rgba(37,211,102,0.3)] !py-4 sm:!py-5 !px-6 sm:!px-10 !text-[11px] !tracking-widest font-black">
                    PARLEM DEL TEU NEGOCI
                </a>
            </div>
        </div>
    </section>

    <!-- ═══ METODOLOGIA WEB ════════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-white px-4 sm:px-6 relative overflow-hidden">
        <div class="max-w-5xl mx-auto">
            <div class="text-center mb-16 sm:mb-24 reveal">
                <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Com treballem</span>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.9]">
                    Així creem la web que converteix visites en clients a Sant Cugat
                </h2>
                <p class="text-zinc-500 font-light text-sm sm:text-base leading-relaxed max-w-2xl mx-auto">
                    Una metodologia documentada per passar d'una web que només existeix a una web que ven, pas a pas i sense fum.
                </p>
            </div>

            <div id="timeline-container" class="relative">
                <div class="hidden md:block absolute left-1/2 top-4 bottom-4 w-px bg-zinc-200 -translate-x-1/2"></div>
                <div id="progress-bar" class="hidden md:block absolute left-1/2 top-4 w-px bg-accent -translate-x-1/2 transition-all duration-100"></div>

                <div class="space-y-16 md:space-y-24 flex flex-col items-center">
                    {steps.map((step, index) => (
                        <div class="flex flex-col md:flex-row items-center gap-6 md:gap-12 w-full relative reveal">
                            <div class:list={["flex-1 w-full", index % 2 === 0 ? "md:order-1 md:text-right" : "md:order-3 md:text-left"]}>
                                <div class="p-8 sm:p-10 bg-zinc-50 border border-black/5 rounded-3xl hover:border-accent/10 hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 relative overflow-hidden group">
                                    <h3 class="text-xl font-black uppercase tracking-tighter mb-2 text-zinc-900">{index + 1}. {step.title}</h3>
                                    <div class:list={["h-0.5 bg-accent w-full mb-4 opacity-80", index % 2 === 0 ? "md:ml-auto" : ""]}></div>
                                    <p class:list={["text-sm text-zinc-500 font-light max-w-md", index % 2 === 0 ? "md:ml-auto" : ""]}>{step.desc}</p>
                                    <div class="absolute -bottom-6 -right-5 text-8xl font-black text-black/[0.02] select-none z-0 group-hover:scale-105 transition-transform duration-500">0{index+1}</div>
                                </div>
                            </div>
                            <div class="md:order-2 w-12 h-12 rounded-full border-2 border-zinc-200 bg-white flex items-center justify-center font-black text-lg z-10 shrink-0 shadow-sm node-circle transition-all">
                                0{index + 1}
                            </div>
                            <div class:list={["hidden md:block md:flex-1", index % 2 === 0 ? "md:order-3" : "md:order-1"]}></div>
                        </div>
                    ))}
                </div>
            </div>
        </div>
    </section>

    <!-- ═══ AUDITORIA WEB ═════════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-zinc-50/50 px-4 sm:px-6 border-t border-black/5 overflow-hidden">
