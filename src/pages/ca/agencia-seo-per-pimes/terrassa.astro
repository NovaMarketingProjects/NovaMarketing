---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { buildAlternates } from '../../../lib/i18n';
import { localAgencySchema } from '../../../lib/schema';
import { strapiClient } from '../../../lib/strapi';
import LogoMarquee from '../../../components/sections/LogoMarquee.astro';
import FaqHome from '../../../components/sections/FaqHome.astro';
import GoogleReviews from '../../../components/global/GoogleReviews.astro';

const SITE_URL = import.meta.env.PUBLIC_SITE_URL || 'https://novamarketing.es';
const alternates = buildAlternates('/agencia-seo-para-pymes/terrassa/', '/ca/agencia-seo-per-pimes/terrassa/', SITE_URL);

let allCases: any[] = [];
try {
  const casesRes = await strapiClient.getCaseStudies('ca');
  allCases = casesRes.data.map((i: any) => i.attributes ?? i).filter((c: any) => {
    const cats = (c.categories || []).map((cat: any) => (cat.slug || cat.attributes?.slug || '').toLowerCase());
    return cats.some((s: string) => s.includes('seo'));
  });
} catch {}

const steps = [
  { title: "Auditoria SEO del teu negoci a Terrassa", desc: "Analitzem la teva web, la teva visibilitat actual a Google i la teva competència directa. Detectem errors tècnics, keywords rendibles sense explotar i oportunitats de venda que la teva competència ja està capturant. Aquest és el teu punt de partida real." },
  { title: "Estratègia documentada per a Terrassa", desc: "Reps un full de ruta per escrit. Quines keywords atacar, quin contingut crear, què arreglar a la teva web i quins resultats esperar en 3, 6 i 12 mesos. Saps en què s'inverteix cada euro abans d'invertir-lo." },
  { title: "Optimització tècnica i continguts", desc: "Arreglem el que impedeix a Google entendre la teva web i creem el contingut que posiciona. Velocitat, indexació, arquitectura, pàgines de servei i articles pensats per atraure clients, no només visites." },
  { title: "Autoritat egarenca i enllaços", desc: "Google posiciona qui considera una referència. Aconseguim enllaços de mitjans i directoris rellevants del teu sector que augmenten l'autoritat del teu domini i empenyen les teves posicions." },
  { title: "Mesura i ajust mes a mes", desc: "Monitoritzem mes a mes les teves posicions, el teu trànsit i els teus leads. A l'informe veus quines keywords pugen, quants clients arriben des de Google i què toca ajustar el mes següent." }
];

const criteria = [
  { title: "Demana casos d'èxit verificables", desc: "Un mur de logos no demostra res. Demana casos amb dades concretes. Quina keyword, quina posició va assolir, en quant de temps i amb quina inversió. Una agència SEO seriosa hauria de poder ensenyar-te resultats de negocis com el teu. Si no poden ensenyar-te'n ni un, segueix buscant." },
  { title: "Pregunta qui portarà el teu compte", desc: "En moltes agències ven un director i executa un júnior amb 30 comptes. Exigeix conèixer la persona que treballarà el teu projecte abans de signar. A nova parles sempre amb el consultor que executa la teva estratègia SEO, presencialment o per videotrucada." },
  { title: "Exigeix la propietat dels teus actius", desc: "La web, el domini, l'analítica i la fitxa de Google Business Profile han d'estar al teu nom. És més habitual del que sembla que una pime porti anys pagant i descobreixi en canviar d'agència que no és propietària ni del seu propi domini. Això no és un servei, és una dependència." },
  { title: "Desconfia de qui garanteix la posició 1 a Google", desc: "Ningú pot garantir la posició 1. Qui ho promet, o menteix o fa servir tècniques que acabaran penalitzant la teva web. El que és seriós és garantir mètode, transparència i feina verificable mes a mes." },
  { title: "Revisa què mesura l'informe mensual", desc: "Si l'informe parla d'impressions i posicions però no de trucades, formularis i vendes, l'agència està mesurant la seva activitat i no el teu negoci. El SEO d'una pime es mesura en clients nous i pressupostos sol·licitats." },
  { title: "Fuig de les permanències llargues", desc: "Una permanència de 12 mesos protegeix l'agència, no a tu. La feina ben feta reté clients sense necessitat de contractes que els lliguin. Per això a nova treballem mes a mes." },
  { title: "Que pensi també en la IA", desc: "Cada cop més clients pregunten a ChatGPT o Perplexity en lloc de buscar a Google. Una agència SEO que ignora el posicionament en IA està optimitzant només la meitat del tauler. Nosaltres integrem SEO i GEO en una sola estratègia." }
];

const faqs = [
  { question: "Quant costa el posicionament SEO a Terrassa?", answer: "L'auditoria SEO costa 1.800 euros i els plans mensuals van des de 400 euros al mes. Pressupost tancat per escrit, sense permanències i sense sorpreses. Abans de signar saps què es fa i quin resultat es persegueix." },
  { question: "Què funciona per a un comerç del centre de Terrassa?", answer: "El pack local complet. Fitxa de Google impecable, ressenyes gestionades, SEO local per a les cerques de la zona i contingut que respon el que pregunta el client. Qui busca des del mòbil tria entre el primer que veu." },
  { question: "Feu SEO per a la indústria egarenca?", answer: "Sí. Can Parellada, Els Bellots i la resta de polígons concentren empreses B2B amb clients que busquen proveïdors a Google amb cerques molt tècniques. Posicionem aquestes keywords per portar pressupostos industrials, no trànsit curiós." },
  { question: "Competiu amb les agències SEO de Barcelona?", answer: "Treballem igual que elles però coneixent el mercat egarenc i el Vallès de primera mà, i amb la proximitat de poder reunir-nos en persona. Moltes pimes de Terrassa venen d'agències de Barcelona que les tractaven com un compte més." },
  { question: "Quant triga el SEO a Terrassa?", answer: "Els primers moviments solen veure's entre el segon i el tercer mes, i els resultats consolidats entre el sisè i el dotzè, segons la competència del teu sector a la ciutat. Al full de ruta inicial et diem què esperar a cada fase." },
  { question: "Com mesureu els resultats?", answer: "Mesurem el que mou la teva caixa. Trucades, formularis, visites al teu local i pressupostos sol·licitats, cadascun atribuït a la seva keyword. Informe mensual de negoci amb reunió inclosa." },
  { question: "Treballeu amb permanència?", answer: "No, treballem mes a mes. Si el servei no t'aporta valor, pots cancel·lar-lo quan vulguis. La nostra permanència real és el resultat que veus als informes cada mes." },
];

const sectors = [
  { icon: '🛒', title: 'SEO per a ecommerce', desc: 'Arquitectura de categories, fitxes optimitzades i SEO de producte. Que qui busca comprar et trobi a tu i no a la teva competència.' },
  { icon: '🏠', title: 'SEO per a immobiliàries', desc: 'Captació de propietaris i compradors amb landings per zona i SEO local per barri. Trànsit que filtra curiosos de clients reals.' },
  { icon: '🍽️', title: 'SEO per a restaurants', desc: 'Aquí mana la fitxa de Google i les ressenyes. Pack local complet per aparèixer quan algú busca on menjar a prop.' },
  { icon: '🧠', title: 'SEO per a psicòlegs', desc: 'El pacient busca confiança abans que preu. Contingut amb autoritat clínica i SEO local per especialitat que converteix cerques en primeres visites.' },
  { icon: '🌿', title: 'SEO per a terapeutes', desc: 'Molta competència genèrica i poca especialitzada. Posicionem la teva consulta per teràpia i zona amb contingut que educa i converteix.' },
  { icon: '🦷', title: 'SEO per a dentistes', desc: 'Sector saturat i amb alta exigència d\'autoritat. Guanyen els qui combinen SEO local impecable, ressenyes gestionades i contingut clínic real.' },
  { icon: '💪', title: 'SEO per a gimnasos', desc: 'Captació estacional amb pics al gener i al setembre. Posicionament local i contingut que omple classes tot l\'any.' },
  { icon: '🏗️', title: 'SEO per a constructores', desc: 'Competència local ferotge i leads de valor alt. Fitxa de Google impecable, landings per zona i keywords que porten pressupostos, no visites.' },
  { icon: '⚖️', title: 'SEO per a advocats', desc: 'Cerques d\'altíssima intenció i CPCs caríssims a Ads. El SEO capta la consulta amb contingut que resol el dubte legal abans que la competència.' },
  { icon: '🏨', title: 'SEO per a hotels', desc: 'Reduir la dependència de les OTAs és l\'objectiu. SEO per a reserva directa, fitxa optimitzada i visibilitat a Google Hotels.' },
  { icon: '🏭', title: 'SEO per a B2B', desc: 'Cicles de venda llargs i pocs decisors. Aquí no importa el volum, importa aparèixer a les deu cerques tècniques del responsable de compres.' },
  { icon: '🎓', title: 'SEO per a escoles', desc: 'Captació estacional amb pics clars. Contingut informacional tot l\'any i posicionament fort a la finestra de matriculació.' },
];

const pageSchema = localAgencySchema({
  pageUrl: `${SITE_URL}/ca/agencia-seo-per-pimes/terrassa/`,
  lang: 'ca',
  cityName: 'Terrassa',
  postalCode: '08221',
  geo: { lat: 41.5633, lng: 2.0087 },
  areaServed: ["Terrassa", "Vallès Occidental", "Barcelona", "España"],
  title: "Agència SEO a Terrassa | Posicionament a Google per a Pimes",
  description: "Agència SEO a Terrassa especialitzada en pimes. Apareix a Google quan els clients de Terrassa busquen el teu servei i converteix aquestes cerques en vendes. Sense permanències.",
  datePublished: '2026-07-15',
  dateModified: '2026-07-15',
  breadcrumbName: 'Agència SEO a Terrassa',
  faqs,
});
---

<BaseLayout
  title="Agència SEO a Terrassa | Posicionament a Google per a Pimes"
  description="Agència SEO a Terrassa especialitzada en pimes. Apareix a Google quan els clients de Terrassa busquen el teu servei i converteix aquestes cerques en vendes. Sense permanències."
  locale="ca"
  alternates={alternates}
  schemas={[pageSchema]}
>

    <!-- ═══ HERO / H1 ═══════════════════════════════════════════════════════ -->
    <section class="pt-24 sm:pt-40 pb-20 px-4 sm:px-6 relative overflow-hidden text-center bg-white border-b border-black/5">
        <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808008_1px,transparent_1px),linear-gradient(to_bottom,#80808008_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_40%,#000_75%,transparent_100%)]"></div>
        <div class="absolute -top-10 left-1/4 w-72 h-72 bg-accent/15 rounded-full blur-3xl opacity-30 animate-pulse"></div>
        <div class="absolute top-20 right-1/4 w-80 h-80 bg-purple-500/5 rounded-full blur-3xl opacity-20"></div>

        <div class="max-w-5xl mx-auto reveal">
            <span class="inline-flex items-center gap-2 bg-accent/5 backdrop-blur-sm px-4 py-2 border border-accent/10 rounded-full text-accent text-[8px] sm:text-[10px] font-black uppercase tracking-[0.3em] mb-8 shadow-sm">
                <span class="w-1.5 h-1.5 bg-accent rounded-full animate-ping"></span>
                Posicionament Web per a Pimes
            </span>
            <h1 class="text-3xl sm:text-5xl md:text-7xl lg:text-8xl uppercase font-extrabold tracking-tighter leading-[0.88] mb-8 text-gradient flex flex-col items-center text-center">
                <span class="lg:whitespace-nowrap">Agència SEO </span>
                <span class="lg:whitespace-nowrap">Posicionament </span>
                <span class="lg:whitespace-nowrap text-mktg-gradient">a Google a Terrassa</span>
            </h1>
            <p class="text-lg sm:text-xl text-zinc-500 font-light leading-relaxed w-[75%] mx-auto mb-8">
                Apareix quan els teus clients busquen el teu servei a Google. Servei de posicionament SEO per a pimes de Terrassa amb estratègia a mida, preus clars i resultats que es mesuren en vendes.
            </p>
            <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3 mb-10">
                {['Sense permanències', 'Tracte directe amb el consultor', 'Informes de negoci'].map(item => (
                    <span class="inline-flex items-center gap-2 text-[11px] sm:text-xs font-black uppercase tracking-widest text-zinc-700">
                        <svg class="w-4 h-4 text-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                        </svg>
                        {item}
                    </span>
                ))}
            </div>
            <div class="flex justify-center mt-4">
                <a href="#contacto" class="contact-modal-trigger btn-mktg-v5 shadow-[0_10px_30px_rgba(0,0,0,0.1)] !py-4 sm:!py-5 !px-6 sm:!px-10 !text-[11px] !tracking-widest font-black">
                    PARLEM DEL TEU NEGOCI
                </a>
            </div>
        </div>
    </section>

    <LogoMarquee />

    <!-- ═══ INTRO: PER QUÈ SEO ═══════════════════════════════════════════ -->
    <section class="py-16 sm:py-24 bg-white px-4 sm:px-6 border-b border-black/5">
        <div class="max-w-6xl mx-auto reveal grid md:grid-cols-[1.3fr_1fr] gap-10 md:gap-16 items-center">
            <div>
                <p class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4">Per què SEO?</p>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-8 text-zinc-900 leading-[0.9]">
                    L'agència de posicionament SEO per a la teva pime a Terrassa
                </h2>
                <div class="space-y-6 text-zinc-600 font-light text-base sm:text-lg leading-relaxed">
                    <p>
                        <strong class="font-semibold text-zinc-900">El SEO és el canal que segueix portant clients quan deixes de pagar per anuncis</strong>. Cada cerca del teu servei a Google és un client amb intenció de compra, i qui apareix primer se l'emporta. A diferència de la publicitat, el posicionament és un actiu que s'acumula mes a mes.
                    </p>
                    <p>
                        Nova és una <strong class="font-semibold text-zinc-900">agència SEO especialitzada en pimes</strong> que treballa amb negocis de Terrassa i tota la seva comarca. Treballem amb un nombre limitat de clients, cada compte el porta directament el consultor fundador i tota l'estratègia s'orienta a una sola mètrica que importa. <strong class="font-semibold text-zinc-900">Quants clients nous arriben des de Google cada mes</strong>.
                    </p>
                </div>
            </div>
            <div class="hidden md:block">
                <img src="/sergio-galos-agencia-seo-per-pimes-terrassa.webp" alt="Sergio Galo's, consultor SEO per a pimes a Terrassa" class="w-full h-auto" loading="lazy" />
            </div>
        </div>
    </section>

    <!-- ═══ SERVEIS SEO ══════════════════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-zinc-50 border-b border-black/5 px-4 sm:px-6">
        <div class="max-w-7xl mx-auto text-center reveal">
            <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Què fem</span>
            <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.9]">
                Servei de posicionament SEO per a pimes a Terrassa
            </h2>
            <div class="text-zinc-500 font-light text-sm sm:text-base leading-relaxed max-w-3xl mx-auto mb-16 space-y-4">
                <p>
                    El <strong class="font-semibold text-zinc-700">posicionament SEO</strong> no és una sola tasca, és un sistema. Aquestes són les nou peces que treballem perquè la teva pime passi de ser invisible a Google a captar clients cada mes des del cercador.
                </p>
                <p>
                    Cada peça s'activa segons el que digui la teva auditoria. No pagues per un paquet tancat d'accions, pagues per les que el teu negoci necessita.
                </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                {[
                    { icon: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z', t: 'Auditoria SEO a Terrassa', d: 'Radiografia tècnica, de contingut i d\'autoritat de la teva web abans de tocar res. El punt de partida de qualsevol estratègia.' },
                    { icon: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4', t: 'SEO tècnic per a la teva web', d: 'Velocitat, indexació, Core Web Vitals i arquitectura. Que Google pugui rastrejar i entendre el teu lloc sense friccions.' },
                    { icon: 'M12 3a9 9 0 100 18 9 9 0 000-18zm0 5a4 4 0 100 8 4 4 0 000-8z', t: 'Keywords del mercat egarenc', d: 'Identifiquem què busquen els teus clients potencials, amb quin volum i quines oportunitats estan sense cobrir al teu sector.' },
                    { icon: 'M9 12h6m-6 4h6M9 8h2m8-3v14a2 2 0 01-2 2H7a2 2 0 01-2-2V5a2 2 0 012-2h6l4 4z', t: 'Continguts per al client de Terrassa', d: 'Creem i optimitzem el contingut que posiciona. Pàgines de servei, articles i arquitectura editorial pensada per vendre.' },
                    { icon: 'M13.828 10.172a4 4 0 010 5.656l-3 3a4 4 0 01-5.656-5.656l1.5-1.5m7.328-1.672a4 4 0 000-5.656 4 4 0 00-5.656 0l-1.5 1.5', t: 'Enllaços amb autoritat local', d: 'Aconseguim enllaços de qualitat en mitjans rellevants per augmentar l\'autoritat del teu domini de manera orgànica i sostinguda.' },
                    { icon: 'M17.657 16.657L13.414 20.9a2 2 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0zM15 11a3 3 0 11-6 0 3 3 0 016 0z', t: 'SEO local per al centre i Vapor Gran', d: 'Posicionem el teu negoci a Google Maps i a les cerques de la teva zona. Imprescindible si els teus clients són a prop teu.' },
                    { icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm8 0V5a2 2 0 012-2h0a2 2 0 012 2v14a2 2 0 01-2 2h0a2 2 0 01-2-2zm-8 0a2 2 0 002 2h2a2 2 0 002-2V9a2 2 0 00-2-2h-2a2 2 0 00-2 2v10z', t: 'Analítica de leads i pressupostos', d: 'Configurem GA4 i Search Console per atribuir cada lead a la seva keyword. Decisions amb dades, no amb intuïcions.' },
                    { icon: 'M8 12h.01M12 12h.01M16 12h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z', t: 'SEO més GEO', d: 'Cada cop més clients pregunten a la IA en lloc de buscar a Google. Integrem posicionament a Google i a la IA en una sola estratègia.' },
                    { icon: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15', t: 'Migracions sense perdre posicions', d: 'Canvis de domini, redissenys o salts de plataforma sense perdre el posicionament que tant ha costat aconseguir.' },
                ].map(c => (
                    <div class="bg-white border border-black/5 rounded-2xl p-6 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 text-left">
                        <div class="flex items-center gap-3 mb-3">
                            <div class="w-10 h-10 rounded-full bg-accent/10 border border-accent/20 flex items-center justify-center flex-shrink-0">
                                <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d={c.icon}/></svg>
                            </div>
                            <h3 class="text-sm font-black uppercase tracking-tight text-zinc-900">{c.t}</h3>
                        </div>
                        <p class="text-sm text-zinc-500 font-light leading-relaxed">{c.d}</p>
                    </div>
                ))}
            </div>

            <div class="mt-12 text-center reveal">
                <a href="#contacto" class="contact-modal-trigger btn-mktg-v5 shadow-[0_10px_30px_rgba(37,211,102,0.3)] !py-4 sm:!py-5 !px-6 sm:!px-10 !text-[11px] !tracking-widest font-black">
                    PARLEM DEL TEU NEGOCI
                </a>
            </div>
        </div>
    </section>

    <!-- ═══ ESTRATÈGIA SEO ════════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-white px-4 sm:px-6 relative overflow-hidden">
        <div class="max-w-5xl mx-auto">
            <div class="text-center mb-16 sm:mb-24 reveal">
                <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Com treballem</span>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.9]">
                    Estratègia SEO per posicionar la teva pime de Terrassa a Google
                </h2>
                <p class="text-zinc-500 font-light text-sm sm:text-base leading-relaxed max-w-2xl mx-auto">
                    Una metodologia documentada per passar de ser invisible a Google a captar clients des del cercador, pas a pas i sense fum.
                </p>
            </div>

            <div id="timeline-container" class="relative">
                <div class="hidden md:block absolute left-1/2 top-4 bottom-4 w-px bg-zinc-200 -translate-x-1/2"></div>
                <div id="progress-bar" class="hidden md:block absolute left-1/2 top-4 w-px bg-accent -translate-x-1/2 transition-all duration-100"></div>

                <div class="space-y-16 md:space-y-24 flex flex-col items-center">
                    {steps.map((step, index) => (
                        <div class="flex flex-col md:flex-row items-center gap-6 md:gap-12 w-full relative reveal">
                            <div class:list={["flex-1 w-full", index % 2 === 0 ? "md:order-1 md:text-right" : "md:order-3 md:text-left"]}>
                                <div class="p-8 sm:p-10 bg-zinc-50 border border-black/5 rounded-3xl hover:border-accent/10 hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 relative overflow-hidden group">
                                    <h3 class="text-xl font-black uppercase tracking-tighter mb-2 text-zinc-900">{index + 1}. {step.title}</h3>
                                    <div class:list={["h-0.5 bg-accent w-full mb-4 opacity-80", index % 2 === 0 ? "md:ml-auto" : ""]}></div>
                                    <p class:list={["text-sm text-zinc-500 font-light max-w-md", index % 2 === 0 ? "md:ml-auto" : ""]}>{step.desc}</p>
                                    <div class="absolute -bottom-6 -right-5 text-8xl font-black text-black/[0.02] select-none z-0 group-hover:scale-105 transition-transform duration-500">0{index+1}</div>
                                </div>
                            </div>
                            <div class="md:order-2 w-12 h-12 rounded-full border-2 border-zinc-200 bg-white flex items-center justify-center font-black text-lg z-10 shrink-0 shadow-sm node-circle transition-all">
                                0{index + 1}
                            </div>
                            <div class:list={["hidden md:block md:flex-1", index % 2 === 0 ? "md:order-3" : "md:order-1"]}></div>
                        </div>
                    ))}
                </div>
            </div>
        </div>
    </section>

    <!-- ═══ AUDITORIA SEO ═════════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-zinc-50/50 px-4 sm:px-6 border-t border-black/5 overflow-hidden">
        <div class="max-w-7xl mx-auto grid lg:grid-cols-[6fr_4fr] gap-12 lg:gap-16 items-start">

            <div class="reveal lg:col-span-2">
