---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { buildAlternates } from '../../../lib/i18n';
import { localAgencySchema } from '../../../lib/schema';
import { strapiClient } from '../../../lib/strapi';
import LogoMarquee from '../../../components/sections/LogoMarquee.astro';
import FaqHome from '../../../components/sections/FaqHome.astro';
import CityPills from '../../../components/global/CityPills.astro';
import GoogleReviews from '../../../components/global/GoogleReviews.astro';

const SITE_URL = import.meta.env.PUBLIC_SITE_URL || 'https://novamarketing.es';
const alternates = buildAlternates('/agencia-ecommerce/google-ads/', '/ca/agencia-ecommerce/google-ads/', SITE_URL);

let allCases: any[] = [];
try {
  const casesRes = await strapiClient.getCaseStudies('ca');
  allCases = casesRes.data.map((i: any) => i.attributes ?? i).filter((c: any) => {
    const cats = (c.categories || []).map((cat: any) => (cat.slug || cat.attributes?.slug || '').toLowerCase());
    return cats.some((s: string) => s.includes('google-ads') || s === 'e-commerce');
  });
} catch {}

const faqs = [
  { question: "Què inclou la gestió de Google Ads per a un ecommerce?", answer: "Inclou auditoria inicial, estratègia documentada i gestió setmanal. Shopping, Performance Max, cerca i remarketing dinàmic, optimització del feed producte a producte, mesura de conversions amb valor real i un informe mensual amb vendes, ROAS i marge." },
  { question: "Quant costa una agència de Google Ads per a ecommerce?", answer: "L'auditoria del teu compte costa 900 euros i la gestió mensual comença en 150 euros al mes amb fee fix, sense percentatges sobre la teva inversió. A això s'hi suma el teu pressupost publicitari, que va íntegre a Google. Pressupost tancat per escrit." },
  { question: "Quant pressupost necessita la meva botiga?", answer: "Depèn del sector i del preu dels teus productes. Com a regla general, recomanem partir d'entre 500 i 1.000 euros al mes perquè Shopping tingui dades suficients per optimitzar." },
  { question: "Què és millor per a una botiga, Shopping o Performance Max?", answer: "Solen conviure. Shopping dona control i dades netes, Performance Max escala quan el compte ja té historial i valors de conversió fiables. L'ordre correcte importa, i el marquem a l'estratègia." },
  { question: "El compte de Google Ads serà meu?", answer: "Sí, sempre. El compte, l'historial, el feed i les conversions queden al teu nom des del primer dia. Si algun dia deixes de treballar amb nosaltres, t'emportes tot l'aprenentatge acumulat." },
  { question: "Com mesureu els resultats?", answer: "En vendes, ROAS i marge. Cada comanda queda atribuïda a la seva campanya amb el seu valor real. A l'informe mensual veus quant has invertit, quant has venut i quines campanyes escalar." },
  { question: "Treballeu amb permanència?", answer: "No, treballem mes a mes. Si el servei no t'aporta valor, pots cancel·lar-lo quan vulguis. La nostra permanència real és el resultat que veus als informes cada mes." },
];

const pageSchema = localAgencySchema({
  pageUrl: `${SITE_URL}/ca/agencia-ecommerce/google-ads/`,
  lang: 'ca',
  cityName: 'Barcelona',
  postalCode: '08035',
  geo: { lat: 41.4114, lng: 2.1526 },
  areaServed: ["España", "Barcelona", "Sabadell", "Sant Cugat del Vallès", "Terrassa", "Vallès Occidental"],
  title: "Agència Google Ads per a Ecommerce | Shopping i PMax | Nova Marketing",
  description: "Campanyes de Google Ads per a ecommerce. Shopping, Performance Max i cerca amb feed optimitzat, fee fix i resultats mesurats en ROAS. Sense permanències.",
  datePublished: '2026-07-17',
  dateModified: '2026-07-17',
  streetAddress: 'Carrer del General Mendoza, 10',
  hasMap: 'https://maps.app.goo.gl/9fbB12UcK32bgjj89',
  aggregateRating: { ratingValue: '5.0', reviewCount: '8' },
  breadcrumbName: "Agència Google Ads per a Ecommerce",
  faqs,
});
---

<BaseLayout
  title="Agència Google Ads per a Ecommerce | Shopping i PMax | Nova Marketing"
  description="Campanyes de Google Ads per a ecommerce. Shopping, Performance Max i cerca amb feed optimitzat, fee fix i resultats mesurats en ROAS. Sense permanències."
  locale="ca"
  alternates={alternates}
  schemas={[pageSchema]}
>

    <!-- ═══ HERO / H1 ═══════════════════════════════════════════════════════ -->
    <section class="pt-24 sm:pt-40 pb-20 px-4 sm:px-6 relative overflow-hidden text-center bg-white border-b border-black/5">
        <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808008_1px,transparent_1px),linear-gradient(to_bottom,#80808008_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_40%,#000_75%,transparent_100%)]"></div>
        <div class="absolute -top-10 left-1/4 w-72 h-72 bg-accent/15 rounded-full blur-3xl opacity-30 animate-pulse"></div>
        <div class="absolute top-20 right-1/4 w-80 h-80 bg-purple-500/5 rounded-full blur-3xl opacity-20"></div>

        <div class="max-w-5xl mx-auto reveal">
            <span class="inline-flex items-center gap-2 bg-accent/5 backdrop-blur-sm px-4 py-2 border border-accent/10 rounded-full text-accent text-[8px] sm:text-[10px] font-black uppercase tracking-[0.3em] mb-8 shadow-sm">
                <span class="w-1.5 h-1.5 bg-accent rounded-full animate-ping"></span>
                Publicitat a Google per a Botigues Online
            </span>
            <h1 class="text-3xl sm:text-5xl md:text-7xl lg:text-8xl uppercase font-extrabold tracking-tighter leading-[0.88] mb-8 text-gradient flex flex-col items-center text-center">
                <span class="lg:whitespace-nowrap">Agència Google Ads </span>
                <span class="lg:whitespace-nowrap text-mktg-gradient">per a Ecommerce</span>
            </h1>
            <p class="text-lg sm:text-xl text-zinc-500 font-light leading-relaxed w-[75%] mx-auto mb-8">
                El teu producte amb foto i preu davant de qui ja l'està buscant. Campanyes de Google Ads per a botigues online amb fee fix i resultats mesurats en ROAS.
            </p>
            <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3 mb-10">
                {['Sense permanències', 'Tracte directe amb el consultor', 'Resultats mesurats en vendes'].map(item => (
                    <span class="inline-flex items-center gap-2 text-[11px] sm:text-xs font-black uppercase tracking-widest text-zinc-700">
                        <svg class="w-4 h-4 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                        {item}
                    </span>
                ))}
            </div>
            <div class="flex justify-center mt-4">
                <a href="#contacto" class="contact-modal-trigger btn-mktg-v5 shadow-[0_10px_30px_rgba(0,0,0,0.1)] !py-4 sm:!py-5 !px-6 sm:!px-10 !text-[11px] !tracking-widest font-black">
                    PARLEM DE LA TEVA BOTIGA
                </a>
            </div>
        </div>
    </section>

    <LogoMarquee />

    <!-- ═══ INTRO ═══════════════════════════════════════════════════════ -->
    <section class="py-16 sm:py-24 bg-white px-4 sm:px-6 border-b border-black/5">
        <div class="max-w-6xl mx-auto reveal grid md:grid-cols-[1.3fr_1fr] gap-10 md:gap-16 items-center">
            <div>
                <p class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4">Per què Google Ads?</p>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-8 text-zinc-900 leading-[0.9]">
                    L'agència de Google Ads per a la teva botiga online
                </h2>
                <div class="space-y-6 text-zinc-600 font-light text-base sm:text-lg leading-relaxed">
                    <p>
                        <strong class="font-semibold text-zinc-900">Google Ads és el canal més ràpid per vendre online</strong>. Shopping posa el teu producte amb foto i preu davant de qui ja el busca, i Performance Max escala el que funciona. La qüestió és quant pagues per cada venda i quin marge et deixa.
                    </p>
                    <p>
                        Nova és una <strong class="font-semibold text-zinc-900">agència SEM especialitzada en ecommerce</strong>. Feed optimitzat, estructura per marges i una sola mètrica que importa. <strong class="font-semibold text-zinc-900">Quant et costa cada venda i quin ROAS deixa cada campanya</strong>.
                    </p>
                </div>
            </div>
            <div class="hidden md:block">
                <img src="/sergio-galos-agencia-ecommerce-google-ads.webp" alt="Sergio Galo's, Consultor de Google Ads per a ecommerce" title="Sergio Galo's, Consultor de Google Ads per a ecommerce" class="w-full h-auto" loading="lazy" />
            </div>
        </div>
    </section>

    <!-- ═══ SERVEIS ══════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-zinc-50 px-4 sm:px-6 border-t border-b border-black/5">
        <div class="max-w-7xl mx-auto text-center reveal">
            <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Què fem</span>
            <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.9]">
                Servei de Google Ads per a ecommerce
            </h2>
            <p class="text-zinc-500 font-light text-sm sm:text-base leading-relaxed max-w-3xl mx-auto mb-16">
                Gestionar Google Ads per a una botiga no és activar una campanya i deixar-la córrer, és un sistema. Aquestes són les nou peces que treballem perquè cada euro torni convertit en comandes.
            </p>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 text-left">
                {[
                    { t: "Auditoria del compte", d: "Radiografia del teu compte, el teu feed i la teva competència abans de tocar res. On es perd pressupost i on hi ha el marge." },
                    { t: "Google Shopping", d: "L'aparador de Google. Feed net, títols optimitzats i pujes per marge perquè el clic arribi mig convençut." },
                    { t: "Performance Max", d: "La campanya automatitzada de Google, ben alimentada i ben vigilada. Potent amb dades bones, un forat sense elles." },
                    { t: "Campanyes de cerca", d: "Anuncis de text per a les cerques de producte i de marca que Shopping no cobreix." },
                    { t: "Optimització del feed", d: "Títols, atributs i imatges del feed treballats producte a producte. El feed decideix quines subhastes guanyes." },
                    { t: "Remarketing dinàmic", d: "Tornem a impactar qui va veure el teu producte i no va comprar, mostrant-li exactament el que va deixar al carret." },
                    { t: "Mesura de conversions", d: "Cada comanda atribuïda a la seva campanya amb el valor real de la venda. Decisions per ROAS, no per clics." },
                    { t: "Pujes per marge", d: "No tots els productes mereixen la mateixa puja. Estructurem les campanyes segons el marge de cada categoria." },
                    { t: "Google Ads més SEO", d: "Les dades de les teves campanyes revelen quines cerques venen. Les fem servir per construir SEO i dependre menys de pagar." },
                ].map((c: any) => (
                    <div class="bg-white border border-black/5 rounded-2xl p-6 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
                        <h3 class="text-sm font-black uppercase tracking-tight text-zinc-900 mb-3">
                            {c.href ? <a href={c.href} class="hover:text-accent transition-colors">{c.t}</a> : c.t}
                            {c.b && <span class="block text-[11px] uppercase tracking-[0.2em] text-accent mt-1 font-semibold">{c.b}</span>}
                        </h3>
                        <p class="text-sm text-zinc-500 font-light leading-relaxed mb-2">{c.d}</p>
                        {c.href && <a href={c.href} class="text-[11px] font-black tracking-widest text-accent hover:underline">SABER MÉS →</a>}
                    </div>
                ))}
            </div>
            <div class="mt-12 text-center reveal">
                <a href="#contacto" class="contact-modal-trigger btn-mktg-v5 shadow-[0_10px_30px_rgba(37,211,102,0.3)] !py-4 sm:!py-5 !px-6 sm:!px-10 !text-[11px] !tracking-widest font-black">PARLEM DE LA TEVA BOTIGA</a>
            </div>
        </div>
    </section>

    <!-- ═══ ESTRATÈGIA ════════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-white px-4 sm:px-6 relative overflow-hidden">
        <div class="max-w-5xl mx-auto">
            <div class="text-center mb-16 sm:mb-24 reveal">
                <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Com treballem</span>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.9]">
                    Estratègia de Google Ads per al teu ecommerce
                </h2>
                <p class="text-zinc-500 font-light text-sm sm:text-base leading-relaxed max-w-2xl mx-auto">
                    Una metodologia documentada, pas a pas i sense fum.
                </p>
            </div>

            <div id="timeline-container" class="relative">
                <div class="hidden md:block absolute left-1/2 top-4 bottom-4 w-px bg-zinc-200 -translate-x-1/2"></div>
                <div id="progress-bar" class="hidden md:block absolute left-1/2 top-4 w-px bg-accent -translate-x-1/2 transition-all duration-100"></div>

                <div class="space-y-16 md:space-y-24 flex flex-col items-center">
                    {[
                        { title: "Auditoria de Compte i Feed", desc: "Analitzem el teu compte, el teu feed de producte i el que fa la teva competència a les subhastes. Detectem pressupost malbaratat i oportunitats per categoria." },
                        { title: "Estratègia de Campanyes Documentada", desc: "Reps un pla per escrit. Quines campanyes llançar, quins productes empènyer, quin pressupost necessites i quin ROAS és raonable al teu sector." },
                        { title: "Feed, Campanyes i Fitxes", desc: "Optimitzem el feed producte a producte, muntem les campanyes amb estructura per marges i preparem les fitxes per convertir el clic en comanda." },
                        { title: "Optimització de Pujes i Pressupost", desc: "Revisem cada setmana. Tallem els productes que gasten sense vendre, pugem la puja on hi ha marge i ajustem per temporada." },
                        { title: "Mesura i Escalat", desc: "Monitorem vendes, ROAS i marge per campanya. A l'informe veus què escala, què es talla i on va el pressupost el mes següent." },
                    ].map((step, index) => (
                        <div class="flex flex-col md:flex-row items-center gap-6 md:gap-12 w-full relative reveal">
                            <div class:list={["flex-1 w-full", index % 2 === 0 ? "md:order-1 md:text-right" : "md:order-3 md:text-left"]}>
                                <div class="p-8 sm:p-10 bg-zinc-50 border border-black/5 rounded-3xl hover:border-accent/10 hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 relative overflow-hidden group">
                                    <h3 class="text-xl font-black uppercase tracking-tighter mb-2 text-zinc-900">{index + 1}. {step.title}</h3>
                                    <div class:list={["h-0.5 bg-accent w-full mb-4 opacity-80", index % 2 === 0 ? "md:ml-auto" : ""]}></div>
                                    <p class:list={["text-sm text-zinc-500 font-light max-w-md", index % 2 === 0 ? "md:ml-auto" : ""]}>{step.desc}</p>
                                    <div class="absolute -bottom-6 -right-5 text-8xl font-black text-black/[0.02] select-none z-0 group-hover:scale-105 transition-transform duration-500">0{index+1}</div>
                                </div>
                            </div>
                            <div class="md:order-2 w-12 h-12 rounded-full border-2 border-zinc-200 bg-white flex items-center justify-center font-black text-lg z-10 shrink-0 shadow-sm node-circle transition-all">
                                0{index + 1}
                            </div>
                            <div class:list={["hidden md:block md:flex-1", index % 2 === 0 ? "md:order-3" : "md:order-1"]}></div>
                        </div>
                    ))}
                </div>
            </div>
        </div>
    </section>

    <!-- ═══ AUDITORIA ═════════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-zinc-50/50 px-4 sm:px-6 border-t border-black/5 overflow-hidden">
        <div class="max-w-7xl mx-auto grid lg:grid-cols-[6fr_4fr] gap-12 lg:gap-16 items-start">
            <div class="reveal lg:col-span-2">
                <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Punt de partida</span>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase text-zinc-900 leading-[0.9]">
                    Auditoria de Google Ads per al teu ecommerce
                </h2>
            </div>
            <div class="reveal">
                <div class="space-y-5 text-zinc-600 font-light text-base leading-relaxed mb-8">
                    <p>Saps quins productes et deixen marge després de pagar el clic? Quina part del teu pressupost se'n va en cerques que mai compren? Gairebé cap botiga ho sap amb dades, i aquí comença tot.</p>
                    <p>La nostra <strong class="font-semibold text-zinc-900">auditoria de Google Ads per a ecommerce</strong> revisa el teu compte campanya a campanya i el teu feed producte a producte, i acaba amb un pla d'acció prioritzat per estalvi i impacte en vendes.</p>
                    <p>Cada punt el revisa un consultor sènior amb experiència en botigues online. El resultat és un diagnòstic de negoci que entén qualsevol gerent.</p>
                    <p>Si ja treballes amb una altra agència, l'auditoria serveix com a segona opinió independent abans de seguir invertint.</p>
                </div>
                <ul class="space-y-3">
                    {["Estructura del compte i qualitat de les campanyes","Salut del feed de producte i els seus atributs","Productes que gasten sense vendre","ROAS real per campanya i categoria","Fugues a la fitxa, el carret i el checkout","Pla d'acció prioritzat per estalvi"].map(item => (
                        <li class="flex items-start gap-3 text-sm text-zinc-700 font-light">
                            <svg class="w-4 h-4 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                            {item}
                        </li>
                    ))}
                </ul>
                <div class="mt-16">
                    <a href="#contacto" class="contact-modal-trigger btn-mktg-v5 shadow-[0_10px_30px_rgba(37,211,102,0.3)] !py-4 sm:!py-5 !px-6 sm:!px-10 !text-[11px] !tracking-widest font-black">
                        VULL LA MEVA AUDITORIA DE GOOGLE ADS
                    </a>
                </div>
            </div>
            <div class="reveal flex flex-col gap-4">
                {[
                    { bg: 'bg-purple-100', color: 'text-purple-600', t: "Revisió completa del compte", d: "Estructura, campanyes, pujes i configuració. Tot el que encareix les teves vendes, documentat." },
                    { bg: 'bg-green-100', color: 'text-green-600', t: "Pla d'acció prioritzat", d: "Un pla ordenat per estalvi i impacte. Sabràs què tallar la primera setmana i on reinvertir." },
                    { bg: 'bg-purple-100', color: 'text-purple-600', t: "Auditoria del feed", d: "Títols, atributs i imatges revisats. El feed decideix quines subhastes guanyes i a quin preu." },
                    { bg: 'bg-amber-100', color: 'text-amber-600', t: "Anàlisi per marge", d: "Creuem cost publicitari amb marge per categoria. Vendre més no sempre és guanyar més." },
                    { bg: 'bg-blue-100', color: 'text-blue-600', t: "Benchmark del teu sector", d: "Comparem els teus anuncis i preus amb els teus tres competidors directes a les mateixes subhastes." },
                ].map(card => (
                    <div class="bg-white rounded-2xl shadow-[0_15px_40px_rgba(0,0,0,0.08)] p-5 flex items-start gap-4">
                        <div class:list={["w-11 h-11 rounded-full flex items-center justify-center flex-shrink-0", card.bg]}>
                            <svg class:list={["w-5 h-5", card.color]} fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                        </div>
                        <div>
                            <h3 class="text-sm font-black text-zinc-900 mb-1">{card.t}</h3>
                            <p class="text-xs text-zinc-500 font-light leading-relaxed">{card.d}</p>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- ═══ QUÈ INCLOU L'AUDITORIA ═══════════════════════════ -->
    <section class="py-20 sm:py-28 bg-white px-4 sm:px-6 border-t border-black/5">
        <div class="max-w-7xl mx-auto">
            <div class="text-center mb-12 sm:mb-16 reveal">
                <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Pas a pas</span>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase text-zinc-900 leading-[0.9]">
                    Què inclou l'auditoria Google Ads de nova
                </h2>
            </div>
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 items-stretch reveal">
                {[
                    { n: '1', t: "Radiografia de la teva inversió", d: "Analitzem quant inverteixes, quines campanyes porten comandes, a quin cost i quina part del pressupost es perd." },
                    { n: '2', t: "Diagnòstic de feed i fitxes", d: "Creuem les dades del compte amb el teu feed i les teves fitxes per explicar què encareix cada venda." },
                    { n: '3', t: "Full de ruta per rendibilitzar", d: "Tanques l'auditoria amb accions ordenades per estalvi i impacte i una videotrucada on ho repassem amb tu." },
                ].map((st, i) => (
                    <div class="flex items-center gap-4 lg:gap-6">
                        {i > 0 && <div class="hidden lg:flex text-3xl text-accent font-black select-none">→</div>}
                        <div class="bg-white border border-black/5 rounded-2xl p-8 shadow-[0_15px_40px_rgba(0,0,0,0.06)] flex-1 text-center h-full">
                            <div class="w-12 h-12 rounded-full bg-accent/10 border border-accent/20 flex items-center justify-center mx-auto mb-4 text-accent font-black text-lg">{st.n}</div>
                            <h3 class="text-base font-black uppercase tracking-tight text-zinc-900 mb-3">{st.t}</h3>
                            <p class="text-sm text-zinc-500 font-light leading-relaxed">{st.d}</p>
                        </div>
                    </div>
                ))}
            </div>
            <p class="text-zinc-500 font-light text-sm sm:text-base leading-relaxed max-w-3xl mx-auto text-center mt-16 reveal">
                La nostra auditoria de Google Ads és el primer pas de qualsevol estratègia de publicitat per a ecommerce. Analitza com treballa avui el teu pressupost, explica per què la teva competència aconsegueix vendes més barates i et deixa un full de ruta clar. També pots contractar-la solta com a segona opinió.
            </p>
            <div class="mt-12 text-center reveal">
                <a href="#contacto" class="contact-modal-trigger btn-mktg-v5 shadow-[0_10px_30px_rgba(37,211,102,0.3)] !py-4 sm:!py-5 !px-6 sm:!px-10 !text-[11px] !tracking-widest font-black">VULL LA MEVA AUDITORIA DE GOOGLE ADS</a>
