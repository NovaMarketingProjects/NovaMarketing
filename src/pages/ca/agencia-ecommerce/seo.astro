---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { buildAlternates } from '../../../lib/i18n';
import { localAgencySchema } from '../../../lib/schema';
import { strapiClient } from '../../../lib/strapi';
import LogoMarquee from '../../../components/sections/LogoMarquee.astro';
import FaqHome from '../../../components/sections/FaqHome.astro';
import CityPills from '../../../components/global/CityPills.astro';
import GoogleReviews from '../../../components/global/GoogleReviews.astro';

const SITE_URL = import.meta.env.PUBLIC_SITE_URL || 'https://novamarketing.es';
const alternates = buildAlternates('/agencia-ecommerce/seo/', '/ca/agencia-ecommerce/seo/', SITE_URL);

let allCases: any[] = [];
try {
  const casesRes = await strapiClient.getCaseStudies('ca');
  allCases = casesRes.data.map((i: any) => i.attributes ?? i).filter((c: any) => {
    const cats = (c.categories || []).map((cat: any) => (cat.slug || cat.attributes?.slug || '').toLowerCase());
    return cats.some((s: string) => s.includes('seo') || s === 'e-commerce');
  });
} catch {}

const faqs = [
  { question: "Què inclou el SEO per a un ecommerce?", answer: "Inclou auditoria inicial, estratègia documentada i execució mensual. Optimització tècnica de la botiga, keyword research de producte, arquitectura de categories, fitxes optimitzades, continguts, link building i un informe mensual amb posicions, trànsit i vendes orgàniques." },
  { question: "Quant costa el SEO per a una botiga online?", answer: "L'auditoria SEO costa 1.800 euros i els plans mensuals van des de 400 euros al mes per a botigues petites i mitjanes i des de 900 per a catàlegs grans o sectors molt competits. Pressupost tancat per escrit i sense permanències." },
  { question: "Quant triga el SEO en un ecommerce?", answer: "Els primers moviments solen veure's entre el segon i el tercer mes, i els resultats consolidats entre el sisè i el dotzè. El termini depèn del teu punt de partida i de la competència del teu sector." },
  { question: "Optimitzeu les fitxes de producte una a una?", answer: "Les més importants sí, i per a la resta del catàleg creem regles i plantilles optimitzades que escalen a milers de productes. La prioritat la marquen el marge i la demanda de cada producte." },
  { question: "El SEO funciona amb catàlegs que canvien molt?", answer: "Sí, amb l'estratègia adequada. L'autoritat es concentra en categories estables i les fitxes hereten aquest posicionament encara que rotin. Així el SEO sobreviu a canvis de temporada i d'estoc." },
  { question: "Com mesureu els resultats?", answer: "En vendes orgàniques, no només en posicions. Cada comanda queda atribuïda al seu canal i a l'informe mensual veus quantes vendes arriben des de Google i quines keywords les porten. Les dades són sempre teves." },
  { question: "Treballeu amb permanència?", answer: "No, treballem mes a mes. Si el servei no t'aporta valor, pots cancel·lar-lo quan vulguis. La nostra permanència real és el resultat que veus als informes cada mes." },
];

const pageSchema = localAgencySchema({
  pageUrl: `${SITE_URL}/ca/agencia-ecommerce/seo/`,
  lang: 'ca',
  cityName: 'Barcelona',
  postalCode: '08035',
  geo: { lat: 41.4114, lng: 2.1526 },
  areaServed: ["España", "Barcelona", "Sabadell", "Sant Cugat del Vallès", "Terrassa", "Vallès Occidental"],
  title: "Agència SEO per a Ecommerce | Posicionament per a Botigues Online",
  description: "Agència de posicionament SEO per a ecommerce. Arquitectura, fitxes de producte i continguts que capten la cerca amb intenció de compra. Sense permanències.",
  datePublished: '2026-07-17',
  dateModified: '2026-07-17',
  streetAddress: 'Carrer del General Mendoza, 10',
  hasMap: 'https://maps.app.goo.gl/9fbB12UcK32bgjj89',
  aggregateRating: { ratingValue: '5.0', reviewCount: '8' },
  breadcrumbName: "Agència SEO per a Ecommerce",
  faqs,
});
---

<BaseLayout
  title="Agència SEO per a Ecommerce | Posicionament per a Botigues Online"
  description="Agència de posicionament SEO per a ecommerce. Arquitectura, fitxes de producte i continguts que capten la cerca amb intenció de compra. Sense permanències."
  locale="ca"
  alternates={alternates}
  schemas={[pageSchema]}
>

    <!-- ═══ HERO / H1 ═══════════════════════════════════════════════════════ -->
    <section class="pt-24 sm:pt-40 pb-20 px-4 sm:px-6 relative overflow-hidden text-center bg-white border-b border-black/5">
        <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808008_1px,transparent_1px),linear-gradient(to_bottom,#80808008_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_40%,#000_75%,transparent_100%)]"></div>
        <div class="absolute -top-10 left-1/4 w-72 h-72 bg-accent/15 rounded-full blur-3xl opacity-30 animate-pulse"></div>
        <div class="absolute top-20 right-1/4 w-80 h-80 bg-purple-500/5 rounded-full blur-3xl opacity-20"></div>

        <div class="max-w-5xl mx-auto reveal">
            <span class="inline-flex items-center gap-2 bg-accent/5 backdrop-blur-sm px-4 py-2 border border-accent/10 rounded-full text-accent text-[8px] sm:text-[10px] font-black uppercase tracking-[0.3em] mb-8 shadow-sm">
                <span class="w-1.5 h-1.5 bg-accent rounded-full animate-ping"></span>
                Posicionament SEO per a Botigues Online
            </span>
            <h1 class="text-3xl sm:text-5xl md:text-7xl lg:text-8xl uppercase font-extrabold tracking-tighter leading-[0.88] mb-8 text-gradient flex flex-col items-center text-center">
                <span class="lg:whitespace-nowrap">Agència SEO </span>
                <span class="lg:whitespace-nowrap text-mktg-gradient">per a Ecommerce</span>
            </h1>
            <p class="text-lg sm:text-xl text-zinc-500 font-light leading-relaxed w-[75%] mx-auto mb-8">
                Apareix quan els teus clients busquen el teu producte a Google. Posicionament SEO per a botigues online amb estratègia a mida i resultats que es mesuren en vendes.
            </p>
            <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3 mb-10">
                {['Sense permanències', 'Tracte directe amb el consultor', 'Resultats mesurats en vendes'].map(item => (
                    <span class="inline-flex items-center gap-2 text-[11px] sm:text-xs font-black uppercase tracking-widest text-zinc-700">
                        <svg class="w-4 h-4 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                        {item}
                    </span>
                ))}
            </div>
            <div class="flex justify-center mt-4">
                <a href="#contacto" class="contact-modal-trigger btn-mktg-v5 shadow-[0_10px_30px_rgba(0,0,0,0.1)] !py-4 sm:!py-5 !px-6 sm:!px-10 !text-[11px] !tracking-widest font-black">
                    PARLEM DE LA TEVA BOTIGA
                </a>
            </div>
        </div>
    </section>

    <LogoMarquee />

    <!-- ═══ INTRO ═══════════════════════════════════════════════════════ -->
    <section class="py-16 sm:py-24 bg-white px-4 sm:px-6 border-b border-black/5">
        <div class="max-w-6xl mx-auto reveal grid md:grid-cols-[1.3fr_1fr] gap-10 md:gap-16 items-center">
            <div>
                <p class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4">Per què SEO?</p>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-8 text-zinc-900 leading-[0.9]">
                    L'agència de posicionament SEO per a la teva botiga online
                </h2>
                <div class="space-y-6 text-zinc-600 font-light text-base sm:text-lg leading-relaxed">
                    <p>
                        <strong class="font-semibold text-zinc-900">El SEO és el canal que segueix portant compradors quan deixes de pagar per anuncis</strong>. Cada cerca del teu producte és un client amb intenció de compra, i qui apareix primer s'emporta la venda. A diferència de la publicitat, el posicionament és un actiu que s'acumula mes a mes.
                    </p>
                    <p>
                        Nova és una <strong class="font-semibold text-zinc-900">agència SEO especialitzada en ecommerce</strong>. Arquitectura de categories, fitxes de producte i contingut pensats per a una sola mètrica que importa. <strong class="font-semibold text-zinc-900">Quantes vendes arriben des de Google cada mes</strong>.
                    </p>
                </div>
            </div>
            <div class="hidden md:block">
                <img src="/sergio-galos-agencia-ecommerce-seo.webp" alt="Sergio Galo's, Consultor SEO per a ecommerce" title="Sergio Galo's, Consultor SEO per a ecommerce" class="w-full h-auto" loading="lazy" />
            </div>
        </div>
    </section>

    <!-- ═══ SERVEIS ══════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-zinc-50 px-4 sm:px-6 border-t border-b border-black/5">
        <div class="max-w-7xl mx-auto text-center reveal">
            <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Què fem</span>
            <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.9]">
                Servei de posicionament SEO per a ecommerce
            </h2>
            <p class="text-zinc-500 font-light text-sm sm:text-base leading-relaxed max-w-3xl mx-auto mb-16">
                El SEO d'una botiga online no és una sola tasca, és un sistema. Aquestes són les nou peces que treballem perquè el teu ecommerce passi de ser invisible a Google a vendre cada dia des del cercador.
            </p>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 text-left">
                {[
                    { t: "Auditoria SEO ecommerce", d: "Radiografia tècnica, de contingut i d'autoritat de la teva botiga abans de tocar res. El punt de partida de qualsevol estratègia." },
                    { t: "SEO tècnic", d: "Velocitat, indexació, Core Web Vitals i rastreig de milers d'URLs de producte sense malbaratar pressupost de rastreig." },
                    { t: "Keyword research de producte", d: "Què busquen els teus compradors, amb quines paraules i en quin moment de la decisió. Keywords que venen, no que només porten visites." },
                    { t: "Continguts i categories", d: "Arquitectura de categories que posiciona i contingut que resol el dubte de compra abans que la teva competència." },
                    { t: "Link building", d: "Enllaços de qualitat en mitjans rellevants que augmenten l'autoritat del teu domini de manera orgànica i sostinguda." },
                    { t: "SEO de fitxes de producte", d: "Títols, descripcions i dades estructurades de producte que posicionen i converteixen. La fitxa és la teva pàgina de venda." },
                    { t: "Analítica i Search Console", d: "Cada venda orgànica atribuïda a la seva keyword i la seva pàgina. Decisions amb dades, no amb intuïcions." },
                    { t: "SEO més GEO", d: "Cada cop més compradors pregunten a la IA abans de comprar. Integrem posicionament a Google i a la IA en una sola estratègia." },
                    { t: "Migracions de plataforma", d: "Canvis de plataforma o redissenys sense perdre el posicionament que tant ha costat aconseguir." },
                ].map((c: any) => (
                    <div class="bg-white border border-black/5 rounded-2xl p-6 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
                        <h3 class="text-sm font-black uppercase tracking-tight text-zinc-900 mb-3">
                            {c.href ? <a href={c.href} class="hover:text-accent transition-colors">{c.t}</a> : c.t}
                            {c.b && <span class="block text-[11px] uppercase tracking-[0.2em] text-accent mt-1 font-semibold">{c.b}</span>}
                        </h3>
                        <p class="text-sm text-zinc-500 font-light leading-relaxed mb-2">{c.d}</p>
                        {c.href && <a href={c.href} class="text-[11px] font-black tracking-widest text-accent hover:underline">SABER MÉS →</a>}
                    </div>
                ))}
            </div>
            <div class="mt-12 text-center reveal">
                <a href="#contacto" class="contact-modal-trigger btn-mktg-v5 shadow-[0_10px_30px_rgba(37,211,102,0.3)] !py-4 sm:!py-5 !px-6 sm:!px-10 !text-[11px] !tracking-widest font-black">PARLEM DE LA TEVA BOTIGA</a>
            </div>
        </div>
    </section>

    <!-- ═══ ESTRATÈGIA ════════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-white px-4 sm:px-6 relative overflow-hidden">
        <div class="max-w-5xl mx-auto">
            <div class="text-center mb-16 sm:mb-24 reveal">
                <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Com treballem</span>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.9]">
                    Estratègia SEO per posicionar el teu ecommerce a Google
                </h2>
                <p class="text-zinc-500 font-light text-sm sm:text-base leading-relaxed max-w-2xl mx-auto">
                    Una metodologia documentada, pas a pas i sense fum.
                </p>
            </div>

            <div id="timeline-container" class="relative">
                <div class="hidden md:block absolute left-1/2 top-4 bottom-4 w-px bg-zinc-200 -translate-x-1/2"></div>
                <div id="progress-bar" class="hidden md:block absolute left-1/2 top-4 w-px bg-accent -translate-x-1/2 transition-all duration-100"></div>

                <div class="space-y-16 md:space-y-24 flex flex-col items-center">
                    {[
                        { title: "Auditoria SEO Completa", desc: "Analitzem la teva botiga, la teva visibilitat actual a Google i la teva competència directa. Detectem errors tècnics, keywords rendibles sense explotar i oportunitats de venda." },
                        { title: "Estratègia SEO Documentada", desc: "Reps un full de ruta per escrit. Quines keywords atacar, quines categories crear, què arreglar a la botiga i quins resultats esperar en 3, 6 i 12 mesos." },
                        { title: "Optimització Tècnica i Continguts", desc: "Arreglem el que impedeix a Google entendre la teva botiga i creem el contingut que posiciona. Categories, fitxes i guies de compra pensades per vendre." },
                        { title: "Autoritat i Enllaços", desc: "Google posiciona qui considera una referència. Aconseguim enllaços de mitjans i directoris rellevants que empenyen les teves posicions." },
                        { title: "Mesura i Ajust Continu", desc: "Monitorem mes a mes posicions, trànsit i vendes orgàniques. A l'informe veus quines keywords pugen i quantes comandes arriben des de Google." },
                    ].map((step, index) => (
                        <div class="flex flex-col md:flex-row items-center gap-6 md:gap-12 w-full relative reveal">
                            <div class:list={["flex-1 w-full", index % 2 === 0 ? "md:order-1 md:text-right" : "md:order-3 md:text-left"]}>
                                <div class="p-8 sm:p-10 bg-zinc-50 border border-black/5 rounded-3xl hover:border-accent/10 hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 relative overflow-hidden group">
                                    <h3 class="text-xl font-black uppercase tracking-tighter mb-2 text-zinc-900">{index + 1}. {step.title}</h3>
                                    <div class:list={["h-0.5 bg-accent w-full mb-4 opacity-80", index % 2 === 0 ? "md:ml-auto" : ""]}></div>
                                    <p class:list={["text-sm text-zinc-500 font-light max-w-md", index % 2 === 0 ? "md:ml-auto" : ""]}>{step.desc}</p>
                                    <div class="absolute -bottom-6 -right-5 text-8xl font-black text-black/[0.02] select-none z-0 group-hover:scale-105 transition-transform duration-500">0{index+1}</div>
                                </div>
                            </div>
                            <div class="md:order-2 w-12 h-12 rounded-full border-2 border-zinc-200 bg-white flex items-center justify-center font-black text-lg z-10 shrink-0 shadow-sm node-circle transition-all">
                                0{index + 1}
                            </div>
                            <div class:list={["hidden md:block md:flex-1", index % 2 === 0 ? "md:order-3" : "md:order-1"]}></div>
                        </div>
                    ))}
                </div>
            </div>
        </div>
    </section>

    <!-- ═══ AUDITORIA ═════════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-zinc-50/50 px-4 sm:px-6 border-t border-black/5 overflow-hidden">
        <div class="max-w-7xl mx-auto grid lg:grid-cols-[6fr_4fr] gap-12 lg:gap-16 items-start">
            <div class="reveal lg:col-span-2">
                <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Punt de partida</span>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase text-zinc-900 leading-[0.9]">
                    Auditoria de posicionament SEO per al teu ecommerce
                </h2>
            </div>
            <div class="reveal">
                <div class="space-y-5 text-zinc-600 font-light text-base leading-relaxed mb-8">
                    <p>Saps en quina posició surt la teva botiga quan algú busca el teu producte? Quines keywords et porten vendes i quines s'emporta la teva competència? Gairebé cap ecommerce ho sap amb dades, i aquí comença tot.</p>
                    <p>La nostra <strong class="font-semibold text-zinc-900">auditoria SEO per a ecommerce</strong> mesura la teva visibilitat real a Google, revisa la salut tècnica de la botiga i analitza la teva competència directa, i acaba amb un pla d'acció prioritzat per impacte en vendes.</p>
                    <p>A diferència de les auditories automàtiques que generen un PDF amb cent errors irrellevants, aquí cada punt el revisa un consultor sènior amb experiència en botigues online.</p>
                    <p>Si ja treballes amb una altra agència, l'auditoria també serveix com a segona opinió independent abans de seguir invertint.</p>
                </div>
                <ul class="space-y-3">
                    {["Salut tècnica amb indexació, velocitat i rastreig","Posicions actuals per a les teves cerques de producte","Anàlisi de la teva competència directa a Google","Keywords rendibles que encara no ataques","Arquitectura de categories i canibalitzacions","Pla d'acció SEO prioritzat per impacte"].map(item => (
                        <li class="flex items-start gap-3 text-sm text-zinc-700 font-light">
                            <svg class="w-4 h-4 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                            {item}
                        </li>
                    ))}
                </ul>
                <div class="mt-16">
                    <a href="#contacto" class="contact-modal-trigger btn-mktg-v5 shadow-[0_10px_30px_rgba(37,211,102,0.3)] !py-4 sm:!py-5 !px-6 sm:!px-10 !text-[11px] !tracking-widest font-black">
                        VULL LA MEVA AUDITORIA SEO
                    </a>
                </div>
            </div>
            <div class="reveal flex flex-col gap-4">
                {[
                    { bg: 'bg-purple-100', color: 'text-purple-600', t: "Revisió tècnica completa", d: "Indexació, velocitat, dades estructurades de producte i errors de rastreig. Tot el que frena la teva botiga, documentat." },
                    { bg: 'bg-green-100', color: 'text-green-600', t: "Pla d'acció prioritzat", d: "Un pla ordenat per impacte i esforç. Sabràs què arreglar la primera setmana i què no mereix ni un euro." },
                    { bg: 'bg-purple-100', color: 'text-purple-600', t: "Keywords de producte", d: "Les cerques que fan els teus compradors quan volen comprar, no només les de més volum." },
                    { bg: 'bg-amber-100', color: 'text-amber-600', t: "Arquitectura de categories", d: "Quines categories posicionen, quines canibalitzen keywords entre si i quina estructura falta per cobrir la demanda." },
                    { bg: 'bg-blue-100', color: 'text-blue-600', t: "Benchmark del teu sector", d: "Comparem la teva visibilitat amb els teus tres competidors directes. Quines keywords els porten vendes i què pots fer millor." },
                ].map(card => (
                    <div class="bg-white rounded-2xl shadow-[0_15px_40px_rgba(0,0,0,0.08)] p-5 flex items-start gap-4">
                        <div class:list={["w-11 h-11 rounded-full flex items-center justify-center flex-shrink-0", card.bg]}>
                            <svg class:list={["w-5 h-5", card.color]} fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                        </div>
                        <div>
                            <h3 class="text-sm font-black text-zinc-900 mb-1">{card.t}</h3>
                            <p class="text-xs text-zinc-500 font-light leading-relaxed">{card.d}</p>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- ═══ QUÈ INCLOU L'AUDITORIA ═══════════════════════════ -->
    <section class="py-20 sm:py-28 bg-white px-4 sm:px-6 border-t border-black/5">
        <div class="max-w-7xl mx-auto">
            <div class="text-center mb-12 sm:mb-16 reveal">
                <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Pas a pas</span>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase text-zinc-900 leading-[0.9]">
                    Què inclou l'auditoria SEO de nova
                </h2>
            </div>
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 items-stretch reveal">
                {[
                    { n: '1', t: "Radiografia de la teva visibilitat a Google", d: "Analitzem en quina posició surts per a les cerques dels teus compradors, quin trànsit reps i què s'emporta la teva competència." },
                    { n: '2', t: "Diagnòstic tècnic i de continguts", d: "Creuem les dades amb la salut tècnica de la teva botiga i les teves categories per explicar exactament què et frena al cercador." },
                    { n: '3', t: "Full de ruta per posicionar", d: "Tanques l'auditoria amb un document d'accions ordenades per impacte i una videotrucada on repassem cada punt amb tu." },
                ].map((st, i) => (
                    <div class="flex items-center gap-4 lg:gap-6">
                        {i > 0 && <div class="hidden lg:flex text-3xl text-accent font-black select-none">→</div>}
                        <div class="bg-white border border-black/5 rounded-2xl p-8 shadow-[0_15px_40px_rgba(0,0,0,0.06)] flex-1 text-center h-full">
                            <div class="w-12 h-12 rounded-full bg-accent/10 border border-accent/20 flex items-center justify-center mx-auto mb-4 text-accent font-black text-lg">{st.n}</div>
                            <h3 class="text-base font-black uppercase tracking-tight text-zinc-900 mb-3">{st.t}</h3>
                            <p class="text-sm text-zinc-500 font-light leading-relaxed">{st.d}</p>
                        </div>
                    </div>
                ))}
