---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { buildAlternates } from '../../lib/i18n';
import { localAgencySchema } from '../../lib/schema';
import { strapiClient } from '../../lib/strapi';
import LogoMarquee from '../../components/sections/LogoMarquee.astro';
import FaqHome from '../../components/sections/FaqHome.astro';
import CityPills from '../../components/global/CityPills.astro';
import GoogleReviews from '../../components/global/GoogleReviews.astro';

const SITE_URL = import.meta.env.PUBLIC_SITE_URL || 'https://novamarketing.es';
const alternates = buildAlternates('/agencia-ecommerce/', '/ca/agencia-ecommerce/', SITE_URL);

let allCases: any[] = [];
try {
  const casesRes = await strapiClient.getCaseStudies('ca');
  allCases = casesRes.data.map((i: any) => i.attributes ?? i).filter((c: any) => {
    const cats = (c.categories || []).map((cat: any) => (cat.slug || cat.attributes?.slug || '').toLowerCase());
    return cats.some((s: string) => s === 'e-commerce' || s === 'ecommerce');
  });
} catch {}

const steps = [
  { title: "Diagnòstic de la Botiga", desc: "Analitzem el teu ecommerce amb dades. Trànsit, taxa de conversió, tiquet mitjà, marges per categoria i quins canals porten vendes de veritat. Detectem on es perden diners i on hi ha l'oportunitat que la teva competència ja explota." },
  { title: "Estratègia Documentada", desc: "Reps un pla per escrit. Quins canals activar, quins productes empènyer, quin pressupost necessita cada campanya i quin retorn és raonable esperar en 3, 6 i 12 mesos. Saps en què s'inverteix cada euro abans d'invertir-lo." },
  { title: "Execució Multicanal", desc: "SEO per captar la cerca, Ads per escalar la venda, email per repetir compra i una web pensada perquè la botiga converteixi més amb el mateix trànsit. Cada canal amb la seva funció i tots mesurant contra el mateix compte de resultats." },
  { title: "Mesura Sense Fum", desc: "Mesurem vendes, ROAS i marge, no likes ni impressions. Cada comanda queda atribuïda al seu canal i la seva campanya. A l'informe mensual veus quant has invertit, quant has venut i quin canal et dona més rendibilitat." },
  { title: "Optimització Contínua", desc: "L'ecommerce no descansa i l'estratègia tampoc. Revisem cada setmana campanyes, productes i conversió, tallem el que no rendeix i reinvertim en el que ven. Mes a mes, el compte millora o s'explica per què." }
];

const criteria = [
  { title: "Demana casos d'èxit verificables", desc: "Un mur de logos no demostra res. Demana casos de botigues online amb dades concretes. Què facturava abans, què factura ara, amb quina inversió i en quant de temps. Una agència de màrqueting ecommerce seriosa hauria de poder ensenyar-te resultats de botigues com la teva. Si no poden ensenyar-te'n ni un, segueix buscant." },
  { title: "Pregunta qui portarà el teu compte", desc: "En moltes agències ven un director i executa un júnior amb 30 comptes. Exigeix conèixer la persona que treballarà la teva botiga abans de signar. A nova parles sempre amb el consultor que executa la teva estratègia, presencialment o per videotrucada." },
  { title: "Exigeix la propietat dels teus actius", desc: "La botiga, el domini, els comptes publicitaris, l'analítica i la llista d'emails han d'estar al teu nom. Hi ha ecommerce que porten anys pagant i descobreixen en canviar d'agència que no són propietaris ni de la seva llista de clients. Això no és un servei, és una dependència." },
  { title: "Que parli de rendibilitat, no de trànsit", desc: "Un ecommerce no viu de visites, viu de marge. Si l'agència et parla de sessions i abast però no de ROAS, tiquet mitjà i cost d'adquisició, està mesurant la seva activitat i no el teu negoci. Exigeix objectius en euros des de la primera proposta." },
  { title: "Revisa què mesura l'informe mensual", desc: "L'informe ha de respondre tres preguntes. Quant has invertit, quant has venut gràcies a aquesta inversió i què es farà el mes que ve per vendre més. Tota la resta és decoració." },
  { title: "Fuig de les permanències llargues", desc: "Una permanència de 12 mesos protegeix l'agència, no a tu. La feina ben feta reté clients sense necessitat de contractes que els lliguin. Per això a nova treballem mes a mes." },
  { title: "Especialització en ecommerce", desc: "Vendre online no és el mateix que captar leads. Feed de producte, estacionalitat, carrets abandonats, marges per categoria i logística que condiciona la promoció. Una agència generalista aprèn amb els teus diners. Una d'especialitzada ja sap què funciona." }
];

const faqs = [
  { question: "Quant costa una agència de màrqueting per a ecommerce?", answer: "Depèn dels canals que activis i de la mida de la teva botiga. Els plans mensuals parteixen de 400 euros al mes per a botigues que arrenquen amb un o dos canals, i creixen segons la inversió publicitària i el volum de feina. Abans de començar reps un pressupost tancat per escrit, amb fee de gestió fix i sense percentatges ocults sobre la teva inversió." },
  { question: "Què inclou el servei de màrqueting per a ecommerce?", answer: "Inclou un diagnòstic inicial de la botiga, una estratègia documentada i l'execució i mesura mensual de cada canal activat. SEO per a ecommerce, campanyes de Google Ads i Meta Ads, email màrqueting, optimització de la conversió i visibilitat a la IA. No apliquem plantilles, cada botiga i cada catàleg competeixen de manera diferent." },
  { question: "Qui portarà el meu compte?", answer: "Sempre la mateixa persona, el consultor fundador. Res de gestors júnior que canvien cada trimestre. Treballem amb un nombre limitat de clients precisament perquè cada botiga tingui seguiment sènior de veritat." },
  { question: "Quant trigaré a veure resultats?", answer: "Depèn del canal. Les campanyes de pagament poden generar vendes la primera setmana, les millores a la web es noten tan bon punt s'apliquen els primers canvis, i el SEO consolida resultats entre el tercer i el dotzè mes. L'estratègia combina canals ràpids i canals que construeixen perquè el compte creixi des del principi." },
  { question: "Com mesureu els resultats?", answer: "En vendes, ROAS i marge. Configurem la mesura de la botiga des del primer dia perquè cada comanda quedi atribuïda al seu canal i la seva campanya. A l'informe mensual veus quant has invertit, quant has venut i quina rendibilitat deixa cada canal. Les dades i els comptes són sempre teus." },
  { question: "Treballeu amb permanència?", answer: "No, treballem mes a mes. Si el servei no t'aporta valor, pots cancel·lar-lo quan vulguis. La nostra permanència real és el resultat que veus als informes cada mes." },
  { question: "Amb quines plataformes treballeu?", answer: "Principalment Shopify, PrestaShop i WooCommerce, que concentren la gran majoria de l'ecommerce a Espanya. Coneixem les particularitats tècniques i de SEO de cadascuna, així que no aprenem amb la teva botiga. Si fas servir una altra plataforma, explica'ns el teu cas i et diem si podem ajudar-te." }
];

const pageSchema = localAgencySchema({
  pageUrl: `${SITE_URL}/ca/agencia-ecommerce/`,
  lang: 'ca',
  cityName: 'Barcelona',
  postalCode: '08035',
  geo: { lat: 41.4114, lng: 2.1526 },
  areaServed: ["España", "Barcelona", "Sabadell", "Sant Cugat del Vallès", "Terrassa", "Vallès Occidental"],
  title: "Agència per a Ecommerce | Màrqueting per a Botigues Online | Nova Marketing",
  description: "Agència de màrqueting especialitzada en ecommerce. SEO, Google Ads, Meta Ads, email màrqueting i disseny web perquè la teva botiga online vengui més. Resultats mesurats en vendes i ROAS. Sense permanències.",
  datePublished: '2026-07-17',
  dateModified: '2026-07-17',
  streetAddress: 'Carrer del General Mendoza, 10',
  hasMap: 'https://maps.app.goo.gl/9fbB12UcK32bgjj89',
  aggregateRating: { ratingValue: '5.0', reviewCount: '8' },
  breadcrumbName: 'Agència per a Ecommerce',
  faqs,
});

const services = [
  { href: '/ca/agencia-ecommerce/seo/', t: 'SEO per a Ecommerce', d: 'Arquitectura de categories, fitxes de producte optimitzades i contingut que capta la cerca amb intenció de compra. Trànsit que arriba volent comprar.' },
  { href: '/ca/agencia-ecommerce/google-ads/', t: 'Google Ads per a Ecommerce', d: 'Shopping, Performance Max i cerca amb feed optimitzat. El teu producte amb foto i preu davant de qui ja l\'està buscant.' },
  { href: '/ca/agencia-ecommerce/meta-ads/', t: 'Meta Ads per a Ecommerce', d: 'Campanyes a Instagram i Facebook amb creatius que venen i catàlegs connectats. De descobrir el producte al carret sense sortir del feed.' },
  { href: '/ca/agencia-ecommerce/email-marketing/', t: 'Email Màrqueting', d: 'Fluxos de carret abandonat, benvinguda i recompra. El canal més rendible d\'un ecommerce, perquè vendre a qui ja et va comprar costa molt menys.' },
  { href: '/ca/agencia-ecommerce/diseno-web/', t: 'Disseny Web per a Ecommerce', d: 'Una web ràpida, adaptada a mòbil i pensada per convertir la visita en client. La base sobre la qual treballen tots els altres canals.' },
  { href: '/ca/agencia-ecommerce/posicionamiento-geo/', t: 'GEO i Visibilitat en IA', d: 'Quan algú pregunta a ChatGPT quin producte comprar, qui surt a la resposta s\'emporta la venda. Treballem els teus senyals perquè la IA recomani la teva botiga.' },
];

const platforms = [
  { href: '/ca/agencia-ecommerce/shopify/', t: 'Màrqueting per a Shopify', d: 'La plataforma que més ràpid creix. Espremem el seu ecosistema d\'apps, el seu checkout optimitzat i la seva integració nativa amb els canals de venda.' },
  { href: '/ca/agencia-ecommerce/prestashop/', t: 'Màrqueting per a PrestaShop', d: 'El clàssic de l\'ecommerce espanyol. Coneixem els seus mòduls, les seves limitacions de SEO i com fer-la competir sense migrar de plataforma.' },
  { href: '/ca/agencia-ecommerce/woocommerce/', t: 'Màrqueting per a WooCommerce', d: 'Tota la flexibilitat de WordPress aplicada a vendre. Velocitat, SEO tècnic i campanyes connectades amb el teu catàleg.' },
];

const cityCards = [
  { href: '/ca/agencia-ecommerce/barcelona/', t: 'Agència Ecommerce a Barcelona', d: 'El major hub d\'ecommerce del sud d\'Europa. Competència feroç on guanya qui millor mesura i més ràpid optimitza.' },
  { href: '/ca/agencia-ecommerce/sabadell/', t: 'Agència Ecommerce a Sabadell', d: 'Comerç amb història que fa el salt online. Ajudem les botigues del Vallès a vendre més enllà del seu carrer.' },
  { href: '/ca/agencia-ecommerce/sant-cugat/', t: 'Agència Ecommerce a Sant Cugat', d: 'Marques amb tiquet alt i client exigent. Ecommerce que ha d\'estar a l\'altura del que ven.' },
  { href: '/ca/agencia-ecommerce/terrassa/', t: 'Agència Ecommerce a Terrassa', d: 'Indústria i comerç egarenc amb producte propi. De vendre a la comarca a vendre a tot Espanya.' },
];
---

<BaseLayout
  title="Agència per a Ecommerce | Màrqueting per a Botigues Online | Nova Marketing"
  description="Agència de màrqueting especialitzada en ecommerce. SEO, Google Ads, Meta Ads, email màrqueting i disseny web perquè la teva botiga online vengui més. Resultats mesurats en vendes i ROAS. Sense permanències."
  locale="ca"
  alternates={alternates}
  schemas={[pageSchema]}
>

    <!-- ═══ HERO / H1 ═══════════════════════════════════════════════════════ -->
    <section class="pt-24 sm:pt-40 pb-20 px-4 sm:px-6 relative overflow-hidden text-center bg-white border-b border-black/5">
        <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808008_1px,transparent_1px),linear-gradient(to_bottom,#80808008_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_40%,#000_75%,transparent_100%)]"></div>
        <div class="absolute -top-10 left-1/4 w-72 h-72 bg-accent/15 rounded-full blur-3xl opacity-30 animate-pulse"></div>
        <div class="absolute top-20 right-1/4 w-80 h-80 bg-purple-500/5 rounded-full blur-3xl opacity-20"></div>

        <div class="max-w-5xl mx-auto reveal">
            <span class="inline-flex items-center gap-2 bg-accent/5 backdrop-blur-sm px-4 py-2 border border-accent/10 rounded-full text-accent text-[8px] sm:text-[10px] font-black uppercase tracking-[0.3em] mb-8 shadow-sm">
                <span class="w-1.5 h-1.5 bg-accent rounded-full animate-ping"></span>
                Màrqueting per a Botigues Online
            </span>
            <h1 class="text-3xl sm:text-5xl md:text-7xl lg:text-8xl uppercase font-extrabold tracking-tighter leading-[0.88] mb-8 text-gradient flex flex-col items-center text-center">
                <span class="lg:whitespace-nowrap">Agència </span>
                <span class="lg:whitespace-nowrap text-mktg-gradient">per a Ecommerce</span>
            </h1>
            <p class="text-lg sm:text-xl text-zinc-500 font-light leading-relaxed w-[75%] mx-auto mb-8">
                La teva botiga online pot vendre molt més. Màrqueting digital per a ecommerce amb estratègia a mida, canals que es complementen i resultats que es mesuren en vendes i marge.
            </p>
            <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3 mb-10">
                {['Sense permanències', 'Tracte directe amb el consultor', 'Resultats mesurats en vendes'].map(item => (
                    <span class="inline-flex items-center gap-2 text-[11px] sm:text-xs font-black uppercase tracking-widest text-zinc-700">
                        <svg class="w-4 h-4 text-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                        </svg>
                        {item}
                    </span>
                ))}
            </div>
            <div class="flex justify-center mt-4">
                <a href="#contacto" class="contact-modal-trigger btn-mktg-v5 shadow-[0_10px_30px_rgba(0,0,0,0.1)] !py-4 sm:!py-5 !px-6 sm:!px-10 !text-[11px] !tracking-widest font-black">
                    PARLEM DE LA TEVA BOTIGA
                </a>
            </div>
        </div>
    </section>

    <LogoMarquee />

    <!-- ═══ INTRO ═══════════════════════════════════════════════════════ -->
    <section class="py-16 sm:py-24 bg-white px-4 sm:px-6 border-b border-black/5">
        <div class="max-w-6xl mx-auto reveal grid md:grid-cols-[1.3fr_1fr] gap-10 md:gap-16 items-center">
            <div>
                <p class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4">Per què una agència ecommerce?</p>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-8 text-zinc-900 leading-[0.9]">
                    L'agència de màrqueting per a la teva botiga online
                </h2>
                <div class="space-y-6 text-zinc-600 font-light text-base sm:text-lg leading-relaxed">
                    <p>
                        <strong class="font-semibold text-zinc-900">Vendre online no és tenir una botiga, és tenir un sistema que l'omple de compradors</strong>. Trànsit que arriba amb intenció, fitxes que converteixen, campanyes rendibles i clients que repeteixen. Quan una peça falla, el marge desapareix encara que les visites pugin.
                    </p>
                    <p>
                        Nova és una <strong class="font-semibold text-zinc-900">agència de màrqueting especialitzada en ecommerce</strong>. Treballem amb un nombre limitat de botigues, cada compte el porta directament el consultor fundador i tota l'estratègia s'orienta a una sola mètrica que importa. <strong class="font-semibold text-zinc-900">Quant ven la teva botiga i amb quin marge</strong>.
                    </p>
                </div>
            </div>
            <div class="hidden md:block">
                <img src="/sergio-galos-agencia-ecommerce.webp" alt="Sergio Galo's, consultor de màrqueting per a ecommerce" title="Sergio Galo's, consultor de màrqueting per a ecommerce" class="w-full h-auto" loading="lazy" />
            </div>
        </div>
    </section>

    <!-- ═══ SERVEIS ══════════════════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-zinc-50 border-b border-black/5 px-4 sm:px-6">
        <div class="max-w-7xl mx-auto text-center reveal">
            <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Què fem</span>
            <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.9]">
                Serveis de Màrqueting Online per a Ecommerce
            </h2>
            <div class="text-zinc-500 font-light text-sm sm:text-base leading-relaxed max-w-3xl mx-auto mb-16 space-y-4">
                <p>
                    Un ecommerce rendible no depèn d'un sol canal, depèn d'un <strong class="font-semibold text-zinc-700">sistema on cada canal fa la seva feina</strong>. Aquestes són les sis peces que combinem segons el que necessiti la teva botiga.
                </p>
                <p>
                    No pagues per un paquet tancat d'accions, pagues per les que el teu compte de resultats necessita.
                </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 text-left">
                {services.map(s => (
                    <div class="service-card p-8 bg-white rounded-2xl border border-zinc-100/80 shadow-sm hover:shadow-2xl hover:-translate-y-2 hover:border-accent/10 transition-all duration-500 relative overflow-hidden flex flex-col justify-between">
                        <h3 class="text-xl font-black uppercase tracking-tighter mb-4 text-zinc-900">
                            <a href={s.href} class="hover:text-accent transition-colors">{s.t}</a>
                        </h3>
                        <p class="text-sm text-zinc-500 font-light leading-relaxed mb-4">{s.d}</p>
                        <a href={s.href} class="text-[11px] font-black tracking-widest text-accent hover:underline">SABER MÉS →</a>
                    </div>
                ))}
            </div>

            <div class="mt-12 text-center reveal">
                <a href="#contacto" class="contact-modal-trigger btn-mktg-v5 shadow-[0_10px_30px_rgba(37,211,102,0.3)] !py-4 sm:!py-5 !px-6 sm:!px-10 !text-[11px] !tracking-widest font-black">
                    PARLEM DE LA TEVA BOTIGA
                </a>
            </div>
        </div>
    </section>

    <!-- ═══ ESTRATÈGIA ════════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-white px-4 sm:px-6 relative overflow-hidden">
        <div class="max-w-5xl mx-auto">
            <div class="text-center mb-16 sm:mb-24 reveal">
                <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Com treballem</span>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.9]">
                    Estratègies de màrqueting digital per a ecommerce
                </h2>
                <p class="text-zinc-500 font-light text-sm sm:text-base leading-relaxed max-w-2xl mx-auto">
                    Una metodologia documentada perquè la teva botiga vengui més cada mes, pas a pas i sense fum.
                </p>
            </div>

            <div id="timeline-container" class="relative">
                <div class="hidden md:block absolute left-1/2 top-4 bottom-4 w-px bg-zinc-200 -translate-x-1/2"></div>
                <div id="progress-bar" class="hidden md:block absolute left-1/2 top-4 w-px bg-accent -translate-x-1/2 transition-all duration-100"></div>

                <div class="space-y-16 md:space-y-24 flex flex-col items-center">
                    {steps.map((step, index) => (
                        <div class="flex flex-col md:flex-row items-center gap-6 md:gap-12 w-full relative reveal">
                            <div class:list={["flex-1 w-full", index % 2 === 0 ? "md:order-1 md:text-right" : "md:order-3 md:text-left"]}>
                                <div class="p-8 sm:p-10 bg-zinc-50 border border-black/5 rounded-3xl hover:border-accent/10 hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 relative overflow-hidden group">
                                    <h3 class="text-xl font-black uppercase tracking-tighter mb-2 text-zinc-900">{index + 1}. {step.title}</h3>
                                    <div class:list={["h-0.5 bg-accent w-full mb-4 opacity-80", index % 2 === 0 ? "md:ml-auto" : ""]}></div>
                                    <p class:list={["text-sm text-zinc-500 font-light max-w-md", index % 2 === 0 ? "md:ml-auto" : ""]}>{step.desc}</p>
                                    <div class="absolute -bottom-6 -right-5 text-8xl font-black text-black/[0.02] select-none z-0 group-hover:scale-105 transition-transform duration-500">0{index+1}</div>
                                </div>
                            </div>
                            <div class="md:order-2 w-12 h-12 rounded-full border-2 border-zinc-200 bg-white flex items-center justify-center font-black text-lg z-10 shrink-0 shadow-sm node-circle transition-all">
                                0{index + 1}
                            </div>
                            <div class:list={["hidden md:block md:flex-1", index % 2 === 0 ? "md:order-3" : "md:order-1"]}></div>
                        </div>
                    ))}
                </div>
            </div>
        </div>
    </section>

    <!-- ═══ AUDITORIA ═════════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-zinc-50/50 px-4 sm:px-6 border-t border-black/5 overflow-hidden">
        <div class="max-w-7xl mx-auto grid lg:grid-cols-[6fr_4fr] gap-12 lg:gap-16 items-start">

            <div class="reveal lg:col-span-2">
                <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Punt de partida</span>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase text-zinc-900 leading-[0.9]">
                    Auditoria de màrqueting digital per al teu ecommerce
                </h2>
            </div>

            <div class="reveal">
                <div class="space-y-5 text-zinc-600 font-light text-base leading-relaxed mb-8">
                    <p>
                        Abans de proposar-te res, auditem. Saps quin canal et deixa més marge? Quant et costa aconseguir cada comanda i quant val un client al llarg de l'any? Gairebé cap botiga ho sap amb dades, i aquí comença tot.
                    </p>
                    <p>
                        La nostra <strong class="font-semibold text-zinc-900">auditoria de màrqueting per a ecommerce</strong> revisa la teva botiga, les teves campanyes i la teva competència amb una sola pregunta al cap. On són els diners que avui s'escapen. I acaba amb un pla d'acció prioritzat per impacte en vendes.
                    </p>
                    <p>
                        A diferència de les anàlisis automàtiques que generen un PDF amb cent avisos irrellevants, aquí cada punt el revisa un consultor sènior amb anys d'experiència en botigues online. El resultat no és un llistat tècnic, és un diagnòstic de negoci que entén qualsevol gerent.
                    </p>
                </div>
                <ul class="space-y-3">
                    {[
                        'Conversió de la botiga per dispositiu i categoria',
                        'Rendibilitat real de cada canal de captació',
                        'Salut del feed de producte i les campanyes actives',
                        'Fugues a la fitxa de producte, el carret i el checkout',
                        'Oportunitats de recompra i email que no explotes',
                        "Pla d'acció prioritzat per impacte en vendes",
                    ].map(item => (
                        <li class="flex items-start gap-3 text-sm text-zinc-700 font-light">
