---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { buildAlternates } from '../../lib/i18n';
import { strapiClient } from '../../lib/strapi';
import LogoMarquee from '../../components/sections/LogoMarquee.astro';
import FaqHome from '../../components/sections/FaqHome.astro';

const SITE_URL = import.meta.env.PUBLIC_SITE_URL || 'https://novamarketing.es';
const alternates = buildAlternates('/agencia-seo-en-barcelona', '/ca/agencia-seo-a-barcelona', SITE_URL);

const faqItems = [
  {
    question: "Com pot el SEO ajudar el meu negoci a destacar en un mercat tan competitiu com Barcelona?",
    answer: "Barcelona té milers d'empreses competint pels mateixos clients. La clau està en la hiperlocalització: posicionar-se per barris concrets com l'Eixample, Gràcia o Sarrià en lloc d'intentar competir amb tota la ciutat alhora. Identifiquem les cerques amb major intenció de compra a la teva zona i el teu sector perquè el teu negoci aparegui primer quan més importa."
  },
  {
    question: "Què diferencia el SEO a Barcelona del SEO en altres ciutats?",
    answer: "La competència és molt més alta i els volums de cerca són majors. Això significa que una bona posició a Google a Barcelona pot generar un flux molt important de clients. Però també requereix una estratègia més robusta: més contingut de qualitat, més autoritat de domini i una arquitectura web més acurada."
  },
  {
    question: "El SEO local funciona per a negocis a l'Eixample o al 22@?",
    answer: "Absolutament. L'Eixample és el districte comercial més dens de Barcelona, i el 22@ concentra empreses tecnològiques i creatives. En ambdós casos, el SEO local per barri és molt efectiu perquè els usuaris cerquen proveïdors propers. Optimitzem la teva presència a Google Maps i a les cerques orgàniques per zona."
  },
  {
    question: "Quant de temps tarda el SEO a posicionar a Barcelona?",
    answer: "Per l'alta competència, l'horitzó habitual a Barcelona és de 4-8 mesos per veure millores significatives en sectors competits. En nínxols més específics pot ser més ràpid. L'important és que el SEO construeix un actiu durador: a diferència de Google Ads, les posicions guanyades no desapareixen quan atures la inversió."
  },
  {
    question: "Treballeu el SEO per a ecommerce i botigues físiques de Barcelona?",
    answer: "Sí, per a tots dos models. Per a botigues físiques treballem el SEO local per barri i l'optimització del Google Business Profile. Per a ecommerce, desenvolupem estratègies de posicionament de categories i fitxes de producte que generen trànsit orgànic qualificat i redueixen la dependència de la publicitat de pagament."
  }
];

// Casos d'èxit SEO
let seoCases: any[] = [];
try {
  const casesRes = await strapiClient.getCaseStudies('ca');
  seoCases = casesRes.data
    .map((i: any) => i.attributes ?? i)
    .filter((c: any) => {
      const cats = (c.categories || []).map((cat: any) => (cat.slug || cat.attributes?.slug || '').toLowerCase());
      return cats.some((s: string) => s.includes('seo') || s.includes('consultor'));
    });
} catch {}

const steps = [
  { title: "Auditoria SEO a Barcelona", desc: "Analitzem el teu web en profunditat i avaluem la competència al teu sector dins de Barcelona. Identifiquem els errors tècnics i les oportunitats de posicionament per barri i per keyword." },
  { title: "Keyword Research per Barris", desc: "Barcelona es posiciona barri a barri. Identifiquem les cerques amb major intenció de compra a la teva zona — Eixample, Gràcia, Poblenou, Sarrià — per atreure el trànsit més qualificat." },
  { title: "SEO On-Page i Continguts", desc: "Creem i optimitzem continguts que posicionen el teu negoci a Barcelona. Des de landing pages de barri fins a articles de blog que construeixen autoritat temàtica al teu sector." },
  { title: "Linkbuilding en Mitjans de Barcelona", desc: "Aconseguim mencions i enllaços en mitjans digitals barcelonins, directoris locals i webs de referència que traslladen autoritat al teu domini i milloren el teu rànquing." },
  { title: "SEO Local i Google Maps", desc: "Posicionem la teva fitxa de Google Business Profile perquè apareguis al pack local quan algú cerca el teu servei al teu barri de Barcelona. Més ressenyes, més visibilitat, més clients." }
];
---

<BaseLayout
  title="Agència SEO a Barcelona | Nova Marketing"
  description="Barcelona és el mercat més competitiu de Catalunya. Posicionem la teva empresa a Google per barris: Eixample, 22@, Gràcia o Sarrià. Auditoria SEO gratis."
  locale="ca"
  alternates={alternates}
>

    <!-- ═══ HERO / H1 ═══════════════════════════════════════════════════════ -->
    <section class="min-h-[88vh] flex items-center justify-center pt-24 pb-16 px-4 sm:px-6 relative overflow-hidden text-center bg-white border-b border-black/5">
        <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808008_1px,transparent_1px),linear-gradient(to_bottom,#80808008_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_40%,#000_75%,transparent_100%)]"></div>
        <div class="absolute -top-10 left-1/4 w-72 h-72 bg-accent/15 rounded-full blur-3xl opacity-30 animate-pulse"></div>
        <div class="absolute top-20 right-1/4 w-80 h-80 bg-purple-500/5 rounded-full blur-3xl opacity-20"></div>

        <div class="max-w-7xl mx-auto reveal relative z-10">
            <span class="inline-flex items-center gap-2 bg-accent/5 backdrop-blur-sm px-4 py-2 border border-accent/10 rounded-full text-accent text-[8px] sm:text-[10px] font-black uppercase tracking-[0.3em] mb-6 shadow-sm">
                <span class="w-1.5 h-1.5 bg-accent rounded-full animate-ping"></span>
                Especialistes en Posicionament SEO a Barcelona
            </span>

            <h1 class="text-4xl sm:text-6xl md:text-7xl lg:text-[5.5rem] uppercase font-black tracking-tighter leading-[0.82] mb-8 text-zinc-900 flex flex-col items-center text-center">
                <span>Agència de</span>
                <span>Posicionament SEO</span>
                <span class="text-mktg-gradient px-4 overflow-visible inline-block">a Barcelona</span>
            </h1>

            <p class="text-base sm:text-lg text-zinc-500 font-light leading-relaxed max-w-2xl mx-auto mb-12">
                Barcelona és el mercat més competitiu de Catalunya. Posicionem la teva empresa a Google per barris estratègics: Eixample, 22@, Gràcia o Sarrià-Sant Gervasi per atreure clients locals d'alt valor.
            </p>

            <div class="flex flex-col sm:flex-row justify-center items-center gap-4">
                <button class="contact-modal-trigger btn-mktg-v5 shadow-[0_20px_40px_-10px_rgba(0,0,0,0.15)] hover:shadow-[0_25px_50px_-12px_rgba(0,0,0,0.25)] hover:-translate-y-1 transition-all duration-300 !py-5 !px-12 !text-[12px] !tracking-wider font-black w-full sm:w-auto">
                    SOL·LICITAR AUDITORIA GRATIS
                </button>
            </div>
        </div>
    </section>

    <!-- ═══ LOGOS CLIENTES (SOCIAL PROOF) ══════════════════════════════════ -->
    <LogoMarquee />

    <!-- ═══ SECCIÓN 1: AUDITORÍA Y ESTRATEGIA ═══════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-zinc-50 border-b border-black/5 px-4 sm:px-6 relative overflow-hidden">
        <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808005_1px,transparent_1px),linear-gradient(to_bottom,#80808005_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_50%,#000_80%,transparent_100%)]"></div>

        <div class="max-w-7xl mx-auto">
            <div class="text-center mb-16 sm:mb-24 reveal">
                <h2 class="text-3xl sm:text-5xl lg:text-7xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.82]">
                    Auditoria i Estratègia <br class="hidden sm:inline" /> SEO a Barcelona
                </h2>
                <p class="text-zinc-500 font-light text-base sm:text-lg leading-relaxed max-w-2xl mx-auto">
                    No comencem a cegues ni fem servir plantilles genèriques. Analitzem el teu web i la competència a Barcelona per dissenyar una estratègia per barri i sector orientada 100% a conversions reals.
                </p>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 items-stretch">
                {[
                    { title: "Auditoria Tècnica", desc: "Corregim errors d'indexació, velocitat i adaptabilitat mòbil perquè Google et valori com la millor opció al teu barri de Barcelona." },
                    { title: "Keywords per Barri", desc: "Analitzem què cerquen els clients a l'Eixample, Gràcia, Poblenou, Sarrià o el 22@ per posicionar termes amb intenció de compra real." },
                    { title: "SEO On-Page", desc: "Optimitzem títols, etiquetes i enllaçat intern per dir-li a Google exactament què vens i en quina zona de Barcelona ho fas." },
                    { title: "Pla d'Enllaços", desc: "Construïm autoritat amb enllaços de mitjans digitals barcelonins i directoris locals que disparen la rellevància del teu domini." }
                ].map((s, i) => (
                    <div class="group flex flex-col justify-between p-8 sm:p-10 h-full bg-white rounded-3xl border border-zinc-100/80 shadow-sm hover:shadow-2xl hover:-translate-y-2 hover:border-accent/10 transition-all duration-500 relative overflow-hidden reveal flex-1">
                        <div class="absolute inset-x-0 h-1 bottom-0 bg-gradient-to-r from-accent via-accent/90 to-purple-600 w-0 group-hover:w-full transition-all duration-500"></div>
                        <div class="absolute -bottom-6 -right-4 text-9xl font-black text-black/2 group-hover:text-accent/[0.04] transition-all duration-500 select-none">
                            0{i + 1}
                        </div>
                        <div class="relative z-10 flex flex-col h-full justify-between">
                            <div>
                                <div class="p-3 bg-zinc-50 border border-black/5 w-fit rounded-xl mb-6 group-hover:bg-accent/5 transition-colors">
                                    <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">{i === 0 && <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>}{i === 1 && <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>}{i === 2 && <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>}{i === 3 && <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>}</svg>
                                </div>
                                <h3 class="text-xl sm:text-2xl uppercase mb-3 tracking-tighter group-hover:text-accent font-black text-zinc-900 border-b border-zinc-100 pb-2 w-fit">{s.title}</h3>
                                <p class="text-xs sm:text-sm text-zinc-500 leading-relaxed font-light">{s.desc}</p>
                            </div>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- ═══ SECCIÓN 2: TIMELINE ═══════════════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-white px-4 sm:px-6 relative overflow-hidden border-b border-black/5">
        <div class="max-w-5xl mx-auto">
            <div class="text-center mb-16 sm:mb-24 reveal">
                <h2 class="text-2xl sm:text-5xl lg:text-7xl font-black tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.85]">
                    Com treballem el SEO a Barcelona
                </h2>
                <div class="text-zinc-500 w-[75%] mx-auto font-light text-sm sm:text-base leading-relaxed space-y-4">
                    <p>
                        Oblida't del SEO en pilot automàtic. Comptaràs amb un <strong>Account Manager dedicat</strong> que treballarà de la mà amb el teu equip per resoldre dubtes, supervisar avenços i mantenir-te informat amb mètriques de negoci reals a Barcelona.
                    </p>
                </div>
            </div>

            <div id="timeline-container" class="relative timeline-container">
                <!-- Vertical Background Line -->
                <div class="hidden md:block absolute left-1/2 top-4 bottom-4 w-px bg-zinc-200 -translate-x-1/2"></div>
                <!-- Vertical Progressing Line -->
                <div class="progress-bar hidden md:block absolute left-1/2 top-4 w-px bg-accent -translate-x-1/2 transition-all duration-100" style="height: 0%;"></div>

                <div class="space-y-16 md:space-y-24 flex flex-col items-center">
                    {steps.map((step, index) => (
                        <div class="flex flex-col md:flex-row items-center gap-6 md:gap-12 w-full relative reveal" style={`transition-delay: ${index * 100}ms`}>

                            <div class:list={["flex-1 w-full", index % 2 === 0 ? "md:order-1 md:text-right" : "md:order-3 md:text-left"]}>
                                <div class="p-8 sm:p-10 bg-zinc-50 border border-black/5 rounded-3xl hover:border-accent/10 hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 relative overflow-hidden group">
                                    <h3 class="text-xl sm:text-2xl font-black uppercase tracking-tighter mb-2 text-zinc-900">{index + 1}. {step.title}</h3>
                                    <div class:list={["h-0.5 bg-accent w-full mb-4 opacity-80", index % 2 === 0 ? "md:ml-auto" : ""]}></div>
                                    <p class:list={["text-sm text-zinc-500 font-light max-w-md", index % 2 === 0 ? "md:ml-auto" : ""]}>{step.desc}</p>
                                    <div class="absolute -bottom-6 -right-5 text-8xl font-black text-black/[0.02] select-none z-0 group-hover:scale-105 transition-transform duration-500">0{index+1}</div>
                                </div>
                            </div>
                            <div class="md:order-2 w-12 h-12 rounded-full border-2 border-zinc-200 bg-white flex items-center justify-center font-black text-lg z-10 shrink-0 shadow-sm node-circle transition-all duration-300">
                                0{index + 1}
                            </div>
                            <div class:list={["hidden md:block md:flex-1", index % 2 === 0 ? "md:order-3" : "md:order-1"]}></div>

                        </div>
                    ))}
                </div>
            </div>
        </div>
    </section>

    <style>
        .timeline-container .reveal {
            opacity: 0;
            transform: translateY(20px);
            transition: all 0.6s cubic-bezier(0.165, 0.84, 0.44, 1);
        }
        .timeline-container .reveal.active {
            opacity: 1;
            transform: translateY(0);
        }
    </style>

    <script is:inline>
        function initTimeline() {
            const timeline = document.getElementById('timeline-container');
            const progressBar = timeline?.querySelector('.progress-bar');

            function updateProgress() {
                if (!timeline || !progressBar) return;
                const rect = timeline.getBoundingClientRect();
                const winHeight = window.innerHeight;
                const topPassed = (winHeight / 2) - rect.top;
                let percentage = (topPassed / rect.height) * 100;
                percentage = Math.max(0, Math.min(100, percentage));
                progressBar.style.height = `${percentage}%`;

                const nodes = timeline.querySelectorAll('.node-circle');
                nodes.forEach((node) => {
                    const nodeTop = node.getBoundingClientRect().top;
                    if (nodeTop < winHeight / 2) {
                        node.classList.add('!border-accent', '!bg-accent', '!text-white');
                    } else {
                        node.classList.remove('!border-accent', '!bg-accent', '!text-white');
                    }
                });
            }

            window.addEventListener('scroll', updateProgress);
            document.addEventListener('astro:page-load', updateProgress);
            updateProgress();
        }
        document.addEventListener('DOMContentLoaded', initTimeline);
        document.addEventListener('astro:page-load', initTimeline);
    </script>

    <!-- ═══ CASOS D'ÈXIT SEO ════════════════════════════════════════════ -->
    {seoCases.length > 0 && (
    <section class="py-20 sm:py-32 bg-zinc-50 border-t border-black/5 px-4 sm:px-6">
        <div class="max-w-7xl mx-auto">
            <div class="mb-16 reveal">
                <span class="text-[10px] font-black uppercase tracking-[0.3em] text-accent mb-4 block">Resultats provats</span>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl uppercase tracking-tighter font-extrabold text-zinc-900 leading-[0.9]">
                    Casos d'èxit de posicionament<br class="hidden md:inline" /> SEO a Barcelona
                </h2>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
                {seoCases.map((cs: any, i: number) => {
                  const catName = (cs.categories || []).map((c: any) => c.name || c.attributes?.name).filter(Boolean).join(' | ');
                  const caseUrl = cs.isPublic && cs.slug ? `/ca/casos-exit/${cs.slug}/` : null;
                  return (
                    <div class="bg-white p-8 border border-black/5 flex flex-col justify-between group hover:shadow-xl hover:-translate-y-1 transition-all duration-300 rounded-2xl reveal" style={`transition-delay: ${i * 80}ms`}>
                      <div>
                        {catName && <span class="text-[10px] font-black uppercase tracking-widest text-accent mb-4 block">{catName}</span>}
                        <h3 class="text-base font-black uppercase tracking-tight text-zinc-900 mb-3 group-hover:text-accent transition-colors leading-tight">{cs.title}</h3>
                        <p class="text-xs text-zinc-500 font-light leading-relaxed">{cs.description}</p>
                      </div>
                      {caseUrl && (
                        <a href={caseUrl} class="mt-6 text-[9px] font-black tracking-[0.25em] text-accent flex items-center gap-1.5 hover:gap-3 transition-all uppercase">
                          VEURE MÉS <span class="text-sm">→</span>
                        </a>
                      )}
                    </div>
                  );
                })}
            </div>
        </div>
    </section>
    )}

    <!-- ═══ FAQ ════════════════════════════════════════════════════════════ -->
    <FaqHome
        items={faqItems}
        title="Preguntes sobre posicionament SEO a Barcelona<br/>que ens fan altres pimes"
    />

</BaseLayout>
