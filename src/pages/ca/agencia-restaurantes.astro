---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { buildAlternates } from '../../lib/i18n';
import { localAgencySchema } from '../../lib/schema';
import { strapiClient } from '../../lib/strapi';
import LogoMarquee from '../../components/sections/LogoMarquee.astro';
import FaqHome from '../../components/sections/FaqHome.astro';
import CityPills from '../../components/global/CityPills.astro';
import GoogleReviews from '../../components/global/GoogleReviews.astro';

const SITE_URL = import.meta.env.PUBLIC_SITE_URL || 'https://novamarketing.es';
const alternates = buildAlternates('/agencia-restaurantes/', '/ca/agencia-restaurantes/', SITE_URL);

let allCases: any[] = [];
try {
  const casesRes = await strapiClient.getCaseStudies('ca');
  allCases = casesRes.data.map((i: any) => i.attributes ?? i).filter((c: any) => {
    const cats = (c.categories || []).map((cat: any) => (cat.slug || cat.attributes?.slug || '').toLowerCase());
    return cats.some((s: string) => s === 'marketing-digital' || s.includes('seo') || s === 'diseno-web');
  });
} catch {}

const faqs = [
  { question: "Quant costa una agència de màrqueting per a restaurants?", answer: "Els plans mensuals parteixen de 400 euros al mes per a restaurants que arrenquen amb un o dos canals, i creixen segons la inversió publicitària i el volum de feina. Abans de començar reps un pressupost tancat per escrit, amb fee de gestió fix." },
  { question: "Què inclou el servei de màrqueting gastronòmic?", answer: "Inclou un diagnòstic inicial, una estratègia documentada i l'execució i mesura mensual de cada canal activat. SEO local i fitxa de Google, campanyes de Google Ads i Meta Ads, email màrqueting, optimització de la web i les reserves, i visibilitat a la IA." },
  { question: "Treballeu amb TheFork i les plataformes de delivery?", answer: "Les plataformes són un canal més, útil però car i compartit amb la teva competència. La nostra feina és construir-te captació pròpia amb la teva fitxa de Google, la teva web i la teva marca, perquè cada any depenguis menys de pagar comissions." },
  { question: "Qui portarà el meu compte?", answer: "Sempre la mateixa persona, el consultor fundador. Res de gestors júnior que canvien cada trimestre." },
  { question: "Quant trigaré a veure resultats?", answer: "Depèn del canal. Les campanyes de pagament i la fitxa de Google poden moure reserves les primeres setmanes, i el SEO consolida resultats entre el tercer i el dotzè mes." },
  { question: "Com mesureu els resultats?", answer: "En reserves, trucades, rutes fins al teu local i comandes, cadascuna atribuïda al seu canal i la seva campanya. A l'informe mensual veus quant has invertit i quantes taules ha omplert el màrqueting." },
  { question: "Treballeu amb permanència?", answer: "No, treballem mes a mes. Si el servei no t'aporta valor, pots cancel·lar-lo quan vulguis." },
];

const pageSchema = localAgencySchema({
  pageUrl: `${SITE_URL}/ca/agencia-restaurantes/`,
  lang: 'ca',
  cityName: 'Barcelona',
  postalCode: '08035',
  geo: { lat: 41.4114, lng: 2.1526 },
  areaServed: ["España", "Barcelona", "Sabadell", "Sant Cugat del Vallès", "Terrassa", "Vallès Occidental"],
  title: "Agència de Màrqueting per a Restaurants | Omple les teves Taules | Nova Marketing",
  description: "Agència de màrqueting especialitzada en restaurants. SEO local, Google Ads, Meta Ads, email i disseny web per omplir taules sense dependre de comissions. Sense permanències.",
  datePublished: '2026-07-17',
  dateModified: '2026-07-17',
  streetAddress: 'Carrer del General Mendoza, 10',
  hasMap: 'https://maps.app.goo.gl/9fbB12UcK32bgjj89',
  aggregateRating: { ratingValue: '5.0', reviewCount: '8' },
  breadcrumbName: "Agència per a Restaurants",
  faqs,
});
---

<BaseLayout
  title="Agència de Màrqueting per a Restaurants | Omple les teves Taules | Nova Marketing"
  description="Agència de màrqueting especialitzada en restaurants. SEO local, Google Ads, Meta Ads, email i disseny web per omplir taules sense dependre de comissions. Sense permanències."
  locale="ca"
  alternates={alternates}
  schemas={[pageSchema]}
>

    <!-- ═══ HERO / H1 ═══════════════════════════════════════════════════════ -->
    <section class="pt-24 sm:pt-40 pb-20 px-4 sm:px-6 relative overflow-hidden text-center bg-white border-b border-black/5">
        <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808008_1px,transparent_1px),linear-gradient(to_bottom,#80808008_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_40%,#000_75%,transparent_100%)]"></div>
        <div class="absolute -top-10 left-1/4 w-72 h-72 bg-accent/15 rounded-full blur-3xl opacity-30 animate-pulse"></div>
        <div class="absolute top-20 right-1/4 w-80 h-80 bg-purple-500/5 rounded-full blur-3xl opacity-20"></div>

        <div class="max-w-5xl mx-auto reveal">
            <span class="inline-flex items-center gap-2 bg-accent/5 backdrop-blur-sm px-4 py-2 border border-accent/10 rounded-full text-accent text-[8px] sm:text-[10px] font-black uppercase tracking-[0.3em] mb-8 shadow-sm">
                <span class="w-1.5 h-1.5 bg-accent rounded-full animate-ping"></span>
                Màrqueting per a Restaurants
            </span>
            <h1 class="text-3xl sm:text-5xl md:text-7xl lg:text-8xl uppercase font-extrabold tracking-tighter leading-[0.88] mb-8 text-gradient flex flex-col items-center text-center">
                <span class="lg:whitespace-nowrap">Agència de Màrqueting </span>
                <span class="lg:whitespace-nowrap text-mktg-gradient">per a Restaurants</span>
            </h1>
            <p class="text-lg sm:text-xl text-zinc-500 font-light leading-relaxed w-[75%] mx-auto mb-8">
                Omple les teves taules sense regalar comissions. Màrqueting digital per a restaurants amb estratègia a mida i resultats que es mesuren en reserves, trucades i comandes.
            </p>
            <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3 mb-10">
                {['Sense permanències', 'Tracte directe amb el consultor', 'Resultats mesurats en reserves'].map(item => (
                    <span class="inline-flex items-center gap-2 text-[11px] sm:text-xs font-black uppercase tracking-widest text-zinc-700">
                        <svg class="w-4 h-4 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                        {item}
                    </span>
                ))}
            </div>
            <div class="flex justify-center mt-4">
                <a href="#contacto" class="contact-modal-trigger btn-mktg-v5 shadow-[0_10px_30px_rgba(0,0,0,0.1)] !py-4 sm:!py-5 !px-6 sm:!px-10 !text-[11px] !tracking-widest font-black">
                    PARLEM DEL TEU RESTAURANT
                </a>
            </div>
        </div>
    </section>

    <LogoMarquee />

    <!-- ═══ INTRO ═══════════════════════════════════════════════════════ -->
    <section class="py-16 sm:py-24 bg-white px-4 sm:px-6 border-b border-black/5">
        <div class="max-w-6xl mx-auto reveal grid md:grid-cols-[1.3fr_1fr] gap-10 md:gap-16 items-center">
            <div>
                <p class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4">Per què una agència gastronòmica?</p>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-8 text-zinc-900 leading-[0.9]">
                    L'agència de màrqueting per al teu restaurant
                </h2>
                <div class="space-y-6 text-zinc-600 font-light text-base sm:text-lg leading-relaxed">
                    <p>
                        <strong class="font-semibold text-zinc-900">A la teva zona hi ha gent decidint ara mateix on menjar</strong>. Busquen a Google, miren ressenyes, pregunten a la IA i trien des del mòbil en dos minuts. Qui apareix primer amb bones fotos i bones ressenyes s'emporta la taula.
                    </p>
                    <p>
                        Nova és una <strong class="font-semibold text-zinc-900">agència de màrqueting especialitzada en restaurants</strong>. Cada compte el porta directament el consultor fundador i tota l'estratègia s'orienta a una sola mètrica que importa. <strong class="font-semibold text-zinc-900">Quantes taules i comandes genera el teu màrqueting cada mes</strong>.
                    </p>
                </div>
            </div>
            <div class="hidden md:block">
                <img src="/sergio-galos-agencia-restaurantes.webp" alt="Sergio Galo's, consultor de màrqueting per a restaurants" title="Sergio Galo's, consultor de màrqueting per a restaurants" class="w-full h-auto" loading="lazy" />
            </div>
        </div>
    </section>

    <!-- ═══ SERVEIS ═══════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-zinc-50 px-4 sm:px-6 border-t border-black/5">
        <div class="max-w-7xl mx-auto">
            <div class="text-center mb-14 sm:mb-20 reveal">
                <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Què fem</span>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.9]">
                    Serveis de Màrqueting Online per a Restaurants
                </h2>
                <p class="text-zinc-500 font-light text-sm sm:text-base leading-relaxed max-w-2xl mx-auto">
                    Omplir un restaurant no depèn d'un sol canal, depèn d'un sistema on cada canal fa la seva feina. Aquestes són les sis peces que combinem segons el que necessiti el teu local.
                </p>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 reveal text-left">
                <div class="service-card p-8 bg-white rounded-2xl border border-zinc-100/80 shadow-sm hover:shadow-2xl hover:-translate-y-2 hover:border-accent/10 transition-all duration-500 relative overflow-hidden flex flex-col justify-between">
                    <h3 class="text-xl font-black uppercase tracking-tighter mb-4 text-zinc-900">
                        <a href="/ca/agencia-restaurantes/seo/" class="hover:text-accent transition-colors">SEO per a Restaurants</a>
                    </h3>
                    <p class="text-sm text-zinc-500 font-light leading-relaxed mb-4">Apareix quan algú busca on menjar a la teva zona. Fitxa de Google, ressenyes i contingut que omple taules sense pagar comissions.</p>
                    <a href="/ca/agencia-restaurantes/seo/" class="text-[11px] font-black tracking-widest text-accent hover:underline">SABER MÉS →</a>
                </div>
                <div class="service-card p-8 bg-white rounded-2xl border border-zinc-100/80 shadow-sm hover:shadow-2xl hover:-translate-y-2 hover:border-accent/10 transition-all duration-500 relative overflow-hidden flex flex-col justify-between">
                    <h3 class="text-xl font-black uppercase tracking-tighter mb-4 text-zinc-900">
                        <a href="/ca/agencia-restaurantes/google-ads/" class="hover:text-accent transition-colors">Google Ads per a Restaurants</a>
                    </h3>
                    <p class="text-sm text-zinc-500 font-light leading-relaxed mb-4">Campanyes per a qui busca restaurant ara mateix a prop teu. Del clic a la reserva sense intermediaris.</p>
                    <a href="/ca/agencia-restaurantes/google-ads/" class="text-[11px] font-black tracking-widest text-accent hover:underline">SABER MÉS →</a>
                </div>
                <div class="service-card p-8 bg-white rounded-2xl border border-zinc-100/80 shadow-sm hover:shadow-2xl hover:-translate-y-2 hover:border-accent/10 transition-all duration-500 relative overflow-hidden flex flex-col justify-between">
                    <h3 class="text-xl font-black uppercase tracking-tighter mb-4 text-zinc-900">
                        <a href="/ca/agencia-restaurantes/meta-ads/" class="hover:text-accent transition-colors">Meta Ads per a Restaurants</a>
                    </h3>
                    <p class="text-sm text-zinc-500 font-light leading-relaxed mb-4">Els teus plats al feed del teu barri. Instagram i Facebook amb creatius que obren la gana i omplen el cap de setmana.</p>
                    <a href="/ca/agencia-restaurantes/meta-ads/" class="text-[11px] font-black tracking-widest text-accent hover:underline">SABER MÉS →</a>
                </div>
                <div class="service-card p-8 bg-white rounded-2xl border border-zinc-100/80 shadow-sm hover:shadow-2xl hover:-translate-y-2 hover:border-accent/10 transition-all duration-500 relative overflow-hidden flex flex-col justify-between">
                    <h3 class="text-xl font-black uppercase tracking-tighter mb-4 text-zinc-900">
                        <a href="/ca/agencia-restaurantes/email-marketing/" class="hover:text-accent transition-colors">Email Màrqueting Gastronòmic</a>
                    </h3>
                    <p class="text-sm text-zinc-500 font-light leading-relaxed mb-4">La teva base de clients avisada d'esdeveniments, menús i dates assenyalades. La taula més barata és la del client que repeteix.</p>
                    <a href="/ca/agencia-restaurantes/email-marketing/" class="text-[11px] font-black tracking-widest text-accent hover:underline">SABER MÉS →</a>
                </div>
                <div class="service-card p-8 bg-white rounded-2xl border border-zinc-100/80 shadow-sm hover:shadow-2xl hover:-translate-y-2 hover:border-accent/10 transition-all duration-500 relative overflow-hidden flex flex-col justify-between">
                    <h3 class="text-xl font-black uppercase tracking-tighter mb-4 text-zinc-900">
                        <a href="/ca/agencia-restaurantes/diseno-web/" class="hover:text-accent transition-colors">Disseny Web per a Restaurants</a>
                    </h3>
                    <p class="text-sm text-zinc-500 font-light leading-relaxed mb-4">Una web ràpida, adaptada a mòbil i pensada per convertir la visita en client. La base sobre la qual treballen tots els altres canals.</p>
                    <a href="/ca/agencia-restaurantes/diseno-web/" class="text-[11px] font-black tracking-widest text-accent hover:underline">SABER MÉS →</a>
                </div>
                <div class="service-card p-8 bg-white rounded-2xl border border-zinc-100/80 shadow-sm hover:shadow-2xl hover:-translate-y-2 hover:border-accent/10 transition-all duration-500 relative overflow-hidden flex flex-col justify-between">
                    <h3 class="text-xl font-black uppercase tracking-tighter mb-4 text-zinc-900">
                        <a href="/ca/agencia-restaurantes/posicionamiento-geo/" class="hover:text-accent transition-colors">GEO i Visibilitat en IA</a>
                    </h3>
                    <p class="text-sm text-zinc-500 font-light leading-relaxed mb-4">Quan algú pregunta a ChatGPT on menjar a la teva zona, la resposta recomana dos o tres llocs. Que un siguis tu.</p>
                    <a href="/ca/agencia-restaurantes/posicionamiento-geo/" class="text-[11px] font-black tracking-widest text-accent hover:underline">SABER MÉS →</a>
                </div>
            </div>
            <div class="mt-12 text-center reveal">
                <a href="#contacto" class="contact-modal-trigger btn-mktg-v5 shadow-[0_10px_30px_rgba(37,211,102,0.3)] !py-4 sm:!py-5 !px-6 sm:!px-10 !text-[11px] !tracking-widest font-black">PARLEM DEL TEU RESTAURANT</a>
            </div>
        </div>
    </section>

    <!-- ═══ ESTRATÈGIA ════════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-white px-4 sm:px-6 relative overflow-hidden">
        <div class="max-w-5xl mx-auto">
            <div class="text-center mb-16 sm:mb-24 reveal">
                <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Com treballem</span>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.9]">
                    Estratègies de màrqueting digital per a restaurants
                </h2>
                <p class="text-zinc-500 font-light text-sm sm:text-base leading-relaxed max-w-2xl mx-auto">
                    Una metodologia documentada per omplir més taules cada mes, pas a pas i sense fum.
                </p>
            </div>

            <div id="timeline-container" class="relative">
                <div class="hidden md:block absolute left-1/2 top-4 bottom-4 w-px bg-zinc-200 -translate-x-1/2"></div>
                <div id="progress-bar" class="hidden md:block absolute left-1/2 top-4 w-px bg-accent -translate-x-1/2 transition-all duration-100"></div>

                <div class="space-y-16 md:space-y-24 flex flex-col items-center">
                    {[
                        { title: "Diagnòstic del Restaurant", desc: "Analitzem la teva captació amb dades. D'on surten avui les teves reserves, quant pagues en comissions a plataformes i quina visibilitat tens al teu barri." },
                        { title: "Estratègia Documentada", desc: "Reps un pla per escrit. Quins canals activar, quins serveis empènyer, quin pressupost necessita cada campanya i quantes reserves és raonable esperar en 3, 6 i 12 mesos." },
                        { title: "Execució Multicanal", desc: "SEO local per a qui busca on menjar, Ads per a qui decideix ara, xarxes per obrir la gana i email perquè repeteixin. Cada canal amb la seva funció." },
                        { title: "Mesura Sense Fum", desc: "Mesurem reserves, trucades i comandes, no likes. Cada reserva queda atribuïda al seu canal i la seva campanya a l'informe mensual." },
                        { title: "Optimització Contínua", desc: "Revisem cada setmana campanyes i conversió, tallem el que no omple taules i reinvertim en el que funciona." },
                    ].map((step, index) => (
                        <div class="flex flex-col md:flex-row items-center gap-6 md:gap-12 w-full relative reveal">
                            <div class:list={["flex-1 w-full", index % 2 === 0 ? "md:order-1 md:text-right" : "md:order-3 md:text-left"]}>
                                <div class="p-8 sm:p-10 bg-zinc-50 border border-black/5 rounded-3xl hover:border-accent/10 hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 relative overflow-hidden group">
                                    <h3 class="text-xl font-black uppercase tracking-tighter mb-2 text-zinc-900">{index + 1}. {step.title}</h3>
                                    <div class:list={["h-0.5 bg-accent w-full mb-4 opacity-80", index % 2 === 0 ? "md:ml-auto" : ""]}></div>
                                    <p class:list={["text-sm text-zinc-500 font-light max-w-md", index % 2 === 0 ? "md:ml-auto" : ""]}>{step.desc}</p>
                                    <div class="absolute -bottom-6 -right-5 text-8xl font-black text-black/[0.02] select-none z-0 group-hover:scale-105 transition-transform duration-500">0{index+1}</div>
                                </div>
                            </div>
                            <div class="md:order-2 w-12 h-12 rounded-full border-2 border-zinc-200 bg-white flex items-center justify-center font-black text-lg z-10 shrink-0 shadow-sm node-circle transition-all">
                                0{index + 1}
                            </div>
                            <div class:list={["hidden md:block md:flex-1", index % 2 === 0 ? "md:order-3" : "md:order-1"]}></div>
                        </div>
                    ))}
                </div>
            </div>
        </div>
    </section>

    <!-- ═══ AUDITORIA ═════════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-zinc-50/50 px-4 sm:px-6 border-t border-black/5 overflow-hidden">
        <div class="max-w-7xl mx-auto grid lg:grid-cols-[6fr_4fr] gap-12 lg:gap-16 items-start">
            <div class="reveal lg:col-span-2">
                <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Punt de partida</span>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase text-zinc-900 leading-[0.9]">
                    Auditoria de màrqueting digital per al teu restaurant
                </h2>
            </div>
            <div class="reveal">
                <div class="space-y-5 text-zinc-600 font-light text-base leading-relaxed mb-8">
                    <p>Saps quant pagues de comissió per cada reserva que arriba de les plataformes? Quina part de les teves taules s'omple pel teu màrqueting i quina per sort? Gairebé cap restaurant ho sap amb dades, i aquí comença tot.</p>
                    <p>La nostra <strong class="font-semibold text-zinc-900">auditoria de màrqueting gastronòmic</strong> revisa la teva fitxa de Google, la teva web, les teves ressenyes i la teva competència amb una sola pregunta al cap. D'on sortiran les teves properes reserves.</p>
                    <p>Cada punt el revisa un consultor sènior amb experiència en hostaleria. El resultat és un diagnòstic de negoci que entén qualsevol hostaler.</p>
                </div>
                <ul class="space-y-3">
                    {["Visibilitat quan algú busca on menjar a la teva zona","Fitxa de Google i ressenyes davant la competència","Cost real de cada reserva per canal","Dependència de plataformes i les seves comissions","Conversió de la teva web i el botó de reservar","Pla d'acció prioritzat per reserves"].map(item => (
                        <li class="flex items-start gap-3 text-sm text-zinc-700 font-light">
                            <svg class="w-4 h-4 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                            {item}
                        </li>
                    ))}
                </ul>
                <div class="mt-16">
                    <a href="#contacto" class="contact-modal-trigger btn-mktg-v5 shadow-[0_10px_30px_rgba(37,211,102,0.3)] !py-4 sm:!py-5 !px-6 sm:!px-10 !text-[11px] !tracking-widest font-black">
                        VULL LA MEVA AUDITORIA GASTRONÒMICA
                    </a>
                </div>
            </div>
            <div class="reveal flex flex-col gap-4">
                {[
                    { bg: 'bg-purple-100', color: 'text-purple-600', t: "Anàlisi de la teva captació", d: "D'on surten avui les teves reserves i comandes, amb dades. La foto real abans d'invertir un euro més." },
                    { bg: 'bg-green-100', color: 'text-green-600', t: "Pla d'acció prioritzat", d: "Un pla ordenat per impacte en reserves i esforç. Sabràs què activar la primera setmana." },
                    { bg: 'bg-purple-100', color: 'text-purple-600', t: "Fitxa de Google i ressenyes", d: "L'aparador número u d'un restaurant. Com apareixes davant els locals de la teva zona." },
                    { bg: 'bg-amber-100', color: 'text-amber-600', t: "Auditoria de campanyes", d: "Si ja inverteixes a Google o Meta, revisem quina part omple taules i quina es perd." },
                    { bg: 'bg-blue-100', color: 'text-blue-600', t: "Benchmark de la teva zona", d: "Comparem la teva visibilitat amb els tres locals que més omplen al teu barri." },
                ].map(card => (
                    <div class="bg-white rounded-2xl shadow-[0_15px_40px_rgba(0,0,0,0.08)] p-5 flex items-start gap-4">
                        <div class:list={["w-11 h-11 rounded-full flex items-center justify-center flex-shrink-0", card.bg]}>
                            <svg class:list={["w-5 h-5", card.color]} fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                        </div>
                        <div>
                            <h3 class="text-sm font-black text-zinc-900 mb-1">{card.t}</h3>
                            <p class="text-xs text-zinc-500 font-light leading-relaxed">{card.d}</p>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- ═══ PLATAFORMES ═══════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-white px-4 sm:px-6 border-t border-black/5">
