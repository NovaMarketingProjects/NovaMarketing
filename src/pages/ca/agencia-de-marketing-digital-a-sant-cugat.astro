---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { buildAlternates } from '../../lib/i18n';
import { localAgencySchema } from '../../lib/schema';
import { strapiClient } from '../../lib/strapi';
import LogoMarquee from '../../components/sections/LogoMarquee.astro';
import FaqHome from '../../components/sections/FaqHome.astro';
import GoogleReviews from '../../components/global/GoogleReviews.astro';

const SITE_URL = import.meta.env.PUBLIC_SITE_URL || 'https://novamarketing.es';
const alternates = buildAlternates('/agencia-de-marketing-digital-en-sant-cugat/', '/ca/agencia-de-marketing-digital-a-sant-cugat/', SITE_URL);

let allCases: any[] = [];
try {
  const casesRes = await strapiClient.getCaseStudies('ca');
  allCases = casesRes.data.map((i: any) => i.attributes ?? i);
} catch {}

const steps = [
  { title: "Diagnòstic Local", desc: "Auditem la teva web, la teva visibilitat actual i la teva competència directa a Sant Cugat i l'àrea metropolitana. Detectem fugues de trànsit, keywords rendibles sense explotar i oportunitats de venda que la teva competència ja està capturant." },
  { title: "Estratègia Documentada", desc: "Reps un full de ruta per escrit: quins canals fer servir, quines keywords atacar, quina inversió necessita cada fase i quins resultats esperar en 3, 6 i 12 mesos. Saps en què s'inverteix cada euro abans d'invertir-lo." },
  { title: "Execució Multicanal", desc: "Coordinem SEO, Google Ads, continguts i analítica perquè la inversió generi leads de qualitat des del primer mes. Ads accelera el curt termini mentre el SEO construeix el teu actiu a mitjà termini." },
  { title: "Mesura Sense Fum", desc: "Configurem l'analítica per atribuir cada lead al seu canal. A l'informe mensual veuràs trucades, formularis i vendes generades, no mètriques de vanitat. Reunió mensual amb el consultor per revisar números." },
  { title: "Optimització Contínua", desc: "Espremem cada euro adaptant campanyes i continguts als pics de demanda de Sant Cugat: estacionalitat del sector, canvis d'algoritme i moviments de la teva competència." }
];

const districts = [
  { title: "Centre i Estació", desc: "L'eix comercial de Sant Cugat, amb un client de renda alta i expectatives exigents. Aquí guanyen els negocis amb una presència digital cuidada: web impecable, ressenyes excel·lents i un posicionament local dominant." },
  { title: "Mira-sol, Valldoreix i La Floresta", desc: "Zones residencials on el client busca serveis \"a prop meu\" des del mòbil, de reformes a salut o educació. Pack local complet: fitxa optimitzada, landings per zona i anuncis geolocalitzats." },
  { title: "Can Sant Joan i el parc empresarial", desc: "Sant Cugat concentra seus corporatives i empreses tecnològiques. Per vendre a aquest teixit B2B cal aparèixer a les cerques tècniques del decisor, amb contingut que demostri autoritat real." },
];

const criteria = [
  { title: "Demana casos d'èxit verificables a Sant Cugat", desc: "Un mur de logos no demostra res. Demana casos de negocis de Sant Cugat amb dades concretes: quina keyword local, quina posició va assolir, en quant de temps i amb quina inversió. Una agència que treballa el mercat de Sant Cugat hauria de poder ensenyar-te resultats a la teva ciutat, o fins i tot al teu sector. Si no poden ensenyar-te'n ni un, segueix buscant." },
  { title: "Pregunta qui portarà el teu compte", desc: "En moltes agències de Sant Cugat ven un director i executa un júnior amb 30 comptes. Exigeix conèixer la persona que treballarà el teu projecte abans de signar, i pregunta si podràs reunir-te amb ella cara a cara: a nova les reunions amb clients de Sant Cugat i el Vallès Occidental poden ser presencials." },
  { title: "Exigeix la propietat dels teus actius", desc: "La web, el compte de Google Ads, la fitxa de Google Business Profile i l'analítica han d'estar al teu nom. És més habitual del que sembla: pimes de Sant Cugat que porten anys pagant i descobreixen en voler canviar d'agència que no són propietàries ni del seu propi domini. Si l'agència reté els teus actius, no estàs contractant un servei: estàs signant una dependència." },
  { title: "Desconfia de qui garanteix la posició 1 a Google a Sant Cugat", desc: "Ningú pot garantir la posició 1 a Google, i menys en un mercat tan disputat com el de Sant Cugat, on cada keyword local la lluiten desenes de competidors. Qui ho promet, o menteix o fa servir tècniques que acabaran penalitzant la teva web. El que és seriós és garantir mètode, transparència i feina verificable." },
  { title: "Revisa què mesura l'informe mensual", desc: "Si l'informe parla d'impressions i abast però no de trucades, formularis i vendes de clients de Sant Cugat, l'agència està mesurant la seva activitat, no el teu negoci. El posicionament local a Sant Cugat es mesura en visites a la teva fitxa, rutes al teu local i pressupostos sol·licitats, no en likes." },
  { title: "Fuig de les agències de marketing amb permanències llargues", desc: "Una permanència de 12 mesos protegeix l'agència, no a tu. Amb tanta oferta d'agències de marketing digital a l'abast, la feina ben feta reté clients sense necessitat de contractes que els lliguin. Per això a nova treballem mes a mes." },
  { title: "Coneixement del negoci local", desc: "No és el mateix posicionar una clínica del centre que una indústria del polígon o un ecommerce que ven a tota Espanya. Una agència que coneix el mercat de Sant Cugat sap què busca el client de cada zona, quina competència hi ha a cada sector i quines keywords locals converteixen. Pregunta què sap l'agència del teu barri, del teu sector i del teu client abans de signar." }
];

const sectors = [
  { icon: '🛒', title: 'Agència de marketing per a ecommerce', href: '/ca/agencia-ecommerce/', desc: "Arquitectura de categories, fitxes optimitzades, feed de Shopping i CRO. El SEO de producte i les campanyes ben estructurades es retroalimenten per vendre més." },
  { icon: '🏠', title: 'Agència de marketing per a immobiliàries', href: '/ca/agencia-inmobiliarias/', desc: "Captació de propietaris i compradors en un mercat caríssim. Landings per zona, SEO local per barri i campanyes que filtren curiosos de clients reals." },
  { icon: '🍽️', title: 'Agència de marketing per a restaurants', href: '/ca/agencia-restaurantes/', desc: "Aquí mana la fitxa de Google i les ressenyes. Treballem el pack local complet perquè apareguis quan algú busca on menjar a prop, i omplir taules entre setmana." },
  { icon: '🧠', title: 'Agència de marketing per a psicòlegs', desc: "El pacient busca confiança abans que preu. Contingut amb autoritat clínica, SEO local per especialitat i campanyes discretes que respecten la sensibilitat del sector." },
  { icon: '🌿', title: 'Agència de marketing per a terapeutes', desc: "Un sector amb molta competència genèrica i poca especialitzada. Posicionem la teva consulta per teràpia i zona, amb contingut que educa i converteix visites en primeres sessions." },
  { icon: '🦷', title: 'Agència de marketing per a dentistes', desc: "Sector saturat a Sant Cugat i amb alta exigència d'E-E-A-T. Guanyen els qui combinen SEO local impecable, ressenyes gestionades i contingut clínic amb autoritat real." },
  { icon: '💪', title: 'Agència de marketing per a gimnasos', desc: "Captació estacional amb pics al gener i al setembre. Campanyes geolocalitzades a pocs minuts del centre, ofertes de prova i retenció mesurada amb dades." },
  { icon: '🏗️', title: 'Agència de marketing per a constructores', desc: "Competència local ferotge i leads de valor alt. El pack guanyador és fitxa de Google impecable, landings per zona i campanyes geolocalitzades que porten pressupostos, no visites." },
  { icon: '⚖️', title: 'Agència de marketing per a advocats', desc: "Cerques d'altíssima intenció i CPCs dels més cars de Google. La clau està a captar la consulta amb contingut que resol el dubte legal concret abans que la competència." },
  { icon: '🏨', title: 'Agència de marketing per a hotels', desc: "Reduir la dependència de les OTAs és l'objectiu: SEO per a reserva directa, fitxa optimitzada, campanyes de marca i estratègia de preus visible a Google Hotels." },
  { icon: '🏭', title: 'Agència de marketing per a B2B', desc: "Cicles de venda llargs i pocs decisors. Aquí no importa el volum: importa aparèixer a les deu cerques tècniques que fa el responsable de compres." },
  { icon: '🎓', title: 'Agència de marketing per a escoles', desc: "Captació estacional amb pics clars. L'estratègia combina contingut informacional tot l'any amb inversió agressiva a la finestra de matriculació." },
];

const faqs = [
  { question: "Quant costa una agència de marketing digital a Sant Cugat?", answer: "Depèn del servei i del punt de partida, però en un mercat amb el poder adquisitiu de Sant Cugat el que és car no és l'agència sinó ser invisible per a un client que compara molt abans de decidir. Treballem amb pressupostos tancats a mida i sense sorpreses: saps el preu exacte abans de signar." },
  { question: "Funciona el marketing digital per a negocis de proximitat a Mira-sol o Valldoreix?", answer: "Molt bé, perquè el client residencial d'aquestes zones busca gairebé tot des del mòbil amb intenció immediata: reformes, salut, educació, restauració. El pack de SEO local, fitxa de Google optimitzada i campanyes geolocalitzades és la via més directa per captar-lo." },
  { question: "Treballeu amb empreses del parc empresarial de Sant Cugat?", answer: "Sí. Sant Cugat concentra seus corporatives i empreses tecnològiques amb decisors que investiguen els proveïdors a fons abans de contactar. Per a aquest perfil treballem contingut amb autoritat tècnica, SEO B2B i campanyes segmentades a càrrecs concrets, no a públic general." },
  { question: "El client de Sant Cugat exigeix un enfocament diferent?", answer: "Sí, i convé assumir-ho des del principi: és un client informat, amb expectatives altes i que compara. Una web mediocre o una fitxa amb tres ressenyes et descarten abans que puguis parlar. Per això aquí cuidem especialment la presència de marca, les ressenyes i el contingut." },
  { question: "Podem reunir-nos en persona?", answer: "Sí. Amb els clients de Sant Cugat i de la resta del Vallès Occidental les reunions poden ser presencials, a la teva oficina o on et vagi millor. També treballem per videotrucada amb el mateix nivell de seguiment si ho prefereixes." },
  { question: "Com mesureu els resultats de l'estratègia?", answer: "Mesurem leads i vendes: trucades, formularis, reserves i pressupostos sol·licitats, cadascun atribuït al seu canal. A l'informe mensual veus resultats de negoci, no mètriques de vanitat, i les dades i els comptes són sempre teus." },
  { question: "Treballeu amb permanència?", answer: "No, treballem mes a mes. Si el servei no t'aporta valor, pots cancel·lar-lo quan vulguis. La nostra permanència real és el resultat que veus als informes cada mes." },
];


const pageSchema = localAgencySchema({
  pageUrl: `${SITE_URL}/ca/agencia-de-marketing-digital-a-sant-cugat/`,
  lang: 'ca',
  cityName: 'Sant Cugat',
  postalCode: '08172',
  geo: { lat: 41.4736, lng: 2.0861 },
  areaServed: ["Sant Cugat del Vallès","Sabadell","Terrassa","Barcelona","Vallès Occidental"],
  title: "▷ Marketing Digital en Sant Cugat | Estrategias para PYMES",
  description: "Marketing digital en Sant Cugat: SEO, Google Ads y diseño web para pymes que buscan crecer y mejorar su presencia online ✅💡",
  datePublished: '2025-06-09',
  dateModified: '2026-07-14',
  faqs,
});

---

<BaseLayout
  title="▷ Marketing Digital en Sant Cugat | Estrategias para PYMES"
  description="Marketing digital en Sant Cugat: SEO, Google Ads y diseño web para pymes que buscan crecer y mejorar su presencia online ✅💡"
  locale="ca"
  alternates={alternates}
  schemas={[pageSchema]}
>

    <!-- ═══ HERO / H1 ═══════════════════════════════════════════════════════ -->
    <section class="pt-24 sm:pt-40 pb-20 px-4 sm:px-6 relative overflow-hidden text-center bg-white border-b border-black/5">
        <!-- Background Grid Mesh -->
        <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808008_1px,transparent_1px),linear-gradient(to_bottom,#80808008_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_40%,#000_75%,transparent_100%)]"></div>

        <!-- Glow Orbs -->
        <div class="absolute -top-10 left-1/4 w-72 h-72 bg-accent/15 rounded-full blur-3xl opacity-30 animate-pulse"></div>
        <div class="absolute top-20 right-1/4 w-80 h-80 bg-purple-500/5 rounded-full blur-3xl opacity-20"></div>

        <div class="max-w-5xl mx-auto reveal">
            <span class="inline-flex items-center gap-2 bg-accent/5 backdrop-blur-sm px-4 py-2 border border-accent/10 rounded-full text-accent text-[8px] sm:text-[10px] font-black uppercase tracking-[0.3em] mb-8 shadow-sm">
                <span class="w-1.5 h-1.5 bg-accent rounded-full animate-ping"></span>
                Impuls Digital per a Pimes
            </span>
            <h1 class="text-3xl sm:text-5xl md:text-7xl lg:text-8xl uppercase font-extrabold tracking-tighter leading-[0.88] mb-8 text-gradient flex flex-col items-center text-center">
                <span class="lg:whitespace-nowrap">Agència de Marketing </span>
                <span class="lg:whitespace-nowrap">Digital a Sant Cugat</span>
            </h1>
            <p class="text-lg sm:text-xl text-zinc-500 font-light leading-relaxed w-[75%] mx-auto mb-8">
                A nova ajudem pimes i autònoms de Sant Cugat a captar clients amb SEO, Google Ads i disseny web. Estratègia a mida, preus clars i resultats que es mesuren en vendes.
            </p>
            <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3 mb-10">
                {['Sense permanències', 'Tracte directe amb el consultor', 'Informes de negoci'].map(item => (
                    <span class="inline-flex items-center gap-2 text-[11px] sm:text-xs font-black uppercase tracking-widest text-zinc-700">
                        <svg class="w-4 h-4 text-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                        </svg>
                        {item}
                    </span>
                ))}
            </div>
            <div class="flex justify-center mt-4">
                <a href="#contacto" class="contact-modal-trigger btn-mktg-v5 shadow-[0_10px_30px_rgba(0,0,0,0.1)] !py-4 sm:!py-5 !px-6 sm:!px-10 !text-[11px] !tracking-widest font-black">
                    PARLEM DEL TEU NEGOCI
                </a>
            </div>
        </div>
    </section>

    <LogoMarquee />

    <!-- ═══ INTRO: QUI SOM ═════════════════════════════════════════════════ -->
    <section class="py-16 sm:py-24 bg-white px-4 sm:px-6 border-b border-black/5">
        <div class="max-w-6xl mx-auto reveal grid md:grid-cols-[1.3fr_1fr] gap-10 md:gap-16 items-center">
            <div>
                <p class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4">Què és Nova?</p>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-8 text-zinc-900 leading-[0.9]">
                    L'agència de marketing digital per a la teva pime a Sant Cugat
                </h2>
                <div class="space-y-6 text-zinc-600 font-light text-base sm:text-lg leading-relaxed">
                    <p>
                        <strong class="font-semibold text-zinc-900">Nova Marketing és una agència de marketing digital especialitzada en pimes</strong> que opera a Sant Cugat i el Vallès Occidental, amb serveis de posicionament SEO, Google Ads, disseny web i posicionament GEO en IA.
                    </p>
                    <p>
                        El nostre enfocament és diferent: treballem amb un nombre limitat de clients, cada compte el porta directament el consultor fundador i tota l'estratègia s'orienta a una sola mètrica que importa: <strong class="font-semibold text-zinc-900">quants clients nous genera la teva inversió cada mes</strong>.
                    </p>
                </div>
            </div>
            <div class="hidden md:block">
                <img src="/sergio-galos-agencia-de-marketing-digital-a-sant-cugat.webp" alt="Sergio Galo's, consultor de màrqueting digital per a pimes a Sant Cugat" title="Sergio Galo's, consultor de màrqueting digital per a pimes a Sant Cugat" class="w-full h-auto" loading="lazy" width="473" height="591" />
            </div>
        </div>
    </section>

    <!-- ═══ SECCIÓ 1: SERVEIS ══════════════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-zinc-50 border-b border-black/5 px-4 sm:px-6">
        <div class="max-w-7xl mx-auto text-center reveal">
            <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Què fem</span>
            <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.9]">
                Serveis de Marketing Online a Sant Cugat
            </h2>
            <p class="text-zinc-500 font-light text-sm sm:text-base leading-relaxed max-w-2xl mx-auto mb-16">
                Quatre serveis, un mateix objectiu: que la teva empresa aparegui on busquen els teus clients a Sant Cugat i converteixi aquest trànsit en facturació.
            </p>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 text-left">
                <!-- SEO -->
                <div class="service-card p-8 bg-white rounded-2xl border border-zinc-100/80 shadow-sm hover:shadow-2xl hover:-translate-y-2 hover:border-accent/10 transition-all duration-500 relative overflow-hidden flex flex-col justify-between">
        <!-- Hover Gradient Overlay -->
        <div class="absolute inset-x-0 h-1 bottom-0 bg-gradient-to-r from-accent via-accent/90 to-purple-600 w-0 group-hover:w-full transition-all duration-500"></div>
                    <h3 class="text-xl font-black uppercase tracking-tighter mb-4 text-zinc-900">
                        <a href="/ca/agencia-seo-per-pimes/sant-cugat/" class="hover:text-accent transition-colors">Agència de Posicionament SEO a Sant Cugat</a>
                    </h3>
                    <p class="text-sm text-zinc-500 font-light leading-relaxed mb-4">
                        Apareix als primers resultats de Google quan els teus clients busquen els teus serveis a Sant Cugat. Optimitzem la teva fitxa de Google Business Profile, la teva web i els teus continguts per dominar les cerques locals del teu sector, des del centre fins a tota la comarca.
                    </p>
                    <a href="/ca/agencia-seo-per-pimes/sant-cugat/" class="text-[11px] font-black tracking-widest text-accent hover:underline">SABER MÉS →</a>
                </div>

                <!-- Google Ads -->
                <div class="service-card p-8 bg-white rounded-2xl border border-zinc-100/80 shadow-sm hover:shadow-2xl hover:-translate-y-2 hover:border-accent/10 transition-all duration-500 relative overflow-hidden flex flex-col justify-between">
        <!-- Hover Gradient Overlay -->
        <div class="absolute inset-x-0 h-1 bottom-0 bg-gradient-to-r from-accent via-accent/90 to-purple-600 w-0 group-hover:w-full transition-all duration-500"></div>
                    <h3 class="text-xl font-black uppercase tracking-tighter mb-4 text-zinc-900">
                        <a href="/ca/agencia-sem-per-pimes/sant-cugat/" class="hover:text-accent transition-colors">Agència de Google Ads a Sant Cugat</a>
                    </h3>
                    <p class="text-sm text-zinc-500 font-light leading-relaxed mb-4">
                        Anuncis hipersegmentats per captar clients des de la primera setmana. No llancis els diners en clics buits: dirigim les teves campanyes a usuaris de Sant Cugat amb intenció real de compra i optimitzem el CPC per maximitzar el retorn de cada euro invertit.
                    </p>
                    <a href="/ca/agencia-sem-per-pimes/sant-cugat/" class="text-[11px] font-black tracking-widest text-accent hover:underline">SABER MÉS →</a>
                </div>

                <!-- Disseny Web -->
                <div class="service-card p-8 bg-white rounded-2xl border border-zinc-100/80 shadow-sm hover:shadow-2xl hover:-translate-y-2 hover:border-accent/10 transition-all duration-500 relative overflow-hidden flex flex-col justify-between">
        <!-- Hover Gradient Overlay -->
        <div class="absolute inset-x-0 h-1 bottom-0 bg-gradient-to-r from-accent via-accent/90 to-purple-600 w-0 group-hover:w-full transition-all duration-500"></div>
                    <h3 class="text-xl font-black uppercase tracking-tighter mb-4 text-zinc-900">
                        <a href="/ca/disseny-web-per-pimes/sant-cugat/" class="hover:text-accent transition-colors">Agència de Disseny Web a Sant Cugat</a>
                    </h3>
                    <p class="text-sm text-zinc-500 font-light leading-relaxed mb-4">
                        Dissenyem l'aparador digital 24/7 que la teva empresa necessita: pàgines web ultraràpides, adaptades a mòbil i 100% enfocades a la conversió, amb l'autoritat que exigeix un mercat tan exigent com el del Vallès.
                    </p>
                    <a href="/ca/disseny-web-per-pimes/sant-cugat/" class="text-[11px] font-black tracking-widest text-accent hover:underline">SABER MÉS →</a>
                </div>

                <!-- Consultoria -->
                <div class="service-card p-8 bg-white rounded-2xl border border-zinc-100/80 shadow-sm hover:shadow-2xl hover:-translate-y-2 hover:border-accent/10 transition-all duration-500 relative overflow-hidden flex flex-col justify-between">
        <!-- Hover Gradient Overlay -->
        <div class="absolute inset-x-0 h-1 bottom-0 bg-gradient-to-r from-accent via-accent/90 to-purple-600 w-0 group-hover:w-full transition-all duration-500"></div>
                    <h3 class="text-xl font-black uppercase tracking-tighter mb-4 text-zinc-900">
                        <a href="/ca/agencia-geo-per-pimes/sant-cugat/" class="hover:text-accent transition-colors">Agència GEO a Sant Cugat</a>
                    </h3>
                    <p class="text-sm text-zinc-500 font-light leading-relaxed mb-4">
                        Els teus clients de Sant Cugat ja pregunten a ChatGPT i Gemini quina empresa contractar. Treballem el teu posicionament GEO perquè la IA recomani el teu negoci abans que la teva competència.
                    </p>
                    <a href="/ca/agencia-geo-per-pimes/sant-cugat/" class="text-[11px] font-black tracking-widest text-accent hover:underline">SABER MÉS →</a>
                </div>
            </div>
        </div>
    </section>

    <!-- ═══ SECCIÓ 2: COM TREBALLEM ═══════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-white px-4 sm:px-6 relative overflow-hidden">
        <div class="max-w-5xl mx-auto">
            <div class="text-center mb-16 sm:mb-24 reveal">
                <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Com treballem</span>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.9]">
                    Estratègies de marketing digital per a pimes a Sant Cugat
                </h2>
                <p class="text-zinc-500 font-light text-sm sm:text-base leading-relaxed max-w-2xl mx-auto">
                    Una metodologia provada en més de 20 projectes perquè competeixis amb garanties al mercat de Sant Cugat, pas a pas i sense fum.
                </p>
            </div>

            <div id="timeline-container" class="relative">
                <div class="hidden md:block absolute left-1/2 top-4 bottom-4 w-px bg-zinc-200 -translate-x-1/2"></div>
                <div id="progress-bar" class="hidden md:block absolute left-1/2 top-4 w-px bg-accent -translate-x-1/2 transition-all duration-100"></div>

                <div class="space-y-16 md:space-y-24 flex flex-col items-center">
                    {steps.map((step, index) => (
