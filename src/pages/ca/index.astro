---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { buildAlternates } from '../../lib/i18n';
import { localAgencySchema } from '../../lib/schema';
import { strapiClient } from '../../lib/strapi';
import LogoMarquee from '../../components/sections/LogoMarquee.astro';
import FaqHome from '../../components/sections/FaqHome.astro';
import GoogleReviews from '../../components/global/GoogleReviews.astro';

const SITE_URL = import.meta.env.PUBLIC_SITE_URL || 'https://novamarketing.es';
const alternates = buildAlternates('/', '/ca/', SITE_URL);

let allCases: any[] = [];
try {
  const casesRes = await strapiClient.getCaseStudies('ca');
  allCases = casesRes.data.map((i: any) => i.attributes ?? i);
} catch {}

const steps = [
  { title: "Diagnòstic Local", desc: "Auditem la teva web, la teva visibilitat actual i la teva competència directa. Detectem fugues de trànsit, keywords rendibles sense explotar i oportunitats de venda que la teva competència ja està capturant." },
  { title: "Estratègia Documentada", desc: "Reps un full de ruta per escrit: quins canals fer servir, quines keywords atacar, quina inversió necessita cada fase i quins resultats esperar en 3, 6 i 12 mesos. Saps en què s'inverteix cada euro abans d'invertir-lo." },
  { title: "Execució Multicanal", desc: "Coordinem SEO, Google Ads, continguts i analítica perquè la inversió generi leads de qualitat des del primer mes. Ads accelera el curt termini mentre el SEO construeix el teu actiu a mitjà termini." },
  { title: "Mesura Sense Fum", desc: "Configurem l'analítica per atribuir cada lead al seu canal. A l'informe mensual veuràs trucades, formularis i vendes generades, no mètriques de vanitat. Reunió mensual amb el consultor per revisar números." },
  { title: "Optimització Contínua", desc: "Espremem cada euro adaptant campanyes i continguts als pics de demanda del teu mercat: estacionalitat del sector, canvis d'algoritme i moviments de la teva competència." }
];

const criteria = [
  { title: "Demana casos d'èxit verificables", desc: "Un mur de logos no demostra res. Demana casos amb dades concretes: quina keyword, quina posició va assolir, en quant de temps i amb quina inversió. Una agència seriosa hauria de poder ensenyar-te resultats de negocis com el teu. Si no poden ensenyar-te'n ni un, segueix buscant." },
  { title: "Pregunta qui portarà el teu compte", desc: "En moltes agències ven un director i executa un júnior amb 30 comptes. Exigeix conèixer la persona que treballarà el teu projecte abans de signar, i pregunta com serà la comunicació: a nova parles sempre amb el consultor que executa la teva estratègia, presencialment o per videotrucada." },
  { title: "Exigeix la propietat dels teus actius", desc: "La web, el compte de Google Ads, la fitxa de Google Business Profile i l'analítica han d'estar al teu nom. És més habitual del que sembla: pimes que porten anys pagant i descobreixen en voler canviar d'agència que no són propietàries ni del seu propi domini. Si l'agència reté els teus actius, no estàs contractant un servei: estàs signant una dependència." },
  { title: "Desconfia de qui garanteix la posició 1 a Google", desc: "Ningú pot garantir la posició 1 a Google. Qui ho promet, o menteix o fa servir tècniques que acabaran penalitzant la teva web. El que és seriós és garantir mètode, transparència i feina verificable." },
  { title: "Revisa què mesura l'informe mensual", desc: "Si l'informe parla d'impressions i abast però no de trucades, formularis i vendes, l'agència està mesurant la seva activitat, no el teu negoci. El marketing d'una pime es mesura en clients nous i pressupostos sol·licitats, no en likes." },
  { title: "Fuig de les agències de marketing amb permanències llargues", desc: "Una permanència de 12 mesos protegeix l'agència, no a tu. La feina ben feta reté clients sense necessitat de contractes que els lliguin. Per això a nova treballem mes a mes." },
  { title: "Especialització en pimes", desc: "No és el mateix treballar per a una multinacional amb departament propi que per a una pime on cada euro compta. Pregunta quants clients com tu porta l'agència, amb quins pressupostos treballa i quins resultats ha aconseguit en empreses de la teva mida." }
];

const sectors = [
  { icon: '🛒', title: 'Agència de marketing per a ecommerce', href: '/ca/agencia-ecommerce/', desc: "Arquitectura de categories, fitxes optimitzades, feed de Shopping i CRO. El SEO de producte i les campanyes ben estructurades es retroalimenten per vendre més." },
  { icon: '🏠', title: 'Agència de marketing per a immobiliàries', href: '/ca/agencia-inmobiliarias/', desc: "Captació de propietaris i compradors en un mercat caríssim. Landings per zona, SEO local per barri i campanyes que filtren curiosos de clients reals." },
  { icon: '🍽️', title: 'Agència de marketing per a restaurants', href: '/ca/agencia-restaurantes/', desc: "Aquí mana la fitxa de Google i les ressenyes. Treballem el pack local complet perquè apareguis quan algú busca on menjar a prop, i omplir taules entre setmana." },
  { icon: '🧠', title: 'Agència de marketing per a psicòlegs', desc: "El pacient busca confiança abans que preu. Contingut amb autoritat clínica, SEO local per especialitat i campanyes discretes que respecten la sensibilitat del sector." },
  { icon: '🌿', title: 'Agència de marketing per a terapeutes', desc: "Un sector amb molta competència genèrica i poca especialitzada. Posicionem la teva consulta per teràpia i zona, amb contingut que educa i converteix visites en primeres sessions." },
  { icon: '🦷', title: 'Agència de marketing per a dentistes', desc: "Sector saturat i amb alta exigència d'E-E-A-T. Guanyen els qui combinen SEO local impecable, ressenyes gestionades i contingut clínic amb autoritat real." },
  { icon: '💪', title: 'Agència de marketing per a gimnasos', desc: "Captació estacional amb pics al gener i al setembre. Campanyes geolocalitzades a pocs minuts del centre, ofertes de prova i retenció mesurada amb dades." },
  { icon: '🏗️', title: 'Agència de marketing per a constructores', desc: "Competència local ferotge i leads de valor alt. El pack guanyador és fitxa de Google impecable, landings per zona i campanyes geolocalitzades que porten pressupostos, no visites." },
  { icon: '⚖️', title: 'Agència de marketing per a advocats', desc: "Cerques d'altíssima intenció i CPCs dels més cars de Google. La clau està a captar la consulta amb contingut que resol el dubte legal concret abans que la competència." },
  { icon: '🏨', title: 'Agència de marketing per a hotels', desc: "Reduir la dependència de les OTAs és l'objectiu: SEO per a reserva directa, fitxa optimitzada, campanyes de marca i estratègia de preus visible a Google Hotels." },
  { icon: '🏭', title: 'Agència de marketing per a B2B', desc: "Cicles de venda llargs i pocs decisors. Aquí no importa el volum: importa aparèixer a les deu cerques tècniques que fa el responsable de compres." },
  { icon: '🎓', title: 'Agència de marketing per a escoles', desc: "Captació estacional amb pics clars. L'estratègia combina contingut informacional tot l'any amb inversió agressiva a la finestra de matriculació." },
];

const faqs = [
  { question: "Quant costa una agència de marketing digital per a pimes?", answer: "Depèn molt dels serveis que necessitis i de si és un projecte puntual o una feina recurrent. No costa el mateix una auditoria o el llançament d'una web que una estratègia mensual de posicionament i captació. Per això a nova no treballem amb tarifes genèriques sinó amb pressupostos tancats a mida: abans de signar saps exactament què es fa, qui ho fa i quin resultat es persegueix." },
  { question: "Què inclou una estratègia de marketing digital per a una pime?", answer: "Inclou una auditoria inicial, un full de ruta documentat i l'execució i mesura mensual de cada acció. Analitzem la teva situació actual i la teva competència, definim quins canals fer servir, quina inversió necessita cada fase i quins resultats esperar a 3, 6 i 12 mesos. No apliquem plantilles: cada sector i cada mercat competeix de manera diferent." },
  { question: "Qui portarà el meu compte?", answer: "El teu compte el porta directament Sergio Galo's, consultor de marketing digital i fundador de Nova Marketing. Sense gestors júnior ni intermediaris: la persona que dissenya la teva estratègia és la mateixa que l'executa i la que et respon a la reunió mensual." },
  { question: "Quant trigaré a veure resultats?", answer: "Hi ha accions que generen clients en setmanes i d'altres que consoliden resultats entre el sisè i el dotzè mes. El termini exacte depèn del punt de partida del teu negoci i de la competència del teu sector. Al full de ruta inicial et diem què esperar a cada fase, amb terminis realistes i sense promeses de fum." },
  { question: "Com mesureu els resultats de l'estratègia?", answer: "Mesurem leads i vendes: cada trucada, formulari o comanda queda atribuïda al seu canal d'origen. Configurem l'analítica des del primer dia i a l'informe mensual veus resultats de negoci, no mètriques de vanitat. A més tens accés total als teus comptes i eines: les dades són teves." },
  { question: "Treballeu amb permanència?", answer: "No, treballem mes a mes. Si el servei no t'aporta valor, pots cancel·lar-lo quan vulguis. La nostra permanència real és el resultat que veus als informes cada mes." },
  { question: "Treballeu amb empreses de tota Espanya?", answer: "Sí: la seu és a Barcelona i bona part dels projectes són de la seva àrea metropolitana, on les reunions poden ser presencials, però treballem amb pimes de tota Espanya per videotrucada amb el mateix nivell de seguiment." }
];


const pageSchema = localAgencySchema({
  pageUrl: `${SITE_URL}/ca/`,
  lang: 'ca',
  cityName: 'Barcelona',
  postalCode: '08035',
  geo: { lat: 41.4114, lng: 2.1526 },
  areaServed: ["España","Barcelona","Sabadell","Sant Cugat del Vallès","Terrassa","Vallès Occidental"],
  title: "▷ Marketing digital para pymes: SEO, Google Ads y diseño web",
  description: "Agència especialitzada en SEO, Google Ads i disseny web per a pimes ⭐ Estratègies a mida i atenció personalitzada per captar clients✅",
  datePublished: '2025-06-09',
  dateModified: '2026-07-14',
  streetAddress: 'Carrer del General Mendoza, 10',
  hasMap: 'https://maps.app.goo.gl/9fbB12UcK32bgjj89',
  aggregateRating: { ratingValue: '5.0', reviewCount: '12' },
  reviews: [
    { author: "이진만", date: '2026-05-14', body: "Como guía turístico, buscaba algo que me ayudara a diferenciarme, y hablé con Sergio de Nova Marketing y ha hecho un trabajo excepcional. 👍👍👍 La ilustración que han diseñado para mi marca es increíble y me va a ayudar muchísimo a posicionar" },
    { author: "Cristina Oliver", date: '2026-05-14', body: "Totalmente recomendados para cualquier pyme. Sergio no se limita a darte consejos analiza tu mercado para mejorar tu posicionamiento SEO. En mi caso necesitaba posicionar en un entorno muy competitivo y Nova Marketing trazó el plan perfecto. Una agencia de marketing que realmente se implica en el éxito de sus clientes." },
    { author: "Alba Delgado Arau", date: '2025-08-14', body: "Tenemos un club de gimnasia artística y nos han ayudado con nuestra estrategia de marketing digital que teníamos un poquito olvidada." },
    { author: "Jesús Antonio García", date: '2025-07-14', body: "Excelente servicio de SEO y el trato siempre ds muy cercano. Recomendados al 100%" },
    { author: "Ester Guillen", date: '2022-07-14', body: "Llegamos un par de meses trabajando juntos y al principio solo cogimos el pack SEM pero segurament contamos una auditoría completa con vosotros. Profesionales y muy recomendable." },
  ],
  faqs,
});

---

<BaseLayout
  title="▷ Marketing digital para pymes: SEO, Google Ads y diseño web"
  description="Agència especialitzada en SEO, Google Ads i disseny web per a pimes ⭐ Estratègies a mida i atenció personalitzada per captar clients✅"
  locale="ca"
  alternates={alternates}
  schemas={[pageSchema]}
>

    <!-- ═══ HERO / H1 ═══════════════════════════════════════════════════════ -->
    <section class="pt-24 sm:pt-40 pb-20 px-4 sm:px-6 relative overflow-hidden text-center bg-white border-b border-black/5">
        <!-- Background Grid Mesh -->
        <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808008_1px,transparent_1px),linear-gradient(to_bottom,#80808008_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_40%,#000_75%,transparent_100%)]"></div>

        <!-- Glow Orbs -->
        <div class="absolute -top-10 left-1/4 w-72 h-72 bg-accent/15 rounded-full blur-3xl opacity-30 animate-pulse"></div>
        <div class="absolute top-20 right-1/4 w-80 h-80 bg-purple-500/5 rounded-full blur-3xl opacity-20"></div>

        <div class="max-w-5xl mx-auto reveal">
            <span class="inline-flex items-center gap-2 bg-accent/5 backdrop-blur-sm px-4 py-2 border border-accent/10 rounded-full text-accent text-[8px] sm:text-[10px] font-black uppercase tracking-[0.3em] mb-8 shadow-sm">
                <span class="w-1.5 h-1.5 bg-accent rounded-full animate-ping"></span>
                Impuls Digital per a Pimes
            </span>
            <h1 class="text-3xl sm:text-5xl md:text-7xl lg:text-8xl uppercase font-extrabold tracking-tighter leading-[0.88] mb-8 text-gradient flex flex-col items-center text-center">
                <span class="lg:whitespace-nowrap">Agència de </span>
                <span class="lg:whitespace-nowrap">Marketing Digital </span>
                <span class="lg:whitespace-nowrap text-mktg-gradient">per a Pimes</span>
            </h1>
            <p class="text-lg sm:text-xl text-zinc-500 font-light leading-relaxed w-[75%] mx-auto mb-8">
                A nova ajudem pimes, autònoms i petites i mitjanes empreses a captar clients amb SEO, Google Ads i disseny web. Estratègia a mida, preus clars i resultats que es mesuren en vendes.
            </p>
            <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3 mb-10">
                {['Sense permanències', 'Tracte directe amb el consultor', 'Informes de negoci'].map(item => (
                    <span class="inline-flex items-center gap-2 text-[11px] sm:text-xs font-black uppercase tracking-widest text-zinc-700">
                        <svg class="w-4 h-4 text-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                        </svg>
                        {item}
                    </span>
                ))}
            </div>
            <div class="flex justify-center mt-4">
                <a href="#contacto" class="contact-modal-trigger btn-mktg-v5 shadow-[0_10px_30px_rgba(0,0,0,0.1)] !py-4 sm:!py-5 !px-6 sm:!px-10 !text-[11px] !tracking-widest font-black">
                    PARLEM DEL TEU NEGOCI
                </a>
            </div>
        </div>
    </section>

    <LogoMarquee />

    <!-- ═══ INTRO: QUI SOM ═════════════════════════════════════════════════ -->
    <section class="py-16 sm:py-24 bg-white px-4 sm:px-6 border-b border-black/5">
        <div class="max-w-6xl mx-auto reveal grid md:grid-cols-[1.3fr_1fr] gap-10 md:gap-16 items-center">
            <div>
                <p class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4">Què és Nova?</p>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-8 text-zinc-900 leading-[0.9]">
                    L'agència de marketing digital per a la teva pime
                </h2>
                <div class="space-y-6 text-zinc-600 font-light text-base sm:text-lg leading-relaxed">
                    <p>
                        <strong class="font-semibold text-zinc-900">Nova Marketing és una agència de marketing digital especialitzada en pimes</strong> que ajuda petites i mitjanes empreses de tota Espanya, amb serveis de posicionament SEO, Google Ads, disseny web i consultoria de marketing.
                    </p>
                    <p>
                        El nostre enfocament és diferent: treballem amb un nombre limitat de clients, cada compte el porta directament el consultor fundador i tota l'estratègia s'orienta a una sola mètrica que importa: <strong class="font-semibold text-zinc-900">quants clients nous genera la teva inversió cada mes</strong>.
                    </p>
                </div>
            </div>
            <div class="hidden md:block">
                <img src="/consultor-marketing-digital.webp" alt="Sergio Galo's - Consultor de marketing digital per a pimes" title="Sergio Galo's - Consultor de marketing digital per a pimes" class="w-full h-auto" loading="lazy" width="473" height="591" />
            </div>
        </div>
    </section>

    <!-- ═══ SECCIÓ 1: SERVEIS ══════════════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-zinc-50 border-b border-black/5 px-4 sm:px-6">
        <div class="max-w-7xl mx-auto text-center reveal">
            <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Què fem</span>
            <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.9]">
                Serveis de Marketing Online per a Pimes
            </h2>
            <p class="text-zinc-500 font-light text-sm sm:text-base leading-relaxed max-w-2xl mx-auto mb-16">
                Quatre serveis, un mateix objectiu: que la teva empresa aparegui on busquen els teus clients i converteixi aquest trànsit en facturació.
            </p>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 text-left">
                <!-- SEO -->
                <div class="service-card p-8 bg-white rounded-2xl border border-zinc-100/80 shadow-sm hover:shadow-2xl hover:-translate-y-2 hover:border-accent/10 transition-all duration-500 relative overflow-hidden flex flex-col justify-between">
        <!-- Hover Gradient Overlay -->
        <div class="absolute inset-x-0 h-1 bottom-0 bg-gradient-to-r from-accent via-accent/90 to-purple-600 w-0 group-hover:w-full transition-all duration-500"></div>
                    <h3 class="text-xl font-black uppercase tracking-tighter mb-4 text-zinc-900">
                        <a href="/ca/agencia-seo-per-pimes/" class="hover:text-accent transition-colors">Agència SEO per a Pimes</a>
                    </h3>
                    <p class="text-sm text-zinc-500 font-light leading-relaxed mb-4">
                        Apareix als primers resultats de Google quan els teus clients busquen els teus serveis. Optimitzem la teva fitxa de Google Business Profile, la teva web i els teus continguts per dominar les cerques del teu sector, tant locals com nacionals.
                    </p>
                    <a href="/ca/agencia-seo-per-pimes/" class="text-[11px] font-black tracking-widest text-accent hover:underline">SABER MÉS →</a>
                </div>

                <!-- Google Ads -->
                <div class="service-card p-8 bg-white rounded-2xl border border-zinc-100/80 shadow-sm hover:shadow-2xl hover:-translate-y-2 hover:border-accent/10 transition-all duration-500 relative overflow-hidden flex flex-col justify-between">
        <!-- Hover Gradient Overlay -->
        <div class="absolute inset-x-0 h-1 bottom-0 bg-gradient-to-r from-accent via-accent/90 to-purple-600 w-0 group-hover:w-full transition-all duration-500"></div>
                    <h3 class="text-xl font-black uppercase tracking-tighter mb-4 text-zinc-900">
                        <a href="/ca/agencia-sem-per-pimes/" class="hover:text-accent transition-colors">Agència de Google Ads per a Pimes</a>
                    </h3>
                    <p class="text-sm text-zinc-500 font-light leading-relaxed mb-4">
                        Anuncis hipersegmentats per captar clients des de la primera setmana. No llancis els diners en clics buits: dirigim les teves campanyes a usuaris amb intenció real de compra i optimitzem el CPC per maximitzar el retorn de cada euro invertit.
                    </p>
                    <a href="/ca/agencia-sem-per-pimes/" class="text-[11px] font-black tracking-widest text-accent hover:underline">SABER MÉS →</a>
                </div>

                <!-- Disseny Web -->
                <div class="service-card p-8 bg-white rounded-2xl border border-zinc-100/80 shadow-sm hover:shadow-2xl hover:-translate-y-2 hover:border-accent/10 transition-all duration-500 relative overflow-hidden flex flex-col justify-between">
        <!-- Hover Gradient Overlay -->
        <div class="absolute inset-x-0 h-1 bottom-0 bg-gradient-to-r from-accent via-accent/90 to-purple-600 w-0 group-hover:w-full transition-all duration-500"></div>
                    <h3 class="text-xl font-black uppercase tracking-tighter mb-4 text-zinc-900">
                        <a href="/ca/disseny-web-per-pimes/" class="hover:text-accent transition-colors">Disseny Web per a Pimes</a>
                    </h3>
                    <p class="text-sm text-zinc-500 font-light leading-relaxed mb-4">
                        Dissenyem l'aparador digital 24/7 que la teva empresa necessita: pàgines web ultraràpides, adaptades a mòbil i 100% enfocades a la conversió, amb l'autoritat que el teu mercat exigeix.
                    </p>
                    <a href="/ca/disseny-web-per-pimes/" class="text-[11px] font-black tracking-widest text-accent hover:underline">SABER MÉS →</a>
                </div>

                <!-- Consultoria -->
                <div class="service-card p-8 bg-white rounded-2xl border border-zinc-100/80 shadow-sm hover:shadow-2xl hover:-translate-y-2 hover:border-accent/10 transition-all duration-500 relative overflow-hidden flex flex-col justify-between">
        <!-- Hover Gradient Overlay -->
        <div class="absolute inset-x-0 h-1 bottom-0 bg-gradient-to-r from-accent via-accent/90 to-purple-600 w-0 group-hover:w-full transition-all duration-500"></div>
                    <h3 class="text-xl font-black uppercase tracking-tighter mb-4 text-zinc-900">
                        <a href="/ca/agencia-geo-per-pimes/" class="hover:text-accent transition-colors">Agència GEO per a Pimes</a>
                    </h3>
                    <p class="text-sm text-zinc-500 font-light leading-relaxed mb-4">
                        Els teus clients ja pregunten a ChatGPT i Gemini quina empresa contractar. Treballem el teu posicionament GEO perquè la IA recomani el teu negoci abans que la teva competència.
                    </p>
                    <a href="/ca/agencia-geo-per-pimes/" class="text-[11px] font-black tracking-widest text-accent hover:underline">SABER MÉS →</a>
                </div>
            </div>
        </div>
    </section>

    <!-- ═══ SECCIÓ 2: COM TREBALLEM ═══════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-white px-4 sm:px-6 relative overflow-hidden">
        <div class="max-w-5xl mx-auto">
            <div class="text-center mb-16 sm:mb-24 reveal">
                <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Com treballem</span>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.9]">
                    Estratègies de marketing digital per a pimes
                </h2>
                <p class="text-zinc-500 font-light text-sm sm:text-base leading-relaxed max-w-2xl mx-auto">
                    Una metodologia provada en més de 20 projectes perquè competeixis amb garanties al teu mercat, pas a pas i sense fum.
                </p>
            </div>

            <div id="timeline-container" class="relative">
                <div class="hidden md:block absolute left-1/2 top-4 bottom-4 w-px bg-zinc-200 -translate-x-1/2"></div>
                <div id="progress-bar" class="hidden md:block absolute left-1/2 top-4 w-px bg-accent -translate-x-1/2 transition-all duration-100"></div>

                <div class="space-y-16 md:space-y-24 flex flex-col items-center">
                    {steps.map((step, index) => (
                        <div class="flex flex-col md:flex-row items-center gap-6 md:gap-12 w-full relative reveal">
