---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHeader from '../../../components/blog/PageHeader.astro';
import SuccessCard from '../../../components/blog/SuccessCard.astro';
import CategoryTabs from '../../../components/blog/CategoryTabs.astro';
import { strapiClient } from '../../../lib/strapi';
import { buildAlternates } from '../../../lib/i18n';

const SITE_URL = import.meta.env.PUBLIC_SITE_URL || 'https://novamarketing.es';
const alternates = buildAlternates('/casos-exito', '/ca/casos-exit', SITE_URL);

// Fetch data
let cases = [];
let categoriesWithCases = [];

try {
  const casesRes = await strapiClient.getCaseStudies('ca');
  cases = casesRes.data.map(i => i.attributes ?? i);
  
  const categoriesRes = await strapiClient.getCaseStudyCategories('ca');
  const allCategories = categoriesRes.data.map(i => i.attributes ?? i);

  categoriesWithCases = allCategories.filter(cat => 
    cases.some(cs => cs.category?.slug === cat.slug)
  );
} catch (e) {
  console.error("DEBUG: Casos CA index error:", e);
}
---

<BaseLayout
  title="Casos d'èxit | Nova Marketing"
  description="Resultats reals aconseguits per a petites i mitjanes empreses. Mira com hem ajudat a créixer als nostres clients."
  locale="ca"
  alternates={alternates}
>
  <PageHeader 
    badge="RESULTATS"
    title="Casos d'<span class='text-mktg-gradient text-3xl sm:text-6xl md:text-8xl lg:text-9xl'>èxit</span>"
    description="Cada projecte és una oportunitat per superar expectatives i generar creixement real."
  />

  <section class="py-20 px-6 sm:px-12 bg-white">
    <div class="max-w-7xl mx-auto">
      
      <CategoryTabs 
        categories={categoriesWithCases} 
        currentCategory="all" 
        baseUrl="/ca/casos-exit"
        locale="ca"
      />

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12">
        {cases.map(cs => (
          <SuccessCard caseStudy={cs} locale="ca" />
        ))}
      </div>

      {cases.length === 0 && (
        <div class="text-center py-40 border-2 border-dashed border-zinc-100 rounded-3xl">
          <p class="text-zinc-400 font-light">Encara no hi ha casos d'èxit en aquesta secció.</p>
        </div>
      )}
    </div>
  </section>

</BaseLayout>
