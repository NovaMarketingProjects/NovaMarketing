---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { buildAlternates } from '../../../lib/i18n';
import { localAgencySchema } from '../../../lib/schema';
import { strapiClient } from '../../../lib/strapi';
import LogoMarquee from '../../../components/sections/LogoMarquee.astro';
import FaqHome from '../../../components/sections/FaqHome.astro';
import GoogleReviews from '../../../components/global/GoogleReviews.astro';

const SITE_URL = import.meta.env.PUBLIC_SITE_URL || 'https://novamarketing.es';
const alternates = buildAlternates('/agencia-sem-para-pymes/terrassa/', '/ca/agencia-sem-per-pimes/terrassa/', SITE_URL);

let allCases: any[] = [];
try {
  const casesRes = await strapiClient.getCaseStudies('ca');
  allCases = casesRes.data.map((i: any) => i.attributes ?? i).filter((c: any) => {
    const cats = (c.categories || []).map((cat: any) => (cat.slug || cat.attributes?.slug || '').toLowerCase());
    return cats.some((s: string) => s.includes('google-ads'));
  });
} catch {}

const steps = [
  { title: "Auditoria del teu compte i del mercat de Terrassa", desc: "Analitzem el teu compte de Google Ads si ja en tens un, la teva web i el que fa la teva competència als anuncis. Detectem pressupost malbaratat, cerques que no converteixen i oportunitats que ningú està pujant. Aquest és el teu punt de partida real." },
  { title: "Estratègia de campanyes per a Terrassa", desc: "Reps un pla per escrit. Quines campanyes llançar, quines cerques atacar, quin pressupost necessites i quin cost per client és raonable al teu sector. Saps en què s'inverteix cada euro abans d'invertir-lo." },
  { title: "Estructura, anuncis i landings", desc: "Muntem les campanyes amb una estructura neta, redactem anuncis que responen al que busca el teu client i preparem la pàgina de destinació per convertir aquell clic en un contacte. L'anunci porta la visita, la landing tanca el lead." },
  { title: "Optimització de pujes per zona", desc: "Revisem les campanyes cada setmana. Tallem les cerques que gasten sense vendre, pugem la puja on hi ha negoci i ajustem horaris, zones i dispositius perquè cada euro treballi on converteix." },
  { title: "Mesura i ajust mes a mes", desc: "Monitorem mes a mes els teus leads, el teu cost per contacte i el teu retorn. A l'informe veus quants clients arriben des dels anuncis, quant costa cadascun i quines campanyes mereixen més pressupost el mes següent." }
];

const criteria = [
  { title: "Demana casos d'èxit verificables", desc: "Un mur de logos no demostra res. Demana casos amb dades concretes. Quina inversió, quin cost per lead, quants clients va generar i en quant de temps. Una agència de Google Ads seriosa hauria de poder ensenyar-te resultats de negocis com el teu. Si no poden ensenyar-te'n ni un, segueix buscant." },
  { title: "Pregunta qui portarà el teu compte", desc: "En moltes agències ven un director i executa un júnior amb 30 comptes. Exigeix conèixer la persona que gestionarà les teves campanyes abans de signar. A nova parles sempre amb el consultor que optimitza el teu compte, presencialment o per videotrucada." },
  { title: "Exigeix que el compte de Google Ads sigui teu", desc: "El compte, l'historial de dades i el píxel de conversió han d'estar al teu nom. Moltes agències creen el compte sota la seva propietat i en marxar perds tot l'aprenentatge acumulat i comences de zero. Això no és un servei, és un segrest de dades." },
  { title: "Desconfia de qui cobra un percentatge opac de la teva inversió", desc: "Si l'agència guanya més com més gastes, el seu incentiu és que gastis més, no que venguis més. Exigeix saber exactament quant pagues de gestió i quant va a Google. A nova el fee és fix i el cent per cent del teu pressupost publicitari va als teus anuncis." },
  { title: "Revisa què mesura l'informe mensual", desc: "Si l'informe parla d'impressions i clics però no de trucades, formularis i vendes, l'agència està mesurant la seva activitat i no el teu negoci. Les campanyes d'una pime es mesuren en clients nous i en el que costa aconseguir cadascun." },
  { title: "Fuig de les permanències llargues", desc: "Una permanència de 12 mesos protegeix l'agència, no a tu. A Google Ads els resultats es veuen en setmanes, així que no hi ha excusa per lligar-te un any. Per això a nova treballem mes a mes." },
  { title: "Que no depengui tot de pagar", desc: "Google Ads porta clients des del primer dia, però quan atures la inversió s'aturen els leads. Una bona agència t'ajuda a fer servir les dades de les campanyes per construir també SEO i visibilitat a la IA. Nosaltres integrem els tres canals en una sola estratègia." }
];

const faqs = [
  { question: "Quant costa una agència de Google Ads a Terrassa?", answer: "L'auditoria del teu compte costa 900 euros i la gestió mensual comença en 150 euros al mes amb fee fix, sense percentatges sobre la teva inversió. A això s'hi suma el teu pressupost publicitari, que va íntegre a Google i recomanem que parteixi d'entre 300 i 500 euros al mes. Pressupost tancat per escrit i sense permanències." },
  { question: "Què funciona per a un comerç del centre de Terrassa?", answer: "Campanyes locals amb radi ajustat, extensions de trucada i d'ubicació connectades amb la teva fitxa de Google i anuncis actius en el teu horari. Qui busca des del mòbil al centre o a Vapor Gran decideix en minuts, així que la landing ha de carregar ràpida i facilitar el contacte." },
  { question: "Feu Google Ads per a la indústria egarenca?", answer: "Sí. Can Parellada, Els Bellots i la resta de polígons concentren empreses B2B amb clients que busquen proveïdors amb termes molt tècnics. Són cerques de poc volum i CPC baix que porten pressupostos industrials, no trànsit curiós." },
  { question: "Competiu amb les agències de Google Ads de Barcelona?", answer: "Treballem igual que elles però coneixent el mercat egarenc i el Vallès de primera mà, i amb la proximitat de poder reunir-nos en persona. Moltes pimes de Terrassa venen d'agències de Barcelona que les tractaven com un compte més." },
  { question: "Quant triga Google Ads a donar resultats a Terrassa?", answer: "És el canal més ràpid que existeix. Les campanyes poden estar mostrant anuncis en qüestió de dies i els primers leads solen arribar les primeres setmanes. L'algoritme necessita entre un i dos mesos de dades per optimitzar del tot el cost per client." },
  { question: "Com mesureu els resultats?", answer: "Mesurem el que mou la teva caixa. Trucades, formularis, visites al teu local i pressupostos sol·licitats, cadascun atribuït a la seva campanya i la seva cerca. Informe mensual de negoci amb reunió inclosa i el compte sempre al teu nom." },
  { question: "Treballeu amb permanència?", answer: "No, treballem mes a mes. Si el servei no t'aporta valor, pots cancel·lar-lo quan vulguis. La nostra permanència real és el resultat que veus als informes cada mes." },
];

const sectors = [
  { icon: '🛒', title: 'Google Ads per a ecommerce', desc: 'Shopping i Performance Max amb feed optimitzat. Que el teu producte surti amb foto i preu just quan algú busca comprar-lo.' },
  { icon: '🏠', title: 'Google Ads per a immobiliàries', desc: 'Captació de propietaris i compradors amb campanyes per zona i anuncis que filtren curiosos abans del clic.' },
  { icon: '🍽️', title: 'Google Ads per a restaurants', desc: 'Campanyes locals que apareixen quan algú busca on menjar a prop, connectades amb la teva fitxa de Google i les reserves.' },
  { icon: '🧠', title: 'Google Ads per a psicòlegs', desc: 'El pacient busca ajuda amb urgència i tria entre el primer que veu. Anuncis per especialitat que converteixen cerques en primeres visites.' },
  { icon: '🌿', title: 'Google Ads per a terapeutes', desc: 'Clics cars si competeixes en genèric. Campanyes per teràpia i zona que paguen només per les cerques que porten pacients.' },
  { icon: '🦷', title: 'Google Ads per a dentistes', desc: 'Un dels CPCs més cars del mercat. Aquí guanya qui millor filtra les cerques i millor converteix la landing, no qui més gasta.' },
  { icon: '💪', title: 'Google Ads per a gimnasos', desc: 'Campanyes estacionals amb pics al gener i al setembre. Promocions locals que omplen classes sense cremar pressupost la resta de l\'any.' },
  { icon: '🏗️', title: 'Google Ads per a constructores', desc: 'Leads de valor alt i molta competència local. Campanyes per servei i zona amb anuncis que porten pressupostos, no curiosos.' },
  { icon: '⚖️', title: 'Google Ads per a advocats', desc: 'Cerques d\'altíssima intenció amb els clics més cars de Google. Estructura quirúrgica per pagar només pels casos que t\'interessen.' },
  { icon: '🏨', title: 'Google Ads per a hotels', desc: 'Campanyes de marca per frenar les OTAs i captar la reserva directa, més visibilitat a Google Hotels.' },
  { icon: '🏭', title: 'Google Ads per a B2B', desc: 'Pocs decisors i cicles llargs. Campanyes de cerca tècnica i remarketing que acompanyen el responsable de compres fins al contacte.' },
  { icon: '🎓', title: 'Google Ads per a escoles', desc: 'Captació concentrada en la finestra de matriculació. Campanyes que apreten quan les famílies decideixen i descansen la resta de l\'any.' },
];

const pageSchema = localAgencySchema({
  pageUrl: `${SITE_URL}/ca/agencia-sem-per-pimes/terrassa/`,
  lang: 'ca',
  cityName: 'Terrassa',
  postalCode: '08221',
  geo: { lat: 41.5633, lng: 2.0087 },
  areaServed: ["Terrassa", "Vallès Occidental", "Barcelona", "España"],
  title: "Agència de Google Ads a Terrassa | Publicitat a Google per a Pimes",
  description: "Agència de Google Ads a Terrassa per a pimes. Campanyes amb fee fix, el compte al teu nom i resultats mesurats en leads i vendes. Sense permanències.",
  datePublished: '2026-07-15',
  dateModified: '2026-07-15',
  breadcrumbName: 'Agència de Google Ads a Terrassa',
  faqs,
});
---

<BaseLayout
  title="Agència de Google Ads a Terrassa | Publicitat a Google per a Pimes"
  description="Agència de Google Ads a Terrassa per a pimes. Campanyes amb fee fix, el compte al teu nom i resultats mesurats en leads i vendes. Sense permanències."
  locale="ca"
  alternates={alternates}
  schemas={[pageSchema]}
>

    <!-- ═══ HERO / H1 ═══════════════════════════════════════════════════════ -->
    <section class="pt-24 sm:pt-40 pb-20 px-4 sm:px-6 relative overflow-hidden text-center bg-white border-b border-black/5">
        <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808008_1px,transparent_1px),linear-gradient(to_bottom,#80808008_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_40%,#000_75%,transparent_100%)]"></div>
        <div class="absolute -top-10 left-1/4 w-72 h-72 bg-accent/15 rounded-full blur-3xl opacity-30 animate-pulse"></div>
        <div class="absolute top-20 right-1/4 w-80 h-80 bg-purple-500/5 rounded-full blur-3xl opacity-20"></div>

        <div class="max-w-5xl mx-auto reveal">
            <span class="inline-flex items-center gap-2 bg-accent/5 backdrop-blur-sm px-4 py-2 border border-accent/10 rounded-full text-accent text-[8px] sm:text-[10px] font-black uppercase tracking-[0.3em] mb-8 shadow-sm">
                <span class="w-1.5 h-1.5 bg-accent rounded-full animate-ping"></span>
                Publicitat a Google per a Pimes
            </span>
            <h1 class="text-3xl sm:text-5xl md:text-7xl lg:text-8xl uppercase font-extrabold tracking-tighter leading-[0.88] mb-8 text-gradient flex flex-col items-center text-center">
                <span class="lg:whitespace-nowrap">Agència SEM </span>
                <span class="lg:whitespace-nowrap">Google Ads </span>
                <span class="lg:whitespace-nowrap text-mktg-gradient">a Terrassa</span>
            </h1>
            <p class="text-lg sm:text-xl text-zinc-500 font-light leading-relaxed w-[75%] mx-auto mb-8">
                Apareix avui mateix quan els teus clients busquen el teu servei a Google. Campanyes de Google Ads per a pimes de Terrassa amb fee fix, el compte al teu nom i resultats que es mesuren en vendes.
            </p>
            <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3 mb-10">
                {['Sense permanències', 'Fee fix sense percentatges', 'El compte és teu'].map(item => (
                    <span class="inline-flex items-center gap-2 text-[11px] sm:text-xs font-black uppercase tracking-widest text-zinc-700">
                        <svg class="w-4 h-4 text-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                        </svg>
                        {item}
                    </span>
                ))}
            </div>
            <div class="flex justify-center mt-4">
                <a href="#contacto" class="contact-modal-trigger btn-mktg-v5 shadow-[0_10px_30px_rgba(0,0,0,0.1)] !py-4 sm:!py-5 !px-6 sm:!px-10 !text-[11px] !tracking-widest font-black">
                    PARLEM DEL TEU NEGOCI
                </a>
            </div>
        </div>
    </section>

    <LogoMarquee />

    <!-- ═══ INTRO: PER QUÈ GOOGLE ADS ═════════════════════════════════════ -->
    <section class="py-16 sm:py-24 bg-white px-4 sm:px-6 border-b border-black/5">
        <div class="max-w-6xl mx-auto reveal grid md:grid-cols-[1.3fr_1fr] gap-10 md:gap-16 items-center">
            <div>
                <p class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4">Per què Google Ads?</p>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-8 text-zinc-900 leading-[0.9]">
                    L'agència de Google Ads per a la teva pime a Terrassa
                </h2>
                <div class="space-y-6 text-zinc-600 font-light text-base sm:text-lg leading-relaxed">
                    <p>
                        <strong class="font-semibold text-zinc-900">Google Ads és el canal més ràpid per aconseguir clients</strong>. Mentre el SEO triga mesos a posicionar, un anunci ben muntat apareix avui davant de qui està buscant el teu servei amb la cartera a la mà. La qüestió no és si funciona, és quant pagues per cada clic i què en fas.
                    </p>
                    <p>
                        Nova és una <strong class="font-semibold text-zinc-900">agència SEM especialitzada en pimes</strong> que treballa amb negocis de Terrassa i tota la seva comarca. Treballem amb un nombre limitat de clients, cada compte el porta directament el consultor fundador i tota la gestió s'orienta a una sola mètrica que importa. <strong class="font-semibold text-zinc-900">Quant et costa aconseguir cada client nou des dels anuncis</strong>.
                    </p>
                </div>
            </div>
            <div class="hidden md:block">
                <img src="/sergio-galos-agencia-sem-per-pimes-terrassa.webp" alt="Sergio Galo's, consultor de Google Ads per a pimes a Terrassa" class="w-full h-auto" loading="lazy" />
            </div>
        </div>
    </section>

    <!-- ═══ SERVEIS SEM ══════════════════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-zinc-50 border-b border-black/5 px-4 sm:px-6">
        <div class="max-w-7xl mx-auto text-center reveal">
            <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Què fem</span>
            <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.9]">
                Servei de Google Ads per a pimes a Terrassa
            </h2>
            <div class="text-zinc-500 font-light text-sm sm:text-base leading-relaxed max-w-3xl mx-auto mb-16 space-y-4">
                <p>
                    Gestionar <strong class="font-semibold text-zinc-700">Google Ads</strong> no és activar una campanya i deixar-la córrer, és un sistema. Aquestes són les nou peces que treballem perquè cada euro del teu pressupost torni convertit en clients.
                </p>
                <p>
                    Cada peça s'activa segons el que digui la teva auditoria. No pagues per un paquet tancat d'accions, pagues per les que el teu negoci necessita.
                </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                {[
                    { icon: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z', t: 'Auditoria de Google Ads a Terrassa', d: 'Radiografia del teu compte, el teu pressupost i la teva competència abans de tocar res. El punt de partida de qualsevol estratègia d\'anuncis.' },
                    { icon: 'M12 3a9 9 0 100 18 9 9 0 000-18zm0 5a4 4 0 100 8 4 4 0 000-8z', t: 'Campanyes per al mercat egarenc', d: 'Anuncis de text que apareixen just quan algú busca el teu servei. El cor de la captació de leads per a una pime.' },
                    { icon: 'M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z', t: 'Google Shopping', d: 'Els teus productes amb foto i preu als resultats de compra. Feed optimitzat perquè el clic arribi ja mig convençut.' },
                    { icon: 'M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z', t: 'Display i YouTube', d: 'Anuncis visuals i de vídeo per donar a conèixer la teva marca a qui encara no et busca, amb segmentació fina i sense cremar pressupost.' },
                    { icon: 'M13 10V3L4 14h7v7l9-11h-7z', t: 'Performance Max', d: 'La campanya automatitzada de Google, ben alimentada i ben vigilada. Potent amb dades bones, un forat de pressupost sense elles.' },
                    { icon: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15', t: 'Remarketing al client de Terrassa', d: 'Tornem a impactar qui va visitar la teva web i no va contactar. Els leads més barats solen estar a la segona visita.' },
                    { icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', t: 'Landings que converteixen en leads', d: 'L\'anunci porta la visita i la landing la converteix. Optimitzem la pàgina de destinació perquè el clic acabi en formulari o trucada.' },
                    { icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm8 0V5a2 2 0 012-2h0a2 2 0 012 2v14a2 2 0 01-2 2h0a2 2 0 01-2-2zm-8 0a2 2 0 002 2h2a2 2 0 002-2V9a2 2 0 00-2-2h-2a2 2 0 00-2 2v10z', t: 'Mesura de trucades i pressupostos', d: 'Configurem les conversions i GA4 per atribuir cada lead a la seva campanya i la seva cerca. Decisions amb dades, no amb intuïcions.' },
                    { icon: 'M8 12h.01M12 12h.01M16 12h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z', t: 'Google Ads més SEO', d: 'Les dades de les teves campanyes revelen quines cerques venen. Les fem servir per construir SEO i que cada cop depenguis menys de pagar.' },
                ].map(c => (
                    <div class="bg-white border border-black/5 rounded-2xl p-6 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 text-left">
                        <div class="flex items-center gap-3 mb-3">
                            <div class="w-10 h-10 rounded-full bg-accent/10 border border-accent/20 flex items-center justify-center flex-shrink-0">
                                <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d={c.icon}/></svg>
                            </div>
                            <h3 class="text-sm font-black uppercase tracking-tight text-zinc-900">{c.t}</h3>
                        </div>
                        <p class="text-sm text-zinc-500 font-light leading-relaxed">{c.d}</p>
                    </div>
                ))}
            </div>

            <div class="mt-12 text-center reveal">
                <a href="#contacto" class="contact-modal-trigger btn-mktg-v5 shadow-[0_10px_30px_rgba(37,211,102,0.3)] !py-4 sm:!py-5 !px-6 sm:!px-10 !text-[11px] !tracking-widest font-black">
                    PARLEM DEL TEU NEGOCI
                </a>
            </div>
        </div>
    </section>

    <!-- ═══ ESTRATÈGIA SEM ════════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-white px-4 sm:px-6 relative overflow-hidden">
        <div class="max-w-5xl mx-auto">
            <div class="text-center mb-16 sm:mb-24 reveal">
                <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Com treballem</span>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.9]">
                    Estratègia de Google Ads per captar clients a Terrassa
                </h2>
                <p class="text-zinc-500 font-light text-sm sm:text-base leading-relaxed max-w-2xl mx-auto">
                    Una metodologia documentada per convertir el teu pressupost publicitari en leads i vendes, pas a pas i sense fum.
                </p>
            </div>

            <div id="timeline-container" class="relative">
                <div class="hidden md:block absolute left-1/2 top-4 bottom-4 w-px bg-zinc-200 -translate-x-1/2"></div>
                <div id="progress-bar" class="hidden md:block absolute left-1/2 top-4 w-px bg-accent -translate-x-1/2 transition-all duration-100"></div>

                <div class="space-y-16 md:space-y-24 flex flex-col items-center">
                    {steps.map((step, index) => (
                        <div class="flex flex-col md:flex-row items-center gap-6 md:gap-12 w-full relative reveal">
                            <div class:list={["flex-1 w-full", index % 2 === 0 ? "md:order-1 md:text-right" : "md:order-3 md:text-left"]}>
                                <div class="p-8 sm:p-10 bg-zinc-50 border border-black/5 rounded-3xl hover:border-accent/10 hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 relative overflow-hidden group">
                                    <h3 class="text-xl font-black uppercase tracking-tighter mb-2 text-zinc-900">{index + 1}. {step.title}</h3>
                                    <div class:list={["h-0.5 bg-accent w-full mb-4 opacity-80", index % 2 === 0 ? "md:ml-auto" : ""]}></div>
                                    <p class:list={["text-sm text-zinc-500 font-light max-w-md", index % 2 === 0 ? "md:ml-auto" : ""]}>{step.desc}</p>
                                    <div class="absolute -bottom-6 -right-5 text-8xl font-black text-black/[0.02] select-none z-0 group-hover:scale-105 transition-transform duration-500">0{index+1}</div>
                                </div>
                            </div>
                            <div class="md:order-2 w-12 h-12 rounded-full border-2 border-zinc-200 bg-white flex items-center justify-center font-black text-lg z-10 shrink-0 shadow-sm node-circle transition-all">
                                0{index + 1}
                            </div>
                            <div class:list={["hidden md:block md:flex-1", index % 2 === 0 ? "md:order-3" : "md:order-1"]}></div>
                        </div>
                    ))}
                </div>
            </div>
        </div>
    </section>

