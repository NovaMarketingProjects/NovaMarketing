---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { buildAlternates } from '../../lib/i18n';

const SITE_URL = import.meta.env.PUBLIC_SITE_URL || 'https://novamarketing.es';
const alternates = buildAlternates('/gracias/', '/ca/gracies/', SITE_URL);
---

<BaseLayout
  title="Gràcies per contactar-nos! | Nova Marketing"
  description="Hem rebut la teva consulta. En breu ens posarem en contacte amb tu."
  locale="ca"
  alternates={alternates}
  noIndex={true}
>
  <section class="min-h-[80vh] flex items-center justify-center px-6 py-24 bg-white relative overflow-hidden">
    <!-- Background grid -->
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808008_1px,transparent_1px),linear-gradient(to_bottom,#80808008_1px,transparent_1px)] bg-[size:24px_24px]"></div>
    <!-- Glow -->
    <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-96 h-96 bg-accent/10 rounded-full blur-3xl"></div>

    <div class="relative z-10 max-w-2xl mx-auto text-center">
      <div class="inline-flex items-center gap-2 bg-accent/5 px-3 py-1.5 border border-accent/10 rounded-full text-accent text-[9px] font-black uppercase tracking-[0.3em] mb-8">
        <span class="w-1.5 h-1.5 bg-accent rounded-full"></span>
        MISSATGE REBUT
      </div>

      <h1 class="text-5xl sm:text-6xl md:text-7xl font-black uppercase tracking-tighter leading-none mb-8 text-zinc-900">
        GRÀCIES<br/>PER CONTACTAR!
      </h1>

      <p class="text-zinc-500 font-light text-lg leading-relaxed mb-12 max-w-md mx-auto">
        Hem rebut la teva consulta.<br/>Un dels nostres especialistes es posarà en contacte amb tu en menys de <strong class="text-zinc-900 font-bold">24 hores</strong>.
      </p>

      <a href="/ca/" class="inline-flex items-center gap-3 bg-zinc-900 text-white font-black uppercase tracking-widest text-[11px] px-10 py-5 rounded-full hover:bg-accent transition-colors duration-300">
        TORNAR A L'INICI <span class="text-base">→</span>
      </a>
    </div>
  </section>
</BaseLayout>
