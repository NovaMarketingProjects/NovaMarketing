---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { buildAlternates } from '../../lib/i18n';
import { localAgencySchema } from '../../lib/schema';
import { strapiClient } from '../../lib/strapi';
import LogoMarquee from '../../components/sections/LogoMarquee.astro';
import FaqHome from '../../components/sections/FaqHome.astro';
import CityPills from '../../components/global/CityPills.astro';
import GoogleReviews from '../../components/global/GoogleReviews.astro';

const SITE_URL = import.meta.env.PUBLIC_SITE_URL || 'https://novamarketing.es';
const alternates = buildAlternates('/agencia-inmobiliarias/', '/ca/agencia-inmobiliarias/', SITE_URL);

let allCases: any[] = [];
try {
  const casesRes = await strapiClient.getCaseStudies('ca');
  allCases = casesRes.data.map((i: any) => i.attributes ?? i).filter((c: any) => {
    const cats = (c.categories || []).map((cat: any) => (cat.slug || cat.attributes?.slug || '').toLowerCase());
    return cats.some((s: string) => s === 'marketing-digital' || s.includes('seo') || s === 'diseno-web');
  });
} catch {}

const faqs = [
  { question: "Quant costa una agència de màrqueting per a immobiliàries?", answer: "Els plans mensuals parteixen de 400 euros al mes per a agències que arrenquen amb un o dos canals, i creixen segons la inversió publicitària i el volum de feina. Abans de començar reps un pressupost tancat per escrit, amb fee de gestió fix i sense percentatges ocults sobre la teva inversió." },
  { question: "Què inclou el servei de màrqueting immobiliari?", answer: "Inclou un diagnòstic inicial, una estratègia documentada i l'execució i mesura mensual de cada canal activat. SEO immobiliari, campanyes de Google Ads i Meta Ads, email màrqueting, optimització de la web i visibilitat a la IA." },
  { question: "Treballeu amb portals immobiliaris?", answer: "Els portals són un canal més, útil però car i compartit amb la teva competència. La nostra feina és construir-te captació pròpia amb la teva web, la teva zona i la teva marca, perquè cada any depenguis menys de pagar visibilitat llogada." },
  { question: "Qui portarà el meu compte?", answer: "Sempre la mateixa persona, el consultor fundador. Res de gestors júnior que canvien cada trimestre. Treballem amb un nombre limitat de clients perquè cada agència tingui seguiment sènior de veritat." },
  { question: "Quant trigaré a veure resultats?", answer: "Depèn del canal. Les campanyes de pagament poden generar leads de valoració la primera setmana, i el SEO consolida resultats entre el tercer i el dotzè mes." },
  { question: "Com mesureu els resultats?", answer: "En captacions, encàrrecs i vendes. Cada lead queda atribuït al seu canal i la seva campanya. A l'informe mensual veus quant has invertit, quants leads han arribat i què et costa cada captació." },
  { question: "Treballeu amb permanència?", answer: "No, treballem mes a mes. Si el servei no t'aporta valor, pots cancel·lar-lo quan vulguis. La nostra permanència real és el resultat que veus als informes cada mes." },
];

const pageSchema = localAgencySchema({
  pageUrl: `${SITE_URL}/ca/agencia-inmobiliarias/`,
  lang: 'ca',
  cityName: 'Barcelona',
  postalCode: '08035',
  geo: { lat: 41.4114, lng: 2.1526 },
  areaServed: ["España", "Barcelona", "Sabadell", "Sant Cugat del Vallès", "Terrassa", "Vallès Occidental"],
  title: "Agència de Màrqueting per a Immobiliàries | Capta Propietaris | Nova Marketing",
  description: "Agència de màrqueting especialitzada en immobiliàries. SEO, Google Ads, Meta Ads, email i disseny web per captar propietaris i compradors a la teva zona. Sense permanències.",
  datePublished: '2026-07-17',
  dateModified: '2026-07-17',
  streetAddress: 'Carrer del General Mendoza, 10',
  hasMap: 'https://maps.app.goo.gl/9fbB12UcK32bgjj89',
  aggregateRating: { ratingValue: '5.0', reviewCount: '8' },
  breadcrumbName: "Agència per a Immobiliàries",
  faqs,
});
---

<BaseLayout
  title="Agència de Màrqueting per a Immobiliàries | Capta Propietaris | Nova Marketing"
  description="Agència de màrqueting especialitzada en immobiliàries. SEO, Google Ads, Meta Ads, email i disseny web per captar propietaris i compradors a la teva zona. Sense permanències."
  locale="ca"
  alternates={alternates}
  schemas={[pageSchema]}
>

    <!-- ═══ HERO / H1 ═══════════════════════════════════════════════════════ -->
    <section class="pt-24 sm:pt-40 pb-20 px-4 sm:px-6 relative overflow-hidden text-center bg-white border-b border-black/5">
        <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808008_1px,transparent_1px),linear-gradient(to_bottom,#80808008_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_40%,#000_75%,transparent_100%)]"></div>
        <div class="absolute -top-10 left-1/4 w-72 h-72 bg-accent/15 rounded-full blur-3xl opacity-30 animate-pulse"></div>
        <div class="absolute top-20 right-1/4 w-80 h-80 bg-purple-500/5 rounded-full blur-3xl opacity-20"></div>

        <div class="max-w-5xl mx-auto reveal">
            <span class="inline-flex items-center gap-2 bg-accent/5 backdrop-blur-sm px-4 py-2 border border-accent/10 rounded-full text-accent text-[8px] sm:text-[10px] font-black uppercase tracking-[0.3em] mb-8 shadow-sm">
                <span class="w-1.5 h-1.5 bg-accent rounded-full animate-ping"></span>
                Màrqueting per a Immobiliàries
            </span>
            <h1 class="text-3xl sm:text-5xl md:text-7xl lg:text-8xl uppercase font-extrabold tracking-tighter leading-[0.88] mb-8 text-gradient flex flex-col items-center text-center">
                <span class="lg:whitespace-nowrap">Agència de Màrqueting </span>
                <span class="lg:whitespace-nowrap text-mktg-gradient">per a Immobiliàries</span>
            </h1>
            <p class="text-lg sm:text-xl text-zinc-500 font-light leading-relaxed w-[75%] mx-auto mb-8">
                Capta propietaris i compradors a la teva zona sense dependre dels portals. Màrqueting digital per a immobiliàries amb estratègia a mida i resultats que es mesuren en captacions i vendes.
            </p>
            <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3 mb-10">
                {['Sense permanències', 'Tracte directe amb el consultor', 'Resultats mesurats en captacions'].map(item => (
                    <span class="inline-flex items-center gap-2 text-[11px] sm:text-xs font-black uppercase tracking-widest text-zinc-700">
                        <svg class="w-4 h-4 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                        {item}
                    </span>
                ))}
            </div>
            <div class="flex justify-center mt-4">
                <a href="#contacto" class="contact-modal-trigger btn-mktg-v5 shadow-[0_10px_30px_rgba(0,0,0,0.1)] !py-4 sm:!py-5 !px-6 sm:!px-10 !text-[11px] !tracking-widest font-black">
                    PARLEM DE LA TEVA IMMOBILIÀRIA
                </a>
            </div>
        </div>
    </section>

    <LogoMarquee />

    <!-- ═══ INTRO ═══════════════════════════════════════════════════════ -->
    <section class="py-16 sm:py-24 bg-white px-4 sm:px-6 border-b border-black/5">
        <div class="max-w-6xl mx-auto reveal grid md:grid-cols-[1.3fr_1fr] gap-10 md:gap-16 items-center">
            <div>
                <p class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4">Per què una agència especialitzada?</p>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-8 text-zinc-900 leading-[0.9]">
                    L'agència de màrqueting per a la teva immobiliària
                </h2>
                <div class="space-y-6 text-zinc-600 font-light text-base sm:text-lg leading-relaxed">
                    <p>
                        <strong class="font-semibold text-zinc-900">A la teva zona hi ha propietaris decidint ara mateix a qui confiar el seu pis</strong>. Busquen a Google, pregunten a la IA i comparen agències des del mòbil. Qui apareix primer amb senyals de confiança s'emporta l'exclusiva.
                    </p>
                    <p>
                        Nova és una <strong class="font-semibold text-zinc-900">agència de màrqueting especialitzada en immobiliàries</strong>. Cada compte el porta directament el consultor fundador i tota l'estratègia s'orienta a una sola mètrica que importa. <strong class="font-semibold text-zinc-900">Quantes captacions i vendes genera el teu màrqueting cada mes</strong>.
                    </p>
                </div>
            </div>
            <div class="hidden md:block">
                <img src="/sergio-galos-agencia-inmobiliarias.webp" alt="Sergio Galo's, consultor de màrqueting per a immobiliàries" title="Sergio Galo's, consultor de màrqueting per a immobiliàries" class="w-full h-auto" loading="lazy" />
            </div>
        </div>
    </section>

    <!-- ═══ SERVEIS ═══════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-zinc-50 px-4 sm:px-6 border-t border-black/5">
        <div class="max-w-7xl mx-auto">
            <div class="text-center mb-14 sm:mb-20 reveal">
                <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Què fem</span>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.9]">
                    Serveis de Màrqueting Online per a Immobiliàries
                </h2>
                <p class="text-zinc-500 font-light text-sm sm:text-base leading-relaxed max-w-2xl mx-auto">
                    La captació immobiliària no depèn d'un sol canal, depèn d'un sistema on cada canal fa la seva feina. Aquestes són les sis peces que combinem segons el que necessiti la teva agència.
                </p>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 reveal text-left">
                <div class="service-card p-8 bg-white rounded-2xl border border-zinc-100/80 shadow-sm hover:shadow-2xl hover:-translate-y-2 hover:border-accent/10 transition-all duration-500 relative overflow-hidden flex flex-col justify-between">
                    <h3 class="text-xl font-black uppercase tracking-tighter mb-4 text-zinc-900">
                        <a href="/ca/agencia-inmobiliarias/seo/" class="hover:text-accent transition-colors">SEO Immobiliari</a>
                    </h3>
                    <p class="text-sm text-zinc-500 font-light leading-relaxed mb-4">Apareix quan algú busca vendre o comprar a la teva zona. Landings per barri i contingut que capta propietaris abans que els portals.</p>
                    <a href="/ca/agencia-inmobiliarias/seo/" class="text-[11px] font-black tracking-widest text-accent hover:underline">SABER MÉS →</a>
                </div>
                <div class="service-card p-8 bg-white rounded-2xl border border-zinc-100/80 shadow-sm hover:shadow-2xl hover:-translate-y-2 hover:border-accent/10 transition-all duration-500 relative overflow-hidden flex flex-col justify-between">
                    <h3 class="text-xl font-black uppercase tracking-tighter mb-4 text-zinc-900">
                        <a href="/ca/agencia-inmobiliarias/google-ads/" class="hover:text-accent transition-colors">Google Ads per a Immobiliàries</a>
                    </h3>
                    <p class="text-sm text-zinc-500 font-light leading-relaxed mb-4">Campanyes per a les cerques amb més intenció del sector, de la valoració de pis a la venda urgent. Leads amb nom i telèfon.</p>
                    <a href="/ca/agencia-inmobiliarias/google-ads/" class="text-[11px] font-black tracking-widest text-accent hover:underline">SABER MÉS →</a>
                </div>
                <div class="service-card p-8 bg-white rounded-2xl border border-zinc-100/80 shadow-sm hover:shadow-2xl hover:-translate-y-2 hover:border-accent/10 transition-all duration-500 relative overflow-hidden flex flex-col justify-between">
                    <h3 class="text-xl font-black uppercase tracking-tighter mb-4 text-zinc-900">
                        <a href="/ca/agencia-inmobiliarias/meta-ads/" class="hover:text-accent transition-colors">Meta Ads per a Immobiliàries</a>
                    </h3>
                    <p class="text-sm text-zinc-500 font-light leading-relaxed mb-4">Instagram i Facebook per captar propietaris que encara no busquen agència i donar sortida a les teves exclusives.</p>
                    <a href="/ca/agencia-inmobiliarias/meta-ads/" class="text-[11px] font-black tracking-widest text-accent hover:underline">SABER MÉS →</a>
                </div>
                <div class="service-card p-8 bg-white rounded-2xl border border-zinc-100/80 shadow-sm hover:shadow-2xl hover:-translate-y-2 hover:border-accent/10 transition-all duration-500 relative overflow-hidden flex flex-col justify-between">
                    <h3 class="text-xl font-black uppercase tracking-tighter mb-4 text-zinc-900">
                        <a href="/ca/agencia-inmobiliarias/email-marketing/" class="hover:text-accent transition-colors">Email Màrqueting Immobiliari</a>
                    </h3>
                    <p class="text-sm text-zinc-500 font-light leading-relaxed mb-4">Nurturing de compradors, seguiment de valoracions i demanda qualificada avisada de cada exclusiva nova.</p>
                    <a href="/ca/agencia-inmobiliarias/email-marketing/" class="text-[11px] font-black tracking-widest text-accent hover:underline">SABER MÉS →</a>
                </div>
                <div class="service-card p-8 bg-white rounded-2xl border border-zinc-100/80 shadow-sm hover:shadow-2xl hover:-translate-y-2 hover:border-accent/10 transition-all duration-500 relative overflow-hidden flex flex-col justify-between">
                    <h3 class="text-xl font-black uppercase tracking-tighter mb-4 text-zinc-900">
                        <a href="/ca/agencia-inmobiliarias/diseno-web/" class="hover:text-accent transition-colors">Disseny Web per a Immobiliàries</a>
                    </h3>
                    <p class="text-sm text-zinc-500 font-light leading-relaxed mb-4">Una web ràpida, adaptada a mòbil i pensada per convertir la visita en client. La base sobre la qual treballen tots els altres canals.</p>
                    <a href="/ca/agencia-inmobiliarias/diseno-web/" class="text-[11px] font-black tracking-widest text-accent hover:underline">SABER MÉS →</a>
                </div>
                <div class="service-card p-8 bg-white rounded-2xl border border-zinc-100/80 shadow-sm hover:shadow-2xl hover:-translate-y-2 hover:border-accent/10 transition-all duration-500 relative overflow-hidden flex flex-col justify-between">
                    <h3 class="text-xl font-black uppercase tracking-tighter mb-4 text-zinc-900">
                        <a href="/ca/agencia-inmobiliarias/posicionamiento-geo/" class="hover:text-accent transition-colors">GEO i Visibilitat en IA</a>
                    </h3>
                    <p class="text-sm text-zinc-500 font-light leading-relaxed mb-4">Quan algú pregunta a ChatGPT quina immobiliària li recomana a la teva zona, la resposta en recomana una o dues. Que siguis tu.</p>
                    <a href="/ca/agencia-inmobiliarias/posicionamiento-geo/" class="text-[11px] font-black tracking-widest text-accent hover:underline">SABER MÉS →</a>
                </div>
            </div>
            <div class="mt-12 text-center reveal">
                <a href="#contacto" class="contact-modal-trigger btn-mktg-v5 shadow-[0_10px_30px_rgba(37,211,102,0.3)] !py-4 sm:!py-5 !px-6 sm:!px-10 !text-[11px] !tracking-widest font-black">PARLEM DE LA TEVA IMMOBILIÀRIA</a>
            </div>
        </div>
    </section>

    <!-- ═══ ESTRATÈGIA ════════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-white px-4 sm:px-6 relative overflow-hidden">
        <div class="max-w-5xl mx-auto">
            <div class="text-center mb-16 sm:mb-24 reveal">
                <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Com treballem</span>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.9]">
                    Estratègies de màrqueting digital per a immobiliàries
                </h2>
                <p class="text-zinc-500 font-light text-sm sm:text-base leading-relaxed max-w-2xl mx-auto">
                    Una metodologia documentada per captar més exclusives i més compradors cada mes, pas a pas i sense fum.
                </p>
            </div>

            <div id="timeline-container" class="relative">
                <div class="hidden md:block absolute left-1/2 top-4 bottom-4 w-px bg-zinc-200 -translate-x-1/2"></div>
                <div id="progress-bar" class="hidden md:block absolute left-1/2 top-4 w-px bg-accent -translate-x-1/2 transition-all duration-100"></div>

                <div class="space-y-16 md:space-y-24 flex flex-col items-center">
                    {[
                        { title: "Diagnòstic de la Immobiliària", desc: "Analitzem la teva captació amb dades. D'on surten avui les teves exclusives i els teus compradors, quant et costa cada lead i quina dependència tens dels portals." },
                        { title: "Estratègia Documentada", desc: "Reps un pla per escrit. Quins canals activar, quina zona atacar, quin pressupost necessita cada campanya i quantes captacions és raonable esperar en 3, 6 i 12 mesos." },
                        { title: "Execució Multicanal", desc: "SEO per dominar la teva zona, Ads per al propietari que decideix avui, xarxes per al que decidirà demà i email per tancar. Cada canal amb la seva funció." },
                        { title: "Mesura Sense Fum", desc: "Mesurem captacions, encàrrecs i vendes, no visites. Cada lead queda atribuït al seu canal i la seva campanya a l'informe mensual." },
                        { title: "Optimització Contínua", desc: "Revisem cada setmana campanyes i conversió, tallem el que no porta leads i reinvertim en el que capta. Mes a mes, el compte millora o s'explica per què." },
                    ].map((step, index) => (
                        <div class="flex flex-col md:flex-row items-center gap-6 md:gap-12 w-full relative reveal">
                            <div class:list={["flex-1 w-full", index % 2 === 0 ? "md:order-1 md:text-right" : "md:order-3 md:text-left"]}>
                                <div class="p-8 sm:p-10 bg-zinc-50 border border-black/5 rounded-3xl hover:border-accent/10 hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 relative overflow-hidden group">
                                    <h3 class="text-xl font-black uppercase tracking-tighter mb-2 text-zinc-900">{index + 1}. {step.title}</h3>
                                    <div class:list={["h-0.5 bg-accent w-full mb-4 opacity-80", index % 2 === 0 ? "md:ml-auto" : ""]}></div>
                                    <p class:list={["text-sm text-zinc-500 font-light max-w-md", index % 2 === 0 ? "md:ml-auto" : ""]}>{step.desc}</p>
                                    <div class="absolute -bottom-6 -right-5 text-8xl font-black text-black/[0.02] select-none z-0 group-hover:scale-105 transition-transform duration-500">0{index+1}</div>
                                </div>
                            </div>
                            <div class="md:order-2 w-12 h-12 rounded-full border-2 border-zinc-200 bg-white flex items-center justify-center font-black text-lg z-10 shrink-0 shadow-sm node-circle transition-all">
                                0{index + 1}
                            </div>
                            <div class:list={["hidden md:block md:flex-1", index % 2 === 0 ? "md:order-3" : "md:order-1"]}></div>
                        </div>
                    ))}
                </div>
            </div>
        </div>
    </section>

    <!-- ═══ AUDITORIA ═════════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-zinc-50/50 px-4 sm:px-6 border-t border-black/5 overflow-hidden">
        <div class="max-w-7xl mx-auto grid lg:grid-cols-[6fr_4fr] gap-12 lg:gap-16 items-start">
            <div class="reveal lg:col-span-2">
                <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Punt de partida</span>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase text-zinc-900 leading-[0.9]">
                    Auditoria de màrqueting digital per a la teva immobiliària
                </h2>
            </div>
            <div class="reveal">
                <div class="space-y-5 text-zinc-600 font-light text-base leading-relaxed mb-8">
                    <p>Saps quant et costa avui cada captació? Quina part dels teus encàrrecs arriba pel teu màrqueting i quina part depèn dels portals? Gairebé cap agència ho sap amb dades, i aquí comença tot.</p>
                    <p>La nostra <strong class="font-semibold text-zinc-900">auditoria de màrqueting immobiliari</strong> revisa la teva web, les teves campanyes i la teva competència amb una sola pregunta al cap. D'on sortiran les teves properes exclusives. I acaba amb un pla d'acció prioritzat per impacte.</p>
                    <p>Cada punt el revisa un consultor sènior amb experiència al sector. El resultat és un diagnòstic de negoci que entén qualsevol gerent d'agència.</p>
                </div>
                <ul class="space-y-3">
                    {["Visibilitat a les cerques de la teva zona","Cost real de cada lead per canal","Conversió de la teva web i el teu valorador","Dependència actual dels portals","Presència davant propietaris que encara no busquen","Pla d'acció prioritzat per captacions"].map(item => (
                        <li class="flex items-start gap-3 text-sm text-zinc-700 font-light">
                            <svg class="w-4 h-4 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                            {item}
                        </li>
                    ))}
                </ul>
                <div class="mt-16">
                    <a href="#contacto" class="contact-modal-trigger btn-mktg-v5 shadow-[0_10px_30px_rgba(37,211,102,0.3)] !py-4 sm:!py-5 !px-6 sm:!px-10 !text-[11px] !tracking-widest font-black">
                        VULL LA MEVA AUDITORIA IMMOBILIÀRIA
                    </a>
                </div>
            </div>
            <div class="reveal flex flex-col gap-4">
                {[
                    { bg: 'bg-purple-100', color: 'text-purple-600', t: "Anàlisi de la teva captació", d: "D'on surten avui les teves exclusives i compradors, amb dades. La foto real abans d'invertir un euro més." },
                    { bg: 'bg-green-100', color: 'text-green-600', t: "Pla d'acció prioritzat", d: "Un pla ordenat per impacte en captacions i esforç. Sabràs què activar la primera setmana." },
                    { bg: 'bg-purple-100', color: 'text-purple-600', t: "Enfocament en el propietari", d: "La captació d'exclusives mana. Analitzem com arribes avui al propietari i com arribar-hi abans que la teva competència." },
                    { bg: 'bg-amber-100', color: 'text-amber-600', t: "Auditoria de campanyes", d: "Si ja inverteixes a Google o Meta, revisem quina part porta leads reals i quina es perd en clics curiosos." },
                    { bg: 'bg-blue-100', color: 'text-blue-600', t: "Benchmark de la teva zona", d: "Comparem la teva visibilitat amb les tres agències que més capten a la teva zona." },
                ].map(card => (
                    <div class="bg-white rounded-2xl shadow-[0_15px_40px_rgba(0,0,0,0.08)] p-5 flex items-start gap-4">
                        <div class:list={["w-11 h-11 rounded-full flex items-center justify-center flex-shrink-0", card.bg]}>
