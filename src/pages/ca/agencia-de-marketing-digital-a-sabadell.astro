---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { buildAlternates } from '../../lib/i18n';
import { localAgencySchema } from '../../lib/schema';
import LogoMarquee from '../../components/sections/LogoMarquee.astro';
import FaqHome from '../../components/sections/FaqHome.astro';
import GoogleReviews from '../../components/global/GoogleReviews.astro';

const SITE_URL = import.meta.env.PUBLIC_SITE_URL || 'https://novamarketing.es';
const alternates = buildAlternates('/agencia-de-marketing-digital-en-sabadell/', '/ca/agencia-de-marketing-digital-a-sabadell/', SITE_URL);

const steps = [
  { title: "Diagnòstic Local", desc: "Auditem la teva web, la teva visibilitat actual i la teva competència directa a Sabadell i l'àrea metropolitana. Detectem fugues de trànsit, keywords rendibles sense explotar i oportunitats de venda que la teva competència ja està capturant." },
  { title: "Estratègia Documentada", desc: "Reps un full de ruta per escrit: quins canals fer servir, quines keywords atacar, quina inversió necessita cada fase i quins resultats esperar en 3, 6 i 12 mesos. Saps en què s'inverteix cada euro abans d'invertir-lo." },
  { title: "Execució Multicanal", desc: "Coordinem SEO, Google Ads, continguts i analítica perquè la inversió generi leads de qualitat des del primer mes. Ads accelera el curt termini mentre el SEO construeix el teu actiu a mitjà termini." },
  { title: "Mesura Sense Fum", desc: "Configurem l'analítica per atribuir cada lead al seu canal. A l'informe mensual veuràs trucades, formularis i vendes generades, no mètriques de vanitat. Reunió mensual amb el consultor per revisar números." },
  { title: "Optimització Contínua", desc: "Espremem cada euro adaptant campanyes i continguts als pics de demanda de Sabadell: estacionalitat del sector, canvis d'algoritme i moviments de la teva competència." }
];

const districts = [
  { title: "Centre i la Rambla", desc: "El cor comercial de Sabadell: botigues, clíniques i despatxos competint per les mateixes cerques locals. Aquí el posicionament es guanya amb una fitxa de Google Business Profile impecable, ressenyes gestionades i SEO local quirúrgic." },
  { title: "Creu Alta, Gràcia i Ca n'Oriac", desc: "Barris de negoci de proximitat on el client busca \"a prop meu\" des del mòbil. Treballem el pack local complet: fitxa optimitzada, landings per zona i anuncis geolocalitzats a pocs minuts del teu local." },
  { title: "Polígons industrials de Sabadell", desc: "Can Roqueta, Sant Pau de Riu-sec i la resta de polígons concentren la indústria B2B de la ciutat. Els seus clients també busquen proveïdors a Google: posicionem keywords tècniques que porten pressupostos, no visites." },
];

const criteria = [
  { title: "Demana casos d'èxit verificables a Sabadell", desc: "Un mur de logos no demostra res. Demana casos de negocis de Sabadell amb dades concretes: quina keyword local, quina posició va assolir, en quant de temps i amb quina inversió. Una agència que treballa el mercat de Sabadell hauria de poder ensenyar-te resultats a la teva ciutat, o fins i tot al teu sector. Si no poden ensenyar-te'n ni un, segueix buscant." },
  { title: "Pregunta qui portarà el teu compte", desc: "En moltes agències de Sabadell ven un director i executa un júnior amb 30 comptes. Exigeix conèixer la persona que treballarà el teu projecte abans de signar, i pregunta si podràs reunir-te amb ella cara a cara: a nova les reunions amb clients de Sabadell i el Vallès Occidental poden ser presencials." },
  { title: "Exigeix la propietat dels teus actius", desc: "La web, el compte de Google Ads, la fitxa de Google Business Profile i l'analítica han d'estar al teu nom. És més habitual del que sembla: pimes de Sabadell que porten anys pagant i descobreixen en voler canviar d'agència que no són propietàries ni del seu propi domini. Si l'agència reté els teus actius, no estàs contractant un servei: estàs signant una dependència." },
  { title: "Desconfia de qui garanteix la posició 1 a Google a Sabadell", desc: "Ningú pot garantir la posició 1 a Google, i menys en un mercat tan disputat com el de Sabadell, on cada keyword local la lluiten desenes de competidors. Qui ho promet, o menteix o fa servir tècniques que acabaran penalitzant la teva web. El que és seriós és garantir mètode, transparència i feina verificable." },
  { title: "Revisa què mesura l'informe mensual", desc: "Si l'informe parla d'impressions i abast però no de trucades, formularis i vendes de clients de Sabadell, l'agència està mesurant la seva activitat, no el teu negoci. El posicionament local a Sabadell es mesura en visites a la teva fitxa, rutes al teu local i pressupostos sol·licitats, no en likes." },
  { title: "Fuig de les agències de marketing amb permanències llargues", desc: "Una permanència de 12 mesos protegeix l'agència, no a tu. Amb tanta oferta d'agències de marketing digital a l'abast, la feina ben feta reté clients sense necessitat de contractes que els lliguin. Per això a nova treballem mes a mes." },
  { title: "Coneixement del negoci local", desc: "No és el mateix posicionar una clínica del centre que una indústria del polígon o un ecommerce que ven a tota Espanya. Una agència que coneix el mercat de Sabadell sap què busca el client de cada zona, quina competència hi ha a cada sector i quines keywords locals converteixen. Pregunta què sap l'agència del teu barri, del teu sector i del teu client abans de signar." }
];

const sectors = [
  { icon: '🛒', title: 'Agència de marketing per a ecommerce', desc: "Arquitectura de categories, fitxes optimitzades, feed de Shopping i CRO. El SEO de producte i les campanyes ben estructurades es retroalimenten per vendre més." },
  { icon: '🏠', title: 'Agència de marketing per a immobiliàries', desc: "Captació de propietaris i compradors en un mercat caríssim. Landings per zona, SEO local per barri i campanyes que filtren curiosos de clients reals." },
  { icon: '🍽️', title: 'Agència de marketing per a restaurants', desc: "Aquí mana la fitxa de Google i les ressenyes. Treballem el pack local complet perquè apareguis quan algú busca on menjar a prop, i omplir taules entre setmana." },
  { icon: '🧠', title: 'Agència de marketing per a psicòlegs', desc: "El pacient busca confiança abans que preu. Contingut amb autoritat clínica, SEO local per especialitat i campanyes discretes que respecten la sensibilitat del sector." },
  { icon: '🌿', title: 'Agència de marketing per a terapeutes', desc: "Un sector amb molta competència genèrica i poca especialitzada. Posicionem la teva consulta per teràpia i zona, amb contingut que educa i converteix visites en primeres sessions." },
  { icon: '🦷', title: 'Agència de marketing per a dentistes', desc: "Sector saturat a Sabadell i amb alta exigència d'E-E-A-T. Guanyen els qui combinen SEO local impecable, ressenyes gestionades i contingut clínic amb autoritat real." },
  { icon: '💪', title: 'Agència de marketing per a gimnasos', desc: "Captació estacional amb pics al gener i al setembre. Campanyes geolocalitzades a pocs minuts del centre, ofertes de prova i retenció mesurada amb dades." },
  { icon: '🏗️', title: 'Agència de marketing per a constructores', desc: "Competència local ferotge i leads de valor alt. El pack guanyador és fitxa de Google impecable, landings per zona i campanyes geolocalitzades que porten pressupostos, no visites." },
  { icon: '⚖️', title: 'Agència de marketing per a advocats', desc: "Cerques d'altíssima intenció i CPCs dels més cars de Google. La clau està a captar la consulta amb contingut que resol el dubte legal concret abans que la competència." },
  { icon: '🏨', title: 'Agència de marketing per a hotels', desc: "Reduir la dependència de les OTAs és l'objectiu: SEO per a reserva directa, fitxa optimitzada, campanyes de marca i estratègia de preus visible a Google Hotels." },
  { icon: '🏭', title: 'Agència de marketing per a B2B', desc: "Cicles de venda llargs i pocs decisors. Aquí no importa el volum: importa aparèixer a les deu cerques tècniques que fa el responsable de compres." },
  { icon: '🎓', title: 'Agència de marketing per a escoles', desc: "Captació estacional amb pics clars. L'estratègia combina contingut informacional tot l'any amb inversió agressiva a la finestra de matriculació." },
];

const faqs = [
  { question: "Quant costa una agència de marketing digital a Sabadell?", answer: "Depèn molt dels serveis que necessitis i de si és un projecte puntual o una feina recurrent. No costa el mateix una auditoria o el llançament d'una web que una estratègia mensual de posicionament i captació. Per això a nova no treballem amb tarifes genèriques sinó amb pressupostos tancats a mida: abans de signar saps exactament què es fa, qui ho fa i quin resultat es persegueix." },
  { question: "Què inclou una estratègia de marketing digital per a una pime a Sabadell?", answer: "Inclou una auditoria inicial, un full de ruta documentat i l'execució i mesura mensual de cada acció. Analitzem la teva situació actual i la teva competència a Sabadell, definim quins canals fer servir, quina inversió necessita cada fase i quins resultats esperar a 3, 6 i 12 mesos. No apliquem plantilles: cada sector i cada zona de Sabadell competeix de manera diferent." },
  { question: "Qui portarà el meu compte?", answer: "El teu compte el porta directament Sergio Galo's, consultor de marketing digital a Sabadell i fundador de Nova Marketing. Sense gestors júnior ni intermediaris: la persona que dissenya la teva estratègia és la mateixa que l'executa i la que et respon a la reunió mensual." },
  { question: "Quant trigaré a veure resultats?", answer: "Hi ha accions que generen clients en setmanes i d'altres que consoliden resultats entre el sisè i el dotzè mes. El termini exacte depèn del punt de partida del teu negoci i de la competència del teu sector a Sabadell. Al full de ruta inicial et diem què esperar a cada fase, amb terminis realistes i sense promeses de fum." },
  { question: "Com mesureu els resultats de l'estratègia?", answer: "Mesurem leads i vendes: cada trucada, formulari o comanda queda atribuïda al seu canal d'origen. Configurem l'analítica des del primer dia i a l'informe mensual veus resultats de negoci, no mètriques de vanitat. A més tens accés total als teus comptes i eines: les dades són teves." },
  { question: "Treballeu amb permanència?", answer: "No, treballem mes a mes. Si el servei no t'aporta valor, pots cancel·lar-lo quan vulguis. La nostra permanència real és el resultat que veus als informes cada mes." },
  { question: "Ateneu només empreses de Sabadell?", answer: "No: la nostra seu és a Barcelona i treballem a tot el Vallès Occidental i la seva àrea d'influència. Amb clients de Sabadell i la comarca les reunions poden ser presencials, i amb empreses de la resta d'Espanya treballem per videotrucada amb el mateix nivell de seguiment." }
];


const pageSchema = localAgencySchema({
  pageUrl: `${SITE_URL}/ca/agencia-de-marketing-digital-a-sabadell/`,
  lang: 'ca',
  cityName: 'Sabadell',
  postalCode: '08202',
  geo: { lat: 41.5463, lng: 2.1086 },
  areaServed: ['Sabadell', 'Terrassa', 'Sant Cugat del Vallès', 'Barcelona', 'Vallès Occidental'],
  title: "Marketing Digital a Sabadell | Nova Marketing",
  description: "Estratègies de creixement digital per a pimes a Sabadell. SEO, Google Ads i Disseny Web enfocats a captar clients i competir al mercat actual.",
  datePublished: '2025-06-09',
  dateModified: '2026-07-14',
  streetAddress: 'Carrer de Bilbao, 1',
  hasMap: 'https://maps.app.goo.gl/ETtzpajqEucNf22D7',
  aggregateRating: { ratingValue: '5.0', reviewCount: '16' },
  reviews: [
    { author: "Rosmelys Lopez", date: '2026-05-14', body: "Sinceramente estoy súper contenta con el trabajo que está haciendo Nova Marketing con el posicionamiento SEO y la página web de mi negocio ✨ Llevamos solo 3 meses y ya estoy notando resultados reales. Además, da gusto" },
    { author: "Belén Carrillo Comellas", date: '2025-08-14', body: "Gestiono redes sociales y necesitaba posicionarme en Google Sabadell y empezamos a trabajar en una estrategia seo. Dos o tres meses después ya empezamos a ver los resultados." },
    { author: "Javier Pelegrin del Bas", date: '2025-10-14', body: "Hemos trabajados el posicionamiento local en Google concepto BuzzMarketing y muy satisfied" },
    { author: "John Muñoz", date: '2025-07-14', body: "Excelente agencia de marketing. Los he contactado en varias ocasiones para asesoramiento y siempre han cumplido con mis expectativas. Profesionalismo, creatividad y compromiso en cada proyecto. Totalmente recomendados." },
    { author: "Lidia Monterrubio", date: '2025-07-14', body: "¡Muy muy buen servicio! Nos ayudó a realizar y hacer posible los proyectos que teníamos en mente para hacer crecer nuestro negocio. Un diez en asesoramiento y acompañamiento en todo el proceso." },
    { author: "Martin Garcia", date: '2025-07-14', body: "Llevamos la estrategia SEM y publicidad en redes sociales con ellos,desde hace varios meses y de momento, trato y resultados de 10" },
  ],
  faqs,
});

---

<BaseLayout
  title="Marketing Digital a Sabadell | Nova Marketing"
  description="Estratègies de creixement digital per a pimes a Sabadell. SEO, Google Ads i Disseny Web enfocats a captar clients i competir al mercat actual."
  locale="ca"
  alternates={alternates}
  schemas={[pageSchema]}
>

    <!-- ═══ HERO / H1 ═══════════════════════════════════════════════════════ -->
    <section class="pt-24 sm:pt-40 pb-20 px-4 sm:px-6 relative overflow-hidden text-center bg-white border-b border-black/5">
        <!-- Background Grid Mesh -->
        <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808008_1px,transparent_1px),linear-gradient(to_bottom,#80808008_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_40%,#000_75%,transparent_100%)]"></div>

        <!-- Glow Orbs -->
        <div class="absolute -top-10 left-1/4 w-72 h-72 bg-accent/15 rounded-full blur-3xl opacity-30 animate-pulse"></div>
        <div class="absolute top-20 right-1/4 w-80 h-80 bg-purple-500/5 rounded-full blur-3xl opacity-20"></div>

        <div class="max-w-5xl mx-auto reveal">
            <span class="inline-flex items-center gap-2 bg-accent/5 backdrop-blur-sm px-4 py-2 border border-accent/10 rounded-full text-accent text-[8px] sm:text-[10px] font-black uppercase tracking-[0.3em] mb-8 shadow-sm">
                <span class="w-1.5 h-1.5 bg-accent rounded-full animate-ping"></span>
                Impuls Digital per a Pimes
            </span>
            <h1 class="text-3xl sm:text-5xl md:text-7xl lg:text-8xl uppercase font-extrabold tracking-tighter leading-[0.88] mb-8 text-gradient flex flex-col items-center text-center">
                <span class="lg:whitespace-nowrap">Agència de Marketing </span>
                <span class="lg:whitespace-nowrap">Digital a Sabadell</span>
            </h1>
            <p class="text-lg sm:text-xl text-zinc-500 font-light leading-relaxed w-[75%] mx-auto mb-8">
                A nova ajudem pimes i autònoms de Sabadell a captar clients amb SEO, Google Ads i disseny web. Estratègia a mida, preus clars i resultats que es mesuren en vendes.
            </p>
            <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3 mb-10">
                {['Sense permanències', 'Tracte directe amb el consultor', 'Informes de negoci'].map(item => (
                    <span class="inline-flex items-center gap-2 text-[11px] sm:text-xs font-black uppercase tracking-widest text-zinc-700">
                        <svg class="w-4 h-4 text-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                        </svg>
                        {item}
                    </span>
                ))}
            </div>
            <div class="flex justify-center mt-4">
                <a href="#contacto" class="contact-modal-trigger btn-mktg-v5 shadow-[0_10px_30px_rgba(0,0,0,0.1)] !py-4 sm:!py-5 !px-6 sm:!px-10 !text-[11px] !tracking-widest font-black">
                    PARLEM DEL TEU NEGOCI
                </a>
            </div>
        </div>
    </section>

    <LogoMarquee />

    <!-- ═══ INTRO: QUI SOM ═════════════════════════════════════════════════ -->
    <section class="py-16 sm:py-24 bg-white px-4 sm:px-6 border-b border-black/5">
        <div class="max-w-6xl mx-auto reveal grid md:grid-cols-[1.3fr_1fr] gap-10 md:gap-16 items-center">
            <div>
                <p class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4">Què és Nova?</p>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-8 text-zinc-900 leading-[0.9]">
                    L'agència de marketing digital per a la teva pime a Sabadell
                </h2>
                <div class="space-y-6 text-zinc-600 font-light text-base sm:text-lg leading-relaxed">
                    <p>
                        <strong class="font-semibold text-zinc-900">Nova Marketing és una agència de marketing digital especialitzada en pimes</strong> que opera a Sabadell i el Vallès Occidental, amb serveis de posicionament SEO, Google Ads, disseny web i consultoria de marketing.
                    </p>
                    <p>
                        El nostre enfocament és diferent: treballem amb un nombre limitat de clients, cada compte el porta directament el consultor fundador i tota l'estratègia s'orienta a una sola mètrica que importa: <strong class="font-semibold text-zinc-900">quants clients nous genera la teva inversió cada mes</strong>.
                    </p>
                </div>
            </div>
            <div class="hidden md:block">
                <img src="/consultor-marketing-digital.webp" alt="Sergio Galo's - Consultor de marketing digital a Sabadell" class="w-full h-auto" loading="lazy" />
            </div>
        </div>
    </section>

    <!-- ═══ SECCIÓ 1: SERVEIS ══════════════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-zinc-50 border-b border-black/5 px-4 sm:px-6">
        <div class="max-w-7xl mx-auto text-center reveal">
            <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Què fem</span>
            <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.9]">
                Serveis de Marketing Online a Sabadell
            </h2>
            <p class="text-zinc-500 font-light text-sm sm:text-base leading-relaxed max-w-2xl mx-auto mb-16">
                Quatre serveis, un mateix objectiu: que la teva empresa aparegui on busquen els teus clients a Sabadell i converteixi aquest trànsit en facturació.
            </p>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 text-left">
                <!-- SEO -->
                <div class="service-card p-8 bg-white rounded-2xl border border-zinc-100/80 shadow-sm hover:shadow-2xl hover:-translate-y-2 hover:border-accent/10 transition-all duration-500 relative overflow-hidden flex flex-col justify-between">
        <!-- Hover Gradient Overlay -->
        <div class="absolute inset-x-0 h-1 bottom-0 bg-gradient-to-r from-accent via-accent/90 to-purple-600 w-0 group-hover:w-full transition-all duration-500"></div>
                    <h3 class="text-xl font-black uppercase tracking-tighter mb-4 text-zinc-900">
                        <a href="/ca/agencia-seo-a-sabadell/" class="hover:text-accent transition-colors">Agència de Posicionament SEO a Sabadell</a>
                    </h3>
                    <p class="text-sm text-zinc-500 font-light leading-relaxed mb-4">
                        Apareix als primers resultats de Google quan els teus clients busquen els teus serveis a Sabadell. Optimitzem la teva fitxa de Google Business Profile, la teva web i els teus continguts per dominar les cerques locals del teu sector, des del centre fins a tota la comarca.
                    </p>
                    <a href="/ca/agencia-seo-a-sabadell/" class="text-[11px] font-black tracking-widest text-accent hover:underline">SABER MÉS →</a>
                </div>

                <!-- Google Ads -->
                <div class="service-card p-8 bg-white rounded-2xl border border-zinc-100/80 shadow-sm hover:shadow-2xl hover:-translate-y-2 hover:border-accent/10 transition-all duration-500 relative overflow-hidden flex flex-col justify-between">
        <!-- Hover Gradient Overlay -->
        <div class="absolute inset-x-0 h-1 bottom-0 bg-gradient-to-r from-accent via-accent/90 to-purple-600 w-0 group-hover:w-full transition-all duration-500"></div>
                    <h3 class="text-xl font-black uppercase tracking-tighter mb-4 text-zinc-900">
                        <a href="/ca/agencia-google-ads-sabadell/" class="hover:text-accent transition-colors">Agència de Google Ads a Sabadell</a>
                    </h3>
                    <p class="text-sm text-zinc-500 font-light leading-relaxed mb-4">
                        Anuncis hipersegmentats per captar clients des de la primera setmana. No llancis els diners en clics buits: dirigim les teves campanyes a usuaris de Sabadell amb intenció real de compra i optimitzem el CPC per maximitzar el retorn de cada euro invertit.
                    </p>
                    <a href="/ca/agencia-google-ads-sabadell/" class="text-[11px] font-black tracking-widest text-accent hover:underline">SABER MÉS →</a>
                </div>

                <!-- Disseny Web -->
                <div class="service-card p-8 bg-white rounded-2xl border border-zinc-100/80 shadow-sm hover:shadow-2xl hover:-translate-y-2 hover:border-accent/10 transition-all duration-500 relative overflow-hidden flex flex-col justify-between">
        <!-- Hover Gradient Overlay -->
        <div class="absolute inset-x-0 h-1 bottom-0 bg-gradient-to-r from-accent via-accent/90 to-purple-600 w-0 group-hover:w-full transition-all duration-500"></div>
                    <h3 class="text-xl font-black uppercase tracking-tighter mb-4 text-zinc-900">
                        <a href="/ca/agencia-disseny-web-sabadell/" class="hover:text-accent transition-colors">Agència de Disseny Web a Sabadell</a>
                    </h3>
                    <p class="text-sm text-zinc-500 font-light leading-relaxed mb-4">
                        Dissenyem l'aparador digital 24/7 que la teva empresa necessita: pàgines web ultraràpides, adaptades a mòbil i 100% enfocades a la conversió, amb l'autoritat que exigeix un mercat tan exigent com el del Vallès.
                    </p>
                    <a href="/ca/agencia-disseny-web-sabadell/" class="text-[11px] font-black tracking-widest text-accent hover:underline">SABER MÉS →</a>
                </div>

                <!-- Consultoria -->
                <div class="service-card p-8 bg-white rounded-2xl border border-zinc-100/80 shadow-sm hover:shadow-2xl hover:-translate-y-2 hover:border-accent/10 transition-all duration-500 relative overflow-hidden flex flex-col justify-between">
        <!-- Hover Gradient Overlay -->
        <div class="absolute inset-x-0 h-1 bottom-0 bg-gradient-to-r from-accent via-accent/90 to-purple-600 w-0 group-hover:w-full transition-all duration-500"></div>
                    <h3 class="text-xl font-black uppercase tracking-tighter mb-4 text-zinc-900">
                        <a href="/ca/consultoria-marketing-digital-sabadell/" class="hover:text-accent transition-colors">Consultoria de Marketing a Sabadell</a>
                    </h3>
                    <p class="text-sm text-zinc-500 font-light leading-relaxed mb-4">
                        El teu marketing no dona resultats? Auditem els teus processos de captació, detectem on es perd el pressupost i tracem un full de ruta amb embuts de venda sòlids per escalar el teu negoci a Sabadell.
                    </p>
                    <a href="/ca/consultoria-marketing-digital-sabadell/" class="text-[11px] font-black tracking-widest text-accent hover:underline">SABER MÉS →</a>
                </div>
            </div>
        </div>
    </section>

    <!-- ═══ SECCIÓ 2: COM TREBALLEM ═══════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-white px-4 sm:px-6 relative overflow-hidden">
        <div class="max-w-5xl mx-auto">
            <div class="text-center mb-16 sm:mb-24 reveal">
