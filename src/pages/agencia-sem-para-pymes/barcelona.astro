---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { buildAlternates } from '../../lib/i18n';
import { localAgencySchema } from '../../lib/schema';
import { strapiClient } from '../../lib/strapi';
import LogoMarquee from '../../components/sections/LogoMarquee.astro';
import FaqHome from '../../components/sections/FaqHome.astro';
import CityPills from '../../components/global/CityPills.astro';
import GoogleReviews from '../../components/global/GoogleReviews.astro';

const SITE_URL = import.meta.env.PUBLIC_SITE_URL || 'https://novamarketing.es';
const alternates = buildAlternates('/agencia-sem-para-pymes/barcelona/', '/ca/agencia-sem-per-pimes/barcelona/', SITE_URL);

let allCases: any[] = [];
try {
  const casesRes = await strapiClient.getCaseStudies('es');
  allCases = casesRes.data.map((i: any) => i.attributes ?? i).filter((c: any) => {
    const cats = (c.categories || []).map((cat: any) => (cat.slug || cat.attributes?.slug || '').toLowerCase());
    return cats.some((s: string) => s.includes('google-ads'));
  });
} catch {}

const steps = [
  { title: "Auditoría de tu cuenta y del mercado barcelonés", desc: "Analizamos tu cuenta de Google Ads si ya tienes una, tu web y lo que hace tu competencia en los anuncios. Detectamos presupuesto desperdiciado, búsquedas que no convierten y oportunidades que nadie está pujando. Ese es tu punto de partida real." },
  { title: "Estrategia para un mercado disputado", desc: "Recibes un plan por escrito. Qué campañas lanzar, qué búsquedas atacar, qué presupuesto necesitas y qué coste por cliente es razonable en tu sector. Sabes en qué se invierte cada euro antes de invertirlo." },
  { title: "Estructura, anuncios y landings", desc: "Montamos las campañas con una estructura limpia, redactamos anuncios que responden a lo que busca tu cliente y preparamos la página de destino para convertir ese clic en un contacto. El anuncio trae la visita, la landing cierra el lead." },
  { title: "Optimización de pujas por distrito", desc: "Revisamos las campañas cada semana. Cortamos las búsquedas que gastan sin vender, subimos la puja donde hay negocio y ajustamos horarios, zonas y dispositivos para que cada euro trabaje donde convierte." },
  { title: "Medición frente a la competencia", desc: "Monitorizamos mes a mes tus leads, tu coste por contacto y tu retorno. En el informe ves cuántos clientes llegan desde los anuncios, cuánto cuesta cada uno y qué campañas merecen más presupuesto el mes siguiente." }
];

const criteria = [
  { title: "Pide casos de éxito verificables", desc: "Un muro de logos no demuestra nada. Pide casos con datos concretos. Qué inversión, qué coste por lead, cuántos clientes generó y en cuánto tiempo. Una agencia de Google Ads seria debería poder enseñarte resultados de negocios como el tuyo. Si no pueden enseñarte ni uno, sigue buscando." },
  { title: "Pregunta quién llevará tu cuenta", desc: "En muchas agencias vende un director y ejecuta un junior con 30 cuentas. Exige conocer a la persona que gestionará tus campañas antes de firmar. En nova hablas siempre con el consultor que optimiza tu cuenta, presencialmente o por videollamada." },
  { title: "Exige que la cuenta de Google Ads sea tuya", desc: "La cuenta, el historial de datos y el píxel de conversión deben estar a tu nombre. Muchas agencias crean la cuenta bajo su propiedad y al irte pierdes todo el aprendizaje acumulado y empiezas de cero. Eso no es un servicio, es un secuestro de datos." },
  { title: "Desconfía de quien cobra un porcentaje opaco de tu inversión", desc: "Si la agencia gana más cuanto más gastas, su incentivo es que gastes más, no que vendas más. Exige saber exactamente cuánto pagas de gestión y cuánto va a Google. En nova el fee es fijo y el cien por cien de tu presupuesto publicitario va a tus anuncios." },
  { title: "Revisa qué mide el informe mensual", desc: "Si el informe habla de impresiones y clics pero no de llamadas, formularios y ventas, la agencia está midiendo su actividad y no tu negocio. Las campañas de una pyme se miden en clientes nuevos y en lo que cuesta conseguir cada uno." },
  { title: "Huye de las permanencias largas", desc: "Una permanencia de 12 meses protege a la agencia, no a ti. En Google Ads los resultados se ven en semanas, así que no hay excusa para atarte un año. Por eso en nova trabajamos mes a mes." },
  { title: "Que no dependa todo de pagar", desc: "Google Ads trae clientes desde el primer día, pero cuando paras la inversión paran los leads. Una buena agencia te ayuda a usar los datos de las campañas para construir también SEO y visibilidad en la IA. Nosotros integramos los tres canales en una sola estrategia." }
];

const faqs = [
  { question: "¿Cuánto cuesta una agencia de Google Ads en Barcelona?", answer: "La auditoría de tu cuenta cuesta 900 euros y la gestión mensual empieza en 150 euros al mes con fee fijo, sin porcentajes sobre tu inversión. En los sectores más competidos de Barcelona el presupuesto publicitario necesario es mayor, y en la auditoría te decimos la cifra realista para el tuyo. Presupuesto cerrado por escrito." },
  { question: "¿Puede una pyme competir en Google Ads con las grandes de Barcelona?", answer: "Sí, siendo más precisa. Las grandes marcas pujan por todo y desperdician mucho. Una pyme puede dominar las búsquedas de su nicho y su distrito con una estructura quirúrgica, negativas bien trabajadas y landings específicas. Ahí el tamaño del presupuesto importa menos que la puntería." },
  { question: "¿Las campañas se segmentan por distrito?", answer: "Cuando tiene sentido, sí. Las búsquedas del Eixample no son las de Gràcia ni las del 22@, y los CPCs tampoco. Ajustamos zonas, pujas y anuncios a la parte de la ciudad donde está tu cliente para no pagar clics que nunca comprarán." },
  { question: "¿Cuánto tarda Google Ads en dar resultados en Barcelona?", answer: "Los anuncios pueden estar activos en días y los primeros leads suelen llegar las primeras semanas. En los sectores más competidos de la ciudad, el algoritmo necesita entre uno y dos meses de datos para afinar el coste por cliente. Te lo decimos con plazos realistas en la hoja de ruta." },
  { question: "¿La cuenta de Google Ads será mía?", answer: "Sí, siempre. La cuenta, el historial, las conversiones y las audiencias quedan a tu nombre desde el primer día. Si algún día dejas de trabajar con nosotros, te llevas todo el aprendizaje acumulado." },
  { question: "¿Cómo medís los resultados?", answer: "Medimos leads y ventas, no clics. Llamadas, formularios y presupuestos solicitados, cada uno atribuido a su campaña y su búsqueda. Informe mensual de negocio con reunión incluida y acceso total a tus cuentas." },
  { question: "¿Trabajáis con permanencia?", answer: "No, trabajamos mes a mes. Si el servicio no te aporta valor, puedes cancelarlo cuando quieras. Nuestra permanencia real es el resultado que ves en los informes cada mes." },
];

const sectors = [
  { icon: '🛒', title: 'Google Ads para ecommerce', href: '/agencia-ecommerce/google-ads/', desc: 'Shopping y Performance Max con feed optimizado. Que tu producto salga con foto y precio justo cuando alguien busca comprarlo.' },
  { icon: '🏠', title: 'Google Ads para inmobiliarias', href: '/agencia-inmobiliarias/google-ads/', desc: 'Captación de propietarios y compradores con campañas por zona y anuncios que filtran curiosos antes del clic.' },
  { icon: '🍽️', title: 'Google Ads para restaurantes', href: '/agencia-restaurantes/google-ads/', desc: 'Campañas locales que aparecen cuando alguien busca dónde comer cerca, conectadas con tu ficha de Google y las reservas.' },
  { icon: '🧠', title: 'Google Ads para psicólogos', desc: 'El paciente busca ayuda con urgencia y elige entre lo primero que ve. Anuncios por especialidad que convierten búsquedas en primeras visitas.' },
  { icon: '🌿', title: 'Google Ads para terapeutas', desc: 'Clics caros si compites en genérico. Campañas por terapia y zona que pagan solo por las búsquedas que traen pacientes.' },
  { icon: '🦷', title: 'Google Ads para dentistas', desc: 'Uno de los CPCs más caros del mercado. Aquí gana quien mejor filtra las búsquedas y mejor convierte la landing, no quien más gasta.' },
  { icon: '💪', title: 'Google Ads para gimnasios', desc: 'Campañas estacionales con picos en enero y septiembre. Promociones locales que llenan clases sin quemar presupuesto el resto del año.' },
  { icon: '🏗️', title: 'Google Ads para constructoras', desc: 'Leads de valor alto y mucha competencia local. Campañas por servicio y zona con anuncios que traen presupuestos, no curiosos.' },
  { icon: '⚖️', title: 'Google Ads para abogados', desc: 'Búsquedas de altísima intención con los clics más caros de Google. Estructura quirúrgica para pagar solo por los casos que te interesan.' },
  { icon: '🏨', title: 'Google Ads para hoteles', desc: 'Campañas de marca para frenar a las OTAs y captar la reserva directa, más visibilidad en Google Hotels.' },
  { icon: '🏭', title: 'Google Ads para B2B', desc: 'Pocos decisores y ciclos largos. Campañas de búsqueda técnica y remarketing que acompañan al responsable de compras hasta el contacto.' },
  { icon: '🎓', title: 'Google Ads para escuelas', desc: 'Captación concentrada en la ventana de matriculación. Campañas que aprietan cuando las familias deciden y descansan el resto del año.' },
];

const pageSchema = localAgencySchema({
  pageUrl: `${SITE_URL}/agencia-sem-para-pymes/barcelona/`,
  lang: 'es',
  cityName: 'Barcelona',
  postalCode: '08035',
  geo: { lat: 41.4114, lng: 2.1526 },
  areaServed: ["Barcelona", "Vallès Occidental", "Barcelona", "España"],
  title: "▷ Google Ads para PYMEs en Barcelona | Campañas con fee fijo",
  description: "Agencia experta en Google Ads en Barcelona para PYMEs con fee fijo ✅ Cuenta a nombre del cliente y resultados medidos en leads y ventas 💡",
  datePublished: '2026-07-15',
  dateModified: '2026-07-15',
  streetAddress: 'Carrer del General Mendoza, 10',
  hasMap: 'https://maps.app.goo.gl/9fbB12UcK32bgjj89',
  aggregateRating: { ratingValue: '5.0', reviewCount: '12' },
  breadcrumbName: 'Agencia de Google Ads en Barcelona',
  faqs,
});
---

<BaseLayout
  title="▷ Google Ads para PYMEs en Barcelona | Campañas con fee fijo"
  description="Agencia experta en Google Ads en Barcelona para PYMEs con fee fijo ✅ Cuenta a nombre del cliente y resultados medidos en leads y ventas 💡"
  locale="es"
  alternates={alternates}
  schemas={[pageSchema]}
>

    <!-- ═══ HERO / H1 ═══════════════════════════════════════════════════════ -->
    <section class="pt-24 sm:pt-40 pb-20 px-4 sm:px-6 relative overflow-hidden text-center bg-white border-b border-black/5">
        <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808008_1px,transparent_1px),linear-gradient(to_bottom,#80808008_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_40%,#000_75%,transparent_100%)]"></div>
        <div class="absolute -top-10 left-1/4 w-72 h-72 bg-accent/15 rounded-full blur-3xl opacity-30 animate-pulse"></div>
        <div class="absolute top-20 right-1/4 w-80 h-80 bg-purple-500/5 rounded-full blur-3xl opacity-20"></div>

        <div class="max-w-5xl mx-auto reveal">
            <span class="inline-flex items-center gap-2 bg-accent/5 backdrop-blur-sm px-4 py-2 border border-accent/10 rounded-full text-accent text-[8px] sm:text-[10px] font-black uppercase tracking-[0.3em] mb-8 shadow-sm">
                <span class="w-1.5 h-1.5 bg-accent rounded-full animate-ping"></span>
                Publicidad en Google para Pymes
            </span>
            <h1 class="text-3xl sm:text-5xl md:text-7xl lg:text-8xl uppercase font-extrabold tracking-tighter leading-[0.88] mb-8 text-gradient flex flex-col items-center text-center">
                <span class="lg:whitespace-nowrap">Agencia SEM </span>
                <span class="lg:whitespace-nowrap text-mktg-gradient">en Barcelona</span>
            </h1>
            <p class="text-lg sm:text-xl text-zinc-500 font-light leading-relaxed w-[75%] mx-auto mb-8">
                Aparece hoy mismo cuando tus clientes buscan tu servicio en Google. Campañas de Google Ads para PYMEs de Barcelona con fee fijo, la cuenta a tu nombre y resultados que se miden en ventas.
            </p>
            <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3 mb-10">
                {['Sin permanencias', 'Fee fijo sin porcentajes', 'La cuenta es tuya'].map(item => (
                    <span class="inline-flex items-center gap-2 text-[11px] sm:text-xs font-black uppercase tracking-widest text-zinc-700">
                        <svg class="w-4 h-4 text-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                        </svg>
                        {item}
                    </span>
                ))}
            </div>
            <div class="flex justify-center mt-4">
                <a href="#contacto" class="contact-modal-trigger btn-mktg-v5 shadow-[0_10px_30px_rgba(0,0,0,0.1)] !py-4 sm:!py-5 !px-6 sm:!px-10 !text-[11px] !tracking-widest font-black">
                    HABLEMOS DE TU NEGOCIO
                </a>
            </div>
        </div>
    </section>

    <LogoMarquee />

    <!-- ═══ INTRO: POR QUÉ GOOGLE ADS ═════════════════════════════════════ -->
    <section class="py-16 sm:py-24 bg-white px-4 sm:px-6 border-b border-black/5">
        <div class="max-w-6xl mx-auto reveal grid md:grid-cols-[1.3fr_1fr] gap-10 md:gap-16 items-center">
            <div>
                <p class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4">¿Por qué Google Ads?</p>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-8 text-zinc-900 leading-[0.9]">
                    La agencia de Google Ads para tu pyme en Barcelona
                </h2>
                <div class="space-y-6 text-zinc-600 font-light text-base sm:text-lg leading-relaxed">
                    <p>
                        <strong class="font-semibold text-zinc-900">Google Ads es el canal más rápido para conseguir clientes</strong>. Mientras el SEO tarda meses en posicionar, un anuncio bien montado aparece hoy delante de quien está buscando tu servicio con la cartera en la mano. La cuestión no es si funciona, es cuánto pagas por cada clic y qué haces con él.
                    </p>
                    <p>
                        Nova es una <strong class="font-semibold text-zinc-900">agencia SEM especializada en PYMEs</strong> que trabaja con negocios de Barcelona y toda su comarca. Trabajamos con un número limitado de clientes, cada cuenta la lleva directamente el consultor fundador y toda la gestión se orienta a una sola métrica que importa. <strong class="font-semibold text-zinc-900">Cuánto te cuesta conseguir cada cliente nuevo desde los anuncios</strong>.
                    </p>
                </div>
            </div>
            <div class="hidden md:block">
                <img src="/sergio-galos-agencia-sem-para-pymes-barcelona.webp" alt="Sergio Galo's, consultor de Google Ads para PYMEs en Barcelona" title="Sergio Galo's, consultor de Google Ads para PYMEs en Barcelona" class="w-full h-auto" loading="lazy" width="473" height="591" />
            </div>
        </div>
    </section>

    <!-- ═══ SERVICIOS SEM ══════════════════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-zinc-50 border-b border-black/5 px-4 sm:px-6">
        <div class="max-w-7xl mx-auto text-center reveal">
            <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Qué hacemos</span>
            <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.9]">
                Servicio de Google Ads para PYMEs en Barcelona
            </h2>
            <div class="text-zinc-500 font-light text-sm sm:text-base leading-relaxed max-w-3xl mx-auto mb-16 space-y-4">
                <p>
                    Gestionar <strong class="font-semibold text-zinc-700">Google Ads</strong> no es activar una campaña y dejarla correr, es un sistema. Estas son las nueve piezas que trabajamos para que cada euro de tu presupuesto vuelva convertido en clientes.
                </p>
                <p>
                    Cada pieza se activa según lo que diga tu auditoría. No pagas por un paquete cerrado de acciones, pagas por las que tu negocio necesita.
                </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                {[
                    { icon: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z', t: 'Auditoría de Google Ads en Barcelona', d: 'Radiografía de tu cuenta, tu presupuesto y tu competencia antes de tocar nada. El punto de partida de cualquier estrategia de anuncios.' },
                    { icon: 'M12 3a9 9 0 100 18 9 9 0 000-18zm0 5a4 4 0 100 8 4 4 0 000-8z', t: 'Campañas en el mercado más disputado', d: 'Anuncios de texto que aparecen justo cuando alguien busca tu servicio. El corazón de la captación de leads para una pyme.' },
                    { icon: 'M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z', t: 'Google Shopping', d: 'Tus productos con foto y precio en los resultados de compra. Feed optimizado para que el clic llegue ya medio convencido.' },
                    { icon: 'M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z', t: 'Display y YouTube', d: 'Anuncios visuales y de vídeo para dar a conocer tu marca a quien todavía no te busca, con segmentación fina y sin quemar presupuesto.' },
                    { icon: 'M13 10V3L4 14h7v7l9-11h-7z', t: 'Performance Max', d: 'La campaña automatizada de Google, bien alimentada y bien vigilada. Potente con datos buenos, un agujero de presupuesto sin ellos.' },
                    { icon: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15', t: 'Remarketing frente a la competencia', d: 'Volvemos a impactar a quien visitó tu web y no contactó. Los leads más baratos suelen estar en la segunda visita.' },
                    { icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', t: 'Landings que convierten el clic caro', d: 'El anuncio trae la visita y la landing la convierte. Optimizamos la página de destino para que el clic acabe en formulario o llamada.' },
                    { icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm8 0V5a2 2 0 012-2h0a2 2 0 012 2v14a2 2 0 01-2 2h0a2 2 0 01-2-2zm-8 0a2 2 0 002 2h2a2 2 0 002-2V9a2 2 0 00-2-2h-2a2 2 0 00-2 2v10z', t: 'Medición del coste por cliente', d: 'Configuramos las conversiones y GA4 para atribuir cada lead a su campaña y su búsqueda. Decisiones con datos, no con intuiciones.' },
                    { icon: 'M8 12h.01M12 12h.01M16 12h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z', t: 'Google Ads más SEO', d: 'Los datos de tus campañas revelan qué búsquedas venden. Los usamos para construir SEO y que cada vez dependas menos de pagar.' },
                ].map(c => (
                    <div class="bg-white border border-black/5 rounded-2xl p-6 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 text-left">
                        <div class="flex items-center gap-3 mb-3">
                            <div class="w-10 h-10 rounded-full bg-accent/10 border border-accent/20 flex items-center justify-center flex-shrink-0">
                                <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d={c.icon}/></svg>
                            </div>
                            <h3 class="text-sm font-black uppercase tracking-tight text-zinc-900">{c.t}</h3>
                        </div>
                        <p class="text-sm text-zinc-500 font-light leading-relaxed">{c.d}</p>
                    </div>
                ))}
            </div>

            <div class="mt-12 text-center reveal">
                <a href="#contacto" class="contact-modal-trigger btn-mktg-v5 shadow-[0_10px_30px_rgba(37,211,102,0.3)] !py-4 sm:!py-5 !px-6 sm:!px-10 !text-[11px] !tracking-widest font-black">
                    HABLEMOS DE TU NEGOCIO
                </a>
            </div>
        </div>
    </section>

    <!-- ═══ ESTRATEGIA SEM ════════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-white px-4 sm:px-6 relative overflow-hidden">
        <div class="max-w-5xl mx-auto">
            <div class="text-center mb-16 sm:mb-24 reveal">
                <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Cómo trabajamos</span>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.9]">
                    Estrategia de Google Ads para captar clientes en Barcelona
                </h2>
                <p class="text-zinc-500 font-light text-sm sm:text-base leading-relaxed max-w-2xl mx-auto">
                    Una metodología documentada para convertir tu presupuesto publicitario en leads y ventas, paso a paso y sin humo.
                </p>
            </div>

            <div id="timeline-container" class="relative">
                <div class="hidden md:block absolute left-1/2 top-4 bottom-4 w-px bg-zinc-200 -translate-x-1/2"></div>
                <div id="progress-bar" class="hidden md:block absolute left-1/2 top-4 w-px bg-accent -translate-x-1/2 transition-all duration-100"></div>

                <div class="space-y-16 md:space-y-24 flex flex-col items-center">
                    {steps.map((step, index) => (
                        <div class="flex flex-col md:flex-row items-center gap-6 md:gap-12 w-full relative reveal">
                            <div class:list={["flex-1 w-full", index % 2 === 0 ? "md:order-1 md:text-right" : "md:order-3 md:text-left"]}>
                                <div class="p-8 sm:p-10 bg-zinc-50 border border-black/5 rounded-3xl hover:border-accent/10 hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 relative overflow-hidden group">
                                    <h3 class="text-xl font-black uppercase tracking-tighter mb-2 text-zinc-900">{index + 1}. {step.title}</h3>
                                    <div class:list={["h-0.5 bg-accent w-full mb-4 opacity-80", index % 2 === 0 ? "md:ml-auto" : ""]}></div>
                                    <p class:list={["text-sm text-zinc-500 font-light max-w-md", index % 2 === 0 ? "md:ml-auto" : ""]}>{step.desc}</p>
                                    <div class="absolute -bottom-6 -right-5 text-8xl font-black text-black/[0.02] select-none z-0 group-hover:scale-105 transition-transform duration-500">0{index+1}</div>
                                </div>
                            </div>
                            <div class="md:order-2 w-12 h-12 rounded-full border-2 border-zinc-200 bg-white flex items-center justify-center font-black text-lg z-10 shrink-0 shadow-sm node-circle transition-all">
                                0{index + 1}
                            </div>
                            <div class:list={["hidden md:block md:flex-1", index % 2 === 0 ? "md:order-3" : "md:order-1"]}></div>
                        </div>
                    ))}
                </div>
            </div>
        </div>
    </section>

    <!-- ═══ AUDITORÍA GOOGLE ADS ═════════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-zinc-50/50 px-4 sm:px-6 border-t border-black/5 overflow-hidden">
