---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { buildAlternates } from '../../lib/i18n';
import { localAgencySchema } from '../../lib/schema';
import { strapiClient } from '../../lib/strapi';
import LogoMarquee from '../../components/sections/LogoMarquee.astro';
import FaqHome from '../../components/sections/FaqHome.astro';
import CityPills from '../../components/global/CityPills.astro';
import GoogleReviews from '../../components/global/GoogleReviews.astro';

const SITE_URL = import.meta.env.PUBLIC_SITE_URL || 'https://novamarketing.es';
const alternates = buildAlternates('/agencia-seo-para-pymes/barcelona/', '/ca/agencia-seo-per-pimes/barcelona/', SITE_URL);

let allCases: any[] = [];
try {
  const casesRes = await strapiClient.getCaseStudies('es');
  allCases = casesRes.data.map((i: any) => i.attributes ?? i).filter((c: any) => {
    const cats = (c.categories || []).map((cat: any) => (cat.slug || cat.attributes?.slug || '').toLowerCase());
    return cats.some((s: string) => s.includes('seo'));
  });
} catch {}

const steps = [
  { title: "Auditoría SEO de tu negocio en Barcelona", desc: "Analizamos tu web, tu visibilidad actual en Google y tu competencia directa. Detectamos errores técnicos, keywords rentables sin explotar y oportunidades de venta que tu competencia ya está capturando. Ese es tu punto de partida real." },
  { title: "Estrategia para un mercado disputado", desc: "Recibes una hoja de ruta por escrito. Qué keywords atacar, qué contenido crear, qué arreglar en tu web y qué resultados esperar en 3, 6 y 12 meses. Sabes en qué se invierte cada euro antes de invertirlo." },
  { title: "Optimización técnica y contenidos", desc: "Arreglamos lo que impide a Google entender tu web y creamos el contenido que posiciona. Velocidad, indexación, arquitectura, páginas de servicio y artículos pensados para atraer clientes, no solo visitas." },
  { title: "Autoridad de marca y enlaces", desc: "Google posiciona a quien considera una referencia. Conseguimos enlaces de medios y directorios relevantes de tu sector que aumentan la autoridad de tu dominio y empujan tus posiciones." },
  { title: "Medición frente a la competencia", desc: "Monitorizamos mes a mes tus posiciones, tu tráfico y tus leads. En el informe ves qué keywords suben, cuántos clientes llegan desde Google y qué toca ajustar el mes siguiente." }
];

const criteria = [
  { title: "Pide casos de éxito verificables", desc: "Un muro de logos no demuestra nada. Pide casos con datos concretos. Qué keyword, qué posición alcanzó, en cuánto tiempo y con qué inversión. Una agencia SEO seria debería poder enseñarte resultados de negocios como el tuyo. Si no pueden enseñarte ni uno, sigue buscando." },
  { title: "Pregunta quién llevará tu cuenta", desc: "En muchas agencias vende un director y ejecuta un junior con 30 cuentas. Exige conocer a la persona que trabajará tu proyecto antes de firmar. En nova hablas siempre con el consultor que ejecuta tu estrategia SEO, presencialmente o por videollamada." },
  { title: "Exige propiedad de tus activos", desc: "La web, el dominio, la analítica y la ficha de Google Business Profile deben estar a tu nombre. Es más habitual de lo que parece que una pyme lleve años pagando y descubra al cambiar de agencia que no es dueña ni de su propio dominio. Eso no es un servicio, es una dependencia." },
  { title: "Desconfía de quien garantiza la posición 1 en Google", desc: "Nadie puede garantizar la posición 1. Quien lo promete, o miente o usa técnicas que acabarán penalizando tu web. Lo serio es garantizar método, transparencia y trabajo verificable mes a mes." },
  { title: "Revisa qué mide el informe mensual", desc: "Si el informe habla de impresiones y posiciones pero no de llamadas, formularios y ventas, la agencia está midiendo su actividad y no tu negocio. El SEO de una pyme se mide en clientes nuevos y presupuestos solicitados." },
  { title: "Huye de las permanencias largas", desc: "Una permanencia de 12 meses protege a la agencia, no a ti. El trabajo bien hecho retiene clientes sin necesidad de contratos que los aten. Por eso en nova trabajamos mes a mes." },
  { title: "Que piense también en la IA", desc: "Cada vez más clientes preguntan a ChatGPT o Perplexity en lugar de buscar en Google. Una agencia SEO que ignora el posicionamiento en IA está optimizando solo la mitad del tablero. Nosotros integramos SEO y GEO en una sola estrategia." }
];

const faqs = [
  { question: "¿Cuánto cuesta el posicionamiento SEO en Barcelona?", answer: "La auditoría SEO cuesta 1.800 euros y los planes mensuales van desde 400 euros al mes para pymes y desde 900 para sectores muy competidos, algo habitual en Barcelona. Presupuesto cerrado por escrito y sin permanencias." },
  { question: "¿Puede una pyme competir en Google con las grandes de Barcelona?", answer: "Sí, siendo más específica. Mientras las grandes marcas van a por todo el mercado, una pyme puede dominar las búsquedas de su nicho y su distrito, donde la competencia real es mucho menor. Ahí es donde enfocamos la estrategia." },
  { question: "¿El SEO funciona distinto según el distrito?", answer: "Sí. Las búsquedas locales del Eixample no son las de Gràcia ni las del 22@. Adaptamos las keywords, la ficha de Google y el contenido a la zona donde compite tu negocio." },
  { question: "¿Cuánto tarda el SEO en Barcelona?", answer: "Al ser el mercado más competido de España, los plazos son algo más largos que la media. Los primeros movimientos suelen verse entre el segundo y el cuarto mes, y los resultados consolidados a partir del sexto. Te lo decimos con plazos realistas en la hoja de ruta." },
  { question: "¿Cómo medís los resultados?", answer: "Medimos leads y ventas. Llamadas, formularios y presupuestos solicitados, cada uno atribuido a su keyword y su canal. Informe mensual de negocio con reunión incluida, y acceso total a tus cuentas." },
  { question: "¿Y si mis clientes ya buscan en la IA en vez de Google?", answer: "Por eso integramos SEO y GEO en una sola estrategia. El mismo contenido y la misma autoridad que te posicionan en Google son la base para aparecer en las respuestas de ChatGPT, Gemini o Google AI Overviews." },
  { question: "¿Trabajáis con permanencia?", answer: "No, trabajamos mes a mes. Si el servicio no te aporta valor, puedes cancelarlo cuando quieras. Nuestra permanencia real es el resultado que ves en los informes cada mes." },
];

const sectors = [
  { icon: '🛒', title: 'SEO para ecommerce', href: '/agencia-ecommerce/seo/', desc: 'Arquitectura de categorías, fichas optimizadas y SEO de producto. Que quien busca comprar te encuentre a ti y no a tu competencia.' },
  { icon: '🏠', title: 'SEO para inmobiliarias', href: '/agencia-inmobiliarias/seo/', desc: 'Captación de propietarios y compradores con landings por zona y SEO local por barrio. Tráfico que filtra curiosos de clientes reales.' },
  { icon: '🍽️', title: 'SEO para restaurantes', href: '/agencia-restaurantes/seo/', desc: 'Aquí manda la ficha de Google y las reseñas. Pack local completo para aparecer cuando alguien busca dónde comer cerca.' },
  { icon: '🧠', title: 'SEO para psicólogos', desc: 'El paciente busca confianza antes que precio. Contenido con autoridad clínica y SEO local por especialidad que convierte búsquedas en primeras visitas.' },
  { icon: '🌿', title: 'SEO para terapeutas', desc: 'Mucha competencia genérica y poca especializada. Posicionamos tu consulta por terapia y zona con contenido que educa y convierte.' },
  { icon: '🦷', title: 'SEO para dentistas', desc: 'Sector saturado y con alta exigencia de autoridad. Ganan quienes combinan SEO local impecable, reseñas gestionadas y contenido clínico real.' },
  { icon: '💪', title: 'SEO para gimnasios', desc: 'Captación estacional con picos en enero y septiembre. Posicionamiento local y contenido que llena clases todo el año.' },
  { icon: '🏗️', title: 'SEO para constructoras', desc: 'Competencia local feroz y leads de valor alto. Ficha de Google impecable, landings por zona y keywords que traen presupuestos, no visitas.' },
  { icon: '⚖️', title: 'SEO para abogados', desc: 'Búsquedas de altísima intención y CPCs carísimos en Ads. El SEO capta la consulta con contenido que resuelve la duda legal antes que la competencia.' },
  { icon: '🏨', title: 'SEO para hoteles', desc: 'Reducir la dependencia de las OTAs es el objetivo. SEO para reserva directa, ficha optimizada y visibilidad en Google Hotels.' },
  { icon: '🏭', title: 'SEO para B2B', desc: 'Ciclos de venta largos y pocos decisores. Aquí no importa el volumen, importa aparecer en las diez búsquedas técnicas del responsable de compras.' },
  { icon: '🎓', title: 'SEO para escuelas', desc: 'Captación estacional con picos claros. Contenido informacional todo el año y posicionamiento fuerte en la ventana de matriculación.' },
];

const pageSchema = localAgencySchema({
  pageUrl: `${SITE_URL}/agencia-seo-para-pymes/barcelona/`,
  lang: 'es',
  cityName: 'Barcelona',
  postalCode: '08035',
  geo: { lat: 41.4114, lng: 2.1526 },
  areaServed: ["Barcelona", "Vallès Occidental", "Barcelona", "España"],
  title: "▷ Agencia SEO en Barcelona | Posicionamiento para PYMEs | Nova Marketing",
  description: "Agencia SEO en Barcelona con estrategias personalizadas ⭐ para PYMEs que buscan mejorar visibilidad y captar clientes locales con posicionamiento orgánico",
  datePublished: '2026-07-15',
  dateModified: '2026-07-15',
  streetAddress: 'Carrer del General Mendoza, 10',
  hasMap: 'https://maps.app.goo.gl/9fbB12UcK32bgjj89',
  aggregateRating: { ratingValue: '5.0', reviewCount: '8' },
  breadcrumbName: 'Agencia SEO en Barcelona',
  faqs,
});
---

<BaseLayout
  title="▷ Agencia SEO en Barcelona | Posicionamiento para PYMEs | Nova Marketing"
  description="Agencia SEO en Barcelona con estrategias personalizadas ⭐ para PYMEs que buscan mejorar visibilidad y captar clientes locales con posicionamiento orgánico"
  locale="es"
  alternates={alternates}
  schemas={[pageSchema]}
>

    <!-- ═══ HERO / H1 ═══════════════════════════════════════════════════════ -->
    <section class="pt-24 sm:pt-40 pb-20 px-4 sm:px-6 relative overflow-hidden text-center bg-white border-b border-black/5">
        <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808008_1px,transparent_1px),linear-gradient(to_bottom,#80808008_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_40%,#000_75%,transparent_100%)]"></div>
        <div class="absolute -top-10 left-1/4 w-72 h-72 bg-accent/15 rounded-full blur-3xl opacity-30 animate-pulse"></div>
        <div class="absolute top-20 right-1/4 w-80 h-80 bg-purple-500/5 rounded-full blur-3xl opacity-20"></div>

        <div class="max-w-5xl mx-auto reveal">
            <span class="inline-flex items-center gap-2 bg-accent/5 backdrop-blur-sm px-4 py-2 border border-accent/10 rounded-full text-accent text-[8px] sm:text-[10px] font-black uppercase tracking-[0.3em] mb-8 shadow-sm">
                <span class="w-1.5 h-1.5 bg-accent rounded-full animate-ping"></span>
                Posicionamiento Web para Pymes
            </span>
            <h1 class="text-3xl sm:text-5xl md:text-7xl lg:text-8xl uppercase font-extrabold tracking-tighter leading-[0.88] mb-8 text-gradient flex flex-col items-center text-center">
                <span class="lg:whitespace-nowrap">Agencia SEO </span>
                <span class="lg:whitespace-nowrap text-mktg-gradient">en Barcelona</span>
            </h1>
            <p class="text-lg sm:text-xl text-zinc-500 font-light leading-relaxed w-[75%] mx-auto mb-8">
                Aparece cuando tus clientes buscan tu servicio en Google. Servicio de posicionamiento SEO para PYMEs de Barcelona con estrategia a medida, precios claros y resultados que se miden en ventas.
            </p>
            <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3 mb-10">
                {['Sin permanencias', 'Trato directo con el consultor', 'Informes de negocio'].map(item => (
                    <span class="inline-flex items-center gap-2 text-[11px] sm:text-xs font-black uppercase tracking-widest text-zinc-700">
                        <svg class="w-4 h-4 text-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                        </svg>
                        {item}
                    </span>
                ))}
            </div>
            <div class="flex justify-center mt-4">
                <a href="#contacto" class="contact-modal-trigger btn-mktg-v5 shadow-[0_10px_30px_rgba(0,0,0,0.1)] !py-4 sm:!py-5 !px-6 sm:!px-10 !text-[11px] !tracking-widest font-black">
                    HABLEMOS DE TU NEGOCIO
                </a>
            </div>
        </div>
    </section>

    <LogoMarquee />

    <!-- ═══ INTRO: POR QUÉ SEO ═══════════════════════════════════════════ -->
    <section class="py-16 sm:py-24 bg-white px-4 sm:px-6 border-b border-black/5">
        <div class="max-w-6xl mx-auto reveal grid md:grid-cols-[1.3fr_1fr] gap-10 md:gap-16 items-center">
            <div>
                <p class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4">¿Por qué SEO?</p>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-8 text-zinc-900 leading-[0.9]">
                    La agencia de posicionamiento SEO para tu pyme en Barcelona
                </h2>
                <div class="space-y-6 text-zinc-600 font-light text-base sm:text-lg leading-relaxed">
                    <p>
                        <strong class="font-semibold text-zinc-900">El SEO es el canal que sigue trayendo clientes cuando dejas de pagar por anuncios</strong>. Cada búsqueda de tu servicio en Google es un cliente con intención de compra, y quien aparece primero se lo lleva. A diferencia de la publicidad, el posicionamiento es un activo que se acumula mes a mes.
                    </p>
                    <p>
                        Nova es una <strong class="font-semibold text-zinc-900">agencia SEO especializada en PYMEs</strong> que trabaja con negocios de Barcelona y toda su comarca. Trabajamos con un número limitado de clientes, cada cuenta la lleva directamente el consultor fundador y toda la estrategia se orienta a una sola métrica que importa. <strong class="font-semibold text-zinc-900">Cuántos clientes nuevos llegan desde Google cada mes</strong>.
                    </p>
                </div>
            </div>
            <div class="hidden md:block">
                <img src="/sergio-galos-agencia-seo-para-pymes-barcelona.webp" alt="Sergio Galo's, consultor SEO para PYMEs en Barcelona" title="Sergio Galo's, consultor SEO para PYMEs en Barcelona" class="w-full h-auto" loading="lazy" width="473" height="591" />
            </div>
        </div>
    </section>

    <!-- ═══ SERVICIOS SEO ══════════════════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-zinc-50 border-b border-black/5 px-4 sm:px-6">
        <div class="max-w-7xl mx-auto text-center reveal">
            <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Qué hacemos</span>
            <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.9]">
                Servicio de posicionamiento SEO para PYMEs en Barcelona
            </h2>
            <div class="text-zinc-500 font-light text-sm sm:text-base leading-relaxed max-w-3xl mx-auto mb-16 space-y-4">
                <p>
                    El <strong class="font-semibold text-zinc-700">posicionamiento SEO</strong> no es una sola tarea, es un sistema. Estas son las nueve piezas que trabajamos para que tu pyme pase de ser invisible en Google a captar clientes cada mes desde el buscador.
                </p>
                <p>
                    Cada pieza se activa según lo que diga tu auditoría. No pagas por un paquete cerrado de acciones, pagas por las que tu negocio necesita.
                </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                {[
                    { icon: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z', t: 'Auditoría SEO en Barcelona', d: 'Radiografía técnica, de contenido y de autoridad de tu web antes de tocar nada. El punto de partida de cualquier estrategia.' },
                    { icon: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4', t: 'SEO técnico para competir', d: 'Velocidad, indexación, Core Web Vitals y arquitectura. Que Google pueda rastrear y entender tu sitio sin fricciones.' },
                    { icon: 'M12 3a9 9 0 100 18 9 9 0 000-18zm0 5a4 4 0 100 8 4 4 0 000-8z', t: 'Keywords en el mercado más disputado', d: 'Identificamos qué buscan tus clientes potenciales, con qué volumen y qué oportunidades están sin cubrir en tu sector.' },
                    { icon: 'M9 12h6m-6 4h6M9 8h2m8-3v14a2 2 0 01-2 2H7a2 2 0 01-2-2V5a2 2 0 012-2h6l4 4z', t: 'Contenidos que destacan entre miles', d: 'Creamos y optimizamos el contenido que posiciona. Páginas de servicio, artículos y arquitectura editorial pensada para vender.' },
                    { icon: 'M13.828 10.172a4 4 0 010 5.656l-3 3a4 4 0 01-5.656-5.656l1.5-1.5m7.328-1.672a4 4 0 000-5.656 4 4 0 00-5.656 0l-1.5 1.5', t: 'Enlaces en medios de Barcelona', d: 'Conseguimos enlaces de calidad en medios relevantes para aumentar la autoridad de tu dominio de forma orgánica y sostenida.' },
                    { icon: 'M17.657 16.657L13.414 20.9a2 2 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0zM15 11a3 3 0 11-6 0 3 3 0 016 0z', t: 'SEO local por distrito', d: 'Posicionamos tu negocio en Google Maps y en las búsquedas de tu zona. Imprescindible si tus clientes están cerca de ti.' },
                    { icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm8 0V5a2 2 0 012-2h0a2 2 0 012 2v14a2 2 0 01-2 2h0a2 2 0 01-2-2zm-8 0a2 2 0 002 2h2a2 2 0 002-2V9a2 2 0 00-2-2h-2a2 2 0 00-2 2v10z', t: 'Analítica frente a la competencia', d: 'Configuramos GA4 y Search Console para atribuir cada lead a su keyword. Decisiones con datos, no con intuiciones.' },
                    { icon: 'M8 12h.01M12 12h.01M16 12h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z', t: 'SEO más GEO', d: 'Cada vez más clientes preguntan a la IA en vez de buscar en Google. Integramos posicionamiento en Google y en la IA en una sola estrategia.' },
                    { icon: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15', t: 'Migraciones sin perder posiciones', d: 'Cambios de dominio, rediseños o saltos de plataforma sin perder el posicionamiento que tanto ha costado conseguir.' },
                ].map(c => (
                    <div class="bg-white border border-black/5 rounded-2xl p-6 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 text-left">
                        <div class="flex items-center gap-3 mb-3">
                            <div class="w-10 h-10 rounded-full bg-accent/10 border border-accent/20 flex items-center justify-center flex-shrink-0">
                                <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d={c.icon}/></svg>
                            </div>
                            <h3 class="text-sm font-black uppercase tracking-tight text-zinc-900">{c.t}</h3>
                        </div>
                        <p class="text-sm text-zinc-500 font-light leading-relaxed">{c.d}</p>
                    </div>
                ))}
            </div>

            <div class="mt-12 text-center reveal">
                <a href="#contacto" class="contact-modal-trigger btn-mktg-v5 shadow-[0_10px_30px_rgba(37,211,102,0.3)] !py-4 sm:!py-5 !px-6 sm:!px-10 !text-[11px] !tracking-widest font-black">
                    HABLEMOS DE TU NEGOCIO
                </a>
            </div>
        </div>
    </section>

    <!-- ═══ ESTRATEGIA SEO ════════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-white px-4 sm:px-6 relative overflow-hidden">
        <div class="max-w-5xl mx-auto">
            <div class="text-center mb-16 sm:mb-24 reveal">
                <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Cómo trabajamos</span>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.9]">
                    Estrategia SEO para posicionar tu pyme de Barcelona en Google
                </h2>
                <p class="text-zinc-500 font-light text-sm sm:text-base leading-relaxed max-w-2xl mx-auto">
                    Una metodología documentada para pasar de ser invisible en Google a captar clientes desde el buscador, paso a paso y sin humo.
                </p>
            </div>

            <div id="timeline-container" class="relative">
                <div class="hidden md:block absolute left-1/2 top-4 bottom-4 w-px bg-zinc-200 -translate-x-1/2"></div>
                <div id="progress-bar" class="hidden md:block absolute left-1/2 top-4 w-px bg-accent -translate-x-1/2 transition-all duration-100"></div>

                <div class="space-y-16 md:space-y-24 flex flex-col items-center">
                    {steps.map((step, index) => (
                        <div class="flex flex-col md:flex-row items-center gap-6 md:gap-12 w-full relative reveal">
                            <div class:list={["flex-1 w-full", index % 2 === 0 ? "md:order-1 md:text-right" : "md:order-3 md:text-left"]}>
                                <div class="p-8 sm:p-10 bg-zinc-50 border border-black/5 rounded-3xl hover:border-accent/10 hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 relative overflow-hidden group">
                                    <h3 class="text-xl font-black uppercase tracking-tighter mb-2 text-zinc-900">{index + 1}. {step.title}</h3>
                                    <div class:list={["h-0.5 bg-accent w-full mb-4 opacity-80", index % 2 === 0 ? "md:ml-auto" : ""]}></div>
                                    <p class:list={["text-sm text-zinc-500 font-light max-w-md", index % 2 === 0 ? "md:ml-auto" : ""]}>{step.desc}</p>
                                    <div class="absolute -bottom-6 -right-5 text-8xl font-black text-black/[0.02] select-none z-0 group-hover:scale-105 transition-transform duration-500">0{index+1}</div>
                                </div>
                            </div>
                            <div class="md:order-2 w-12 h-12 rounded-full border-2 border-zinc-200 bg-white flex items-center justify-center font-black text-lg z-10 shrink-0 shadow-sm node-circle transition-all">
                                0{index + 1}
                            </div>
                            <div class:list={["hidden md:block md:flex-1", index % 2 === 0 ? "md:order-3" : "md:order-1"]}></div>
                        </div>
                    ))}
                </div>
            </div>
        </div>
    </section>

    <!-- ═══ AUDITORÍA SEO ═════════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-zinc-50/50 px-4 sm:px-6 border-t border-black/5 overflow-hidden">
        <div class="max-w-7xl mx-auto grid lg:grid-cols-[6fr_4fr] gap-12 lg:gap-16 items-start">

            <div class="reveal lg:col-span-2">
                <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Punto de partida</span>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase text-zinc-900 leading-[0.9]">
                    Auditoría de posicionamiento SEO para tu PYME de Barcelona
                </h2>
            </div>

            <div class="reveal">
