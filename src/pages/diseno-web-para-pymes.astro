---
import BaseLayout from '../layouts/BaseLayout.astro';
import { buildAlternates } from '../lib/i18n';
import { localAgencySchema } from '../lib/schema';
import { strapiClient } from '../lib/strapi';
import LogoMarquee from '../components/sections/LogoMarquee.astro';
import FaqHome from '../components/sections/FaqHome.astro';
import CityPills from '../components/global/CityPills.astro';
import GoogleReviews from '../components/global/GoogleReviews.astro';

const SITE_URL = import.meta.env.PUBLIC_SITE_URL || 'https://novamarketing.es';
const alternates = buildAlternates('/diseno-web-para-pymes/', '/ca/disseny-web-per-pimes/', SITE_URL);

let allCases: any[] = [];
try {
  const casesRes = await strapiClient.getCaseStudies('es');
  allCases = casesRes.data.map((i: any) => i.attributes ?? i).filter((c: any) => {
    const cats = (c.categories || []).map((cat: any) => (cat.slug || cat.attributes?.slug || '').toLowerCase());
    return cats.some((s: string) => s === 'diseno-web');
  });
} catch {}

const steps = [
  { title: "Briefing y Objetivos de Negocio", desc: "Antes de diseñar nada, entendemos tu negocio. Qué vendes, a quién, qué hace tu competencia y qué tiene que conseguir la web. Una web sin objetivo es un folleto caro. La tuya nace con una misión concreta, convertir visitas en clientes." },
  { title: "Arquitectura y Contenidos", desc: "Definimos qué páginas necesita tu web, cómo se organizan y qué dice cada una. La estructura se piensa para el usuario y para Google a la vez, con las keywords de tu sector integradas desde el primer boceto." },
  { title: "Diseño y Desarrollo", desc: "Diseñamos una web que transmite confianza en tres segundos y la desarrollamos con código limpio y rápido. Adaptada a móvil desde el primer píxel, porque ahí está la mayoría de tus visitas." },
  { title: "SEO Técnico y Velocidad", desc: "Cada web sale optimizada de serie. Core Web Vitals en verde, datos estructurados, indexación correcta y tiempos de carga que no espantan ni a tus clientes ni a Google. Lo que otros venden como extra, aquí es el estándar." },
  { title: "Lanzamiento y Mantenimiento", desc: "Publicamos, medimos y no desaparecemos. Analítica configurada desde el día uno, copias de seguridad, actualizaciones y soporte directo. Tu web es un activo vivo que mejora cada mes, no un proyecto que se entrega y se olvida." }
];

const criteria = [
  { title: "Pide webs reales que pueda visitar", desc: "Un portfolio de capturas bonitas no demuestra nada. Pide direcciones de webs vivas, entra desde el móvil y comprueba cómo cargan. Una agencia de diseño web seria debería poder enseñarte proyectos de negocios como el tuyo funcionando hoy." },
  { title: "Pregunta quién hará tu web", desc: "En muchas agencias vende un comercial y ejecuta una plantilla comprada. Exige saber quién diseña, quién desarrolla y con quién hablarás durante el proyecto. En nova hablas siempre con el consultor que lleva tu proyecto." },
  { title: "Exige la propiedad de tu web y tu dominio", desc: "El dominio, el hosting, la web y sus contenidos deben estar a tu nombre. Hay pymes que llevan años pagando y descubren al querer cambiar de agencia que no son dueñas ni de su propio dominio. Eso no es un servicio, es una dependencia." },
  { title: "Desconfía de las webs a 300 euros", desc: "Una web tirada de precio suele ser una plantilla clonada, lenta y sin ningún trabajo de SEO. La acabas pagando dos veces, la segunda cuando alguien tiene que rehacerla para que funcione. Lo barato en diseño web es lo que no genera clientes." },
  { title: "Revisa qué pasa después del lanzamiento", desc: "Una web sin mantenimiento envejece mal. Actualizaciones, seguridad, copias y pequeños cambios forman parte del servicio. Pregunta qué incluye el soporte y cuánto cuesta cada cambio antes de firmar, no después." },
  { title: "Huye de las permanencias largas", desc: "Una permanencia de 24 meses protege a la agencia, no a ti. El trabajo bien hecho retiene clientes sin contratos que los aten. Por eso en nova trabajamos sin permanencias." },
  { title: "Que la web nazca preparada para SEO y para la IA", desc: "Una web bonita que Google no entiende es invisible. Y cada vez más clientes preguntan a ChatGPT antes de buscar. Exige datos estructurados, contenido citable y velocidad de serie. Nosotros diseñamos cada web para posicionar en Google y en la IA desde el primer día." }
];

const faqs = [
  { question: "¿Cuánto cuesta una página web para una pyme?", answer: "Depende del proyecto. Una landing page para campañas parte de 400 euros, una web a medida desde 120 euros al mes en 12 cuotas y una tienda online desde 130 euros al mes en 12 cuotas. Antes de empezar recibes un presupuesto cerrado por escrito y sabes exactamente qué incluye cada opción." },
  { question: "¿Cuánto se tarda en hacer una web?", answer: "Una web corporativa suele estar lista en 3 a 5 semanas y una tienda online en 6 a 8, contando desde que recibimos los contenidos y materiales de tu negocio. En el briefing inicial te damos un calendario con fechas concretas de entrega y revisiones." },
  { question: "¿La web, el dominio y el hosting serán míos?", answer: "Sí, siempre. El dominio se registra a tu nombre, los contenidos son tuyos y tienes acceso completo a todo. Si algún día dejas de trabajar con nosotros, te llevas tu web entera. Nos parece lo mínimo, aunque en el sector no sea lo habitual." },
  { question: "¿Con qué tecnología hacéis las webs?", answer: "La que más convenga a tu proyecto. WordPress cuando necesitas gestionar contenido con autonomía, desarrollo a medida cuando la velocidad y el SEO son críticos, y plataformas de ecommerce consolidadas para las tiendas online. La tecnología es un medio, el criterio es qué convierte mejor para tu negocio." },
  { question: "¿La web incluye SEO?", answer: "Toda web que sale de nova incluye la base SEO de serie. Estructura pensada con keywords, velocidad optimizada, datos estructurados, indexación correcta y textos orientados a las búsquedas de tus clientes. Si después quieres competir por posiciones, nuestro servicio de posicionamiento SEO continúa el trabajo desde esa base." },
  { question: "¿Qué pasa si necesito cambios después del lanzamiento?", answer: "Tienes un periodo de ajustes incluido tras el lanzamiento y después puedes contratar mantenimiento mensual o pedir cambios puntuales con presupuesto cerrado. Nunca te quedas solo con la web." },
  { question: "¿Trabajáis con permanencia?", answer: "No. Pagas por el trabajo entregado, en pago único o en 12 cuotas, sin permanencias ni cuotas ocultas. Nuestra permanencia real es que la web te genere clientes cada mes." }
];

const sectors = [
  { icon: '🛒', title: 'Diseño web para ecommerce', href: '/agencia-ecommerce/diseno-web/', desc: 'Tiendas online rápidas, con fichas que venden y un proceso de compra sin fricciones. El diseño trabaja para el carrito, no contra él.' },
  { icon: '🏠', title: 'Diseño web para inmobiliarias', href: '/agencia-inmobiliarias/diseno-web/', desc: 'Buscadores de propiedades claros, fichas con la información que decide y formularios que convierten visitas en visitas al piso.' },
  { icon: '🍽️', title: 'Diseño web para restaurantes', href: '/agencia-restaurantes/diseno-web/', desc: 'Carta legible desde el móvil, reservas en dos toques y una web conectada con tu ficha de Google. El comensal decide en segundos.' },
  { icon: '🧠', title: 'Diseño web para psicólogos', desc: 'El paciente busca confianza antes que precio. Webs serenas, con autoridad clínica y una primera cita a un clic de distancia.' },
  { icon: '🌿', title: 'Diseño web para terapeutas', desc: 'Tu web es tu consulta antes de la consulta. Diseño que transmite lo que haces y contenido que convierte dudas en primeras visitas.' },
  { icon: '🦷', title: 'Diseño web para dentistas', desc: 'Sector saturado donde la web decide. Casos reales, reseñas visibles y cita online para convertir la búsqueda en paciente.' },
  { icon: '💪', title: 'Diseño web para gimnasios', desc: 'Horarios claros, tarifas sin letra pequeña y alta online. Una web que llena clases en enero y las mantiene el resto del año.' },
  { icon: '🏗️', title: 'Diseño web para constructoras', desc: 'Proyectos documentados con fotos reales y formularios que filtran curiosos. La web que convierte visitas en presupuestos.' },
  { icon: '⚖️', title: 'Diseño web para abogados', desc: 'Autoridad y claridad. Webs por especialidad que resuelven la duda legal del cliente y lo llevan a la consulta.' },
  { icon: '🏨', title: 'Diseño web para hoteles', desc: 'Reserva directa sin depender de las OTAs. Webs con motor de reservas, fotos que venden y velocidad de carga impecable.' },
  { icon: '🏭', title: 'Diseño web para B2B', desc: 'Fichas técnicas descargables, casos de éxito y formularios pensados para el responsable de compras. Webs que generan presupuestos.' },
  { icon: '🎓', title: 'Diseño web para escuelas', desc: 'Proyecto educativo bien contado, visitas al centro a un clic y matrícula online. La web que las familias comparan antes de decidir.' },
];

const pageSchema = localAgencySchema({
  pageUrl: `${SITE_URL}/diseno-web-para-pymes/`,
  lang: 'es',
  cityName: 'Barcelona',
  postalCode: '08035',
  geo: { lat: 41.4114, lng: 2.1526 },
  areaServed: ["España", "Barcelona", "Sabadell", "Sant Cugat del Vallès", "Terrassa", "Vallès Occidental"],
  title: "Diseño Web para PYMEs | Páginas Web que Venden | Nova Marketing",
  description: "Agencia de diseño web especializada en PYMEs. Webs corporativas, landings y tiendas online rápidas, optimizadas para Google y pensadas para convertir visitas en clientes. Sin permanencias.",
  datePublished: '2026-07-16',
  dateModified: '2026-07-16',
  streetAddress: 'Carrer del General Mendoza, 10',
  hasMap: 'https://maps.app.goo.gl/9fbB12UcK32bgjj89',
  aggregateRating: { ratingValue: '5.0', reviewCount: '8' },
  breadcrumbName: 'Diseño Web para PYMEs',
  faqs,
});
---

<BaseLayout
  title="Diseño Web para PYMEs | Páginas Web que Venden | Nova Marketing"
  description="Agencia de diseño web especializada en PYMEs. Webs corporativas, landings y tiendas online rápidas, optimizadas para Google y pensadas para convertir visitas en clientes. Sin permanencias."
  locale="es"
  alternates={alternates}
  schemas={[pageSchema]}
>

    <!-- ═══ HERO / H1 ═══════════════════════════════════════════════════════ -->
    <section class="pt-24 sm:pt-40 pb-20 px-4 sm:px-6 relative overflow-hidden text-center bg-white border-b border-black/5">
        <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808008_1px,transparent_1px),linear-gradient(to_bottom,#80808008_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_40%,#000_75%,transparent_100%)]"></div>
        <div class="absolute -top-10 left-1/4 w-72 h-72 bg-accent/15 rounded-full blur-3xl opacity-30 animate-pulse"></div>
        <div class="absolute top-20 right-1/4 w-80 h-80 bg-purple-500/5 rounded-full blur-3xl opacity-20"></div>

        <div class="max-w-5xl mx-auto reveal">
            <span class="inline-flex items-center gap-2 bg-accent/5 backdrop-blur-sm px-4 py-2 border border-accent/10 rounded-full text-accent text-[8px] sm:text-[10px] font-black uppercase tracking-[0.3em] mb-8 shadow-sm">
                <span class="w-1.5 h-1.5 bg-accent rounded-full animate-ping"></span>
                Diseño Web para Pymes
            </span>
            <h1 class="text-3xl sm:text-5xl md:text-7xl lg:text-8xl uppercase font-extrabold tracking-tighter leading-[0.88] mb-8 text-gradient flex flex-col items-center text-center">
                <span class="lg:whitespace-nowrap">Diseño Páginas Web </span>
                <span class="lg:whitespace-nowrap text-mktg-gradient">para PYMEs</span>
            </h1>
            <p class="text-lg sm:text-xl text-zinc-500 font-light leading-relaxed w-[75%] mx-auto mb-8">
                Tu web es tu mejor comercial o tu peor enemigo. Diseñamos páginas web para PYMEs rápidas, optimizadas para Google y pensadas para convertir visitas en clientes.
            </p>
            <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3 mb-10">
                {['Sin permanencias', 'La web y el dominio son tuyos', 'SEO incluido de serie'].map(item => (
                    <span class="inline-flex items-center gap-2 text-[11px] sm:text-xs font-black uppercase tracking-widest text-zinc-700">
                        <svg class="w-4 h-4 text-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                        </svg>
                        {item}
                    </span>
                ))}
            </div>
            <div class="flex justify-center mt-4">
                <a href="#contacto" class="contact-modal-trigger btn-mktg-v5 shadow-[0_10px_30px_rgba(0,0,0,0.1)] !py-4 sm:!py-5 !px-6 sm:!px-10 !text-[11px] !tracking-widest font-black">
                    HABLEMOS DE TU NEGOCIO
                </a>
            </div>
        </div>
    </section>

    <LogoMarquee />

    <!-- ═══ INTRO: POR QUÉ TU WEB ═══════════════════════════════════════ -->
    <section class="py-16 sm:py-24 bg-white px-4 sm:px-6 border-b border-black/5">
        <div class="max-w-6xl mx-auto reveal grid md:grid-cols-[1.3fr_1fr] gap-10 md:gap-16 items-center">
            <div>
                <p class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4">¿Por qué tu web importa?</p>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-8 text-zinc-900 leading-[0.9]">
                    La agencia de diseño web para tu pyme
                </h2>
                <div class="space-y-6 text-zinc-600 font-light text-base sm:text-lg leading-relaxed">
                    <p>
                        <strong class="font-semibold text-zinc-900">Tu web trabaja las 24 horas, la pregunta es si trabaja a favor o en contra</strong>. Antes de llamarte, tu cliente te ha buscado, ha entrado en tu página desde el móvil y ha decidido en segundos si eres de fiar. Una web lenta o anticuada le manda directo a tu competencia.
                    </p>
                    <p>
                        Nova es una <strong class="font-semibold text-zinc-900">agencia de diseño web especializada en PYMEs</strong>. No hacemos webs para ganar premios de diseño, las hacemos con un objetivo medible. <strong class="font-semibold text-zinc-900">Que cada visita tenga la máxima probabilidad de convertirse en un cliente</strong>.
                    </p>
                </div>
            </div>
            <div class="hidden md:block">
                <img src="/sergio-galos-diseno-web-para-pymes.webp" alt="Sergio Galo's, consultor de diseño web para PYMEs" title="Sergio Galo's, consultor de diseño web para PYMEs" class="w-full h-auto" loading="lazy" />
            </div>
        </div>
    </section>

    <!-- ═══ SERVICIOS WEB ══════════════════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-zinc-50 border-b border-black/5 px-4 sm:px-6">
        <div class="max-w-7xl mx-auto text-center reveal">
            <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Qué hacemos</span>
            <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.9]">
                Servicio de diseño web para PYMEs
            </h2>
            <div class="text-zinc-500 font-light text-sm sm:text-base leading-relaxed max-w-3xl mx-auto mb-16 space-y-4">
                <p>
                    Una <strong class="font-semibold text-zinc-700">página web que vende</strong> no es solo diseño, es un sistema. Estas son las nueve piezas que trabajamos para que tu web deje de ser una tarjeta de visita y se convierta en tu mejor canal de captación.
                </p>
                <p>
                    Cada pieza se activa según lo que necesite tu proyecto. No pagas por un paquete cerrado de acciones, pagas por las que tu negocio necesita.
                </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                {[
                    { icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', t: 'Webs corporativas', d: 'La web de empresa que presenta tu negocio, transmite confianza y convierte. Estructura pensada para el cliente y para Google.' },
                    { icon: 'M13 10V3L4 14h7v7l9-11h-7z', t: 'Landing pages', d: 'Páginas de aterrizaje para tus campañas con un solo objetivo. Que el clic acabe en llamada o formulario, sin distracciones.' },
                    { icon: 'M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z', t: 'Tiendas online', d: 'Ecommerce rápido con fichas optimizadas, pasarela de pago fiable y un proceso de compra que no pierde carritos por el camino.' },
                    { icon: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15', t: 'Rediseño web', d: 'Renovamos webs anticuadas sin perder el posicionamiento conseguido. Migración cuidada, redirecciones y mejora medible.' },
                    { icon: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4', t: 'WordPress y a medida', d: 'WordPress cuando necesitas autonomía para editar y desarrollo a medida cuando velocidad y SEO son críticos. El criterio manda.' },
                    { icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6', t: 'Velocidad y Core Web Vitals', d: 'Webs que cargan en verde. La velocidad decide si el visitante se queda y es factor de posicionamiento en Google.' },
                    { icon: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z', t: 'SEO desde el diseño', d: 'Arquitectura, keywords, datos estructurados e indexación integrados desde el primer boceto, no parcheados después.' },
                    { icon: 'M9 12h6m-6 4h6M9 8h2m8-3v14a2 2 0 01-2 2H7a2 2 0 01-2-2V5a2 2 0 012-2h6l4 4z', t: 'Textos que venden', d: 'Redactamos los contenidos de tu web orientados a lo que busca tu cliente. El diseño atrae y el texto convierte.' },
                    { icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm8 0V5a2 2 0 012-2h0a2 2 0 012 2v14a2 2 0 01-2 2h0a2 2 0 01-2-2zm-8 0a2 2 0 002 2h2a2 2 0 002-2V9a2 2 0 00-2-2h-2a2 2 0 00-2 2v10z', t: 'Mantenimiento y soporte', d: 'Actualizaciones, seguridad, copias diarias y cambios sin esperas. Tu web siempre al día y tú a lo tuyo, tu negocio.' },
                ].map(c => (
                    <div class="bg-white border border-black/5 rounded-2xl p-6 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 text-left">
                        <div class="flex items-center gap-3 mb-3">
                            <div class="w-10 h-10 rounded-full bg-accent/10 border border-accent/20 flex items-center justify-center flex-shrink-0">
                                <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d={c.icon}/></svg>
                            </div>
                            <h3 class="text-sm font-black uppercase tracking-tight text-zinc-900">{c.t}</h3>
                        </div>
                        <p class="text-sm text-zinc-500 font-light leading-relaxed">{c.d}</p>
                    </div>
                ))}
            </div>

            <div class="mt-12 text-center reveal">
                <a href="#contacto" class="contact-modal-trigger btn-mktg-v5 shadow-[0_10px_30px_rgba(37,211,102,0.3)] !py-4 sm:!py-5 !px-6 sm:!px-10 !text-[11px] !tracking-widest font-black">
                    HABLEMOS DE TU NEGOCIO
                </a>
            </div>
        </div>
    </section>

    <!-- ═══ METODOLOGÍA WEB ════════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-white px-4 sm:px-6 relative overflow-hidden">
        <div class="max-w-5xl mx-auto">
            <div class="text-center mb-16 sm:mb-24 reveal">
                <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Cómo trabajamos</span>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.9]">
                    Así creamos la web que convierte visitas en clientes
                </h2>
                <p class="text-zinc-500 font-light text-sm sm:text-base leading-relaxed max-w-2xl mx-auto">
                    Una metodología documentada para pasar de una web que solo existe a una web que vende, paso a paso y sin humo.
                </p>
            </div>

            <div id="timeline-container" class="relative">
                <div class="hidden md:block absolute left-1/2 top-4 bottom-4 w-px bg-zinc-200 -translate-x-1/2"></div>
                <div id="progress-bar" class="hidden md:block absolute left-1/2 top-4 w-px bg-accent -translate-x-1/2 transition-all duration-100"></div>

                <div class="space-y-16 md:space-y-24 flex flex-col items-center">
                    {steps.map((step, index) => (
                        <div class="flex flex-col md:flex-row items-center gap-6 md:gap-12 w-full relative reveal">
                            <div class:list={["flex-1 w-full", index % 2 === 0 ? "md:order-1 md:text-right" : "md:order-3 md:text-left"]}>
                                <div class="p-8 sm:p-10 bg-zinc-50 border border-black/5 rounded-3xl hover:border-accent/10 hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 relative overflow-hidden group">
                                    <h3 class="text-xl font-black uppercase tracking-tighter mb-2 text-zinc-900">{index + 1}. {step.title}</h3>
                                    <div class:list={["h-0.5 bg-accent w-full mb-4 opacity-80", index % 2 === 0 ? "md:ml-auto" : ""]}></div>
                                    <p class:list={["text-sm text-zinc-500 font-light max-w-md", index % 2 === 0 ? "md:ml-auto" : ""]}>{step.desc}</p>
                                    <div class="absolute -bottom-6 -right-5 text-8xl font-black text-black/[0.02] select-none z-0 group-hover:scale-105 transition-transform duration-500">0{index+1}</div>
                                </div>
                            </div>
                            <div class="md:order-2 w-12 h-12 rounded-full border-2 border-zinc-200 bg-white flex items-center justify-center font-black text-lg z-10 shrink-0 shadow-sm node-circle transition-all">
                                0{index + 1}
                            </div>
                            <div class:list={["hidden md:block md:flex-1", index % 2 === 0 ? "md:order-3" : "md:order-1"]}></div>
                        </div>
                    ))}
                </div>
            </div>
        </div>
    </section>

    <!-- ═══ AUDITORÍA WEB ═════════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-zinc-50/50 px-4 sm:px-6 border-t border-black/5 overflow-hidden">
        <div class="max-w-7xl mx-auto grid lg:grid-cols-[6fr_4fr] gap-12 lg:gap-16 items-start">

            <div class="reveal lg:col-span-2">
                <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Punto de partida</span>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase text-zinc-900 leading-[0.9]">
                    Auditoría web gratuita para tu PYME
