---
import BaseLayout from '../layouts/BaseLayout.astro';
import { strapiClient, getStrapiImageUrl } from '../lib/strapi';
import LogoMarquee from '../components/sections/LogoMarquee.astro';

let caseStudies: any[] = [];
try {
  const res = await strapiClient.getCaseStudies('es', { limit: 50 });
  const allCases = res?.data?.map((i: any) => i.attributes ?? i) ?? [];
  const seoSlugs = ['seo', 'seo-local', 'consultoria-seo', 'posicionamiento-seo'];
  caseStudies = allCases
    .filter((cs: any) => {
      if (!cs.slug) return false;
      const cats: any[] = cs.categories || [];
      return cats.some((c: any) => {
        const name: string = (c.name || c.attributes?.name || '').toLowerCase();
        const slug: string = (c.slug || c.attributes?.slug || '').toLowerCase();
        return name.includes('seo') || seoSlugs.includes(slug);
      });
    });
} catch (_) {}

const faqs = [
  {
    q: '¿Cómo puede el SEO local ayudar a mi negocio en Sabadell a atraer más clientes?',
    a: 'El SEO local en Sabadell te permite aparecer cuando alguien busca tus servicios cerca del centro, en la Rambla, en Creu Alta o en los polígons industrials del Vallès. Optimizamos tu Google Business Profile y tu web para que aparezcas primero cuando un potencial cliente busca lo que vendes en Sabadell y su entorno.',
  },
  {
    q: '¿Cuánto tiempo tarda en funcionar el SEO en Sabadell?',
    a: 'En mercados como Sabadell, con un nivel de competencia medio-alto según el sector, los primeros resultados suelen verse entre 3 y 6 meses. El SEO es una inversión a largo plazo que, a diferencia de los anuncios, sigue generando visitas y clientes aunque dejes de invertir activamente.',
  },
  {
    q: '¿Es importante el SEO para tiendas y negocios locales del Mercat Central de Sabadell?',
    a: 'Absolutamente. Los negocios de proximidad en Sabadell, ya sea en el Mercat Central, en el carrer de Gràcia o en la zona comercial del centro, tienen una oportunidad enorme con el SEO local. Posicionar bien tu ficha de Google Maps y tu web local puede marcar la diferencia frente a competidores que todavía no invierten en SEO.',
  },
  {
    q: '¿Puede mi empresa industrial de los polígons de Sabadell beneficiarse del SEO?',
    a: 'Sí. Las empresas B2B de los polígons industrials del Vallès Occidental tienen mucho que ganar con el SEO. Sus clientes también buscan proveedores en Google. Posicionamos tu empresa para palabras clave industriales y de servicios B2B que generan presupuestos y contratos, no solo visitas.',
  },
  {
    q: '¿El SEO local en Sabadell incluye la gestión de Google Maps?',
    a: 'Sí, incluimos la optimización del Google Business Profile de tu empresa en Sabadell. Esto es clave para aparecer en el pack local de Google (los 3 resultados con mapa) cuando alguien busca tu servicio en la ciudad. También gestionamos reseñas y actualizamos la información para maximizar la visibilidad.',
  },
];
---

<BaseLayout
  title="Agencia SEO en Sabadell — Más visitas, más clientes | nova."
  description="Posicionamos tu empresa en Google para captar clientes en Sabadell y toda la comarca del Vallès Occidental. Auditoría gratuita, estrategia local y resultados medibles."
  noIndex={true}
  locale="es"
  hideHeader={true}
  hideFooter={true}
>

<!-- ─── Sending overlay ─── -->
<div id="lp-sending" class="fixed inset-0 z-[200] bg-white flex flex-col items-center justify-center hidden">
  <div class="flex flex-col items-center gap-8 px-8 max-w-sm w-full text-center">
    <div class="w-16 h-16 rounded-full border-4 border-zinc-100 border-t-accent animate-spin"></div>
    <div>
      <div class="text-2xl font-black uppercase tracking-tighter text-black mb-2">Enviando...</div>
      <p class="text-zinc-400 font-light text-sm">Procesando tu solicitud, un momento.</p>
    </div>
    <div class="w-full bg-zinc-100 rounded-full h-1 overflow-hidden">
      <div id="lp-progress" class="h-full bg-accent rounded-full"></div>
    </div>
  </div>
</div>

<!-- ═══ NAV LANDING ═══════════════════════════════════════════════════ -->
<header class="fixed top-0 left-0 right-0 z-50 bg-white/90 backdrop-blur-md border-b border-black/5 py-2 sm:py-3 leading-none">
  <div class="relative w-full px-6 sm:px-12 md:px-24 lg:px-32 xl:px-44 flex items-center justify-between h-12 md:h-14 gap-6">
    <a href="/" class="flex items-center h-full flex-shrink-0">
      <div class="text-[2.8rem] sm:text-[3rem] font-heading font-black tracking-tighter leading-none flex items-center -translate-y-0.5">
        <span class="hover-animate-gradient">nova.</span>
      </div>
    </a>
    <nav class="hidden lg:flex items-center gap-6 xl:gap-8">
      {[
        { href: '#auditoria', label: 'Auditoría y estrategia' },
        { href: '#metodo', label: 'Cómo trabajamos' },
        { href: '#resultados', label: 'Resultados' },
        { href: '#casos', label: 'Casos de éxito' },
        { href: '#faq', label: 'FAQ' },
      ].map(l => (
        <a href={l.href} class="text-[11px] font-bold uppercase tracking-[0.15em] text-zinc-700 hover:text-accent transition-colors whitespace-nowrap">
          {l.label}
        </a>
      ))}
    </nav>
    <a href="#solicitar" class="btn-mktg-v5 !py-3 !px-6 !text-[11px] font-black flex-shrink-0">
      AUDITORÍA GRATIS
    </a>
  </div>
</header>

<!-- ═══ HERO ═══════════════════════════════════════════════════════════ -->
<section class="min-h-[100dvh] flex items-center px-4 sm:px-6 relative overflow-hidden bg-white border-b border-black/5 pt-16 pb-[220px] sm:pb-10">
  <!-- Background mesh -->
  <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808008_1px,transparent_1px),linear-gradient(to_bottom,#80808008_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_60%_60%_at_50%_40%,#000_70%,transparent_100%)]"></div>
  <div class="absolute -top-10 left-1/4 w-72 h-72 bg-accent/15 rounded-full blur-3xl opacity-30 animate-pulse"></div>
  <div class="absolute top-20 right-1/3 w-80 h-80 bg-purple-500/5 rounded-full blur-3xl opacity-20"></div>

  <!-- Consultant image: anchored to the very bottom-right of the hero, flush with the edge -->
  <div class="hidden lg:block absolute bottom-0 right-[-8%] h-[82%] z-[1] pointer-events-none select-none">
    <img src="/consultor-marketing-digital.webp" alt="Sergio Galo's - Fundador & Consultor SEO" class="h-full w-auto object-contain object-bottom" />
  </div>

  <!-- Name card: elemento propio por encima de todo (z-[3] > grid z-[2]) -->
  <div class="hidden lg:block absolute bottom-[14%] right-[12%] bg-white rounded-xl px-5 py-3 shadow-[0_10px_30px_rgba(0,0,0,0.15)] z-[3]">
    <div class="text-sm font-black text-zinc-900 leading-tight">Sergio Galo's</div>
    <div class="text-[11px] font-bold text-accent leading-tight mt-0.5">Fundador & Consultor SEO</div>
  </div>

  <div class="w-full relative z-[2]">
    <div class="grid lg:grid-cols-[1.5fr_1fr_0.55fr] gap-8 lg:gap-10 items-center px-6 lg:px-12 xl:px-20 max-w-[1700px] mx-auto">

      <!-- Copy: Left Column -->
      <div class="reveal">
        <div class="flex justify-center lg:justify-start mb-6">
          <h2 class="inline-flex items-center gap-2 bg-accent/10 backdrop-blur-sm px-4 py-2 border border-accent/25 rounded-full text-accent text-[10px] sm:text-[11px] font-black uppercase tracking-[0.25em] shadow-sm">
            <span class="w-2 h-2 bg-accent rounded-full animate-ping"></span>
            Agencia SEO en Sabadell
          </h2>
        </div>

        <h1 class="text-3xl sm:text-5xl lg:text-6xl xl:text-7xl uppercase font-black tracking-tighter leading-[0.9] mb-6 lg:mb-8 text-zinc-900 text-center sm:text-left">
          Tu competencia <br>ya sale en <br><span class="text-mktg-gradient">Google</span>. <br>¿Y tú?
        </h1>

        <p class="text-zinc-500 font-light text-base sm:text-lg lg:text-xl leading-relaxed mb-8 lg:mb-10 text-center sm:text-left max-w-xl">
          Auditoría gratuita para saber por qué no apareces en Google y cómo convertir esas búsquedas en clientes, no solo en visitas.
        </p>

        <div class="flex flex-col gap-3 mb-8 lg:mb-10">
          {[
            'Auditoría SEO gratuita',
            'Aumento de clientes potenciales orgánicos',
            'Especialistas en pymes de Sabadell',
          ].map(item => (
            <span class="inline-flex items-center gap-3 text-sm lg:text-base font-black uppercase tracking-widest text-zinc-800">
              <span class="w-7 h-7 bg-accent/10 border border-accent/20 rounded-full flex items-center justify-center flex-shrink-0">
                <svg class="w-3.5 h-3.5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                </svg>
              </span>
              {item}
            </span>
          ))}
        </div>

        <!-- Desktop claim -->
        <div class="hidden sm:inline-flex items-start gap-3 border-l-4 border-accent pl-4">
          <p class="font-black uppercase tracking-tight text-zinc-900 leading-tight text-base lg:text-xl">
            Somos la agencia SEO nº1 en Sabadell
          </p>
        </div>

      </div>

      <!-- Form: Center Column, slightly overlapping the image -->
      <div id="solicitar" class="reveal hidden lg:block">
        <div class="bg-white rounded-3xl shadow-[0_25px_60px_-10px_rgba(0,0,0,0.18)] p-8">
          <span class="text-[8px] font-black uppercase tracking-[0.4em] text-accent block mb-3">Sin compromiso</span>
          <div class="text-xl font-black uppercase tracking-tighter mb-6 leading-tight">Si contactas hoy,<br>Auditoría SEO Gratuita</div>

          <form id="seo-sabadell-form" class="space-y-4">
            <div class="flex flex-col gap-1.5">
              <label class="text-[8px] font-black uppercase tracking-widest opacity-40">Nombre *</label>
              <input type="text" name="name" required class="border-b border-zinc-300 py-2 focus:border-accent outline-none transition-colors bg-transparent text-sm" />
            </div>
            <div class="flex flex-col gap-1.5">
              <label class="text-[8px] font-black uppercase tracking-widest opacity-40">Email *</label>
              <input type="email" name="email" required class="border-b border-zinc-300 py-2 focus:border-accent outline-none transition-colors bg-transparent text-sm" />
            </div>
            <div class="flex flex-col gap-1.5">
              <label class="text-[8px] font-black uppercase tracking-widest opacity-40">Teléfono</label>
              <input type="tel" name="phone" class="border-b border-zinc-300 py-2 focus:border-accent outline-none transition-colors bg-transparent text-sm" />
            </div>
            <div class="flex flex-col gap-1.5">
              <label class="text-[8px] font-black uppercase tracking-widest opacity-40">Web de tu empresa</label>
              <input type="text" name="url" placeholder="www.tuempresa.com" class="border-b border-zinc-300 py-2 focus:border-accent outline-none transition-colors bg-transparent text-sm placeholder:text-zinc-300" />
            </div>
            <div class="flex flex-col gap-1.5">
              <label class="text-[8px] font-black uppercase tracking-widest opacity-40">Mensaje</label>
              <textarea name="msg" rows="2" class="border-b border-zinc-300 py-2 focus:border-accent outline-none transition-colors bg-transparent text-sm resize-none"></textarea>
            </div>

            <div class="flex items-start gap-2 pt-2">
              <input type="checkbox" id="lp-terms" name="terms" required class="mt-0.5 accent-accent flex-shrink-0" />
              <label for="lp-terms" class="text-[8px] text-zinc-500 font-light cursor-pointer select-none leading-tight">
                Acepto la <a href="/privacidad/" class="underline hover:text-accent transition-colors">política de privacidad</a>.
              </label>
            </div>

            <button type="submit" id="lp-submit-btn" class="w-full btn-mktg-v5 !py-3 text-sm shadow-[0_15px_35px_rgba(37,211,102,0.25)] hover:shadow-[0_20px_45px_rgba(37,211,102,0.3)] transition-shadow">
              Quiero mi auditoría gratis →
            </button>
          </form>
        </div>
      </div>

      <!-- Spacer: reserved for the absolutely-positioned consultant image -->
      <div class="hidden lg:block" aria-hidden="true"></div>

    </div>
  </div>

  <!-- Mobile: tarjeta + claim fijados al fondo del hero -->
  <div class="sm:hidden absolute bottom-4 left-4 right-4 flex flex-col gap-5">
    <div class="bg-white rounded-3xl border border-black/5 shadow-[0_25px_50px_-12px_rgba(0,0,0,0.15)] p-6">
      <span class="text-[8px] font-black uppercase tracking-[0.4em] text-accent block mb-2">Sin compromiso</span>
      <div class="text-lg font-black uppercase tracking-tighter mb-4 leading-tight">Si contactas hoy,<br>Auditoría SEO Gratuita</div>
      <button class="contact-modal-trigger w-full btn-mktg-v5 !py-3 text-sm shadow-[0_15px_35px_rgba(37,211,102,0.25)]">
        Quiero mi auditoría gratis →
      </button>
    </div>
    <p class="font-black uppercase tracking-tight text-zinc-900 leading-none text-center text-xs">
      Somos la agencia SEO nº1 en Sabadell
    </p>
  </div>
</section>

<LogoMarquee />

<!-- ═══ AUDITORÍA Y ESTRATEGIA ════════════════════════════════════════ -->
<section id="auditoria" class="py-20 sm:py-32 bg-zinc-50 border-y border-black/5 px-4 sm:px-6 relative overflow-hidden">
  <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808005_1px,transparent_1px),linear-gradient(to_bottom,#80808005_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_50%,#000_80%,transparent_100%)]"></div>
  <div class="max-w-7xl mx-auto relative z-10">
    <div class="text-center mb-16 sm:mb-24 reveal">
      <span class="text-[10px] font-black uppercase tracking-[0.3em] text-accent mb-4 block">Nuestro enfoque</span>
      <h2 class="text-3xl sm:text-5xl lg:text-7xl uppercase tracking-tighter font-black mb-6">
        Auditoría y Estrategia<br class="hidden sm:inline" /> SEO en Sabadell
      </h2>
      <p class="text-zinc-500 font-light text-base sm:text-lg max-w-2xl mx-auto leading-relaxed">
        No empezamos a ciegas ni usamos plantillas genéricas. Analizamos tu presencia digital en Sabadell de arriba a abajo para diseñar una estrategia orientada 100% a conversiones en el mercado local del Vallès.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 gap-6">
      {[
        { num: '01', title: 'Auditoría Técnica Local', desc: 'Corregimos errores de indexación, velocidad y adaptabilidad móvil para que Google te valore como la mejor opción en Sabadell.' },
        { num: '02', title: 'Keywords del Vallès', desc: 'Analizamos qué buscan los clientes de Sabadell, Can Feu y Creu Alta para posicionar términos con intención de compra real en la comarca.' },
        { num: '03', title: 'SEO On-Page', desc: 'Optimizamos títulos, etiquetas y enlazado interno para decirle a Google exactamente qué vendes y dónde lo haces en Sabadell.' },
        { num: '04', title: 'Plan de Enlaces', desc: 'Construimos autoridad con enlaces de medios y directorios locales del Vallès Occidental que disparan la relevancia de tu dominio.' },
      ].map((p, i) => (
        <div class="group p-8 sm:p-10 bg-white border border-zinc-100/60 rounded-3xl hover:border-accent/20 hover:shadow-2xl hover:-translate-y-2 transition-all duration-500 relative overflow-hidden flex gap-6 reveal" style={`transition-delay: ${i * 80}ms`}>
          <div class="absolute bottom-0 inset-x-0 h-1 bg-gradient-to-r from-accent via-accent/90 to-purple-600 w-0 group-hover:w-full transition-all duration-500"></div>
          <div class="text-4xl font-black tracking-tighter text-black/5 group-hover:text-accent/10 transition-colors select-none flex-shrink-0 leading-none mt-1">{p.num}</div>
          <div>
            <h3 class="text-lg sm:text-xl font-black uppercase tracking-tighter mb-3 text-zinc-900">{p.title}</h3>
            <p class="text-sm text-zinc-500 font-light leading-relaxed">{p.desc}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-16 text-center reveal">
      <button class="contact-modal-trigger btn-mktg-v5 shadow-[0_10px_30px_rgba(37,211,102,0.3)]">
        SOLICITAR AUDITORÍA GRATUITA
      </button>
    </div>
  </div>
</section>

<!-- ═══ CÓMO TRABAJAMOS ════════════════════════════════════════════════ -->
<section id="metodo" class="py-20 sm:py-32 bg-accent px-4 sm:px-6">
  <div class="max-w-7xl mx-auto grid md:grid-cols-2 gap-12 sm:gap-20 items-center">
    <div class="reveal text-white">
      <span class="text-[10px] font-black uppercase tracking-[0.5em] mb-6 sm:mb-10 block opacity-70">El proceso</span>
      <div class="text-4xl sm:text-7xl lg:text-8xl font-black uppercase tracking-tighter leading-[0.82] mb-8 sm:mb-10">
        Cómo<br>trabajamos<br>el SEO
      </div>
      <p class="text-white/70 font-light text-base sm:text-xl max-w-md leading-relaxed mb-8">
        Olvídate del SEO en piloto automático. Contarás con un Account Manager dedicado que trabajará de la mano con tu equipo para resolver dudas, supervisar avances y mantenerte informado con métricas de negocio reales en Sabadell.
      </p>
      <ul class="text-[9px] sm:text-xs font-black tracking-widest space-y-3 uppercase opacity-90 text-white">
        <li>→ AUDITORÍA TÉCNICA COMPLETA</li>
        <li>→ ESTRATEGIA DE KEYWORDS LOCAL</li>
        <li>→ LINK BUILDING DE CALIDAD</li>
        <li>→ SEGUIMIENTO MENSUAL REAL</li>
      </ul>
    </div>

    <div class="reveal space-y-4">
      {[
        { num: '01', title: 'Auditoría SEO en Sabadell', desc: 'Analizamos tu web y tu presencia en el mercado del Vallès Occidental. Detectamos errores técnicos, oportunidades de posicionamiento local y la brecha frente a tus competidores en Sabadell.' },
        { num: '02', title: 'Keyword Research Local', desc: 'Identificamos las búsquedas exactas que realizan los usuarios de Sabadell, Can Feu, Creu Alta y toda la comarca del Vallès para captar tráfico con alta intención de compra.' },
        { num: '03', title: 'SEO On-Page para tu Negocio', desc: 'Optimizamos títulos, contenidos y estructura de tu web para que Google entienda que eres la mejor opción para clientes en Sabadell y su entorno.' },
        { num: '04', title: 'Linkbuilding con Autoridad', desc: 'Conseguimos enlaces de medios y directorios de referencia del Vallès Occidental que aumentan la autoridad de tu dominio y suben tu posición en Google.' },
        { num: '05', title: 'SEO Local y Google Maps', desc: 'Posicionamos tu Google Business Profile para que aparezcas en el pack local de Sabadell cuando alguien busca tu servicio cerca de la Rambla, el Mercat Central o los polígons industrials.' },
      ].map(s => (
        <div class="bg-white/10 backdrop-blur-sm p-6 sm:p-8 rounded-3xl border border-white/10 hover:bg-white/15 transition-colors flex gap-6 items-start">
          <div class="text-white/40 font-black text-lg tracking-tighter flex-shrink-0 w-8">{s.num}</div>
          <div>
            <h3 class="text-sm font-black uppercase tracking-tight text-white mb-1">{s.title}</h3>
            <p class="text-white/60 font-light text-sm leading-relaxed">{s.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ═══ CONSULTOR SEO + STATS ══════════════════════════════════════════ -->
<section id="resultados" class="py-20 sm:py-32 bg-white px-4 sm:px-6 relative overflow-hidden">
  <div class="absolute -top-40 right-1/4 w-96 h-96 bg-accent/10 rounded-full blur-3xl opacity-20 animate-pulse"></div>
  <div class="max-w-7xl mx-auto">

    <!-- Consultor copy -->
    <div class="grid md:grid-cols-2 gap-12 sm:gap-20 items-center mb-20 sm:mb-32">
      <div class="reveal">
        <span class="text-[10px] font-black uppercase tracking-[0.3em] text-accent mb-4 block">Estrategia SEO</span>
        <h2 class="text-3xl sm:text-5xl lg:text-6xl uppercase tracking-tighter font-black mb-6">
          Consultor de posicionamiento SEO en Sabadell
        </h2>
        <p class="text-zinc-500 font-light text-base sm:text-lg leading-relaxed mb-8">
          Como consultor experto en SEO en Sabadell, diseño estrategias de posicionamiento orgánico para que tu empresa aparezca cuando tus clientes te buscan en Google. Conozco el mercado local del Vallès Occidental —desde la Rambla de Sabadell y el Eix Macià hasta los polígons industrials de Can Roqueta— y construyo visibilidad orgánica duradera orientada a conversiones reales.
        </p>
        <button class="contact-modal-trigger btn-mktg-v5 shadow-[0_10px_30px_rgba(37,211,102,0.3)]">
          QUIERO POSICIONAR MI EMPRESA
        </button>
      </div>
      <div class="reveal space-y-4">
        {[
          { icon: `<svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><circle cx="12" cy="12" r="3"/></svg>`, title: 'SEO Técnico', desc: 'Arquitectura y velocidad optimizadas para que Google pueda rastrear e indexar tu web correctamente.' },
