---
/**
 * BaseLayout.astro — v5 Minimalist Premium (Back to Example Design)
 * Shell HTML principal con el fondo de partículas, el resplandor del cursor y SEO.
 */
import SeoHead from '../components/seo/SeoHead.astro';
import SchemaOrg from '../components/seo/SchemaOrg.astro';
import Header from '../components/global/Header.astro';
import Footer from '../components/global/Footer.astro';
import CtaSticky from '../components/cta/CtaSticky.astro';
import ContactModal from '../components/cta/ContactModal.astro';
import CookieBanner from '../components/global/CookieBanner.astro';
import '../styles/global.css';

import type { Locale } from '../lib/i18n';
import type { SeoFields, GlobalSettings } from '../lib/strapi';

interface Props {
  title: string;
  description: string;
  ogDescription?: string;
  canonical?: string;
  ogImage?: string;
  noIndex?: boolean;
  locale?: Locale;
  alternates?: { lang: string; url: string }[];
  seo?: SeoFields;
  schemas?: object[];
  settings?: GlobalSettings;
  hideHeader?: boolean;
  hideFooter?: boolean;
}

const {
  title,
  description,
  ogDescription,
  canonical,
  ogImage,
  noIndex = false,
  locale = 'es',
  alternates = [],
  seo,
  schemas = [],
  settings,
  hideHeader = false,
  hideFooter = false,
} = Astro.props;

const SITE_URL = import.meta.env.PUBLIC_SITE_URL || 'https://novamarketing.es';
---

<!DOCTYPE html>
<html lang={locale === 'ca' ? 'ca' : 'es'}>
<head>
  <!-- Google Consent Mode v2 (defaults DENIED) + Tag Manager + GA4 config.
       Un único script para reducir el número de ficheros en la ruta de red. -->
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('consent', 'default', {
      analytics_storage: 'denied',
      ad_storage: 'denied',
      wait_for_update: 500,
    });
    // Restore consent for returning visitors who already accepted
    try {
      if (localStorage.getItem('cookie_consent') === 'accepted') {
        gtag('consent', 'update', { analytics_storage: 'granted', ad_storage: 'granted' });
      }
    } catch(_) {}

    // Google tag (gtag.js) config: queda encolado en dataLayer hasta que cargue la librería
    gtag('js', new Date());
    gtag('config', 'G-X8YZVZTRSN');

    // Los scripts de Google (~600 KB con lo que arrastra GTM) se cargan cuando
    // el contenido ya está pintado: primera interacción del usuario o 3,5 s tras
    // el load, lo que llegue antes. El sitio carga tan rápido que el load se
    // dispara ANTES del primer pintado, así que un load a secas no basta: los
    // scripts entraban igualmente en el grafo del LCP móvil (5,9 s simulados).
    // Los eventos previos quedan encolados en dataLayer y no se pierde medición.
    var tagsLoaded = false;
    function loadGoogleTags() {
      if (tagsLoaded) return;
      tagsLoaded = true;
      window.dataLayer.push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });
      var gtm = document.createElement('script');
      gtm.async = true;
      gtm.src = 'https://www.googletagmanager.com/gtm.js?id=GTM-5XJ5NNLL';
      document.head.appendChild(gtm);
      var ga = document.createElement('script');
      ga.async = true;
      ga.src = 'https://www.googletagmanager.com/gtag/js?id=G-X8YZVZTRSN';
      document.head.appendChild(ga);
      ['pointerdown', 'touchstart', 'keydown', 'scroll'].forEach(function (ev) {
        window.removeEventListener(ev, loadGoogleTags);
      });
    }
    ['pointerdown', 'touchstart', 'keydown', 'scroll'].forEach(function (ev) {
      window.addEventListener(ev, loadGoogleTags, { once: true, passive: true });
    });
    if (document.readyState === 'complete') {
      setTimeout(loadGoogleTags, 3500);
    } else {
      window.addEventListener('load', function () { setTimeout(loadGoogleTags, 3500); });
    }
  </script>

  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="verify-getalink" content="verify-getalink-11915" />

  <!-- Preconnect for third-party origins -->
  <link rel="preconnect" href="https://www.googletagmanager.com" crossorigin />
  <link rel="dns-prefetch" href="https://www.google-analytics.com" />

  <!-- Preload above-the-fold fonts -->
  <link rel="preload" href="/fonts/Montserrat-Black.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/Inter-Regular.woff2" as="font" type="font/woff2" crossorigin />

  <SeoHead
    title={seo?.metaTitle || title}
    description={seo?.metaDescription || description}
    ogDescription={ogDescription}
    canonical={seo?.canonicalUrl || canonical}
    ogImage={seo?.ogImage ? `${SITE_URL}${seo.ogImage.url}` : ogImage}
    noIndex={seo?.noIndex ?? noIndex}
    locale={locale}
    alternates={alternates}
    siteUrl={SITE_URL}
  />

  {schemas.map(schema => (
    <SchemaOrg schema={schema} />
  ))}

  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="icon" type="image/png" sizes="144x144" href="/favicon.png" />
  <link rel="apple-touch-icon" href="/favicon.png" />

  <script type="speculationrules" set:html={JSON.stringify({
    prerender: [{
      where: {
        and: [
          { href_matches: "/*" },
          { not: { href_matches: "/logout" } },
          { not: { selector_matches: "[rel~=nofollow]" } },
          { not: { selector_matches: "[data-no-prerender]" } }
        ]
      },
      eagerness: "moderate"
    }]
  })} />
</head>

<body class="bg-white text-black antialiased selection:bg-accent selection:text-white">
  <!-- Google Tag Manager (noscript) -->
  <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-5XJ5NNLL"
  height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
  <!-- End Google Tag Manager (noscript) -->

  <!-- v5 Dynamic Layers -->
  <canvas id="canvas-bg"></canvas>
  <div class="cursor-glow" id="cursor-glow"></div>

  {!hideHeader && <Header locale={locale} alternates={alternates} settings={settings} />}

  <main id="main-content">
    <slot />
  </main>

  {!hideFooter && <Footer locale={locale} settings={settings} />}

  <CtaSticky locale={locale} settings={settings} />
  <ContactModal locale={locale} />
  <CookieBanner locale={locale} />

  <!-- Global v5 Scripts (Particles + Cursor + Reveal) -->
  <script>
    /* 1. Reveal Animation */
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('active');
            }
        });
    }, { threshold: 0.1 });

    /* 2. Particle Canvas Background */
    function initParticles() {
        const canvas = document.getElementById('canvas-bg') as HTMLCanvasElement;
        if (!canvas) return;
        const ctx = canvas.getContext('2d');
        if (!ctx) return;
        
        let particles: any[] = [];
        const particleCount = 20;

        function resize() {
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
        }

        class Particle {
            x: number; y: number; size: number; speedX: number; speedY: number; opacity: number;
            constructor() {
                this.x = Math.random() * canvas.width;
                this.y = Math.random() * canvas.height;
                this.size = Math.random() * 2 + 1;
                this.speedX = (Math.random() - 0.5) * 0.3;
                this.speedY = (Math.random() - 0.5) * 0.3;
                this.opacity = Math.random() * 0.2 + 0.1;
            }
            update() {
                this.x += this.speedX;
                this.y += this.speedY;
                if (this.x < 0 || this.x > canvas.width) this.speedX *= -1;
                if (this.y < 0 || this.y > canvas.height) this.speedY *= -1;
            }
            draw() {
                if (!ctx) return;
                ctx.fillStyle = `rgba(59, 130, 246, ${this.opacity})`;
                ctx.beginPath();
                ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
                ctx.fill();
            }
        }

        function create() {
            particles = [];
            for (let i = 0; i < particleCount; i++) {
                particles.push(new Particle());
            }
        }

        function animate() {
            ctx!.clearRect(0, 0, canvas.width, canvas.height);
            particles.forEach(p => {
                p.update();
                p.draw();
            });
            requestAnimationFrame(animate);
        }

        window.addEventListener('resize', resize);
        resize();
        create();
        animate();
    }

    /* 3. Cursor Glow Effect */
    function initCursorGlow() {
        const glow = document.getElementById('cursor-glow');
        if (!glow) return;
        window.addEventListener('mousemove', (e) => {
            glow.style.left = e.clientX + 'px';
            glow.style.top = e.clientY + 'px';
        });
    }

    /* Init Core */
    function init() {
        // Los elementos ya visibles al cargar NO se re-animan: re-pintarlos desde
        // opacidad 0 retrasaba el LCP en móvil hasta el final de la animación.
        // Solo se observa (y anima) lo que entra al hacer scroll.
        const vh = window.innerHeight;
        document.querySelectorAll('.reveal').forEach(el => {
            if (el.getBoundingClientRect().top >= vh) observer.observe(el);
        });
        // Efectos visuales no críticos: se difieren a tiempo de inactividad para
        // evitar reflows forzados durante la carga inicial (leen tamaño del viewport).
        const runVisuals = () => { initParticles(); initCursorGlow(); };
        if ('requestIdleCallback' in window) {
            (window as any).requestIdleCallback(runVisuals, { timeout: 1500 });
        } else {
            setTimeout(runVisuals, 200);
        }
    }

    document.addEventListener('DOMContentLoaded', init);
    document.addEventListener('astro:page-load', init);
  </script>

</body>
</html>
